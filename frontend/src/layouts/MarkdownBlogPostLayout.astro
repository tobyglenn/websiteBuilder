---
import Layout from './Layout.astro';
import ShareButtons from '../components/ShareButtons.jsx';
import { ArrowLeft, User, Calendar, Tag } from 'lucide-react';

const { frontmatter } = Astro.props;

const post = {
  title: String(frontmatter?.title || 'Untitled'),
  description: String(frontmatter?.description || ''),
  date: String(frontmatter?.date || ''),
  tags: Array.isArray(frontmatter?.tags) ? frontmatter.tags : [],
  categories: Array.isArray(frontmatter?.categories) ? frontmatter.categories : [],
  image: String(frontmatter?.image || ''),
  author: String(frontmatter?.author || 'Toby Glenn Peters'),
};

const category = String(post.categories[0] || 'Analysis');
const rawBody = typeof Astro.props.rawContent === 'function'
  ? Astro.props.rawContent()
  : String(Astro.props.content || '');

function readTime(content = '') {
  const words = String(content).split(/\s+/).filter(Boolean).length;
  return `${Math.max(1, Math.round(words / 200))} min read`;
}
---

<Layout
  title={`${post.title} - TobyOnFitnessTech`}
  description={post.description || post.title}
  image={post.image}
  ogType="article"
  publishedTime={post.date}
  modifiedTime={post.date}
  author={post.author}
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Blog', url: '/blog' },
    { name: post.title, url: Astro.url.pathname },
  ]}
>
  <article class="bg-neutral-950 min-h-screen pb-24">
    <div class="relative bg-neutral-900 border-b border-neutral-800 pb-16 pt-24 md:pt-32">
      <div class="absolute inset-0 bg-gradient-to-b from-blue-900/10 to-transparent pointer-events-none" />
      <div class="container mx-auto px-4 relative z-10 max-w-4xl">
        <a href="/blog?category=All#category-filters" class="inline-flex items-center text-sm font-semibold text-blue-400 hover:text-blue-300 transition-colors mb-8 group">
          <ArrowLeft size={16} class="mr-2 group-hover:-translate-x-1 transition-transform" /> Back to Analysis
        </a>

        <div class="flex items-center gap-4 text-xs font-bold tracking-wider text-blue-500 uppercase mb-4">
          <span class="bg-blue-900/30 px-3 py-1 rounded-full border border-blue-500/30">{category}</span>
          <span class="text-neutral-500">•</span>
          <span>{readTime(rawBody)}</span>
        </div>

        <h1 class="text-3xl md:text-5xl font-bold text-white mb-6 leading-tight">
          {post.title}
        </h1>

        {post.description && (
          <p class="max-w-3xl text-lg md:text-xl leading-relaxed text-neutral-300 mb-8">
            {post.description}
          </p>
        )}

        <div class="flex items-center gap-6 text-sm text-neutral-400 border-t border-neutral-800 pt-6">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-neutral-800 flex items-center justify-center text-neutral-500">
              <User size={16} />
            </div>
            <span class="font-medium text-white">Toby</span>
          </div>
          <div class="flex items-center gap-2">
            <Calendar size={16} />
            <span>{post.date ? new Date(post.date).toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' }) : 'Draft'}</span>
          </div>
        </div>

        <ShareButtons url={Astro.url.href} title={post.title} client:load />
      </div>
    </div>

    <div class="container mx-auto px-4 py-12 max-w-3xl">
      <div class="markdown-shell rounded-3xl border border-neutral-800 bg-neutral-900/55 px-6 py-8 md:px-10 md:py-10 shadow-[0_30px_80px_rgba(0,0,0,0.28)]">
      <div class="markdown-article">
        <slot />
      </div>
      </div>

      {post.tags.length > 0 && (
        <div class="mt-16 pt-8 border-t border-neutral-800">
          <div class="flex items-center gap-4 flex-wrap">
            <Tag size={16} class="text-neutral-500" />
            <div class="flex flex-wrap gap-2">
              {post.tags.map((tag) => (
                <span class="text-sm bg-neutral-900 border border-neutral-800 px-3 py-1 rounded-full text-neutral-400 hover:text-white transition-colors cursor-pointer">#{String(tag)}</span>
              ))}
            </div>
          </div>
        </div>
      )}
    </div>
  </article>
</Layout>

<style is:global>
  .markdown-article > h1:first-child {
    display: none;
  }

  .markdown-article {
    color: rgb(212 212 216);
    font-size: 1.075rem;
    line-height: 1.9;
  }

  .markdown-article > p:first-of-type {
    color: rgb(229 229 229);
    font-size: 1.18rem;
    line-height: 1.95;
    padding-left: 1rem;
    border-left: 3px solid rgb(59 130 246);
    margin-bottom: 2.25rem;
  }

  .markdown-article p {
    margin: 0 0 1.35rem;
    color: rgb(212 212 216);
  }

  .markdown-article h2 {
    margin: 3.25rem 0 1.25rem;
    padding-left: 1rem;
    border-left: 4px solid rgb(59 130 246);
    color: rgb(255 255 255);
    font-size: 1.9rem;
    line-height: 1.2;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .markdown-article h3 {
    margin: 2.1rem 0 1rem;
    color: rgb(191 219 254);
    font-size: 1.35rem;
    line-height: 1.35;
    font-weight: 700;
  }

  .markdown-article h4,
  .markdown-article h5,
  .markdown-article h6 {
    margin: 1.8rem 0 0.8rem;
    color: rgb(229 231 235);
    font-size: 1.05rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .markdown-article ul,
  .markdown-article ol {
    margin: 0 0 1.6rem 0;
    padding-left: 1.35rem;
  }

  .markdown-article li {
    margin-bottom: 0.65rem;
    padding-left: 0.2rem;
    color: rgb(212 212 216);
  }

  .markdown-article li::marker {
    color: rgb(96 165 250);
  }

  .markdown-article strong {
    color: rgb(255 255 255);
    font-weight: 700;
  }

  .markdown-article em {
    color: rgb(229 231 235);
  }

  .markdown-article a {
    color: rgb(96 165 250);
    text-decoration: underline;
    text-decoration-color: rgba(96, 165, 250, 0.35);
    text-underline-offset: 0.22em;
    transition: color 160ms ease, text-decoration-color 160ms ease;
  }

  .markdown-article a:hover {
    color: rgb(191 219 254);
    text-decoration-color: rgba(191, 219, 254, 0.7);
  }

  .markdown-article blockquote {
    margin: 2rem 0;
    padding: 1rem 1.2rem;
    border-left: 4px solid rgb(59 130 246);
    background: rgba(15, 23, 42, 0.55);
    color: rgb(229 231 235);
    font-style: italic;
  }

  .markdown-article hr {
    margin: 2.5rem 0;
    border: 0;
    border-top: 1px solid rgba(82, 82, 91, 0.5);
  }

  .markdown-article code {
    font-size: 0.92em;
    color: rgb(224 231 255);
    background: rgba(15, 23, 42, 0.75);
    border: 1px solid rgba(59, 130, 246, 0.18);
    border-radius: 0.45rem;
    padding: 0.12rem 0.38rem;
  }

  .markdown-article pre {
    margin: 1.8rem 0;
    padding: 1rem 1.1rem;
    overflow-x: auto;
    border-radius: 1rem;
    border: 1px solid rgba(63, 63, 70, 0.8);
    background: rgba(10, 10, 10, 0.8);
  }

  .markdown-article pre code {
    padding: 0;
    border: 0;
    background: transparent;
  }

  @media (max-width: 768px) {
    .markdown-article {
      font-size: 1rem;
      line-height: 1.8;
    }

    .markdown-article > p:first-of-type {
      font-size: 1.08rem;
      margin-bottom: 1.8rem;
    }

    .markdown-article h2 {
      font-size: 1.55rem;
      margin-top: 2.6rem;
    }

    .markdown-article h3 {
      font-size: 1.2rem;
    }
  }
</style>
