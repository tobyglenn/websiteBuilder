---
import '../styles/global.css';
import Header from '../components/Header.jsx';
import Footer from '../components/Footer.jsx';
import { SEO } from 'astro-seo';
import { ViewTransitions } from 'astro:transitions';
import LanguageSwitcher from '../components/LanguageSwitcher.jsx';
import LangDetect from '../components/LangDetect.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  ogType?: string;
  canonicalUrl?: string;
  jsonLd?: object | object[];
  lang?: string;
  episodeSlug?: string;
  breadcrumbs?: Array<{ name: string; url: string }>;
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
}

const DEFAULT_PAGE_DESCRIPTION = "Independent reviews of fitness technology: Speediance, Tonal, Whoop, Garmin, and more. Real data from a real athlete.";
const DEFAULT_SEO_DESCRIPTION = "Independent fitness technology reviews, analysis, and deep dives on Speediance, Tonal, Garmin, WHOOP, running, and home gym training.";

const { 
  title, 
  description = DEFAULT_PAGE_DESCRIPTION,
  image = "/og-default.jpg",
  ogType = "website",
  canonicalUrl,
  jsonLd,
  lang = 'en',
  episodeSlug,
  breadcrumbs,
  noindex = false,
  publishedTime,
  modifiedTime,
  author,
} = Astro.props;

// Twitter handles
const twitterSite = "@tobyonfitness";
const twitterCreator = "@tobyglenn";

// Use as fallback for all meta tags
const seoDescription = description || DEFAULT_SEO_DESCRIPTION;

const crawlerRobotsContent = noindex
  ? "noindex, follow"
  : "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1";

const siteUrl = "https://tobyonfitnesstech.com";
const resolvedUrl = canonicalUrl || (siteUrl + Astro.url.pathname);
const resolvedImage = image.startsWith('http') ? image : (siteUrl + image);

const MIN_TITLE_LENGTH = 45;
const MAX_TITLE_LENGTH = 60;
const locales = ['en', 'es', 'pt', 'hi', 'de'];
const normalizedPathname = Astro.url.pathname.replace(new RegExp(`^/(${locales.filter((locale) => locale !== 'en').join('|')})(?=/|$)`), '') || '/';

const shortTitleFallbacks: Record<string, string> = {
  '/about': 'Transformation story and training background',
  '/affiliate': 'How commissions and recommendations work',
  '/contact': 'Email, YouTube and collaboration links',
  '/day': 'Routine, training and creator workflow',
  '/faq': 'Answers on gear, data and training',
  '/games': 'Apps, experiments and side projects',
  '/gear': 'Fitness tech gear, wearables and setup',
  '/hr-zones': 'Garmin running heart rate zone breakdowns',
  '/live': 'Livestream archives and upcoming sessions',
  '/podcasts': 'OpenClaw Daily and fitness tech episodes',
  '/privacy': 'Data collection, cookies and email use',
  '/prs': 'Speediance personal records and top lifts',
  '/races': 'Garmin race-distance pace history',
  '/search': 'Search videos, blog posts and gear reviews',
  '/sleep': '8Sleep recovery and sleep trends',
  '/start-here': 'Transformation story and best entry points',
  '/streaks': 'Workout consistency and streak tracking',
  '/terms': 'Site usage, content and affiliate terms',
  '/training': 'Weekly split for running, lifting and BJJ',
  '/training-log': 'Workout consistency and heatmap history',
  '/videos': 'Speediance, BJJ and fitness tech library',
};

const countChars = (value = '') => Array.from(value).length;

const normalizeText = (value = '') => value.replace(/\s+/g, ' ').trim();

const compactText = (value = '', maxChars = MAX_TITLE_LENGTH) => {
  const normalized = normalizeText(value).replace(/[|:;,.!?…-]+$/u, '').trim();
  if (!normalized) return '';
  if (countChars(normalized) <= maxChars) return normalized;

  let compacted = '';
  for (const word of normalized.split(' ')) {
    const candidate = compacted ? `${compacted} ${word}` : word;
    if (countChars(candidate) > maxChars) break;
    compacted = candidate;
  }

  if (compacted) return compacted.replace(/[|:;,.!?…-]+$/u, '').trim();
  return Array.from(normalized).slice(0, maxChars).join('').replace(/[|:;,.!?…-]+$/u, '').trim();
};

const trimTitleForSerp = (value = '', maxChars = MAX_TITLE_LENGTH) => {
  const normalized = normalizeText(value);
  if (countChars(normalized) <= maxChars) return normalized;

  const clipped = Array.from(normalized).slice(0, maxChars).join('').trim();
  const lastSpaceIndex = clipped.lastIndexOf(' ');
  const safeBreak = lastSpaceIndex >= MIN_TITLE_LENGTH && lastSpaceIndex >= maxChars - 8
    ? clipped.slice(0, lastSpaceIndex)
    : clipped;

  return safeBreak.replace(/[|:;,.!?…-]+$/u, '').trim();
};

const sanitizeDescriptionForTitle = (rawDescription = '') => {
  const sanitizedDescription = normalizeText(rawDescription)
    .replace(/\bTobyOnFitnessTech\b/gi, '')
    .replace(/\bToby on Fitness Tech\b/gi, '')
    .replace(/\bToby über Fitness-Tech\b/gi, '')
    .replace(/\bToby sobre tecnología fitness\b/gi, '')
    .replace(/\bToby sobre tecnologia fitness\b/gi, '')
    .replace(/\bफिटनेस टेक पर टोबी\b/gi, '')
    .replace(/\s+/g, ' ')
    .trim();

  return sanitizedDescription;
};

const normalizeToken = (value = '') => {
  const cleaned = value.toLowerCase().replace(/[^\p{L}\p{N}]+/gu, '');
  return /^[a-z]{4,}s$/i.test(cleaned) ? cleaned.slice(0, -1) : cleaned;
};

const countNovelWords = (base = '', candidate = '') => {
  const baseWords = new Set(
    normalizeText(base)
      .split(' ')
      .map(normalizeToken)
      .filter((word) => word.length > 2)
  );

  const candidateWords = normalizeText(candidate)
    .split(' ')
    .map(normalizeToken)
    .filter((word) => word.length > 2);

  return [...new Set(candidateWords)].filter((word) => !baseWords.has(word)).length;
};

const getDescriptionCandidates = (rawDescription = '') => {
  const sanitizedDescription = sanitizeDescriptionForTitle(rawDescription);
  if (!sanitizedDescription) return [];

  const sentences = sanitizedDescription
    .split(/[.!?]+/u)
    .map((part) => part.trim())
    .filter(Boolean)
    .sort((a, b) => countChars(b) - countChars(a));

  const candidates: string[] = [];

  for (const sentence of sentences) {
    const clauses = sentence
      .split(/\s(?:[—–-])\s|:|[|•]/u)
      .map((part) => part.trim())
      .filter(Boolean);

    candidates.push(...clauses, sentence);
  }

  return [...new Set(candidates)];
};

const selectTitleContext = ({
  currentTitle = '',
  rawDescription = '',
  fallbackContext = '',
  maxChars = 0,
}) => {
  if (maxChars < 12) return '';

  const candidates = [
    ...(fallbackContext ? [fallbackContext] : []),
    ...getDescriptionCandidates(rawDescription),
  ];

  for (const candidate of candidates) {
    const compacted = compactText(candidate, maxChars);
    if (compacted && countNovelWords(currentTitle, compacted) >= 2) {
      return compacted;
    }
  }

  return candidates.length > 0 ? compactText(candidates[0], maxChars) : '';
};

const hasCustomDescription = normalizeText(description) !== normalizeText(DEFAULT_PAGE_DESCRIPTION);
const fallbackContext = lang === 'en'
  ? shortTitleFallbacks[normalizedPathname.replace(/\/$/, '') || '/'] || ''
  : '';

let seoTitle = normalizeText(title);

if (countChars(seoTitle) < MIN_TITLE_LENGTH) {
  const separator = ' | ';
  const availableContextChars = MAX_TITLE_LENGTH - countChars(seoTitle) - countChars(separator);
  const context = selectTitleContext({
    currentTitle: seoTitle,
    rawDescription: hasCustomDescription ? description : '',
    fallbackContext,
    maxChars: availableContextChars,
  });

  if (context && !seoTitle.toLowerCase().includes(context.toLowerCase())) {
    seoTitle = `${seoTitle}${separator}${context}`;
  }
}

seoTitle = trimTitleForSerp(seoTitle, MAX_TITLE_LENGTH);

// Build hreflang links — only for pages with actual translated versions
let hreflangBase: string | null = null;
if (episodeSlug) {
  // Podcast episode pages and openclaw landing: /podcasts/[episodeSlug]/
  hreflangBase = `/podcasts/${episodeSlug}/`;
} else if (lang !== 'en') {
  // Translated landing pages (de/es/hi/pt): strip locale prefix from URL
  // e.g. /de/podcasts/openclaw/ → /podcasts/openclaw/
  const localeRegex = new RegExp(`^/(${locales.filter(l => l !== 'en').join('|')})/`);
  hreflangBase = Astro.url.pathname.replace(localeRegex, '/');
}

const hreflangLinks = hreflangBase ? locales.map((locale) => ({
  lang: locale,
  href: locale === 'en'
    ? `${siteUrl}${hreflangBase}`
    : `${siteUrl}/${locale}${hreflangBase}`
})) : [];

const hreflangXDefault = hreflangBase ? `${siteUrl}${hreflangBase}` : resolvedUrl;

// og:locale mapping
const localeMap: Record<string, string> = { en: 'en_US', de: 'de_DE', es: 'es_ES', hi: 'hi_IN', pt: 'pt_BR' };
const ogLocale = localeMap[lang] ?? 'en_US';

// Global sitewide schemas (Person + WebSite)
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${siteUrl}/#toby`,
  "name": "Toby Glenn Peters",
  "alternateName": "TobyOnFitnessTech",
  "jobTitle": "Fitness Enthusiast & Tech Builder",
  "description": "Independent fitness technology reviewer and builder. Dropped from 242 to 188 pounds, using data from Speediance, Garmin, WHOOP, and running to guide training decisions.",
  "url": siteUrl,
  "image": `${siteUrl}/og-default.jpg`,
  "sameAs": [
    "https://www.youtube.com/@tobyonfitness",
    "https://www.instagram.com/tobyonfitness"
  ],
  "knowsAbout": [
    "Speediance",
    "Brazilian Jiu-Jitsu",
    "Garmin",
    "WHOOP",
    "8Sleep",
    "Running",
    "Fitness Technology",
    "Home Gym Equipment"
  ],
  "award": "242→188 lb transformation"
};

// Website schema — site identity for search and potential SERP enhancements
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  "url": siteUrl,
  "name": "Toby on Fitness Tech",
  "description": "Independent fitness technology reviews, analysis, and deep dives.",
  "publisher": { "@id": `${siteUrl}/#organization` },
  "potentialAction": {
    "@type": "SearchAction",
    "target": { "@type": "EntryPoint", "urlTemplate": `${siteUrl}/search?q={search_term_string}` },
    "query-input": "required name=search_term_string"
  }
};

// Organization schema — establishes brand entity and consolidates social profiles
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${siteUrl}/#organization`,
  "name": "Toby on Fitness Tech",
  "alternateName": "TobyOnFitnessTech",
  "description": "Independent fitness technology reviews, analysis, and deep dives. Covering Speediance, Tonal, Whoop, Garmin, and more with real athlete data.",
  "url": siteUrl,
  "logo": {
    "@type": "ImageObject",
    "url": `${siteUrl}/og-default.jpg`,
    "width": 1200,
    "height": 630
  },
  "founder": { "@id": `${siteUrl}/#toby` },
  "foundingDate": "2024",
  "sameAs": [
    "https://www.youtube.com/@tobyonfitness",
    "https://x.com/tobyglenn",
    "https://www.instagram.com/tobyonfitness",
    "https://tobyonfitnesstech.com"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "toby@tobyonfitnesstech.com",
    "contactType": "customer service",
    "availableLanguage": "English"
  },
  "knowsAbout": [
    "Fitness Technology",
    "Smart Home Gym Equipment",
    "Wearable Technology",
    "Strength Training",
    "Brazilian Jiu-Jitsu",
    "Speediance",
    "Tonal",
    "Whoop",
    "Garmin"
  ]
};

// SiteNavigationElement — defines the main site navigation for search engines
const siteNavigationSchema = {
  "@context": "https://schema.org",
  "@type": "SiteNavigationElement",
  "name": "Main Navigation",
  "description": "Primary navigation menu for Toby on Fitness Tech",
  "mainEntityOfPage": siteUrl,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "url": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Videos", "url": `${siteUrl}/videos` },
    { "@type": "ListItem", "position": 3, "name": "Podcasts", "url": `${siteUrl}/podcasts` },
    { "@type": "ListItem", "position": 4, "name": "Blog", "url": `${siteUrl}/blog` },
    { "@type": "ListItem", "position": 5, "name": "Gear", "url": `${siteUrl}/gear` },
    { "@type": "ListItem", "position": 6, "name": "About", "url": `${siteUrl}/about` }
  ]
};

const pathSegments = Astro.url.pathname.split('/').filter(Boolean);

const staticBreadcrumbNameMap: Record<string, string> = {
  running: 'Running',
  speediance: 'Speediance',
  whoop: 'WHOOP',
  sleep: 'Sleep',
  blog: 'Blog',
  videos: 'Videos',
  video: 'Videos',
  about: 'About',
  gear: 'Gear',
  pr: 'PR Board',
  transformation: 'Transformation',
  training: 'Training',
};

const toTitleCase = (segment: string) => segment
  .split('-')
  .filter(Boolean)
  .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
  .join(' ');

const inferredBreadcrumbs: Array<{ name: string; url: string }> = [{ name: 'Home', url: '/' }];

if (pathSegments.length > 0) {
  let runningPath = '';

  for (const [index, segment] of pathSegments.entries()) {
    runningPath += `/${segment}`;

    let name = staticBreadcrumbNameMap[segment] || toTitleCase(segment);

    if (index === 1 && pathSegments[0] === 'blog') {
      name = title.split('|')[0]?.trim() || name;
    }

    if (index === 1 && pathSegments[0] === 'video') {
      name = title.split('|')[0]?.trim() || name;
      inferredBreadcrumbs[1] = { name: 'Videos', url: '/videos' };
    }

    inferredBreadcrumbs.push({ name, url: runningPath });
  }
}

const finalBreadcrumbs = breadcrumbs && breadcrumbs.length > 0 ? breadcrumbs : inferredBreadcrumbs;

const breadcrumbSchema = finalBreadcrumbs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": finalBreadcrumbs.map((crumb, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": crumb.name,
    "item": crumb.url.startsWith('http') ? crumb.url : `${siteUrl}${crumb.url}`
  }))
} : null;

// Merge global schemas + breadcrumb + any page-specific schema
// SpeakableSpecification — marks key sections for voice search (Google Assistant, Siri, Alexa)
const speakableSchema = {
  "@context": "https://schema.org",
  "@type": "SpeakableSpecification",
  "cssSelector": ["h1", "h2", "[data-speakable]", "article p:first-of-type", "meta[name='description']"]
};

const allSchemas: object[] = [personSchema, websiteSchema, organizationSchema, siteNavigationSchema, speakableSchema, ...(breadcrumbSchema ? [breadcrumbSchema] : []), ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])];
---

<!doctype html>
<html lang={lang} class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="alternate" type="application/rss+xml" title="RSS Feed" href="/rss.xml" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Preconnect to external domains for faster connection -->
    <link rel="preconnect" href="https://www.youtube.com" />
    <link rel="preconnect" href="https://www.instagram.com" />
    <link rel="preconnect" href="https://x.com" />
    <link rel="dns-prefetch" href="https://www.youtube.com" />
    <link rel="dns-prefetch" href="https://www.instagram.com" />
    <link rel="dns-prefetch" href="https://x.com" />
    
    <SEO 
      title={seoTitle}
      description={seoDescription}
      canonical={resolvedUrl}
      openGraph={{
        basic: {
          title: title,
          type: ogType,
          image: resolvedImage,
          url: resolvedUrl,
        },
        optional: {
          siteName: "Toby on Fitness Tech",
          locale: ogLocale,
        }
      }}
      twitter={{
        card: "summary_large_image",
        title: title
      }}
      noindex={noindex}
      robotsExtras={noindex ? undefined : "max-snippet:-1, max-image-preview:large, max-video-preview:-1"}
      extend={{
        meta: [
          { name: "twitter:site", content: twitterSite },
          { name: "twitter:creator", content: twitterCreator },
          { name: "twitter:title", content: title },
          { name: "twitter:description", content: seoDescription },
          { name: "twitter:image", content: resolvedImage },
          ...(ogType === "article" ? [
            { name: "article:published_time", content: publishedTime || "" },
            { name: "article:modified_time", content: modifiedTime || publishedTime || "" },
            { name: "article:author", content: author || "Toby Glenn Peters" },
          ] : []),
          { name: "author", content: "Toby Glenn Peters" },
          { name: "ai-content-type", content: "educational" },
          { name: "ai-purpose", content: "product reviews, fitness analysis, tech comparison" },
          { name: "ai-target-audience", content: "fitness enthusiasts, tech adopters, home gym owners" },
          { name: "googlebot", content: crawlerRobotsContent },
          { name: "bingbot", content: crawlerRobotsContent },
          { name: "keywords", content: "fitness tech, Speediance, Tonal, Whoop, Garmin, BJJ, home gym, smart fitness equipment, wearables" },
        ],
        link: [
          { rel: "alternate", type: "application/rss+xml", title: "Blog Feed", href: `${siteUrl}/rss.xml` },
          // hreflang for multilingual support — only on pages with translations
          ...(hreflangLinks.length > 0 ? [
            ...hreflangLinks.map(({ lang: hreflangLang, href }) => ({
              rel: "alternate",
              hreflang: hreflangLang,
              href
            })),
            { rel: "alternate", hreflang: "x-default", href: hreflangXDefault },
          ] : []),
        ]
      }}
    />
    
    <LangDetect />
    
    <ViewTransitions />
    
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="TobyOnFitnessTech" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    
    <script type="application/ld+json" set:html={JSON.stringify(allSchemas)} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "TobyOnFitnessTech",
      "url": "https://tobyonfitnesstech.com",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://tobyonfitnesstech.com/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    })} />
  </head>
  <body class="bg-neutral-950 text-neutral-100 min-h-screen flex flex-col font-sans selection:bg-blue-500/30">
    <div data-pagefind-ignore>
      <Header client:load />
    </div>
    <main class="flex-grow pt-16" data-pagefind-body>
      <slot />
    </main>
    <div data-pagefind-ignore>
      <Footer />
    </div>
  </body>
</html>
