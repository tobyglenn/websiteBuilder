	        <a href={`/video/${video.id}`} class="group block bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden transition-all hover:-translate-y-1 hover:border-neutral-700">
	          <div class="aspect-video relative overflow-hidden bg-neutral-950">
	            <img src={video.thumbnail || `https://i.ytimg.com/vi/${video.id}/hqdefault.jpg`} alt={video.title} class="w-full h-full object-cover" loading="lazy" />
	            {video.duration_formatted && <span class="absolute bottom-2 right-2 bg-black/75 text-white text-xs px-2 py-1 rounded">{video.duration_formatted}</span>}
	          </div>
	          <div class="p-4">
	            <h3 class="text-white font-bold text-sm line-clamp-2 group-hover:text-blue-400">{video.title}</h3>
