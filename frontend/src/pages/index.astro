---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.jsx';
import Newsletter from '../components/Newsletter.jsx';
import { BLOG_POSTS } from '../data/mock.js';
import videosData from '../data/videos.json';
import { Play, ArrowRight, Clock } from 'lucide-react';

const allVideos = videosData.videos || [];
const recentVideos = allVideos.filter(v => !v.is_live).slice(0, 3);
const recentPosts = BLOG_POSTS.slice(0, 3);

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://tobyonfitnesstech.com/#webpage-home",
  "name": "Toby on Fitness Tech - Home",
  "description": "Independent reviews of fitness technology: Speediance, Tonal, Whoop, Garmin, and more. Real data from a real athlete.",
  "url": "https://tobyonfitnesstech.com",
  "inLanguage": "en",
  "primaryImageOfPage": {
    "@type": "ImageObject",
    "url": "https://tobyonfitnesstech.com/images/og-home.jpg"
  },
  "isPartOf": {
    "@id": "https://tobyonfitnesstech.com/#website"
  },
  "about": {
    "@id": "https://tobyonfitnesstech.com/#organization"
  },
  "author": {
    "@id": "https://tobyonfitnesstech.com/#person"
  }
};
---

<Layout 
  title="Toby on Fitness Tech - Reviews, Analysis, & Live Streams"
  description="Independent fitness tech reviews from a real athlete. Speediance vs Tonal, Whoop vs Garmin, BJJ commentary, and transformation data. No fluff, just real numbers."
  jsonLd={webPageSchema}
>
	
	<Hero client:load />

	{/* By The Numbers Stats Section */}
	<section class="py-20 bg-neutral-900 border-y border-neutral-800">
		<div class="container mx-auto px-4">
			<div class="text-center mb-12">
				<span class="text-blue-500 font-bold uppercase tracking-widest text-sm mb-2 block">By The Numbers</span>
				<h2 class="text-3xl md:text-4xl font-bold text-white">Real Data. Real Results.</h2>
				<p class="text-neutral-500 mt-3 max-w-xl mx-auto">Numbers don't lie. Here's what the training actually produced.</p>
			</div>
			
			<div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
				<div class="bg-neutral-950 rounded-2xl p-6 md:p-8 border border-neutral-800 hover:border-blue-500/50 transition-all hover:shadow-lg hover:shadow-blue-900/10 group">
					<div class="text-4xl md:text-5xl font-black text-white mb-2 group-hover:text-blue-400 transition-colors">1.29M</div>
					<div class="text-sm md:text-base font-semibold text-neutral-400 uppercase tracking-wide">Lbs Lifted</div>
					<div class="text-xs text-neutral-600 mt-2">Speediance</div>
				</div>
				<div class="bg-neutral-950 rounded-2xl p-6 md:p-8 border border-neutral-800 hover:border-blue-500/50 transition-all hover:shadow-lg hover:shadow-blue-900/10 group">
					<div class="text-4xl md:text-5xl font-black text-white mb-2 group-hover:text-blue-400 transition-colors">266</div>
					<div class="text-sm md:text-base font-semibold text-neutral-400 uppercase tracking-wide">Miles Run</div>
					<div class="text-xs text-neutral-600 mt-2">Garmin</div>
				</div>
				<div class="bg-neutral-950 rounded-2xl p-6 md:p-8 border border-neutral-800 hover:border-blue-500/50 transition-all hover:shadow-lg hover:shadow-blue-900/10 group">
					<div class="text-4xl md:text-5xl font-black text-white mb-2 group-hover:text-blue-400 transition-colors">218</div>
					<div class="text-sm md:text-base font-semibold text-neutral-400 uppercase tracking-wide">Lbs Now</div>
					<div class="text-xs text-neutral-600 mt-2">242 → 188 → 218</div>
				</div>
				<div class="bg-neutral-950 rounded-2xl p-6 md:p-8 border border-neutral-800 hover:border-blue-500/50 transition-all hover:shadow-lg hover:shadow-blue-900/10 group">
					<div class="text-4xl md:text-5xl font-black text-white mb-2 group-hover:text-blue-400 transition-colors">Brown</div>
					<div class="text-sm md:text-base font-semibold text-neutral-400 uppercase tracking-wide">Belt</div>
					<div class="text-xs text-neutral-600 mt-2">10+ Years Training</div>
				</div>
			</div>
			
			<div class="mt-10 text-center">
				<a href="/transformation" class="inline-flex items-center gap-2 text-blue-500 hover:text-blue-400 font-semibold transition-colors text-sm">
					See Full Journey <ArrowRight size={16} />
				</a>
			</div>
		</div>
	</section>

	{/* Recent Videos Section */}
	<section class="py-16 bg-neutral-950">
		<div class="container mx-auto px-4">
			<div class="flex items-end justify-between mb-12 border-b border-neutral-900 pb-8">
				<div>
					<h2 class="text-3xl md:text-4xl font-bold mb-4 bg-gradient-to-r from-white to-neutral-400 bg-clip-text text-transparent">Latest Uploads</h2>
					<p class="text-neutral-500 max-w-2xl">
						Fresh from the lab. In-depth testing and honest reviews.
					</p>
				</div>
				<a href="/videos" class="hidden md:flex items-center gap-2 text-blue-500 hover:text-blue-400 font-semibold transition-colors group">
					View All Videos <ArrowRight size={18} class="group-hover:translate-x-1 transition-transform" />
				</a>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{recentVideos.map((video) => (
					<a href={video.is_live ? `https://www.youtube.com/live/${video.id}` : `/video/${video.id}`} target={video.is_live ? '_blank' : '_self'} class="group block relative bg-neutral-900 rounded-2xl overflow-hidden border border-neutral-800 hover:border-neutral-700 transition-all hover:shadow-2xl hover:shadow-blue-900/10">
						<div class="aspect-video relative overflow-hidden">
							<img src={video.thumbnail} alt={video.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
							<div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors" />
							
							{video.is_live ? (
								<div class="absolute top-3 left-3 flex items-center gap-1.5 bg-red-600 text-white text-xs font-bold px-2.5 py-1 rounded-full uppercase tracking-wide">
									<span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span> Live
								</div>
							) : video.duration_formatted && (
								<div class="absolute bottom-3 right-3 bg-black/80 backdrop-blur-sm text-white text-xs font-mono px-2 py-1 rounded border border-white/10 flex items-center gap-1">
									<Clock size={10} /> {video.duration_formatted}
								</div>
							)}

							<div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 transform scale-90 group-hover:scale-100">
								<div class="bg-blue-600/90 p-4 rounded-full shadow-xl backdrop-blur-sm">
									<Play className="text-white fill-white ml-1" size={24} />
								</div>
							</div>
						</div>
						
						<div class="p-6">
							<div class="flex items-center justify-between text-xs text-neutral-500 mb-3 font-medium uppercase tracking-wider">
								{video.is_live ? (
									<span class="flex items-center gap-1 text-red-400 font-bold"><span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse inline-block"></span> LIVE NOW</span>
								) : (
									<span>{video.viewCount?.toLocaleString() ?? 0} views</span>
								)}
								<span>{new Date(video.publishedAt).toLocaleDateString()}</span>
							</div>
							
							<h3 class="text-lg font-bold text-white mb-3 line-clamp-2 leading-snug group-hover:text-blue-400 transition-colors">
								{video.title}
							</h3>
							
							<p class="text-neutral-400 text-sm line-clamp-2 mb-4 leading-relaxed">
								{video.description}
							</p>
						</div>
					</a>
				))}
			</div>
			
			<div class="mt-12 text-center md:hidden">
				<a href="/videos" class="inline-flex items-center gap-2 px-6 py-3 bg-neutral-900 border border-neutral-800 rounded-full text-white font-semibold hover:bg-neutral-800 transition-colors">
					View All Videos <ArrowRight size={16} />
				</a>
			</div>
		</div>
	</section>

	{/* Recent Blog Posts */}
	<section class="py-16 bg-neutral-900 border-t border-neutral-800">
		<div class="container mx-auto px-4">
			<div class="flex items-end justify-between mb-12">
				<div>
					<span class="text-blue-500 font-bold uppercase tracking-widest text-sm mb-2 block">The Analysis Log</span>
					<h2 class="text-3xl md:text-4xl font-bold text-white">Written Reviews</h2>
				</div>
				<a href="/blog" class="hidden md:flex items-center gap-2 text-neutral-400 hover:text-white transition-colors group text-sm font-medium">
					Read More Analysis <ArrowRight size={16} class="group-hover:translate-x-1 transition-transform" />
				</a>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				{recentPosts.map((post) => (
					<article class="flex flex-col group border-l-2 border-neutral-800 pl-6 hover:border-blue-500 transition-colors py-2">
						<span class="text-xs font-bold text-neutral-500 uppercase tracking-wider mb-2">{post.category}</span>
						<h3 class="text-xl font-bold text-white mb-3 leading-tight group-hover:text-blue-400 transition-colors">
							<a href={`/blog/${post.slug}`}>{post.title}</a>
						</h3>
						<p class="text-neutral-400 text-sm line-clamp-3 mb-4 leading-relaxed flex-grow">
							{post.excerpt}
						</p>
						<a href={`/blog/${post.slug}`} class="text-sm font-semibold text-blue-500 hover:text-blue-400 flex items-center gap-1 group/link">
							Read Article <ArrowRight size={14} class="group-hover/link:translate-x-1 transition-transform" />
						</a>
					</article>
				))}
			</div>
		</div>
	</section>

	{/* Data Deep Dive Section */}
	<section class="py-20 bg-neutral-900 border-t border-neutral-800">
		<div class="container mx-auto px-4">
			<div class="text-center mb-12">
				<span class="text-blue-500 font-bold uppercase tracking-widest text-sm mb-2 block">Dive Deeper</span>
				<h2 class="text-3xl md:text-4xl font-bold text-white">Your Data, Decoded.</h2>
				<p class="text-neutral-500 mt-3 max-w-xl mx-auto">Every workout, every mile, every sleep score — tracked and analyzed.</p>
			</div>
			
			<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
				{/* Running */}
				<a href="/running" class="bg-neutral-950 rounded-xl p-5 border border-neutral-800 hover:border-blue-500/50 transition-all group">
					<div class="text-2xl mb-3">🏃</div>
					<h3 class="font-bold text-white mb-1 group-hover:text-blue-400 transition-colors">Running</h3>
					<p class="text-xs text-neutral-500">265 miles · 111 runs</p>
				</a>
				{/* Speediance */}
				<a href="/speediance" class="bg-neutral-950 rounded-xl p-5 border border-neutral-800 hover:border-blue-500/50 transition-all group">
					<div class="text-2xl mb-3">🏋️</div>
					<h3 class="font-bold text-white mb-1 group-hover:text-blue-400 transition-colors">Lifting</h3>
					<p class="text-xs text-neutral-500">1.29M lbs · 125 workouts</p>
				</a>
				{/* Sleep */}
				<a href="/sleep" class="bg-neutral-950 rounded-xl p-5 border border-neutral-800 hover:border-blue-500/50 transition-all group">
					<div class="text-2xl mb-3">😴</div>
					<h3 class="font-bold text-white mb-1 group-hover:text-blue-400 transition-colors">Sleep</h3>
					<p class="text-xs text-neutral-500">Avg 68 score · 8 nights</p>
				</a>
				{/* Transformation */}
				<a href="/transformation" class="bg-neutral-950 rounded-xl p-5 border border-neutral-800 hover:border-blue-500/50 transition-all group">
					<div class="text-2xl mb-3">📈</div>
					<h3 class="font-bold text-white mb-1 group-hover:text-blue-400 transition-colors">Transformation</h3>
					<p class="text-xs text-neutral-500">242 → 188 → 218 lbs</p>
				</a>
				{/* Training */}
				<a href="/training" class="bg-neutral-950 rounded-xl p-5 border border-neutral-800 hover:border-blue-500/50 transition-all group">
					<div class="text-2xl mb-3">🎯</div>
					<h3 class="font-bold text-white mb-1 group-hover:text-blue-400 transition-colors">Training</h3>
					<p class="text-xs text-neutral-500">Volume trends · PRs</p>
				</a>
				{/* BJJ */}
				<a href="/bjj" class="bg-neutral-950 rounded-xl p-5 border border-neutral-800 hover:border-blue-500/50 transition-all group">
					<div class="text-2xl mb-3">🥋</div>
					<h3 class="font-bold text-white mb-1 group-hover:text-blue-400 transition-colors">BJJ</h3>
					<p class="text-xs text-neutral-500">Brown belt · 10+ years</p>
				</a>
				{/* Gear */}
				<a href="/gear" class="bg-neutral-950 rounded-xl p-5 border border-neutral-800 hover:border-blue-500/50 transition-all group">
					<div class="text-2xl mb-3">⚙️</div>
					<h3 class="font-bold text-white mb-1 group-hover:text-blue-400 transition-colors">Gear</h3>
					<p class="text-xs text-neutral-500">What I actually use</p>
				</a>
				{/* PR Board */}
				<a href="/prs" class="bg-neutral-950 rounded-xl p-5 border border-neutral-800 hover:border-yellow-500/50 transition-all group">
					<div class="text-2xl mb-3">🥇</div>
					<h3 class="font-bold text-white mb-1 group-hover:text-yellow-400 transition-colors">PR Board</h3>
					<p class="text-xs text-neutral-500">388 lb deadlift · 25 PRs</p>
				</a>
				{/* A Day in the Data */}
				<a href="/day" class="bg-neutral-950 rounded-xl p-5 border border-neutral-800 hover:border-blue-500/50 transition-all group">
					<div class="text-2xl mb-3">📅</div>
					<h3 class="font-bold text-white mb-1 group-hover:text-blue-400 transition-colors">A Day in the Data</h3>
					<p class="text-xs text-neutral-500">24h of tracking</p>
				</a>
			</div>
		</div>
	</section>
	<Newsletter client:visible />

</Layout>
