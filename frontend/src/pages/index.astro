---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.jsx';
import NewsletterSignup from '../components/NewsletterSignup.jsx';
import { CANONICAL_BLOG_POSTS } from '../lib/blogPosts';
import videosData from '../data/videos.json';
import {
  Activity,
  ArrowRight,
  CalendarDays,
  Clock,
  Dumbbell,
  Eye,
  Flame,
  HeartPulse,
  Play,
  Trophy,
  Youtube,
} from 'lucide-react';
import { lifetimeStats } from '../data/stats.js';
import homepageFitnessData from '../data/homepageFitnessData.json';
import { recentActivity } from '../data/recentActivity.js';
import weeklyProgress from '../data/weeklyProgress.js';
import { isLikelyShortVideo } from '../lib/videoMeta.js';

function readTime(content = '') {
  const words = content.split(/\s+/).filter(Boolean).length;
  return `${Math.max(1, Math.round(words / 200))} min read`;
}

function formatBlogDate(value) {
  const timestamp = Date.parse(value || '');
  if (Number.isNaN(timestamp)) return 'Undated';
  return new Date(timestamp).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}

function formatCompactCount(value) {
  const amount = Number(value || 0);
  if (amount < 1000) return amount.toLocaleString('en-US');
  return new Intl.NumberFormat('en-US', {
    notation: 'compact',
    maximumFractionDigits: 1,
  }).format(amount);
}

function formatViews(count) {
  const amount = Number(count || 0);
  if (amount >= 1000) return `${(amount / 1000).toFixed(1)}K views`;
  return `${amount.toLocaleString('en-US')} views`;
}

function formatRangeDate(key) {
  if (!key) return '';
  return new Date(`${key}T12:00:00Z`).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC',
  });
}

function formatTrainingMetric(value, suffix = '') {
  const amount = Number(value || 0);
  const formatted = Number.isInteger(amount)
    ? amount.toLocaleString('en-US')
    : amount.toLocaleString('en-US', { maximumFractionDigits: 1 });
  return `${formatted}${suffix}`;
}

function goalPercent(goal) {
  return Math.min(100, Math.round((Number(goal.current || 0) / Number(goal.target || 1)) * 100));
}

const allVideos = videosData.videos || [];
const officialChannelStats = videosData.channelStats || {};
const latestLongFormVideos = [...allVideos]
  .filter((video) => !video.is_live && !isLikelyShortVideo(video) && video.publishedAt)
  .sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime());
const featuredVideo = [...latestLongFormVideos]
  .sort((a, b) => Number(b.viewCount || 0) - Number(a.viewCount || 0))[0] || latestLongFormVideos[0];
const recentVideos = latestLongFormVideos
  .filter((video) => video.id !== featuredVideo?.id)
  .slice(0, 3);
const channelTotalVideos = Number(officialChannelStats.videoCount || allVideos.length);
const channelTotalViews = Number(
  officialChannelStats.viewCount
  || allVideos.reduce((sum, video) => sum + Number(video.viewCount || 0), 0)
);
const channelSubscriberCount = Number(officialChannelStats.subscriberCount || 0);
const channelShortsCount = allVideos.filter((video) => isLikelyShortVideo(video)).length;
const channelLatestDate = latestLongFormVideos[0]
  ? new Date(latestLongFormVideos[0].publishedAt).toLocaleDateString('en-US', {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
    })
  : 'N/A';

const recentPosts = [...CANONICAL_BLOG_POSTS]
  .sort((a, b) => new Date(b.published_at).getTime() - new Date(a.published_at).getTime())
  .slice(0, 3);

const formattedLifetimeStats = {
  lbsLifted: new Intl.NumberFormat('en-US').format(lifetimeStats.totalLbsLifted),
  milesRun: new Intl.NumberFormat('en-US', {
    minimumFractionDigits: 1,
    maximumFractionDigits: 1,
  }).format(lifetimeStats.totalMilesRun),
  workouts: new Intl.NumberFormat('en-US').format(lifetimeStats.totalWorkouts),
};
const strengthSessions = new Intl.NumberFormat('en-US').format(
  homepageFitnessData.lifetimeStats?.sourceBreakdown?.strengthSessions || 0,
);

const weeklyRange = weeklyProgress.dateRange || {};
const thisWeekDateRange = `${formatRangeDate(weeklyRange.thisWeekStart)}-${formatRangeDate(weeklyRange.thisWeekEnd)}, ${weeklyRange.thisWeekEnd?.slice(0, 4) || ''}`;
const lastWeekDateRange = `${formatRangeDate(weeklyRange.lastWeekStart)}-${formatRangeDate(weeklyRange.lastWeekEnd)}, ${weeklyRange.lastWeekEnd?.slice(0, 4) || ''}`;
const weeklyMetrics = [
  { label: 'Workouts', current: weeklyProgress.workouts?.thisWeek || 0, previous: weeklyProgress.workouts?.lastWeek || 0, suffix: '' },
  { label: 'Runs', current: weeklyProgress.runs?.thisWeek || 0, previous: weeklyProgress.runs?.lastWeek || 0, suffix: '' },
  { label: 'Volume', current: weeklyProgress.volume?.thisWeek || 0, previous: weeklyProgress.volume?.lastWeek || 0, suffix: ' lbs' },
  { label: 'Miles', current: weeklyProgress.miles?.thisWeek || 0, previous: weeklyProgress.miles?.lastWeek || 0, suffix: ' mi' },
  { label: 'BJJ', current: weeklyProgress.bjj?.thisWeek || 0, previous: weeklyProgress.bjj?.lastWeek || 0, suffix: '' },
];
const yearlyGoals = homepageFitnessData.yearlyGoals || {};
const goalRows = [
  { label: 'Running', ...yearlyGoals.running },
  { label: 'Lifting', ...yearlyGoals.lifting },
  { label: 'Workouts', ...yearlyGoals.workouts },
  { label: 'BJJ', ...yearlyGoals.bjj },
].filter((goal) => Number(goal.target) > 0);
const latestTrainingActivity = recentActivity.slice(0, 3);
const trainingSnapshot = homepageFitnessData.trainingStats || {};
const recoverySnapshot = homepageFitnessData.recovery || {};
const trainingFocus = homepageFitnessData.trainingFocus || {};
const trainingUpdatedAt = new Date(homepageFitnessData.generatedAt || Date.now()).toLocaleString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
  hour: 'numeric',
  minute: '2-digit',
});

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://tobyonfitnesstech.com/#webpage-home',
  name: 'Toby on Fitness Tech - Home',
  description: 'Independent reviews of fitness technology: Speediance, Tonal, WHOOP, Garmin, and more. Real data from a real athlete.',
  url: 'https://tobyonfitnesstech.com',
  inLanguage: 'en',
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: 'https://tobyonfitnesstech.com/images/og-home.jpg',
  },
  isPartOf: { '@id': 'https://tobyonfitnesstech.com/#website' },
  about: { '@id': 'https://tobyonfitnesstech.com/#organization' },
  author: { '@id': 'https://tobyonfitnesstech.com/#person' },
};
---

<Layout
  title="Toby on Fitness Tech - Reviews, Analysis, & Live Streams"
  description="Independent fitness tech reviews from a real athlete. Speediance vs Tonal, WHOOP vs Garmin, BJJ commentary, and transformation data. No fluff, just real numbers."
  jsonLd={webPageSchema}
>
  <div data-homepage-section="hero" data-homepage-title="Hero and featured story" data-homepage-purpose="orientation">
    <Hero client:load lang="en" />
  </div>

  <section
    id="blog"
    data-homepage-section="latest-articles"
    data-homepage-title="Latest articles"
    data-homepage-purpose="content-discovery"
    class="border-t border-neutral-800 bg-neutral-950 py-16"
  >
    <div class="container mx-auto px-4">
      <div class="mb-10 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <div>
          <span class="mb-2 block text-sm font-bold uppercase tracking-widest text-blue-400">Latest from the Blog</span>
          <h2 class="text-3xl font-bold text-white md:text-4xl">Fresh Analysis & Reviews</h2>
          <p class="mt-3 max-w-2xl text-neutral-400">The newest posts on fitness tech, training trends, and what the data actually says.</p>
        </div>
        <a href="/blog/" class="inline-flex items-center gap-2 self-start rounded-lg border border-neutral-700 px-5 py-2.5 font-semibold text-white transition-colors hover:border-blue-500/60 hover:text-blue-400 md:self-auto">
          View all posts <ArrowRight size={16} />
        </a>
      </div>

      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
        {recentPosts.map((post) => (
          <a href={`/blog/${post.slug}/`} class="group block overflow-hidden rounded-lg border border-neutral-800 bg-neutral-900 transition-colors hover:border-blue-500/50">
            {post.image && (
              <div class="aspect-video overflow-hidden bg-neutral-950">
                <img src={post.image} alt={post.title} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
              </div>
            )}
            <div class="p-5">
              <span class="text-xs font-semibold uppercase tracking-wide text-blue-400">{post.category}</span>
              <h3 class="mt-3 line-clamp-2 text-lg font-bold leading-snug text-white transition-colors group-hover:text-blue-400">{post.title}</h3>
              <div class="mt-2 flex items-center gap-2 text-xs text-neutral-500">
                <span>{formatBlogDate(post.published_at)}</span>
                <span aria-hidden="true">/</span>
                <span>{readTime(post.content)}</span>
              </div>
              <p class="mt-3 text-sm leading-relaxed text-neutral-400">
                {post.excerpt.length > 105 ? `${post.excerpt.slice(0, 105)}...` : post.excerpt}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section
    id="training-proof"
    data-homepage-section="training-proof"
    data-homepage-title="Current training proof"
    data-homepage-purpose="proof"
    class="border-y border-neutral-800 bg-neutral-900 py-16"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="flex flex-col gap-5 border-b border-neutral-700 pb-8 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <div class="mb-3 flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-emerald-400">
            <Activity size={17} />
            Training proof
          </div>
          <h2 class="text-3xl font-bold text-white md:text-4xl">What the work looks like right now</h2>
          <p class="mt-3 max-w-3xl text-neutral-400">
            A single current view of weekly training, recent activity, recovery, yearly progress, and the lifetime totals behind the reviews.
          </p>
        </div>
        <div class="flex items-center gap-2 text-sm text-neutral-400">
          <CalendarDays size={16} className="text-neutral-500" />
          Updated {trainingUpdatedAt} ET
        </div>
      </div>

      <div class="grid border-b border-neutral-700 lg:grid-cols-[minmax(0,2fr)_minmax(18rem,1fr)]">
        <div class="py-8 lg:border-r lg:border-neutral-700 lg:pr-8">
          <div class="mb-6 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <h3 class="text-xl font-bold text-white">This week vs last week</h3>
              <p class="mt-1 text-sm text-neutral-500">{thisWeekDateRange} vs {lastWeekDateRange}</p>
            </div>
            <p class="text-sm text-neutral-400">
              Current focus: <span class="font-semibold capitalize text-white">{trainingFocus.focus || 'mixed training'}</span>
            </p>
          </div>

          <div class="grid grid-cols-2 border-y border-neutral-700 sm:grid-cols-3 xl:grid-cols-5">
            {weeklyMetrics.map((metric, index) => (
              <div class:list={['min-w-0 py-5 pr-4', index > 0 && 'border-l border-neutral-700 pl-4', index === 4 && 'col-span-2 border-t sm:col-span-1 sm:border-t-0']}>
                <div class="text-xs font-semibold uppercase tracking-wide text-neutral-500">{metric.label}</div>
                <div class="mt-2 text-2xl font-bold text-white">{formatTrainingMetric(metric.current, metric.suffix)}</div>
                <div class="mt-1 text-xs text-neutral-500">Last week: {formatTrainingMetric(metric.previous, metric.suffix)}</div>
              </div>
            ))}
          </div>

          <div class="mt-8 grid gap-8 sm:grid-cols-2">
            <div>
              <div class="mb-4 flex items-center gap-2">
                <Flame size={18} className="text-orange-400" />
                <h3 class="font-bold text-white">Latest activity</h3>
              </div>
              <div class="divide-y divide-neutral-700 border-y border-neutral-700">
                {latestTrainingActivity.map((item) => (
                  <div class="py-4">
                    <div class="flex items-center justify-between gap-4">
                      <span class="text-xs font-semibold uppercase tracking-wide text-neutral-500">{item.type}</span>
                      <span class="text-xs text-neutral-500">{item.date}</span>
                    </div>
                    <div class="mt-1 font-semibold text-white">{item.title}</div>
                    <div class="mt-1 text-sm text-neutral-400">{item.subtitle}</div>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <div class="mb-4 flex items-center gap-2">
                <HeartPulse size={18} className="text-rose-400" />
                <h3 class="font-bold text-white">Current signals</h3>
              </div>
              <dl class="divide-y divide-neutral-700 border-y border-neutral-700">
                <div class="flex items-center justify-between gap-4 py-4">
                  <dt class="text-sm text-neutral-400">Training streak</dt>
                  <dd class="font-bold text-white">{trainingSnapshot.trainingStreak || 0} days</dd>
                </div>
                <div class="flex items-center justify-between gap-4 py-4">
                  <dt class="text-sm text-neutral-400">Last workout</dt>
                  <dd class="text-right font-bold text-white">{trainingSnapshot.lastWorkoutData?.type || 'N/A'} / {trainingSnapshot.lastWorkoutData?.date || 'N/A'}</dd>
                </div>
                <div class="flex items-center justify-between gap-4 py-4">
                  <dt class="text-sm text-neutral-400">WHOOP recovery</dt>
                  <dd class="font-bold text-white">{recoverySnapshot.currentScore ?? 'N/A'}%</dd>
                </div>
                <div class="flex items-center justify-between gap-4 py-4">
                  <dt class="text-sm text-neutral-400">Last sleep score</dt>
                  <dd class="font-bold text-white">{recoverySnapshot.lastSleepScore ?? 'N/A'}</dd>
                </div>
              </dl>
            </div>
          </div>
        </div>

        <aside class="py-8 lg:pl-8" aria-labelledby="year-progress-heading">
          <div class="mb-4 flex items-center gap-2">
            <Trophy size={18} className="text-amber-400" />
            <h3 id="year-progress-heading" class="text-xl font-bold text-white">2026 progress</h3>
          </div>
          <div class="divide-y divide-neutral-700 border-y border-neutral-700">
            {goalRows.map((goal) => (
              <div class="py-4">
                <div class="flex items-baseline justify-between gap-4 text-sm">
                  <span class="font-semibold text-white">{goal.label}</span>
                  <span class="text-neutral-400">{formatTrainingMetric(goal.current)} / {formatTrainingMetric(goal.target)} {goal.unit}</span>
                </div>
                <div class="mt-3 h-2 overflow-hidden rounded bg-neutral-800" role="progressbar" aria-label={`${goal.label} goal progress`} aria-valuenow={goalPercent(goal)} aria-valuemin="0" aria-valuemax="100">
                  <div class="h-full rounded bg-emerald-500" style={{ width: `${goalPercent(goal)}%` }}></div>
                </div>
                <div class="mt-1 text-right text-xs font-semibold text-emerald-400">{goalPercent(goal)}%</div>
              </div>
            ))}
          </div>
        </aside>
      </div>

      <div class="grid border-b border-neutral-700 md:grid-cols-3">
        <div class="py-7 md:pr-6">
          <div class="flex items-center gap-2 text-sm text-neutral-500"><Dumbbell size={17} /> Lifetime lifting</div>
          <div class="mt-2 text-3xl font-bold text-white">{formattedLifetimeStats.lbsLifted} lbs</div>
          <div class="mt-1 text-sm text-neutral-500">{strengthSessions} strength sessions</div>
        </div>
        <div class="border-t border-neutral-700 py-7 md:border-l md:border-t-0 md:px-6">
          <div class="flex items-center gap-2 text-sm text-neutral-500"><Activity size={17} /> Lifetime running</div>
          <div class="mt-2 text-3xl font-bold text-white">{formattedLifetimeStats.milesRun} miles</div>
          <div class="mt-1 text-sm text-neutral-500">Garmin-backed activity history</div>
        </div>
        <div class="border-t border-neutral-700 py-7 md:border-l md:border-t-0 md:pl-6">
          <div class="flex items-center gap-2 text-sm text-neutral-500"><Flame size={17} /> Tracked workouts</div>
          <div class="mt-2 text-3xl font-bold text-white">{formattedLifetimeStats.workouts}</div>
          <div class="mt-1 text-sm text-neutral-500">Strength, running, and BJJ combined</div>
        </div>
      </div>

      <nav class="flex flex-wrap gap-x-6 gap-y-3 pt-7" aria-label="Explore training data">
        <a href="/training/" class="inline-flex items-center gap-1.5 font-semibold text-blue-400 hover:text-blue-300">Training trends <ArrowRight size={15} /></a>
        <a href="/running/" class="inline-flex items-center gap-1.5 font-semibold text-blue-400 hover:text-blue-300">Running data <ArrowRight size={15} /></a>
        <a href="/speediance/" class="inline-flex items-center gap-1.5 font-semibold text-blue-400 hover:text-blue-300">Lifting data <ArrowRight size={15} /></a>
        <a href="/whoop/" class="inline-flex items-center gap-1.5 font-semibold text-blue-400 hover:text-blue-300">Recovery data <ArrowRight size={15} /></a>
        <a href="/bjj/" class="inline-flex items-center gap-1.5 font-semibold text-blue-400 hover:text-blue-300">BJJ history <ArrowRight size={15} /></a>
        <a href="/prs/" class="inline-flex items-center gap-1.5 font-semibold text-blue-400 hover:text-blue-300">PR board <ArrowRight size={15} /></a>
      </nav>
    </div>
  </section>

  <section
    id="watch"
    data-homepage-section="video-hub"
    data-homepage-title="Featured and latest videos"
    data-homepage-purpose="video-discovery"
    class="border-b border-neutral-800 bg-neutral-950 py-16"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mb-10 flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
        <div>
          <div class="mb-3 flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-red-400">
            <Youtube size={18} />
            Watch
          </div>
          <h2 class="text-3xl font-bold text-white md:text-4xl">Featured and latest videos</h2>
          <p class="mt-3 max-w-2xl text-neutral-400">One place for the strongest long-form video and the newest uploads.</p>
        </div>
        <a href="/videos/" class="inline-flex items-center gap-2 self-start rounded-lg border border-neutral-700 px-5 py-2.5 font-semibold text-white transition-colors hover:border-red-500/60 hover:text-red-400 md:self-auto">
          Browse all videos <ArrowRight size={16} />
        </a>
      </div>

      <div class="grid gap-8 lg:grid-cols-[minmax(0,1.7fr)_minmax(20rem,1fr)]">
        {featuredVideo && (
          <div data-video-location="homepage_featured">
            <div class="aspect-video overflow-hidden rounded-lg border border-neutral-800 bg-neutral-900">
              <iframe
                class="h-full w-full"
                src={`https://www.youtube.com/embed/${featuredVideo.id}?rel=0`}
                title={featuredVideo.title}
                data-analytics-video-id={featuredVideo.id}
                loading="lazy"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
            <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <div class="text-xs font-semibold uppercase tracking-wide text-red-400">Viewer favorite</div>
                <h3 class="mt-2 text-xl font-bold text-white">{featuredVideo.title}</h3>
                <p class="mt-2 text-sm text-neutral-500">{formatViews(featuredVideo.viewCount)} / {featuredVideo.duration_formatted || 'Long-form'}</p>
              </div>
              <a href={`/video/${featuredVideo.id}/`} class="inline-flex shrink-0 items-center gap-2 font-semibold text-blue-400 hover:text-blue-300">
                Video page <ArrowRight size={15} />
              </a>
            </div>
          </div>
        )}

        <div class="border-y border-neutral-700">
          {recentVideos.map((video) => (
            <a href={`/video/${video.id}/`} class="group grid grid-cols-[8rem_1fr] gap-4 border-b border-neutral-700 py-5 last:border-b-0 sm:grid-cols-[10rem_1fr]">
              <div class="relative aspect-video overflow-hidden rounded bg-neutral-900">
                <img src={video.thumbnail} alt={video.title} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
                <div class="absolute inset-0 flex items-center justify-center bg-black/30">
                  <Play size={24} className="text-white" fill="currentColor" />
                </div>
              </div>
              <div class="min-w-0">
                <div class="text-xs font-semibold uppercase tracking-wide text-neutral-500">Latest upload</div>
                <h3 class="mt-1 line-clamp-2 font-bold leading-snug text-white transition-colors group-hover:text-blue-400">{video.title}</h3>
                <div class="mt-2 flex flex-wrap items-center gap-3 text-xs text-neutral-500">
                  <span class="inline-flex items-center gap-1"><Eye size={13} /> {formatViews(video.viewCount)}</span>
                  {video.duration_formatted && <span class="inline-flex items-center gap-1"><Clock size={13} /> {video.duration_formatted}</span>}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <div class="mt-10 grid border-y border-neutral-700 sm:grid-cols-2 lg:grid-cols-5">
        <div class="py-5 lg:pr-5">
          <div class="text-2xl font-bold text-white">{formatCompactCount(channelSubscriberCount)}</div>
          <div class="text-xs uppercase tracking-wide text-neutral-500">Subscribers</div>
        </div>
        <div class="border-t border-neutral-700 py-5 sm:border-l sm:border-t-0 sm:pl-5 lg:pr-5">
          <div class="text-2xl font-bold text-white">{formatCompactCount(channelTotalViews)}</div>
          <div class="text-xs uppercase tracking-wide text-neutral-500">Total views</div>
        </div>
        <div class="border-t border-neutral-700 py-5 sm:border-t lg:border-l lg:pl-5 lg:pr-5">
          <div class="text-2xl font-bold text-white">{formatCompactCount(channelTotalVideos)}</div>
          <div class="text-xs uppercase tracking-wide text-neutral-500">Videos</div>
        </div>
        <div class="border-t border-neutral-700 py-5 sm:border-l sm:pl-5 lg:border-l lg:pr-5">
          <div class="text-2xl font-bold text-white">{formatCompactCount(channelShortsCount)}</div>
          <div class="text-xs uppercase tracking-wide text-neutral-500">Shorts</div>
        </div>
        <div class="border-t border-neutral-700 py-5 lg:border-l lg:pl-5">
          <div class="text-lg font-bold text-white">{channelLatestDate}</div>
          <div class="text-xs uppercase tracking-wide text-neutral-500">Latest long-form upload</div>
        </div>
      </div>
    </div>
  </section>

  <div
    id="newsletter"
    data-homepage-section="newsletter"
    data-homepage-title="Newsletter signup"
    data-homepage-purpose="conversion"
  >
    <NewsletterSignup client:visible formLocation="homepage_newsletter" />
  </div>
</Layout>
