---
import Layout from '../layouts/Layout.astro';

// Weekly training schedule - full body minus legs, prioritized: Running > Lifting > BJJ
const weeklySchedule = [
  {
    day: "Monday",
    focus: "Running + Lifting",
    icon: "🏃",
    exercises: ["5K easy run", "Bench Press", "Lat Pulldown", "Overhead Press", "Barbell Row"],
    priority: 1
  },
  {
    day: "Tuesday",
    focus: "BJJ",
    icon: "🥋",
    exercises: ["Gi drilling", "Sparring rounds", "positional work"],
    priority: 3
  },
  {
    day: "Wednesday",
    focus: "Running + Lifting",
    icon: "🏃",
    exercises: ["6K tempo run", "Deadlift", "Hip Thrust", "Pull-ups", "Face Pulls"],
    priority: 1
  },
  {
    day: "Thursday",
    focus: "Active Recovery",
    icon: "🔄",
    exercises: ["Easy 3K jog", "mobility work", "stretching"],
    priority: 0
  },
  {
    day: "Friday",
    focus: "Running + Lifting",
    icon: "🏃",
    exercises: ["Interval speedwork", "Incline Bench", "Lat Pulldown", "Bicep Curls", "Tricep Extensions"],
    priority: 1
  },
  {
    day: "Saturday",
    focus: "BJJ",
    icon: "🥋",
    exercises: ["Open mat", "technical drilling", "live rolling"],
    priority: 3
  },
  {
    day: "Sunday",
    focus: "Rest",
    icon: "😴",
    exercises: ["Rest day", "sleep recovery", "light walking"],
    priority: 0
  }
];

const stats = {
  workoutsPerWeek: 6,
  restDays: 1,
  runningDays: 4,
  liftingDays: 3,
  bjjDays: 2
};

const pageTitle = "Training Week";
const pageDescription = "A typical training week: running, full-body lifting (minus legs), and BJJ. My prioritized approach to fitness: Running > Lifting > BJJ.";

const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "Toby's Training Week",
  "description": "A weekly training program combining running, full-body lifting, and Brazilian Jiu-Jitsu.",
  "provider": {
    "@type": "Person",
    "name": "Toby"
  },
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": "https://schema.org/OfflineMode",
    "courseWorkload": "P6D"
  }
};
---

<Layout title={pageTitle} description={pageDescription} jsonLd={courseSchema}>
  <main class="max-w-5xl mx-auto px-4 py-12">
    {/* Hero Section */}
    <section class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Training Week</h1>
      <p class="text-lg text-neutral-400 max-w-2xl mx-auto">
        A typical week balancing my three pillars: running, full-body lifting (minus legs), and BJJ.
        Everything's prioritized: <span class="text-blue-400 font-semibold">Running &gt; Lifting &gt; BJJ</span>
      </p>
    </section>

    {/* Stats Overview */}
    <section class="mb-12">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-blue-400 mb-1">{stats.workoutsPerWeek}</div>
          <div class="text-sm text-neutral-400">Workouts/Week</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-white mb-1">{stats.restDays}</div>
          <div class="text-sm text-neutral-400">Rest Days</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-green-400 mb-1">{stats.runningDays}</div>
          <div class="text-sm text-neutral-400">Running Days</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-purple-400 mb-1">{stats.liftingDays}</div>
          <div class="text-sm text-neutral-400">Lifting Days</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-orange-400 mb-1">{stats.bjjDays}</div>
          <div class="text-sm text-neutral-400">BJJ Days</div>
        </div>
      </div>
    </section>

    {/* Weekly Schedule Grid */}
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
        <span>📅</span> Weekly Schedule
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-7 gap-4">
        {weeklySchedule.map((day) => (
          <div class={`bg-neutral-900 border rounded-xl p-5 transition-all hover:scale-[1.02] ${
            day.priority === 0 
              ? 'border-neutral-800 opacity-70' 
              : day.priority === 1 
                ? 'border-blue-500/30 hover:border-blue-500/60' 
                : day.priority === 2 
                  ? 'border-purple-500/30 hover:border-purple-500/60'
                  : 'border-orange-500/30 hover:border-orange-500/60'
          }`}>
            <div class="flex items-center gap-2 mb-3">
              <span class="text-2xl">{day.icon}</span>
              <h3 class="text-lg font-bold text-white">{day.day}</h3>
            </div>
            <div class={`text-sm font-semibold mb-3 ${
              day.priority === 1 ? 'text-blue-400' : 
              day.priority === 2 ? 'text-purple-400' : 
              day.priority === 3 ? 'text-orange-400' : 'text-neutral-500'
            }`}>
              {day.focus}
            </div>
            <ul class="space-y-1">
              {day.exercises.map((ex) => (
                <li class="text-sm text-neutral-400 flex items-start gap-2">
                  <span class="text-neutral-600 mt-1">•</span>
                  <span>{ex}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    {/* Training Philosophy */}
    <section class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8">
      <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-2">
        <span>🧠</span> Training Philosophy
      </h2>
      <div class="space-y-4">
        <p class="text-neutral-300 text-lg">
          My training is organized by priority: <span class="text-blue-400 font-bold">Running &gt; Lifting &gt; BJJ</span>
        </p>
        <div class="grid md:grid-cols-3 gap-6 mt-6">
          <div class="bg-neutral-950 rounded-xl p-5 border border-blue-500/20">
            <div class="text-3xl mb-2">🏆</div>
            <h3 class="text-blue-400 font-bold mb-2">#1 Running</h3>
            <p class="text-neutral-400 text-sm">
              Cardio is the foundation. Whether it's easy miles, tempo runs, or intervals, running comes first. 
              A strong aerobic base supports everything else.
            </p>
          </div>
          <div class="bg-neutral-950 rounded-xl p-5 border border-purple-500/20">
            <div class="text-3xl mb-2">💪</div>
            <h3 class="text-purple-400 font-bold mb-2">#2 Lifting</h3>
            <p class="text-neutral-400 text-sm">
              Full-body sessions minus legs (Speediance handles the heavy compounds). 
              Focus on pressing, pulling, and hypertrophy. Three days per week.
            </p>
          </div>
          <div class="bg-neutral-950 rounded-xl p-5 border border-orange-500/20">
            <div class="text-3xl mb-2">🥋</div>
            <h3 class="text-orange-400 font-bold mb-2">#3 BJJ</h3>
            <p class="text-neutral-400 text-sm">
              Two days per week for technique and rolling. Jiu-Jitsu keeps me humble and provides 
              excellent anaerobic conditioning and skill work.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
