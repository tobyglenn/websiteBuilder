---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'Training Week — TobyOnFitnessTech';
const pageDescription = 'A realistic 7-day training schedule built around Toby’s philosophy: Running > Lifting > BJJ, with full-body (minus legs) strength focus and recovery balance.';

const weeklySchedule = [
  {
    day: 'Monday',
    focus: 'Easy Run + Upper Push',
    exercises: ['30–40 min easy run (Zone 2)', 'Chest press', 'Overhead press', 'Triceps extensions'],
  },
  {
    day: 'Tuesday',
    focus: 'BJJ Technique + Pull',
    exercises: ['BJJ drilling / positional rounds', 'Lat pulldown', 'Seated row', 'Face pulls'],
  },
  {
    day: 'Wednesday',
    focus: 'Quality Run + Core',
    exercises: ['Intervals or tempo run', 'Planks + dead bugs', 'Anti-rotation press', 'Mobility work'],
  },
  {
    day: 'Thursday',
    focus: 'Full Body (Minus Legs) Strength',
    exercises: ['Bench press', 'Bent-over row', 'Shoulder raises', 'Biceps + triceps superset'],
  },
  {
    day: 'Friday',
    focus: 'Longer Run + Recovery',
    exercises: ['Steady endurance run', 'Breathwork', 'Stretching + foam roll', 'Light mobility'],
  },
  {
    day: 'Saturday',
    focus: 'BJJ Open Mat + Accessories',
    exercises: ['Live rolls / situational rounds', 'Rear delt work', 'Core finisher', 'Grip / carry work'],
  },
  {
    day: 'Sunday',
    focus: 'Rest / Active Recovery',
    exercises: ['Walk + sunlight', 'Mobility flow', 'Optional easy spin', 'Early sleep focus'],
  },
];

const workoutsPerWeek = 6;
const restDays = 1;

const courseSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: 'Training Week',
  description:
    'A weekly hybrid training approach prioritizing running first, lifting second, and Brazilian Jiu-Jitsu third with full-body (minus legs) strength sessions.',
  provider: {
    '@type': 'Organization',
    name: 'TobyOnFitnessTech',
    url: 'https://tobyonfitnesstech.com',
  },
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Training Week', url: '/training' }]}
>
  <main class="min-h-screen bg-neutral-950 text-white">
    <section class="pt-32 pb-14 md:pt-40 md:pb-20 border-b border-neutral-900">
      <div class="container mx-auto px-4">
        <p class="text-xs font-bold tracking-widest uppercase text-blue-400 mb-4">WEEKLY PLAN</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-5">Training Week</h1>
        <p class="text-lg md:text-xl text-neutral-300 max-w-3xl leading-relaxed">
          A practical weekly split built around what matters most: run performance first, upper-body-focused
          strength second, and BJJ third—while protecting recovery.
        </p>
      </div>
    </section>

    <section class="py-14 md:py-16 border-b border-neutral-900">
      <div class="container mx-auto px-4">
        <div class="flex items-end justify-between gap-4 mb-6">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold">Mon–Sun Schedule</h2>
            <p class="text-sm text-neutral-400 mt-2">Full body minus legs, with running as the anchor.</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
          {weeklySchedule.map((item) => (
            <article class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5 hover:border-blue-500/40 transition-colors">
              <div class="flex items-center justify-between mb-3">
                <h3 class="text-lg font-bold text-white">{item.day}</h3>
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-blue-500/15 text-blue-300 border border-blue-500/30">
                  Primary Focus
                </span>
              </div>
              <p class="text-blue-300 font-medium mb-4">{item.focus}</p>
              <ul class="space-y-2">
                {item.exercises.map((exercise) => (
                  <li class="text-sm text-neutral-300 flex items-start gap-2">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-blue-400 shrink-0"></span>
                    <span>{exercise}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="py-14 md:py-16 border-b border-neutral-900">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div class="lg:col-span-2 bg-neutral-900 border border-neutral-800 rounded-2xl p-6 md:p-7">
            <p class="text-xs font-bold tracking-widest uppercase text-blue-400 mb-3">Training Philosophy</p>
            <h2 class="text-2xl md:text-3xl font-bold mb-4">Running &gt; Lifting &gt; BJJ</h2>
            <p class="text-neutral-300 leading-relaxed mb-4">
              The week is intentionally ordered by priority. Running quality and consistency drive the plan,
              lifting supports performance and durability, and BJJ rounds out skill and conditioning without
              compromising recovery.
            </p>
            <p class="text-neutral-400 text-sm leading-relaxed">
              Strength sessions are full body with an upper-body bias (minus dedicated leg days), using movements
              commonly tracked in Speediance by muscle group—push, pull, shoulders, arms, and core accessories.
            </p>
          </div>

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 md:p-7">
            <p class="text-xs font-bold tracking-widest uppercase text-blue-400 mb-4">Weekly Stats</p>
            <div class="space-y-4">
              <div class="flex items-center justify-between border-b border-neutral-800 pb-3">
                <span class="text-neutral-400">Workouts / Week</span>
                <span class="text-2xl font-black text-blue-300">{workoutsPerWeek}</span>
              </div>
              <div class="flex items-center justify-between border-b border-neutral-800 pb-3">
                <span class="text-neutral-400">Rest Days</span>
                <span class="text-2xl font-black text-blue-300">{restDays}</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-neutral-400">Priority Order</span>
                <span class="text-sm font-semibold text-white">Run → Lift → BJJ</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(courseSchema)} />
</Layout>
