---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.jsx';
import Footer from '../components/Footer.jsx';
import {
  RECOVERY_RECORDS,
  AVG_RECOVERY,
  AVG_HRV,
  AVG_RHR,
  AVG_SLEEP_PERF,
  TOTAL_DAYS,
  RECENT_RECORDS,
  TREND_DATA,
  RECOVERY_BREAKDOWN,
} from '../data/whoop';

const CHART_W = 800;
const CHART_H = 280;
const PADDING = 30;

const latest = RECOVERY_RECORDS[RECOVERY_RECORDS.length - 1] ?? null;

function linePath(data, key, min, max) {
  if (data.length < 2) return '';
  const width = CHART_W - PADDING * 2;
  const height = CHART_H - PADDING * 2;

  return data
    .map((point, i) => {
      const x = PADDING + (i / (data.length - 1)) * width;
      const y = PADDING + (1 - (point[key] - min) / (max - min || 1)) * height;
      return `${i === 0 ? 'M' : 'L'} ${x.toFixed(2)} ${y.toFixed(2)}`;
    })
    .join(' ');
}

const recoveryValues = TREND_DATA.map((d) => d.recovery);
const hrvValues = TREND_DATA.map((d) => d.hrv);

const recMin = Math.min(...recoveryValues, 0);
const recMax = Math.max(...recoveryValues, 100);
const hrvMin = Math.min(...hrvValues);
const hrvMax = Math.max(...hrvValues);

const recoveryPath = linePath(TREND_DATA, 'recovery', recMin, recMax);
const hrvPath = linePath(TREND_DATA, 'hrv', hrvMin, hrvMax);

const totalBreakdown = RECOVERY_BREAKDOWN.green + RECOVERY_BREAKDOWN.yellow + RECOVERY_BREAKDOWN.red || 1;
const radius = 70;
const circumference = 2 * Math.PI * radius;

const greenArc = (RECOVERY_BREAKDOWN.green / totalBreakdown) * circumference;
const yellowArc = (RECOVERY_BREAKDOWN.yellow / totalBreakdown) * circumference;
const redArc = (RECOVERY_BREAKDOWN.red / totalBreakdown) * circumference;
---

<Layout
  title="WHOOP Recovery Dashboard | TobyOnFitnessTech"
  description="Real WHOOP recovery analytics with trend charts, breakdowns, and daily records."
>
  <Header client:load />

  <main class="min-h-screen bg-neutral-950 text-white pt-20 pb-16 px-4">
    <section class="max-w-6xl mx-auto mb-10">
      <p class="text-blue-500 text-sm uppercase tracking-wide mb-2">WHOOP Analytics</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-3">WHOOP Recovery Dashboard</h1>
      <p class="text-neutral-400 max-w-3xl">
        Real recovery metrics from WHOOP, including HRV, resting heart rate, and sleep performance trends.
      </p>
    </section>

    <section class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-3 gap-4 mb-10">
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5">
        <p class="text-sm text-neutral-400">Average Recovery</p>
        <p class="text-3xl font-semibold text-blue-500">{AVG_RECOVERY}%</p>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5">
        <p class="text-sm text-neutral-400">Average HRV</p>
        <p class="text-3xl font-semibold text-blue-500">{AVG_HRV} ms</p>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5">
        <p class="text-sm text-neutral-400">Average Resting HR</p>
        <p class="text-3xl font-semibold text-blue-500">{AVG_RHR} bpm</p>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5">
        <p class="text-sm text-neutral-400">Average Sleep Performance</p>
        <p class="text-3xl font-semibold text-blue-500">{AVG_SLEEP_PERF}%</p>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5">
        <p class="text-sm text-neutral-400">Days Tracked</p>
        <p class="text-3xl font-semibold text-blue-500">{TOTAL_DAYS}</p>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5">
        <p class="text-sm text-neutral-400">Latest Recovery</p>
        <p class="text-3xl font-semibold text-blue-500">{latest ? `${latest.recovery_score}%` : 'N/A'}</p>
      </div>
    </section>

    <section class="max-w-6xl mx-auto grid gap-6 lg:grid-cols-2 mb-10">
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5">
        <h2 class="text-xl font-semibold mb-4">Recovery Trend</h2>
        <svg viewBox={`0 0 ${CHART_W} ${CHART_H}`} class="w-full h-auto">
          <path d={recoveryPath} fill="none" stroke="#3b82f6" stroke-width="3" stroke-linecap="round" />
        </svg>
      </div>

      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5">
        <h2 class="text-xl font-semibold mb-4">HRV Trend</h2>
        <svg viewBox={`0 0 ${CHART_W} ${CHART_H}`} class="w-full h-auto">
          <path d={hrvPath} fill="none" stroke="#60a5fa" stroke-width="3" stroke-linecap="round" />
        </svg>
      </div>
    </section>

    <section class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-6 mb-10">
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5">
        <h2 class="text-xl font-semibold mb-4">Recovery Breakdown</h2>
        <div class="flex items-center gap-8">
          <svg width="180" height="180" viewBox="0 0 180 180">
            <g transform="translate(90,90) rotate(-90)">
              <circle r={radius} cx="0" cy="0" fill="none" stroke="#262626" stroke-width="20" />
              <circle r={radius} cx="0" cy="0" fill="none" stroke="#22c55e" stroke-width="20" stroke-dasharray={`${greenArc} ${circumference - greenArc}`} stroke-dashoffset="0" />
              <circle r={radius} cx="0" cy="0" fill="none" stroke="#eab308" stroke-width="20" stroke-dasharray={`${yellowArc} ${circumference - yellowArc}`} stroke-dashoffset={-greenArc} />
              <circle r={radius} cx="0" cy="0" fill="none" stroke="#ef4444" stroke-width="20" stroke-dasharray={`${redArc} ${circumference - redArc}`} stroke-dashoffset={-(greenArc + yellowArc)} />
            </g>
          </svg>
          <div class="space-y-2 text-sm">
            <p><span class="inline-block w-3 h-3 bg-green-500 rounded-full mr-2"></span>Green (67-100): {RECOVERY_BREAKDOWN.green}</p>
            <p><span class="inline-block w-3 h-3 bg-yellow-500 rounded-full mr-2"></span>Yellow (34-66): {RECOVERY_BREAKDOWN.yellow}</p>
            <p><span class="inline-block w-3 h-3 bg-red-500 rounded-full mr-2"></span>Red (0-33): {RECOVERY_BREAKDOWN.red}</p>
          </div>
        </div>
      </div>

      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5 overflow-x-auto">
        <h2 class="text-xl font-semibold mb-4">Recent 10 Days</h2>
        <table class="w-full text-sm">
          <thead>
            <tr class="text-neutral-400 border-b border-neutral-800">
              <th class="text-left py-2">Date</th>
              <th class="text-left py-2">Recovery</th>
              <th class="text-left py-2">HRV</th>
              <th class="text-left py-2">Resting HR</th>
              <th class="text-left py-2">Sleep</th>
            </tr>
          </thead>
          <tbody>
            {RECENT_RECORDS.map((row) => (
              <tr class="border-b border-neutral-800/70">
                <td class="py-2">{row.date}</td>
                <td class="py-2">{row.recovery_score}%</td>
                <td class="py-2">{row.hrv.toFixed(1)}</td>
                <td class="py-2">{row.resting_hr}</td>
                <td class="py-2">{row.sleep_performance}%</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
