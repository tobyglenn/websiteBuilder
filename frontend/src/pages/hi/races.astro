---
import Layout from '../../layouts/Layout.astro';
import { getRaceData, getPRs, getStats } from '../../data/races.js';

const races = getRaceData();
const prs = getPRs();
const stats = getStats();

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Toby कौन-कौन सी रेस दूरी दौड़ता है?", "acceptedAnswer": { "@type": "Answer", "text": "Toby Garmin Fenix 7 के जरिए 5K, 10K, हाफ मैराथन और मैराथन दूरी ट्रैक करता है। मौजूदा डेटा में 5K दूरी की ट्रेनिंग रन शामिल हैं।" } },
    { "@type": "Question", "name": "Toby का 5K PR क्या है?", "acceptedAnswer": { "@type": "Answer", "text": prs['5K'] ? `Toby की सबसे तेज 5K दूरी की रन ${prs['5K'].date} को ${prs['5K'].pace}/मील की गति से पूरी हुई थी।` : "अभी तक कोई 5K डेटा दर्ज नहीं है।" } },
    { "@type": "Question", "name": "क्या Toby आधिकारिक रेस दौड़ता है?", "acceptedAnswer": { "@type": "Answer", "text": "ये एंट्रियाँ Garmin-ट्रैक्ड ट्रेनिंग रन को दिखाती हैं जो रेस दूरी पर हुई हैं, आधिकारिक रेस इवेंट्स नहीं। ये आउटडोर और ट्रेडमिल सत्रों से वास्तविक प्रदर्शन डेटा दर्शाती हैं।" } }
  ]
};
const distanceCategories = ['5K', '10K', 'Half Marathon', 'Marathon'];
const categoryIcons: Record<string, string> = { '5K': '🏃', '10K': '⚡', 'Half Marathon': '🎯', 'Marathon': '🏆' };
const categoryDistances: Record<string, string> = { '5K': '3.1 mi', '10K': '6.2 mi', 'Half Marathon': '13.1 mi', 'Marathon': '26.2 mi' };
---
<Layout title="रेस परिणाम — TobyOnFitnessTech" description="Garmin Fenix 7 के जरिए ट्रैक की गई रेस-दूरी रन। 5K, 10K, हाफ मैराथन पेस PRs और HR डेटा के साथ पूरी रेस हिस्ट्री।" jsonLd={faqSchema}><main class="min-h-screen bg-neutral-950 text-white"><section class="pt-28 pb-14 md:pt-36 md:pb-20 relative overflow-hidden"><div class="absolute inset-0 bg-gradient-to-br from-blue-900/10 via-transparent to-transparent pointer-events-none" /><div class="absolute right-0 top-0 w-64 h-64 bg-blue-600/5 rounded-full blur-3xl pointer-events-none" /><div class="container mx-auto px-4 relative z-10"><div class="max-w-3xl"><p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-4">Garmin Fenix 7 · रेस दूरी</p><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-5 leading-tight">रेस परिणाम.<br /><span class="bg-gradient-to-r from-blue-400 to-purple-500 bg-clip-text text-transparent">हर मील ट्रैक की गई।</span></h2><p class="text-lg text-neutral-400 leading-relaxed max-w-2xl mb-8">Garmin GPS के जरिए कैप्चर की गई सभी रेस-दूरी रन। असली पेस, असली HR — कोई cherry-picking नहीं।</p><div class="flex flex-wrap gap-3"><span class="px-4 py-1.5 rounded-full text-xs font-semibold bg-blue-600/20 border border-blue-500/30 text-blue-400">🏃 {stats.totalRaces} रेस-दूरी रन</span><span class="px-4 py-1.5 rounded-full text-xs font-semibold bg-neutral-800 border border-neutral-700 text-neutral-400">5K: {stats.byCategory['5K']}</span><span class="px-4 py-1.5 rounded-full text-xs font-semibold bg-neutral-800 border border-neutral-700 text-neutral-400">10K: {stats.byCategory['10K']}</span><span class="px-4 py-1.5 rounded-full text-xs font-semibold bg-neutral-800 border border-neutral-700 text-neutral-400">Half: {stats.byCategory['Half Marathon']}</span></div></div></div></section>{Object.keys(prs).length > 0 && (<section class="py-12 border-t border-neutral-800"><div class="container mx-auto px-4"><h2 class="text-2xl font-bold mb-8 flex items-center gap-2">🥇 <span>पर्सनल रिकॉर्ड्स</span></h2><div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">{distanceCategories.map(cat => prs[cat] && (<div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5 hover:border-blue-500/40 transition-colors"><div class="flex items-center justify-between mb-3"><span class="text-2xl">{categoryIcons[cat]}</span><span class="text-xs font-semibold text-blue-400 bg-blue-600/10 border border-blue-500/20 px-2 py-0.5 rounded-full">{categoryDistances[cat]}</span></div><p class="text-xs text-neutral-500 uppercase tracking-widest mb-1">{cat} PR</p><p class="text-3xl font-bold text-white mb-1">{prs[cat].pace}<span class="text-sm font-normal text-neutral-400">/mi</span></p><p class="text-sm text-neutral-400 mb-2">फ़िनिश: {prs[cat].duration}</p><p class="text-xs text-neutral-500 truncate" title={prs[cat].name}>{prs[cat].name}</p><p class="text-xs text-neutral-600 mt-1">{prs[cat].date} · {prs[cat].type}</p></div>))}</div></div></section>)}<section class="py-12 border-t border-neutral-800"><div class="container mx-auto px-4"><h2 class="text-2xl font-bold mb-8 flex items-center gap-2">📋 <span>रेस इतिहास</span><span class="text-sm font-normal text-neutral-500 ml-2">({races.length} एंट्रियाँ)</span></h2>{races.length === 0 ? (<p class="text-neutral-500 text-center py-12">अभी तक कोई रेस-दूरी रन नहीं मिली।</p>) : (<div class="overflow-x-auto rounded-xl border border-neutral-800"><table class="w-full text-sm"><thead><tr class="bg-neutral-900 text-neutral-400 text-xs uppercase tracking-wider"><th class="px-4 py-3 text-left">तारीख</th><th class="px-4 py-3 text-left">नाम</th><th class="px-4 py-3 text-center">दूरी</th><th class="px-4 py-3 text-center">श्रेणी</th><th class="px-4 py-3 text-center">समय</th><th class="px-4 py-3 text-center">पेस</th><th class="px-4 py-3 text-center">औसत HR</th><th class="px-4 py-3 text-center">प्रकार</th></tr></thead><tbody>{races.map((race, i) => (<tr class={`border-t border-neutral-800 hover:bg-neutral-900/60 transition-colors ${i % 2 === 0 ? 'bg-neutral-950' : 'bg-neutral-900/30'}`}><td class="px-4 py-3 text-neutral-400 whitespace-nowrap">{race.date}</td><td class="px-4 py-3 text-white max-w-[180px] truncate" title={race.name}>{race.name}</td><td class="px-4 py-3 text-center text-neutral-300">{race.distance.toFixed(2)} mi</td><td class="px-4 py-3 text-center"><span class="text-xs font-semibold text-blue-400 bg-blue-600/10 border border-blue-500/20 px-2 py-0.5 rounded-full">{race.distanceCategory}</span></td><td class="px-4 py-3 text-center text-white font-mono">{race.durationFormatted}</td><td class="px-4 py-3 text-center text-blue-400 font-mono font-semibold">{race.paceFormatted}/mi</td><td class="px-4 py-3 text-center text-neutral-400">{race.hr ? `${Math.round(race.hr)} bpm` : '—'}</td><td class="px-4 py-3 text-center"><span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${race.type === 'Treadmill' ? 'bg-neutral-800 text-neutral-400' : 'bg-green-900/20 text-green-400 border border-green-500/20'}`}>{race.type}</span></td></tr>))}</tbody></table></div>)}<p class="text-xs text-neutral-600 mt-6 text-center">नोट: ये Garmin-ट्रैक्ड ट्रेनिंग रन हैं जो रेस दूरी पर की गईं, आधिकारिक रेस इवेंट्स नहीं।</p></div></section></main></Layout>
