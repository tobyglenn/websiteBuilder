---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "आप सुबह 6:30 बजे ट्रेनिंग क्यों करते हैं?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "सुबह ही वह एकमात्र समय है जब कुछ भी मेरी ट्रेनिंग छीन नहीं सकता। सुबह 8:00 बजे तक मैं खत्म कर चुका होता हूँ — चाहे वेट उठाना हो या मैट पर काम — और बाकी दिन काम और परिवार का होता है। रात में ट्रेनिंग करना मेरे लिए कभी काम नहीं किया: मुझे दूसरी ऊर्जा मिल जाती है जो मेरी नींद खराब कर देती है, और रात 9 बजे तक मैं इतना थक जाता हूँ कि सच में जोर नहीं लगा पाता। जल्दी करना ही एकमात्र भरोसेमंद जवाब है।"
      }
    },
    {
      "@type": "Question",
      "name": "आपका मौजूदा ट्रेनिंग स्प्लिट क्या है?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "पूरे शरीर की ट्रेनिंग, लेकिन पैरों को छोड़कर, Speediance पर हफ्ते में 4x। BJJ हफ्ते में 3–4x। दौड़ना हफ्ते में 2–3x। कुल मिलाकर यह लगभग 10 घंटे की ट्रेनिंग बनती है — और यही मेरी सीमा है, उसके बाद WHOOP लाल चमकने लगता है और रिकवरी गिर जाती है। मैं पैरों के लिए अलग से ट्रेनिंग नहीं करता क्योंकि BJJ और दौड़ना उसे पर्याप्त रूप से कवर कर देते हैं, और मैं पावरलिफ्टिंग में प्रतिस्पर्धा नहीं कर रहा हूँ।"
      }
    },
    {
      "@type": "Question",
      "name": "आप पैरों की ट्रेनिंग क्यों नहीं करते?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "BJJ में पैरों पर आधारित बहुत सारी मूवमेंट होती हैं — गार्ड, टेकडाउन, ट्रांज़िशन। दौड़ना पैरों पर सीधा तनाव जोड़ता है। इन दोनों के बीच, मेरे पैरों को बिना अलग वेट-ट्रेनिंग सेशन के ही पर्याप्त ट्रेनिंग स्टिम्युलस मिल जाता है। इसके ऊपर भारी स्क्वाट या डेडलिफ्ट जोड़ने से उस सिस्टम पर ज्यादा लोड पड़ने का खतरा है जो पहले से ही बहुत मेहनत कर रहा है, और रिकवरी प्रभावित होगी। अगर मैं BJJ नहीं कर रहा होता, तो मैं पैरों को फिर से जोड़ देता।"
      }
    },
    {
      "@type": "Question",
      "name": "आप प्रोग्रेस कैसे ट्रैक करते हैं?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "दैनिक रिकवरी स्कोर और HRV के लिए WHOOP। हर रन के लिए Garmin (GPS, HR ज़ोन, पेस, ट्रेनिंग लोड)। Speediance अपने-आप लिफ्टिंग वॉल्यूम, 1RM अनुमान और PR हिस्ट्री ट्रैक करता है। नींद के चरणों के लिए 8Sleep। मैंने OpenClaw पर एक AI मॉर्निंग रिपोर्ट बनाई है जो मेरे उठने से पहले यह सब एक साथ खींचती है और मुझे confidence percentage के साथ ट्रेनिंग recommendation देती है।"
      }
    },
    {
      "@type": "Question",
      "name": "Speediance बनाम Tonal — मुझे कौन-सा खरीदना चाहिए?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "मैंने सालों तक Tonal इस्तेमाल किया और फिर बदला। छोटा जवाब: मेंबरशिप को शामिल करने पर 5 साल में दो Speediance की कीमत एक Tonal से कम पड़ती है। Speediance 260 lbs तक जाता है, इसमें कोई अनिवार्य subscription नहीं है, और इसका हार्डवेयर टिकाऊ है। सिर्फ एक क्षेत्र में Tonal अब भी आगे है: महिला कोच विकल्प और वीडियो प्रोडक्शन क्वालिटी। अगर आपका पार्टनर खास तौर पर किसी महिला-नेतृत्व वाले guided अनुभव चाहता/चाहती है, तो Tonal सही जवाब है। बाकी सभी के लिए, Speediance।"
      }
    },
    {
      "@type": "Question",
      "name": "WHOOP या Garmin — क्या दोनों की ज़रूरत है?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "दोनों अलग-अलग सवालों का जवाब देते हैं। Garmin जवाब देता है: मैंने क्या किया? — activity log, GPS, pace, HR zones। WHOOP जवाब देता है: मैं कितना recover हुआ? — रातभर की physiology, HRV baseline, readiness। अगर आप सिर्फ एक चाहते हैं: अगर आप दौड़ते हैं तो Garmin, अगर आपको रिकवरी ज्यादा महत्वपूर्ण लगती है तो WHOOP। मैं दोनों इस्तेमाल करता हूँ क्योंकि मैं ट्रेनिंग को इतना गंभीरता से लेता हूँ कि दोनों सवालों के सही जवाब चाहता हूँ।"
      }
    },
    {
      "@type": "Question",
      "name": "क्या 8Sleep Pod पैसे वसूल है?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "अगर आपको रात में ज्यादा गर्मी लगती है, तो हाँ। यह एकमात्र चीज़ है जिसने मेरे deep sleep percentage को लगातार बेहतर किया है। तापमान नियंत्रण ही इसकी असली खासियत है — sleep tracking नहीं। मैं इसे WHOOP के साथ इस्तेमाल करता हूँ क्योंकि 8Sleep का sleep stages data मुझे एक स्वतंत्र रीड देता है। subscription की लागत वाकई है, लेकिन गंभीर एथलीट के रूप में रिकवरी के लिए यह जो डेटा देता है, उसके खिलाफ बहस करना मुश्किल है।"
      }
    },
    {
      "@type": "Question",
      "name": "कौन-सा Speediance मॉडल — Original, 2S, या Gym Monster 2?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "अगर आपको शांत माहौल चाहिए (ऑफिस जिम) या आप नियमित रूप से 180 lbs से ऊपर उठाते हैं, तो 2S लें। अगर शोर समस्या नहीं है और आप पैसे बचाना चाहते हैं, तो Original लें — warranty के साथ $1,000–1,500 में open-box Original एक शानदार डील है। Gym Monster 2 में बड़ी स्क्रीन और AI form coach जुड़ता है, जो शुरुआती लोगों के लिए उपयोगी है लेकिन advanced lifters के लिए जरूरत से ज्यादा है। मेरे पास एक Original (लिविंग रूम) और एक 2S (ऑफिस) दोनों हैं।"
      }
    },
    {
      "@type": "Question",
      "name": "आपने 6 महीनों में 54 lbs कैसे कम किए?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "फार्मास्यूटिकल सपोर्ट (tirzepatide GLP-1, restructured TRT protocol, मसल प्रिज़र्वेशन के लिए Anavar), हफ्ते में 6 दिन 800–1,200 कैलोरी, रोज़ 10,000–20,000 कदम, और प्रति दिन 30,000–50,000 lbs लिफ्टिंग वॉल्यूम। मैंने पूरी ईमानदार breakdown — हर दवा और dose सहित — <a href="/blog/242-to-188-the-honest-truth/" class="text-blue-400 hover:underline">242 to 188: The Honest Truth</a> पोस्ट में लिखी है। मैंने यह नैचुरली नहीं किया। मैं इसके विपरीत दिखावा नहीं करूँगा।"
      }
    },
    {
      "@type": "Question",
      "name": "क्या आप अभी भी GLP-1 दवा ले रहे हैं?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "नहीं। tirzepatide protocol खास तौर पर 6-महीने वाले cut के लिए था। अब मैं मसल-बिल्डिंग फेज़ में हूँ (188 → 218 lbs), जिसका मतलब है ज्यादा खाना, कम नहीं। मैं अभी भी TRT पर हूँ — यह एक शारीरिक चोट से हुए primary hypogonadism की वजह से स्थायी है। लेकिन GLP-1 एक खास लक्ष्य के लिए इस्तेमाल किया गया टूल था, कोई lifestyle नहीं।"
      }
    },
    {
      "@type": "Question",
      "name": "क्या 40 के बाद मसल बनाई जा सकती है?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "हाँ, कुछ शर्तों के साथ। रिकवरी में ज्यादा समय लगता है। नींद और भी ज़्यादा महत्वपूर्ण हो जाती है। पोषण में गलती की गुंजाइश कम हो जाती है। लेकिन मसल-बिल्डिंग का मैकेनिज़्म गायब नहीं होता — progressive overload अब भी काम करता है, protein synthesis अब भी होती है। cut के बाद से मैं 188 से 218 lbs तक गया हूँ, और उस दौरान Speediance पर 1.29M lbs उठाई हैं। डेटा कहता है कि यह काम कर रहा है।"
      }
    },
    {
      "@type": "Question",
      "name": "अब आपकी डाइट कैसी दिखती है?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "हाई प्रोटीन, मध्यम कार्ब्स, और obsessively ट्रैक नहीं करता। जब मुझे सटीक होना होता है, तब मैं Cronometer इस्तेमाल करता हूँ। सामान्य नियम: ट्रेनिंग के आसपास खाओ, प्रोटीन को प्राथमिकता दो, और जब मसल बनाने की कोशिश कर रहे हो तो भूखे पेट सोने मत जाओ। lean bulk के लिए calorie surplus उतना बड़ा नहीं होता जितना लोग सोचते हैं — maintenance से 200–300 ऊपर काफी है। इससे ज्यादा और आप जरूरत से तेजी से फैट जोड़ रहे हैं।"
      }
    },
    {
      "@type": "Question",
      "name": "क्या कोई कंटेंट sponsored है?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "कोई paid sponsorship नहीं। कुछ gear links affiliate links हो सकते हैं (जहाँ लागू हो वहाँ disclosed), लेकिन कोई brand मुझे coverage के लिए पैसा नहीं देता और न ही यह नियंत्रित करता है कि मैं क्या कहता हूँ। यहाँ review किए गए हर उपकरण को मैंने अपनी जेब से खरीदा है। Speediance, Tonal, WHOOP, Garmin, 8Sleep — सब retail पर खरीदे गए हैं। reviews के मायने रखने का यही एक तरीका है।"
      }
    },
    {
      "@type": "Question",
      "name": "आप कितनी बार पोस्ट करते हैं?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "YouTube videos तब जाती हैं जब मेरे पास कहने लायक कुछ होता है — आम तौर पर हफ्ते में 2–4 बार। ब्लॉग पोस्ट वीडियो transcripts से generate होती हैं और लगातार publish की जाती हैं। data dashboards live data sources से अपने-आप update होते रहते हैं। सिर्फ पोस्टिंग शेड्यूल निभाने के लिए पोस्ट नहीं — कंटेंट तब होता है जब दिखाने के लिए कुछ असली हो।"
      }
    },
    {
      "@type": "Question",
      "name": "मैं आपसे संपर्क कैसे करूँ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "YouTube comments सबसे अच्छा तरीका हैं — मैं उन्हें पढ़ता हूँ और जो वीडियो फ़ॉर्म में जवाब देने लायक हों, उनका जवाब देता हूँ। जल्दी सवालों के लिए, comments section ईमेल से तेज़ जवाब देता है। business inquiries के लिए, YouTube चैनल के About section में दिए गए ईमेल का उपयोग करें।"
      }
    }
  ]
};
---

<Layout
  title="FAQ - TobyOnFitnessTech"
  description="Toby की ट्रेनिंग, gear stack, weight loss journey, और यह साइट कैसे काम करती है—इन सब पर आम सवाल।"
  breadcrumbs={[{ name: "होम", url: "/" }, { name: "FAQ", url: "/faq" }]}
  jsonLd={faqSchema}
>
  <main class="min-h-screen bg-neutral-950 text-white">

    {/* Hero */}
    <section class="pt-20 pb-12 md:pt-28 md:pb-16">
      <div class="container mx-auto px-4 text-center">
        <span class="text-blue-500 font-bold uppercase tracking-widest text-sm mb-3 block">FAQ</span>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">आम सवाल</h1>
        <p class="text-neutral-400 text-lg max-w-xl mx-auto">वह सब कुछ जो लोग सच में gear, ट्रेनिंग, weight loss, और इस साइट के बारे में पूछते हैं।</p>
      </div>
    </section>

    {/* FAQ Sections */}
    <section class="pb-20">
      <div class="container mx-auto px-4 max-w-3xl space-y-10">

        {/* Training Philosophy */}
        <div>
          <h2 class="text-2xl font-bold text-white mb-4 pb-3 border-b border-neutral-800">🏋️ ट्रेनिंग फ़िलॉसफ़ी</h2>
          <div class="space-y-3">
            <details class="group bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden">
              <summary class="flex items-center justify-between cursor-pointer p-5 font-semibold text-white hover:text-blue-400 transition-colors list-none">
                आप सुबह 6:30 बजे ट्रेनिंग क्यों करते हैं?
                <span class="text-neutral-500 group-open:rotate-180 transition-transform flex-shrink-0 ml-4">▼</span>
              </summary>
              <div class="px-5 pb-5 text-neutral-400 leading-relaxed">
                सुबह ही वह एकमात्र समय है जब कुछ भी मेरी ट्रेनिंग छीन नहीं सकता। सुबह 8:00 बजे तक मैं खत्म कर चुका होता हूँ — चाहे वेट उठाना हो या मैट पर काम — और बाकी दिन काम और परिवार का होता है। रात में ट्रेनिंग करना मेरे लिए कभी काम नहीं किया: मुझे दूसरी ऊर्जा मिल जाती है जो मेरी नींद खराब कर देती है, और रात 9 बजे तक मैं इतना थक जाता हूँ कि सच में जोर नहीं लगा पाता। जल्दी करना ही एकमात्र भरोसेमंद जवाब है।
              </div>
            </details>
            <details class="group bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden">
              <summary class="flex items-center justify-between cursor-pointer p-5 font-semibold text-white hover:text-blue-400 transition-colors list-none">
                आपका मौजूदा ट्रेनिंग स्प्लिट क्या है?
                <span class="text-neutral-500 group-open:rotate-180 transition-transform flex-shrink-0 ml-4">▼</span>
              </summary>
              <div class="px-5 pb-5 text-neutral-400 leading-relaxed">
                पूरे शरीर की ट्रेनिंग, लेकिन पैरों को छोड़कर, Speediance पर हफ्ते में 4x। BJJ हफ्ते में 3–4x। दौड़ना हफ्ते में 2–3x। कुल मिलाकर यह लगभग 10 घंटे की ट्रेनिंग बनती है — और यही मेरी सीमा है, उसके बाद WHOOP लाल चमकने लगता है और रिकवरी गिर जाती है। मैं पैरों के लिए अलग से ट्रेनिंग नहीं करता क्योंकि BJJ और दौड़ना उसे पर्याप्त रूप से कवर कर देते हैं, और मैं पावरलिफ्टिंग में प्रतिस्पर्धा नहीं कर रहा हूँ।
              </div>
            </details>
            <details class="group bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden">
              <summary class="flex items-center justify-between cursor-pointer p-5 font-semibold text-white hover:text-blue-400 transition-colors list-none">
                आप पैरों की ट्रेनिंग क्यों नहीं करते?
                <span class="text-neutral-500 group-open:rotate-180 transition-transform flex-shrink-0 ml-4">▼</span>
              </summary>
              <div class="px-5 pb-5 text-neutral-400 leading-relaxed">
