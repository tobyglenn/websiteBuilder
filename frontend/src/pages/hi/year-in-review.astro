---
import Layout from '../layouts/Layout.astro';
import { getYearInReview2025 } from '../data/yearInReview.js';

const yearInReview = getYearInReview2025();
const { garmin, speediance, eightSleep, whoop, combined } = yearInReview;

const pageTitle = "2025 वर्ष की समीक्षा | टोबी ऑन फिटनेस टेक";
const pageDescription = "2025 के फिटनेस डेटा पर एक व्यापक नज़र: Garmin, Speediance, 8Sleep और WHOOP से दौड़, स्ट्रेंथ ट्रेनिंग, नींद और रिकवरी मेट्रिक्स।";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "आपने 2025 में कितनी मील दौड़ लगाई?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `मैंने 2025 में ${garmin.totalRuns} दौड़ों में ${garmin.totalMiles} मील दौड़ी।`
      }
    },
    {
      "@type": "Question",
      "name": "आपने 2025 में Speediance पर कितना वॉल्यूम उठाया?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `मैंने ${speediance.totalWorkouts} वर्कआउट्स में ${speediance.totalVolumeFmt} वॉल्यूम उठाया।`
      }
    },
    {
      "@type": "Question",
      "name": "2025 में 8Sleep पर आपका औसत स्लीप स्कोर क्या था?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `मेरा औसत स्लीप स्कोर ${eightSleep.avgSleepScore} था, जो ${eightSleep.totalNights} ट्रैक की गई रातों में दर्ज हुआ।`
      }
    },
    {
      "@type": "Question",
      "name": "2025 में आपकी औसत WHOOP रिकवरी क्या थी?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `मेरा औसत रिकवरी स्कोर ${whoop.avgRecovery}% था और ${whoop.recoveryRate}% दिनों में मैं ग्रीन रिकवरी में था।`
      }
    }
  ]
};
---

<Layout 
  title={pageTitle} 
  description={pageDescription}
  jsonLd={faqSchema}
>
  <div class="container mx-auto px-4 py-12">
    <!-- Hero Section -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-blue-500/20 text-blue-400 text-sm font-medium rounded-full mb-4">
        2025 वार्षिक रिपोर्ट
      </span>
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-4">
        वर्ष की समीक्षा
      </h1>
      <p class="text-xl text-neutral-400 max-w-2xl mx-auto">
        दौड़, स्ट्रेंथ ट्रेनिंग, नींद और रिकवरी में मेरी फिटनेस यात्रा पर एक व्यापक नज़र।
      </p>
    </div>

    <!-- Combined Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
        <div class="text-3xl md:text-4xl font-bold text-white mb-2">
          {combined.totalWorkouts.toLocaleString()}
        </div>
        <div class="text-neutral-400 text-sm">कुल वर्कआउट्स</div>
        <div class="text-xs text-neutral-500 mt-1">दौड़ + स्ट्रेंथ</div>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
        <div class="text-3xl md:text-4xl font-bold text-white mb-2">
          {garmin.totalMiles.toLocaleString()}
        </div>
        <div class="text-neutral-400 text-sm">दौड़ी गई मील</div>
        <div class="text-xs text-neutral-500 mt-1">{garmin.totalRuns} दौड़ें</div>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
        <div class="text-3xl md:text-4xl font-bold text-white mb-2">
          {speediance.totalVolumeFmt}
        </div>
        <div class="text-neutral-400 text-sm">उठाया गया वॉल्यूम</div>
        <div class="text-xs text-neutral-500 mt-1">{speediance.totalWorkouts} वर्कआउट्स</div>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
        <div class="text-3xl md:text-4xl font-bold text-white mb-2">
          {eightSleep.avgSleepScore}
        </div>
        <div class="text-neutral-400 text-sm">औसत स्लीप स्कोर</div>
        <div class="text-xs text-neutral-500 mt-1">{eightSleep.totalNights} रातें</div>
      </div>
    </div>

    <!-- Running Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
        <span class="w-10 h-10 bg-blue-500/20 rounded-xl flex items-center justify-center text-blue-400">🏃</span>
        दौड़
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{garmin.totalMiles.toLocaleString()}</div>
          <div class="text-neutral-400">कुल मील</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{garmin.totalRuns}</div>
          <div class="text-neutral-400">कुल दौड़ें</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{garmin.totalHours}h</div>
          <div class="text-neutral-400">दौड़ने का समय</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{garmin.avgPace}</div>
          <div class="text-neutral-400">औसत पेस/mi</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{garmin.avgHR}</div>
          <div class="text-neutral-400">औसत HR</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{garmin.totalCalories.toLocaleString()}</div>
          <div class="text-neutral-400">जली हुई कैलोरी</div>
        </div>
      </div>
      {garmin.longestRun && (
        <div class="mt-4 bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <h3 class="text-lg font-semibold text-white mb-2">सबसे लंबी दौड़</h3>
          <p class="text-neutral-300">
            <span class="text-blue-400 font-bold">{garmin.longestRun.miles} मील</span> {garmin.longestRun.date} को 
            (पेस: {garmin.longestRun.pace}/mi)
          </p>
        </div>
      )}
    </section>

    <!-- Speediance Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
        <span class="w-10 h-10 bg-blue-500/20 rounded-xl flex items-center justify-center text-blue-400">💪</span>
        Speediance स्ट्रेंथ ट्रेनिंग
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{speediance.totalVolumeFmt}</div>
          <div class="text-neutral-400">कुल वॉल्यूम</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{speediance.totalWorkouts}</div>
          <div class="text-neutral-400">कुल वर्कआउट्स</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{speediance.totalHours}h</div>
          <div class="text-neutral-400">ट्रेनिंग का समय</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{speediance.avgVolume.toLocaleString()}</div>
          <div class="text-neutral-400">औसत वॉल्यूम/वर्कआउट</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{speediance.totalCalories.toLocaleString()}</div>
          <div class="text-neutral-400">जली हुई कैलोरी</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{speediance.highestSession?.volume.toLocaleString() || 0}</div>
          <div class="text-neutral-400">सबसे अधिक वॉल्यूम</div>
        </div>
      </div>
      {speediance.topWorkouts.length > 0 && (
        <div class="mt-4 bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <h3 class="text-lg font-semibold text-white mb-4">वॉल्यूम के आधार पर शीर्ष वर्कआउट्स</h3>
          <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-4">
            {speediance.topWorkouts.map((workout, i) => (
              <div class="text-center">
                <div class="text-2xl font-bold text-blue-400">#{i + 1}</div>
                <div class="text-white font-medium truncate">{workout.name}</div>
                <div class="text-neutral-400 text-sm">{(workout.volume / 1000).toFixed(0)}K lbs</div>
              </div>
            ))}
          </div>
        </div>
      )}
    </section>

    <!-- Sleep Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
        <span class="w-10 h-10 bg-blue-500/20 rounded-xl flex items-center justify-center text-blue-400">😴</span>
        8Sleep रिकवरी
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{eightSleep.avgSleepScore}</div>
          <div class="text-neutral-400">औसत स्लीप स्कोर</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{eightSleep.avgTotalSleepHrs}h</div>
          <div class="text-neutral-400">औसत कुल नींद</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{eightSleep.totalNights}</div>
          <div class="text-neutral-400">ट्रैक की गई रातें</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{eightSleep.avgHR}</div>
          <div class="text-neutral-400">औसत हार्ट रेट</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{eightSleep.avgRHR}</div>
          <div class="text-neutral-400">औसत रेस्टिंग HR</div>
        </div>
      </div>
    </section>

    <!-- WHOOP Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
        <span class="w-10 h-10 bg-blue-500/20 rounded-xl flex items-center justify-center text-blue-400">💓</span>
        WHOOP रिकवरी और स्ट्रेन
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{whoop.avgRecovery}%</div>
          <div class="text-neutral-400">औसत रिकवरी</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{whoop.avgStrain}</div>
          <div class="text-neutral-400">औसत स्ट्रेन</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{whoop.avgSleep}h</div>
          <div class="text-neutral-400">औसत नींद</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{whoop.avgHRV}</div>
          <div class="text-neutral-400">औसत HRV</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{whoop.avgRHR}</div>
          <div class="text-neutral-400">औसत RHR</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{whoop.recoveryRate}%</div>
          <div class="text-neutral-400">ग्रीन रिकवरी वाले दिन</div>
        </div>
      </div>
    </section>

    <!-- Navigation Links -->
    <div class="border-t border-neutral-800 pt-12">
      <h3 class="text-xl font-semibold text-white mb-6 text-center">और आँकड़े देखें</h3>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        <a href="/running/" class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-blue-500 transition-colors group">
          <div class="text-lg font-semibold text-white group-hover:text-blue-400 transition-colors">दौड़</div>
          <div class="text-neutral-400 text-sm">पूरा रन लॉग और विश्लेषण</div>
        </a>
        <a href="/speediance/" class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-blue-500 transition-colors group">
          <div class="text-lg font-semibold text-white group-hover:text-blue-400 transition-colors">Speediance</div>
          <div class="text-neutral-400 text-sm">स्ट्रेंथ ट्रेनिंग डेटा</div>
        </a>
        <a href="/sleep/" class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-blue-500 transition-colors group">
          <div class="text-lg font-semibold text-white group-hover:text-blue-400 transition-colors">नींद</div>
          <div class="text-neutral-400 text-sm">8Sleep विश्लेषण</div>
        </a>
        <a href="/whoop/" class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-blue-500 transition-colors group">
          <div class="text-lg font-semibold text-white group-hover:text-blue-400 transition-colors">WHOOP</div>
          <div class="text-neutral-400 text-sm">रिकवरी और स्ट्रेन</div>
        </a>
      </div>
    </div>
  </div>
</Layout>
