---
import Layout from '../../layouts/Layout.astro';
import { CANONICAL_BLOG_POSTS } from '../../lib/blogPosts';
import { ArrowRight } from 'lucide-react';

function readTime(content = '') {
  const words = content.split(/\s+/).filter(Boolean).length;
  return `${Math.max(1, Math.round(words / 200))} मिनट पढ़ें`;
}

function formatBlogDate(value) {
  const timestamp = Date.parse(value || '');
  if (Number.isNaN(timestamp)) return 'तारीख नहीं';
  return new Date(timestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

// Filter blog posts related to BJJ
const bjjPosts = CANONICAL_BLOG_POSTS.filter(post => {
  const category = post.category?.toLowerCase() || '';
  const tags = post.tags?.map(t => t.toLowerCase()) || [];
  const title = post.title?.toLowerCase() || '';
  const excerpt = post.excerpt?.toLowerCase() || '';
  
  return category === 'bjj' || 
    tags.some(tag => tag === 'bjj' || tag === 'jiu-jitsu' || tag === 'jiu jitsu') ||
    title.includes('bjj') || title.includes('jiu-jitsu') || title.includes('jiu jitsu') ||
    excerpt.includes('bjj') || excerpt.includes('jiu-jitsu') || excerpt.includes('jiu jitsu');
}).slice(0, 6);

const totalBjjPosts = CANONICAL_BLOG_POSTS.filter(post => {
  const category = post.category?.toLowerCase() || '';
  const tags = post.tags?.map(t => t.toLowerCase()) || [];
  const title = post.title?.toLowerCase() || '';
  const excerpt = post.excerpt?.toLowerCase() || '';
  
  return category === 'bjj' || 
    tags.some(tag => tag === 'bjj' || tag === 'jiu-jitsu' || tag === 'jiu jitsu') ||
    title.includes('bjj') || title.includes('jiu-jitsu') || title.includes('jiu jitsu') ||
    excerpt.includes('bjj') || excerpt.includes('jiu-jitsu') || excerpt.includes('jiu jitsu');
}).length;

// BJJ Stats
const stats = {
  rank: "ब्राउन बेल्ट",
  startedYear: 2023,
  competitions: 1,
  bjjDaysPerWeek: "2-3"
};

// Journey timeline data from /about page
const journeyTimeline = [
  {
    year: "2023",
    title: "BJJ यात्रा की शुरुआत",
    description: "242→188 lb परिवर्तन के हिस्से के रूप में Brazilian Jiu-Jitsu शुरू किया। वजन घटाने की यात्रा के दौरान BJJ को शारीरिक आउटलेट और मानसिक सहारे, दोनों के रूप में इस्तेमाल किया।",
    highlight: true
  },
  {
    year: "2023",
    title: "व्हाइट बेल्ट",
    description: "बुनियादी बातें, पोज़िशनल हायरार्की और बेसिक सबमिशन सीखे। ध्यान सर्वाइवल पर और गार्ड में सहज होने पर रहा।",
    highlight: false
  },
  {
    year: "2024",
    title: "ब्लू बेल्ट",
    description: "ब्लू बेल्ट पर प्रमोट हुए। अधिक परिष्कृत गार्ड गेम विकसित करना शुरू किया और नियमित प्रतियोगिता भी शुरू की।",
    highlight: false
  },
  {
    year: "2024-2025",
    title: "पर्पल बेल्ट",
    description: "मध्यवर्ती बेल्ट चरण। स्ट्रेंथ ट्रेनिंग के संतुलन के साथ तकनीकों को निखारना जारी रखा।",
    highlight: false
  },
  {
    year: "2025",
    title: "ब्राउन बेल्ट पर प्रमोशन",
    description: "एक क्षेत्रीय टूर्नामेंट में तीसरा स्थान और रिवर्स ट्रायंगल सबमिशन के साथ ब्राउन बेल्ट हासिल की।",
    highlight: true
  },
  {
    year: "वर्तमान",
    title: "ब्राउन बेल्ट - वर्तमान",
    description: "एक समर्पित BJJ जिम में सप्ताह में 2-3x ट्रेनिंग। फोकस गार्ड रिटेंशन, सबमिशन और स्ट्रेंथ बनाते हुए कंडीशनिंग बनाए रखने पर है।",
    highlight: true
  }
];

// BJJ Philosophy
const philosophy = [
  {
    icon: "🛡️",
    title: "सुरक्षा सबसे पहले",
    description: "मैं रोल जीतने से पहले चोट से बचाव को प्राथमिकता देता हूँ। BJJ जीवनभर की साधना है — अपने आप और ट्रेनिंग पार्टनर्स की सुरक्षा किसी भी सबमिशन से पहले आती है।"
  },
  {
    icon: "🔄",
    title: "परिणामों से ऊपर प्रक्रिया",
    description: "रोल जीतने के बजाय सुधार पर ध्यान देने से तेज प्रगति होती है। बेल्ट इस कला के प्रति समर्पण का एक उप-उत्पाद है।"
  },
  {
    icon: "⏳",
    title: "दीर्घकालिक सोच",
    description: "आज समझदारी से ट्रेनिंग करने का मतलब है आने वाले दशकों तक ट्रेनिंग करना। मैं रिकवरी के आधार पर इंटेंसिटी बदलता हूँ और अपने WHOOP डेटा को सुनता हूँ।"
  },
  {
    icon: "🧠",
    title: "एथलेटिक क्षमता से ऊपर तकनीक",
    description: "BJJ में तकनीक को कच्ची ताकत से ज्यादा महत्व मिलता है। बड़े प्रैक्टिशनर के रूप में भी सही लीवरेज और पोज़िशनिंग हर बार ताकत को मात देते हैं।"
  }
];

// Notable moments
const notableMoments = [
  { year: "2023", event: "BJJ शुरू किया - 242 lbs" },
  { year: "2023", event: "54 lb परिवर्तन पूरा - 188 lbs" },
  { year: "2025", event: "ब्राउन बेल्ट प्रमोशन" },
  { year: "2025", event: "क्षेत्रीय टूर्नामेंट में तीसरा स्थान - रिवर्स ट्रायंगल" }
];

// JSON-LD Schema
const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Brazilian Jiu-Jitsu - Toby on Fitness Tech",
  "description": "Toby की BJJ यात्रा को फॉलो करें: 2023 में शुरुआत, ब्राउन बेल्ट, क्षेत्रीय टूर्नामेंटों में हिस्सा, सप्ताह में 2-3x ट्रेनिंग। ट्रेनिंग फ़िलॉसफ़ी, सीखे गए सबक और प्रगति।",
  "url": "https://tobyonfitnesstech.com/bjj",
  "inLanguage": "en",
  "isPartOf": {
    "@id": "https://tobyonfitnesstech.com/#website"
  },
  "about": {
    "@type": "Person",
    "name": "Toby Peters",
    "description": "Brazilian Jiu-Jitsu में ब्राउन बेल्ट, 2023 से ट्रेनिंग"
  },
  "keywords": "BJJ, Brazilian Jiu-Jitsu, jiu-jitsu, ब्राउन बेल्ट, grappling, मार्शल आर्ट्स, ट्रेनिंग, प्रतियोगिता"
};
---

<Layout
  title="Brazilian Jiu-Jitsu - ब्राउन बेल्ट यात्रा | Toby on Fitness Tech"
  description="Toby की BJJ यात्रा को फॉलो करें: 2023 में शुरुआत, ब्राउन बेल्ट, क्षेत्रीय टूर्नामेंटों में हिस्सा, सप्ताह में 2-3x ट्रेनिंग। ट्रेनिंग फ़िलॉसफ़ी, सीखे गए सबक और प्रगति।"
  jsonLd={webPageSchema}
>
  <main class="min-h-screen bg-neutral-950 text-white">
    
    {/* ── Hero Section ─────────────────────────────────────────────────────── */}
    <section class="pt-28 pb-14 md:pt-36 md:pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-blue-900/10 via-transparent to-transparent pointer-events-none" />
      <div class="absolute right-0 top-0 w-72 h-72 bg-blue-600/5 rounded-full blur-3xl pointer-events-none" />
      <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-3xl">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-4">🥋 Brazilian Jiu-Jitsu</p>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
            Brazilian<br />
            <span class="text-blue-500">Jiu-Jitsu</span>
          </h2>
          <p class="text-xl text-neutral-400 mb-10 leading-relaxed max-w-2xl">
            2023 में शुरुआत। ब्राउन बेल्ट। क्षेत्रीय टूर्नामेंटों में हिस्सा लिया।
            तकनीक को कच्ची ताकत से ऊपर रखने वाली यह तकनीकी यात्रा सुरक्षा और दीर्घकालिकता पर केंद्रित है।
          </p>

          {/* Belt Display */}
          <div class="flex items-center gap-3 mb-8">
            <div class="text-4xl">🥋</div>
            <div>
              <div class="text-2xl font-bold text-white">{stats.rank}</div>
              <div class="text-sm text-neutral-400">वर्तमान रैंक</div>
            </div>
          </div>

          {/* Stat pills */}
          <div class="flex flex-wrap gap-3">
            <div class="flex items-center gap-2 bg-neutral-900 border border-neutral-800 rounded-full px-4 py-2">
              <span class="w-3 h-3 rounded-full bg-blue-500 inline-block flex-shrink-0"></span>
              <span class="text-sm font-semibold text-white">{stats.rank}</span>
            </div>
            <div class="flex items-center gap-2 bg-neutral-900 border border-neutral-800 rounded-full px-4 py-2">
              <span class="text-sm font-semibold text-white">शुरुआत {stats.startedYear}</span>
            </div>
            <div class="flex items-center gap-2 bg-neutral-900 border border-neutral-800 rounded-full px-4 py-2">
              <span class="text-sm font-semibold text-white">{stats.competitions} प्रतियोगिता</span>
            </div>
            <div class="flex items-center gap-2 bg-neutral-900 border border-neutral-800 rounded-full px-4 py-2">
              <span class="text-sm font-semibold text-white">{stats.bjjDaysPerWeek}x / सप्ताह</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ── Stats Cards Row ─────────────────────────────────────────────────── */}
    <section class="py-12 bg-neutral-900/40 border-y border-neutral-800">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-colors text-center">
            <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-2">{stats.rank}</div>
            <div class="text-sm font-semibold text-neutral-400 uppercase tracking-wide">वर्तमान बेल्ट</div>
          </div>
          <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-colors text-center">
            <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-2">{stats.startedYear}</div>
            <div class="text-sm font-semibold text-neutral-400 uppercase tracking-wide">ट्रेनिंग शुरू</div>
          </div>
          <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-colors text-center">
            <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-2">{totalBjjPosts}</div>
            <div class="text-sm font-semibold text-neutral-400 uppercase tracking-wide">BJJ पोस्ट्स</div>
          </div>
          <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-colors text-center">
            <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-2">तीसरा</div>
            <div class="text-sm font-semibold text-neutral-400 uppercase tracking-wide">सर्वश्रेष्ठ परिणाम</div>
          </div>
        </div>
      </div>
    </section>

    {/* ── Notable Moments ───────────────────────────────────────────────────── */}
    <section class="py-12 bg-neutral-900/20">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-4">खास पल</p>
          <div class="flex flex-wrap gap-4">
            {notableMoments.map(moment => (
              <div class="flex items-center gap-2 bg-neutral-900 border border-neutral-800 rounded-full px-4 py-2">
                <span class="text-xs font-bold text-blue-400">{moment.year}</span>
                <span class="text-sm text-neutral-300">{moment.event}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* ── Journey Timeline Section ────────────────────────────────────────── */}
    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-2">यात्रा</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-10">BJJ प्रगति</h2>

          <div class="space-y-0">
            {journeyTimeline.map((entry, i) => (
              <div class="relative flex gap-6 md:gap-10">
                {/* Vertical line + belt dot */}
                <div class="flex flex-col items-center flex-shrink-0 w-10">
                  <div
                    class={`w-5 h-5 rounded-full border-4 border-neutral-950 flex-shrink-0 mt-1 ${entry.highlight ? 'ring-2 ring-blue-500 ring-offset-2 ring-offset-neutral-950' : ''}`}
                    style={`background-color: ${entry.highlight ? '#3b82f6' : '#4b5563'};`}
                  />
                  {i < journeyTimeline.length - 1 && (
                    <div class="flex-1 w-0.5 bg-neutral-800 mt-1 mb-0 min-h-[60px]" />
                  )}
                </div>

                {/* Content card */}
                <div class={`pb-8 flex-1 ${entry.highlight ? 'border border-blue-700/40 bg-blue-900/5 rounded-xl p-5 -mt-1' : ''}`}>
                  <div class="flex items-center gap-3 mb-1 flex-wrap">
                    <span class="text-xs font-bold uppercase tracking-wider px-2.5 py-0.5 rounded-full bg-blue-500/20 text-blue-400">
                      {entry.year}
                    </span>
                    {entry.highlight && (
                      <span class="text-xs bg-blue-500/20 text-blue-400 px-2 py-0.5 rounded-full font-semibold">माइलस्टोन</span>
                    )}
                  </div>
                  <h3 class="text-lg font-bold text-white mb-2">{entry.title}</h3>
                  <p class="text-sm text-neutral-400 leading-relaxed">{entry.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* ── Training Schedule ────────────────────────────────────────────────── */}
    <section class="py-16 md:py-20 bg-neutral-900/40 border-y border-neutral-800">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-2">ट्रेनिंग</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-4">BJJ ट्रेनिंग शेड्यूल</h2>
          <p class="text-neutral-400 mb-8 leading-relaxed max-w-2xl">
            मैं एक समर्पित BJJ जिम में सप्ताह में 2-3 बार BJJ ट्रेन करता हूँ। हर सेशन में तकनीकी अभ्यास, पोज़िशनल ड्रिल्स और लाइव स्पैरिंग (रोलिंग) शामिल होते हैं। 
            मेरी फिटनेस हायरार्की में BJJ तीसरी प्राथमिकता है: <span class="text-blue-400 font-semibold">दौड़ना &gt; वेट ट्रेनिंग &gt; BJJ</span>
          </p>
          
          <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
              <div>
                <div class="text-2xl font-bold text-blue-400">2-3x</div>
                <div class="text-sm text-neutral-400">प्रति सप्ताह</div>
              </div>
              <div>
                <div class="text-2xl font-bold text-blue-400">Gi & No-Gi</div>
                <div class="text-sm text-neutral-400">स्टाइल्स</div>
              </div>
              <div>
                <div class="text-2xl font-bold text-blue-400">तकनीक</div>
                <div class="text-sm text-neutral-400">+ रोलिंग</div>
              </div>
              <div>
                <div class="text-2xl font-bold text-blue-400">242</div>
                <div class="text-sm text-neutral-400">लॉग किए गए सेशन</div>
              </div>
            </div>
          </div>

          <div class="mt-6 text-center">
            <a 
              href="/training/" 
              class="inline-flex items-center gap-2 text-sm text-blue-500 hover:text-blue-400 transition-colors font-medium"
            >
              पूरी ट्रेनिंग वीक देखें
              <ArrowRight size={16} />
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* ── BJJ Philosophy Section ────────────────────────────────────────────── */}
    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-2">दर्शन</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-10">जिउ-जित्सु के प्रति दृष्टिकोण</h2>

          <div class="grid md:grid-cols-2 gap-4">
            {philosophy.map(item => (
              <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-blue-500/40 transition-colors">
                <div class="text-3xl mb-4">{item.icon}</div>
                <h3 class="font-bold text-white mb-3">{item.title}</h3>
                <p class="text-sm text-neutral-400 leading-relaxed">{item.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* ── Related Blog Posts ───────────────────────────────────────────────── */}
    {bjjPosts.length > 0 && (
      <section class="py-16 md:py-20 bg-neutral-900/40 border-y border-neutral-800">
        <div class="container mx-auto px-4">
          <div class="max-w-4xl mx-auto">
            <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-2">और पढ़ें</p>
            <h2 class="text-3xl md:text-4xl font-bold mb-4">फ़ीचर्ड BJJ पोस्ट्स</h2>
            <p class="text-neutral-400 mb-10 max-w-xl">
              BJJ ट्रेनिंग, तकनीक, सुरक्षा और मार्शल आर्ट्स की यात्रा पर विचार।
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
              {bjjPosts.map((post) => (
                <a href={`/blog/${post.slug}/`} class="group block bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden hover:border-blue-500/50 transition-all">
                  {post.image && (
                    <div class="aspect-video overflow-hidden bg-neutral-950">
                      <img
                        src={post.image}
                        alt={post.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        loading="lazy"
                      />
                    </div>
                  )}
                  <div class="p-5">
                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold uppercase tracking-wide bg-blue-500/10 text-blue-400 border border-blue-500/20">
                      {post.category || 'BJJ'}
                    </span>
                    <h3 class="mt-3 text-lg font-bold text-white leading-snug group-hover:text-blue-400 transition-colors line-clamp-2">
                      {post.title}
                    </h3>
                    <div class="mt-2 text-xs text-neutral-500 flex items-center gap-2">
                      <span>{formatBlogDate(post.published_at)}</span>
                      <span>•</span>
                      <span>{readTime(post.content)}</span>
                    </div>
                    <p class="mt-3 text-sm text-neutral-400 leading-relaxed line-clamp-2">
                      {post.excerpt}
                    </p>
                  </div>
                </a>
              ))}
            </div>

            <div class="mt-8 text-center">
              <a 
                href="/blog/" 
                class="inline-flex items-center gap-2 text-sm text-blue-500 hover:text-blue-400 transition-colors font-medium"
              >
                सभी ब्लॉग पोस्ट्स देखें
                <ArrowRight size={16} />
              </a>
            </div>
          </div>
        </div>
      </section>
