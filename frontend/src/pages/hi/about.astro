---
import Layout from '../../layouts/Layout.astro';
import { weightData, getStats } from '../../data/weight.js';

const siteUrl = "https://tobyonfitnesstech.com";
const weightStats = getStats();
const chartWidth = 600;
const chartHeight = 260;
const wPadding = 44;
const weights = weightData.map(d => d.weight);
const minW = Math.min(...weights) - 10;
const maxW = Math.max(...weights) + 10;
const wRange = maxW - minW;
const wPoints = weightData.map((d, i) => { const x = wPadding + (i / (weightData.length - 1)) * (chartWidth - 2 * wPadding); const y = chartHeight - wPadding - ((d.weight - minW) / wRange) * (chartHeight - 2 * wPadding); return `${x},${y}`; }).join(' ');
const profilePageSchema = { "@context": "https://schema.org", "@type": "ProfilePage", "@id": `${siteUrl}/hi/about/#profilepage`, "name": "Toby Glenn Peters के बारे में", "description": "Toby Glenn Peters एक स्वतंत्र फिटनेस टेक समीक्षक हैं, जिन्होंने डेटा-आधारित ट्रेनिंग, Speediance, Tonal, WHOOP, Garmin और Brazilian Jiu-Jitsu की मदद से 242 से 188 lbs तक का सफर तय किया।", "url": `${siteUrl}/hi/about/`, "inLanguage": "hi-IN", "isPartOf": { "@id": `${siteUrl}/#website` }, "about": { "@id": `${siteUrl}/#toby` }, "mainEntity": { "@context": "https://schema.org", "@type": "Person", "@id": `${siteUrl}/#toby`, "name": "Toby Glenn Peters", "alternateName": ["TobyOnFitnessTech", "Toby on Fitness Tech"], "jobTitle": "फिटनेस उत्साही और टेक निर्माता", "description": "Toby Glenn Peters ने जुनूनी डेटा ट्रैकिंग, Speediance, Tonal और Brazilian Jiu-Jitsu की मदद से 242 से 188 lbs तक का बदलाव किया। स्वतंत्र फिटनेस टेक समीक्षक — न कोई प्रोग्राम, न फालतू दावे।", "url": siteUrl, "image": [{ "@type": "ImageObject", "@id": `${siteUrl}/#toby-image-before`, "url": `${siteUrl}/progress/progress_230.jpg`, "caption": "फिटनेस परिवर्तन से पहले 230 lbs पर Toby Glenn Peters — 4 अगस्त 2023", "width": 400, "height": 533 }, { "@type": "ImageObject", "@id": `${siteUrl}/#toby-image-after`, "url": `${siteUrl}/progress/progress_188.jpg`, "caption": "54 lbs वजन घटाने के बाद 188 lbs पर Toby Glenn Peters — 4 जनवरी 2024", "width": 400, "height": 533 }, { "@type": "ImageObject", "@id": `${siteUrl}/#toby-image-current`, "url": `${siteUrl}/progress/progress_229.jpg`, "caption": "मसल बिल्डिंग चरण में 229 lbs पर Toby Glenn Peters — 3 फ़रवरी 2026", "width": 400, "height": 533 }], "sameAs": ["https://www.youtube.com/@tobyonfitness", "https://www.instagram.com/tobyonfitness"], "knowsAbout": ["Speediance", "BJJ", "Garmin", "WHOOP", "8Sleep", "Running", "Brazilian Jiu-Jitsu"], "award": "242→188 lbs परिवर्तन", "worksFor": { "@id": `${siteUrl}/#organization` }, "nationality": { "@type": "Country", "name": "United States" } }, "breadcrumb": { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "होम", "item": `${siteUrl}/hi/` }, { "@type": "ListItem", "position": 2, "name": "परिचय", "item": `${siteUrl}/hi/about/` }] } };
---

<Layout title="Toby Glenn Peters के बारे में - TobyOnFitnessTech" description="Toby Glenn Peters ने जुनूनी डेटा ट्रैकिंग, Speediance, Tonal और Brazilian Jiu-Jitsu की मदद से 242 से 188 lbs तक का बदलाव किया। स्वतंत्र फिटनेस टेक समीक्षक — न कोई प्रोग्राम, न फालतू दावे।" breadcrumbs={[{ name: "होम", url: "/hi/" }, { name: "परिचय", url: "/hi/about" }]} jsonLd={profilePageSchema}>
<main class="min-h-screen bg-neutral-950 text-white"><section id="hero" class="pt-20 pb-12 md:pt-28 md:pb-16 relative overflow-hidden"><div class="absolute inset-0 bg-gradient-to-b from-blue-900/10 to-transparent pointer-events-none" /><div class="container mx-auto px-4 relative z-10"><div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16"><div class="flex-1 max-w-2xl"><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">मैं प्रोग्राम नहीं बेचता।<br /><span class="bg-gradient-to-r from-blue-500 to-purple-500 bg-clip-text text-transparent">मैं सिर्फ़ वही दर्ज करता हूँ जो वास्तव में काम करता है।</span></h2><p class="text-xl text-neutral-400 mb-8 leading-relaxed">प्रोग्रामर। BJJ अभ्यासकर्ता। डेटा-नर्ड। <br/>मैंने 6 महीनों में 54 lbs कम किए और मैं यहाँ ठीक-ठीक दिखाने के लिए हूँ कि कैसे।</p></div><div class="flex-shrink-0 w-full lg:w-auto"><div class="flex gap-3 items-end"><div class="relative group"><div class="w-44 md:w-52 rounded-2xl overflow-hidden border border-neutral-800 shadow-xl"><img src="/progress/progress_230.jpg" alt="पहले — 230 lbs" class="w-full aspect-[3/4] object-cover object-top" loading="eager" /></div><div class="absolute bottom-3 left-0 right-0 flex justify-center"><span class="bg-black/80 backdrop-blur-sm text-neutral-300 text-xs font-bold px-3 py-1 rounded-full border border-neutral-700">230 lbs</span></div></div><div class="flex flex-col items-center gap-1 pb-10 text-neutral-500"><div class="h-px w-6 bg-neutral-700"></div><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg><div class="h-px w-6 bg-neutral-700"></div></div><div class="relative group"><div class="w-44 md:w-52 rounded-2xl overflow-hidden border border-blue-500/40 shadow-xl shadow-blue-900/20"><img src="/progress/progress_188.jpg" alt="बाद में — 188 lbs" class="w-full aspect-[3/4] object-cover object-top" loading="eager" /></div><div class="absolute bottom-3 left-0 right-0 flex justify-center"><span class="bg-blue-600/90 backdrop-blur-sm text-white text-xs font-bold px-3 py-1 rounded-full">188 lbs</span></div><div class="absolute -top-3 -right-3 bg-blue-600 text-white text-xs font-black px-2.5 py-1.5 rounded-full shadow-lg rotate-6">−54 lbs</div></div></div><p class="text-center text-neutral-600 text-xs mt-4 tracking-wider uppercase">6 महीने · कोई बहाना नहीं</p></div></div></div></section><section id="stats" class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><div class="flex flex-col md:flex-row gap-12 items-center"><div class="md:w-1/2"><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8"><h2 class="text-2xl font-bold mb-6 text-blue-400">मुख्य आँकड़े</h2><div class="grid grid-cols-2 gap-6"><div><div class="text-4xl font-bold text-white mb-1">242</div><div class="text-sm text-neutral-500 uppercase tracking-wider">शुरुआती वजन</div></div><div><div class="text-4xl font-bold text-blue-500 mb-1">188</div><div class="text-sm text-neutral-500 uppercase tracking-wider">4 जनवरी 2024 को हासिल</div></div><div><div class="text-4xl font-bold text-white mb-1">6 महीने</div><div class="text-sm text-neutral-500 uppercase tracking-wider">अवधि</div></div><div><div class="text-4xl font-bold text-white mb-1">0</div><div class="text-sm text-neutral-500 uppercase tracking-wider">बहाने</div></div><div><div class="text-4xl font-bold text-white mb-1">54 lbs</div><div class="text-sm text-neutral-500 uppercase tracking-wider">कुल कमी</div></div><div><div class="text-4xl font-bold text-white mb-1">1M+</div><div class="text-sm text-neutral-500 uppercase tracking-wider">कुल उठाए गए lbs</div></div></div></div></div><div class="md:w-1/2 space-y-6 text-neutral-300 leading-relaxed text-lg"><h2 class="text-3xl font-bold text-white">बड़ा मोड़</h2><p>2024 के अंत में मेरा वजन 242 पाउंड था। पारंपरिक कार्डियो — जिस पर ज़्यादातर लोग वजन घटाने के लिए भरोसा करते हैं — मेरे लिए काम नहीं कर रहा था। तब मैंने एक अधिक समझदार समाधान बनाने का फैसला किया।</p><p>मैं प्रोग्रामर हूँ, इसलिए मैं डेटा में गहराई तक गया: WHOOP रिकवरी स्कोर, Garmin एक्टिविटी ट्रैकिंग, 8Sleep स्लीप क्वालिटी और Cronometer के जरिए कैलोरी का बारीक रिकॉर्ड। जिस भी वेरिएबल को मैं नियंत्रित कर सकता था, उसे नियंत्रित किया। जिसे माप सकता था, उसे मापा।</p><p>मेरी ट्रेनिंग का केंद्र एक <strong class="text-white">डिजिटल केबल मशीन</strong> बन गई — एक स्मार्ट होम जिम, जिसने मुझे घर से भारी ट्रेनिंग करने दी। अब तक मैं उस पर 1,000,000 lbs से ज़्यादा लिफ्टिंग वॉल्यूम दर्ज कर चुका हूँ। कोई बढ़ा-चढ़ाकर बात नहीं — मेरे पास इसका डेटा है।</p><p>मशीन ट्रेनिंग के साथ-साथ मैं <strong class="text-white">Brazilian Jiu-Jitsu</strong> में लौटा — शारीरिक आउटलेट और मानसिक सहारे के रूप में। BJJ ने मुझे अनुशासित, विनम्र और लगातार बने रहने पर मजबूर किया — तब भी जब वज़न मशीन मेरी उम्मीद के अनुसार नहीं चल रही थी।</p><p>छह महीने बाद: 188 lbs. कुल 54 lbs कम।</p><div class="pt-2"><a href="/hi/videos/?category=transformation" class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 font-semibold transition-colors group">ट्रांसफ़ॉर्मेशन वीडियो देखें <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a><span class="mx-2 text-neutral-600">|</span><a href="/hi/fitness-age/" class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 font-semibold transition-colors group">अपनी फिटनेस आयु निकालें</a></div></div></div></div></section><section id="weight-journey" class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><div class="max-w-3xl mx-auto"><h2 class="text-3xl font-bold text-white mb-8 text-center">वजन की यात्रा</h2><div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8"><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5 text-center"><p class="text-sm text-neutral-400 mb-1">शुरुआत</p><p class="text-3xl font-bold text-white">{weightStats.start} lbs</p></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5 text-center"><p class="text-sm text-neutral-400 mb-1">सबसे कम</p><p class="text-3xl font-bold text-green-400">{weightStats.lowest} lbs</p></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5 text-center"><p class="text-sm text-neutral-400 mb-1">वर्तमान</p><p class="text-3xl font-bold text-blue-400">{weightStats.current} lbs</p></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5 text-center"><p class="text-sm text-neutral-400 mb-1">बदलाव</p><p class={`text-3xl font-bold ${weightStats.totalChange < 0 ? 'text-green-400' : 'text-purple-400'}`}>{weightStats.totalChange > 0 ? '+' : ''}{weightStats.totalChange} lbs</p></div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6"><h3 class="text-lg font-semibold text-white mb-4">समय के साथ वजन</h3><svg viewBox={`0 0 ${chartWidth} ${chartHeight}`} class="w-full h-auto" preserveAspectRatio="xMidYMid meet"><defs><linearGradient id="wGradient" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#3b82f6" /><stop offset="100%" stop-color="#8b5cf6" /></linearGradient></defs>{[0, 0.25, 0.5, 0.75, 1].map((ratio) => { const y = wPadding + ratio * (chartHeight - 2 * wPadding); const w = Math.round(maxW - ratio * wRange); return (<g><line x1={wPadding} y1={y} x2={chartWidth - wPadding} y2={y} stroke="#262626" stroke-width="1" stroke-dasharray="4" /><text x={wPadding - 6} y={y + 4} text-anchor="end" fill="#525252" font-size="11">{w}</text></g>); })}{weightData.filter((_, i) => i % 2 === 0).map((d, i) => { const x = wPadding + ((i * 2) / (weightData.length - 1)) * (chartWidth - 2 * wPadding); const label = new Date(d.date).toLocaleDateString('hi-IN', { month: 'short', year: '2-digit' }); return <text x={x} y={chartHeight - 8} text-anchor="middle" fill="#525252" font-size="10">{label}</text>; })}<polyline points={wPoints} fill="none" stroke="url(#wGradient)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />{weightData.map((d, i) => { const x = wPadding + (i / (weightData.length - 1)) * (chartWidth - 2 * wPadding); const y = chartHeight - wPadding - ((d.weight - minW) / wRange) * (chartHeight - 2 * wPadding); return <circle cx={x} cy={y} r="5" fill="#3b82f6" stroke="#171717" stroke-width="2" />; })}</svg></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 mt-6 space-y-4 text-neutral-300 leading-relaxed"><p><strong class="text-white">242 → 188:</strong> जनवरी 2023 से मार्च 2024 के बीच मैंने फार्मास्यूटिकल सपोर्ट (GLP-1, TRT, Anavar), सख्त कैलोरी नियंत्रण और हाई-वॉल्यूम ट्रेनिंग की मदद से 54 lbs कम किए। लक्ष्य था: lean होना, आदत बनाना और खुद को साबित करना कि मैं कर सकता हूँ।</p><p><strong class="text-white">188 → 218:</strong> 188 lbs तक पहुँचने के बाद मैंने बिल्डिंग फेज़ शुरू किया। ज़्यादा खाना, प्रोटीन को प्राथमिकता देना, Speediance पर प्रोग्रेसिव ओवरलोड और BJJ जोड़ना — इन सबके साथ वजन 30 lbs बढ़ा, और अब मैं पहले से अधिक ताकतवर, बेहतर कंडीशन वाला और सक्षम हूँ।</p><p><strong class="text-white">सीख:</strong> तराजू एक उपकरण है, जज नहीं। हर चरण का अपना उद्देश्य था। परिवर्तन खत्म नहीं हुआ है — उसने बस एक नया अध्याय शुरू किया है।</p></div></div></div></section><section id="running-stats" class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><h2 class="text-3xl md:text-4xl font-bold text-white mb-8 text-center">रनिंग आँकड़े</h2><div class="grid grid-cols-2 md:grid-cols-3 gap-6"><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center"><div class="text-4xl font-bold text-white mb-2">111</div><div class="text-sm text-neutral-400 uppercase tracking-wider">कुल रन</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center"><div class="text-4xl font-bold text-white mb-2">265.1 mi</div><div class="text-sm text-neutral-400 uppercase tracking-wider">कुल मील</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center"><div class="text-4xl font-bold text-white mb-2">67.2 h</div><div class="text-sm text-neutral-400 uppercase tracking-wider">कुल घंटे</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center"><div class="text-4xl font-bold text-white mb-2">15:12/mi</div><div class="text-sm text-neutral-400 uppercase tracking-wider">औसत पेस</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center"><div class="text-4xl font-bold text-white mb-2">5 mi</div><div class="text-sm text-neutral-400 uppercase tracking-wider">सबसे लंबी रन (30 जून 2025)</div></div></div></div></section><section id="build-phase" class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><div class="max-w-5xl mx-auto"><p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-3">अध्याय 2</p><h2 class="text-3xl md:text-4xl font-bold text-white mb-10">188 lbs अंत नहीं, शुरुआत थी।</h2><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8 mb-10"><h3 class="text-xl font-bold mb-6 text-blue-400">बिल्ड फेज़ के आँकड़े</h3><div class="grid grid-cols-2 md:grid-cols-4 gap-6"><div><div class="text-3xl font-bold text-white mb-1">1,296,447</div><div class="text-xs text-neutral-500 uppercase tracking-wider">जुलाई 2025 से उठाए गए lbs</div></div><div><div class="text-3xl font-bold text-white mb-1">125</div><div class="text-xs text-neutral-500 uppercase tracking-wider">Speediance सेशन</div></div><div><div class="text-3xl font-bold text-white mb-1">265.1 mi</div><div class="text-xs text-neutral-500 uppercase tracking-wider">दौड़े गए मील (पिछला वर्ष)</div></div><div><div class="text-3xl font-bold text-white mb-1">111</div><div class="text-xs text-neutral-500 uppercase tracking-wider">लॉग किए गए रन</div></div></div></div><div class="space-y-6 text-neutral-300 leading-relaxed text-lg"><p>4 जनवरी 2024 को मैं 188 lbs पर पहुँचा और मुझे तुरंत समझ आ गया कि कट सिर्फ़ पहला चरण था। वजन कम करना subtraction की समस्या है। उसके ऊपर कुछ बनाना एक अलग — और सच कहूँ तो अधिक दिलचस्प — चुनौती है। तब से वजन बढ़ रहा है: 188 → 205 → 218-229 lbs, शुरुआती 2026 तक। यह setback नहीं है। यही योजना थी।</p><p><strong class="text-white">Speediance</strong> दूसरे चरण का केंद्र बन गया। सिर्फ़ जुलाई 2025 से फ़रवरी 2026 के बीच मैंने 125 सेशन दर्ज किए और <strong class="text-white">1,296,447 lbs</strong> कुल वॉल्यूम मूव किया। मेरी सबसे बेहतरीन सिंगल सेशन: 2 फ़रवरी 2026 को 50 मिनट में 35,305 lbs। मशीन द्वारा ट्रैक किए गए शीर्ष लिफ्ट — 294 lb 1RM के साथ बारबेल लैट पुलडाउन, 198 lbs का बेंट-ओवर रो, और केबल सिस्टम के जरिए 90 lbs का बेंच प्रेस। यह अनुमान नहीं हैं। मशीन हर रेप दर्ज करती है।</p><p>साथ ही मैंने रनिंग को भी शुरुआत से दोबारा बनाया। मैंने 1-मील सेशन से शुरुआत की — सचमुच सिर्फ़ न रुकने की कोशिश करते हुए। 2026 की शुरुआत तक मैं 5-मील रन कर रहा हूँ। पिछले साल में 111 रन लॉग: 84 बाहर, 27 ट्रेडमिल पर, 2 ओपन-वॉटर स्विम। <strong class="text-white">कुल 265.1 मील।</strong> तेज़ नहीं। लेकिन लगातार, प्रोग्रेसिव और निर्माणशील। वजन बढ़ना कोई ऐसी चीज़ नहीं जिसे समझाना पड़े — मसल का भी वजन होता है। यही तो उद्देश्य है।</p><p>अब हर ट्रेनिंग निर्णय पूरे स्टैक से गुजरता है: WHOOP मुझे हर सुबह रिकवरी स्कोर देता है, 8Sleep बताता है कि रात सच में कैसी रही, और <strong class="text-white">OpenClaw</strong> पर बनाया गया मेरा AI असिस्टेंट यह सब पढ़ता है — Garmin एक्टिविटी, स्लीप डेटा, HRV ट्रेंड्स — और फिर यह तय करने से पहले कि मुझे ज़ोर लगाना है या पीछे हटना है, एक daily readiness recommendation देता है। सिस्टम निर्णयों को तर्कसंगत बनाता है। कोई अनुमान नहीं, सिर्फ़ डेटा।</p></div></div></div></section><section id="progress-photos" class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><div class="mb-10"><h2 class="text-3xl font-bold mb-3">प्रगति की तस्वीरें</h2><p class="text-neutral-400 text-lg">242 → 188 lbs. हर फोटो वास्तविक, बिना एडिट की हुई और वजन के साथ दर्ज है।</p></div><div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 mb-8">{[{ src: '/progress/progress_230.jpg', label: '230 lbs', date: '4 अगस्त 2023' },{ src: '/progress/progress_220.jpg', label: '220 lbs', date: '7 सित. 2023' },{ src: '/progress/progress_200.jpg', label: '200 lbs', date: '1 दिस. 2023' },{ src: '/progress/progress_188.jpg', label: '188 lbs', date: '4 जन. 2024' },{ src: '/progress/progress_191.jpg', label: '191 lbs', date: '6 फ़र. 2024' },{ src: '/progress/progress_211.jpg', label: '211 lbs', date: '2 जून 2024' },{ src: '/progress/progress_229.jpg', label: '229 lbs', date: '3 फ़र. 2026' },{ src: '/progress/workout_action.jpg', label: 'ट्रेनिंग', date: '' },].map(({ src, label, date }) => (<div class="relative group overflow-hidden rounded-xl bg-neutral-900 border border-neutral-800 hover:border-neutral-600 transition-all"><div class="aspect-[3/4]"><img src={src} alt={label} class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" loading="lazy" /></div><div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/85 via-black/40 to-transparent pt-8 pb-2 px-2 text-center pointer-events-none"><span class="text-white text-xs font-bold block leading-tight drop-shadow">{label}</span>{date && <span class="text-neutral-400 text-[10px] block">{date}</span>}</div></div>))}</div><div class="bg-neutral-900/50 border border-neutral-800 rounded-2xl p-6 flex flex-col md:flex-row items-center gap-6"><div class="flex-shrink-0 text-5xl">📊</div><div><h3 class="text-xl font-bold text-white mb-2">हर डेटा पॉइंट दर्ज</h3><p class="text-neutral-400">ये तस्वीरें पूरी कहानी नहीं बतातीं। हर तस्वीर के पीछे WHOOP रिकवरी स्कोर, Garmin ट्रेनिंग लोड, 8Sleep स्लीप क्वालिटी डेटा और Cronometer न्यूट्रिशन लॉग्स हैं। यह परिवर्तन संयोग नहीं, व्यवस्थित प्रयास था।</p></div></div></div></section><section id="focus" class="py-16 bg-neutral-900/30 border-y border-neutral-900"><div class="container mx-auto px-4"><h2 class="text-3xl font-bold mb-12 text-center">मेरा फ़ोकस</h2><div class="grid md:grid-cols-3 gap-8"><div class="space-y-4"><h3 class="text-xl font-bold text-white">होम जिम टेक</h3><p class="text-neutral-400">मैंने अपनी डिजिटल केबल मशीन पर 1,000,000 lbs से ज़्यादा उठाए हैं। मैं फर्मवेयर अपडेट्स टेस्ट करता हूँ, मोड्स की तुलना करता हूँ और बग्स ढूँढता हूँ ताकि आपको ऐसा न करना पड़े। अगर कोई मशीन कहती है कि वह जिम की जगह ले सकती है, तो मैं उसे verify करता हूँ।</p></div><div class="space-y-4"><h3 class="text-xl font-bold text-white">BJJ और ग्रैपलिंग</h3><p class="text-neutral-400">जिउ-जित्सु सिर्फ़ खेल नहीं, एक सिस्टम है। मैं मैच फुटेज का विश्लेषण करता हूँ, बेल्ट संस्कृति पर बात करता हूँ और तकनीकों के पीछे का “क्यों” समझाता हूँ।</p></div><div class="space-y-4"><h3 class="text-xl font-bold text-white">डेटा और ऑटोमेशन</h3><p class="text-neutral-400">Whoop रिकवरी स्कोर से लेकर अपने AI असिस्टेंट (OpenClaw) को बनाने तक, जो मेरी दिनचर्या और ट्रेनिंग मैनेज करता है। जिसे मापा और स्वचालित किया जा सकता है, उसमें मेरी रुचि है।</p></div></div></div></section><section class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><div class="max-w-4xl mx-auto"><h2 class="text-3xl font-bold text-white mb-8 text-center">ट्रेनिंग दर्शन</h2><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8 space-y-6"><div class="flex gap-4"><div class="text-3xl">🌅</div><div><h3 class="text-xl font-bold text-white mb-2">मैं सुबह 6:30 बजे क्यों ट्रेन करता हूँ</h3><p class="text-neutral-400">सुबह ट्रेनिंग के लिए होती है, उससे पहले कि दिन आपकी ऊर्जा चुरा ले। 6:30 बजे ट्रेनिंग का मतलब है कि 8:00 बजे तक मैं या तो लिफ्टिंग कर चुका होता हूँ या मैट पर जा चुका होता हूँ, और दिन का बाकी हिस्सा काम, परिवार और रिकवरी के लिए बचता है। रात में ट्रेनिंग मेरे लिए कभी काम नहीं आई — मुझे दूसरा energy spike मिलता है जो नींद बिगाड़ देता है, और रात 9 बजे तक मैं hard rolling के लिए बहुत थका होता हूँ।</p></div></div><div class="flex gap-4"><div class="text-3xl">🔄</div><div><h3 class="text-xl font-bold text-white mb-2">BJJ + लिफ्टिंग + रनिंग = स्टैक</h3><p class="text-neutral-400">मैं इनमें से किसी एक को नहीं चुनता — मैं तीनों करता हूँ। BJJ 3-4x/सप्ताह मेरा grappling तेज़ रखता है और cardio भी देता है। Speediance पर 4x/सप्ताह लिफ्टिंग से मसल और स्ट्रेंथ बनती है। 2-3x/सप्ताह रनिंग cardiovascular base बनाए रखती है। कुंजी यह है कि किसी एक चीज़ में हद से ज़्यादा न हो: कुल 10 घंटे/सप्ताह मेरी ऊपरी सीमा है, उसके बाद रिकवरी प्रभावित होने लगती है।</p></div></div></div></div></div></section><section class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><div class="max-w-5xl mx-auto"><div class="text-center mb-10"><span class="text-blue-500 font-bold uppercase tracking-widest text-sm mb-2 block">मील</span><h2 class="text-3xl md:text-4xl font-bold text-white">रनिंग लॉग</h2><p class="text-neutral-500 mt-3 max-w-xl mx-auto">54 lbs वजन कम करते समय मैंने रनिंग नहीं की। रनिंग बाद में आई — और शायद उसी ने मेरी जान बचाई।</p></div><div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8"><div class="bg-neutral-900 rounded-xl p-5 border border-neutral-800 text-center"><div class="text-3xl font-black text-white mb-1">266</div><div class="text-xs text-neutral-500 uppercase tracking-wide">कुल मील</div></div><div class="bg-neutral-900 rounded-xl p-5 border border-neutral-800 text-center"><div class="text-3xl font-black text-white mb-1">113</div><div class="text-xs text-neutral-500 uppercase tracking-wide">लॉग किए गए रन</div></div><div class="bg-neutral-900 rounded-xl p-5 border border-neutral-800 text-center"><div class="text-3xl font-black text-white mb-1">67h</div><div class="text-xs text-neutral-500 uppercase tracking-wide">कुल समय</div></div><div class="bg-neutral-900 rounded-xl p-5 border border-neutral-800 text-center"><div class="text-3xl font-black text-white mb-1">15:12</div><div class="text-xs text-neutral-500 uppercase tracking-wide">औसत पेस /mi</div></div><div class="bg-neutral-900 rounded-xl p-5 border border-neutral-800 text-center"><div class="text-3xl font-black text-white mb-1">5.0</div><div class="text-xs text-neutral-500 uppercase tracking-wide">सबसे लंबी रन (mi)</div></div><div class="bg-neutral-900 rounded-xl p-5 border border-neutral-800 text-center"><div class="text-3xl font-black text-white mb-1">76.8</div><div class="text-xs text-neutral-500 uppercase tracking-wide">सर्वश्रेष्ठ महीना (mi)</div></div></div><div class="text-center"><a href="/hi/running/" class="inline-flex items-center gap-2 text-blue-500 hover:text-blue-400 font-semibold transition-colors text-sm">पूरा रनिंग डैशबोर्ड देखें →</a></div></div></div></section><section class="py-16 border-t border-neutral-900 bg-neutral-950"><div class="container mx-auto px-4"><div class="max-w-5xl mx-auto"><h2 class="text-3xl md:text-4xl font-bold text-white mb-6 text-center">मेरी BJJ यात्रा</h2><p class="text-neutral-300 text-base md:text-lg mb-4">एक ब्राउन बेल्ट BJJ अभ्यासकर्ता के रूप में, मैट वह जगह है जहाँ मैं खुद को फिर से रीसेट करता हूँ। एक समर्पित BJJ जिम में ट्रेनिंग का मतलब है हफ्ते में 3-4 क्लास, नियमित rolling sessions और positional drills की ऐसी प्रणाली जो जीवन व्यस्त होने पर भी मेरे खेल को तेज़ रखती है। ये क्लास मेरे लिए एक रिचुअल हैं — तकनीक, लाइव स्पारिंग और उन ट्रेनिंग पार्टनर्स के साथ गलतियों को सुधारना जो काम की उम्मीद करते हैं।</p><p class="text-neutral-300 text-base md:text-lg mb-4">यह कहानी 2023 में 242→188 lbs कट के साथ शुरू हुई, जिसमें jiu-jitsu, WHOOP रिकवरी संकेत और नियंत्रित कैलोरी रणनीति का बड़ा योगदान था। उसके बाद फोकस बदल गया: मैंने 2024 और 2025 ताकत और मसल दोबारा बनाने में लगाए, 205 से 218 lbs तक बढ़ते हुए भी मैट पर लगातार जाता रहा और BJJ को अपनी conditioning ईमानदार रखने दिया।</p><p class="text-neutral-300 text-base md:text-lg mb-4">प्रतियोगिता मेरे लिए कंपास रही है। ब्राउन बेल्ट पर मैंने एक regional tournament में reverse triangle finish के साथ तीसरा स्थान लिया — एक याद दिलाने वाला पल कि grit, perfection से बड़ी चीज़ है। उस रात का विस्तार मेरे <a href="/blog/speediance-customization-why-it-breaks-settings/" class="text-blue-500 hover:text-cyan-400 font-semibold">tournament recap</a> में दर्ज है, और उस scramble से मिली सीख आज भी यह तय करती है कि मैं strength work और rolling को कैसे balance करता हूँ।</p><p class="text-neutral-300 text-base md:text-lg mb-4">मैट कभी सिखाना बंद नहीं करता। इस यात्रा को मेरे व्यापक BJJ commentary के साथ समझने के लिए <a href="/blog/mike-israetel-bjj-black-belt-defence/" class="text-blue-500 hover:text-cyan-400 font-semibold">Mat Science का belt culture पर लेख</a> पढ़ें, या देखें कि मेरा OpenClaw BJJ buddy project हर रिपोर्ट में ट्रेनिंग डेटा को कैसे जोड़ता है (<a href="/blog/openclaw-automation/" class="text-blue-500 hover:text-cyan-400 font-semibold">BJJ automation build log</a>)।</p><div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-8"><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6"><span class="text-xs uppercase tracking-widest text-blue-500">2023 फ़ैट लॉस</span><p class="text-3xl font-black text-white mt-3">242→188 lbs</p><p class="text-neutral-400 text-sm mt-2">lean, disciplined और jiu-jitsu-driven. WHOOP रिकवरी ने deficit को ईमानदार रखा।</p></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6"><span class="text-xs uppercase tracking-widest text-blue-500">वर्तमान बिल्ड</span><p class="text-3xl font-black text-white mt-3">205→218 lbs</p><p class="text-neutral-400 text-sm mt-2">मसल-बिल्डिंग फेज़ जो BJJ वॉल्यूम का सम्मान करता है — strength, running और rolling का संतुलन।</p></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6"><span class="text-xs uppercase tracking-widest text-blue-500">साप्ताहिक मैट टाइम</span><p class="text-3xl font-black text-white mt-3">3-4 क्लास</p><p class="text-neutral-400 text-sm mt-2">टेक्नीक राउंड, संरचित ड्रिल और ओपन-मैट रोलिंग उन पार्टनर्स के साथ जो हर सेशन को ईमानदार रखते हैं।</p></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6"><span class="text-xs uppercase tracking-widest text-blue-500">प्रतियोगिता</span><p class="text-3xl font-black text-white mt-3">ब्राउन बेल्ट</p><p class="text-neutral-400 text-sm mt-2">टूर्नामेंट, रैंकिंग मैच और overtime bouts की विनम्रता जो मुझे लगातार विकसित होने की याद दिलाती है।</p></div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8 mt-10"><div class="flex items-center justify-between text-xs text-neutral-500 uppercase tracking-widest"><span>बेल्ट और मैट टाइमलाइन</span><span class="text-blue-500">अभी भी आगे बढ़ रहा हूँ</span></div><div class="grid mt-6 gap-4 md:grid-cols-4"><div class="rounded-lg border border-neutral-800 bg-neutral-950/50 p-4"><p class="text-xs uppercase tracking-widest text-neutral-500">बुनियाद</p><p class="text-base font-semibold text-white mt-3">व्हाइट बेल्ट</p><p class="text-neutral-400 text-sm mt-1">जिम में घंटों guard-retention drills के साथ बुनियाद रखी।</p></div><div class="rounded-lg border border-neutral-800 bg-neutral-950/50 p-4"><p class="text-xs uppercase tracking-widest text-neutral-500">गति</p><p class="text-base font-semibold text-white mt-3">ब्लू → पर्पल</p><p class="text-neutral-400 text-sm mt-1">pressure passing बनाया और tournament circuit में जाकर अपनी प्रगति परख़ी।</p></div><div class="rounded-lg border border-neutral-800 bg-neutral-950/50 p-4"><p class="text-xs uppercase tracking-widest text-neutral-500">मान्यता</p><p class="text-base font-semibold text-white mt-3">पर्पल → ब्राउन</p><p class="text-neutral-400 text-sm mt-1">ब्राउन बेल्ट, तीसरा स्थान और एक reverse triangle जिसने लॉग्स में अपनी जगह बना ली।</p></div><div class="rounded-lg border border-neutral-800 bg-neutral-950/50 p-4"><p class="text-xs uppercase tracking-widest text-neutral-500">दैनिक मेहनत</p><p class="text-base font-semibold text-white mt-3">अब ब्राउन बेल्ट</p><p class="text-neutral-400 text-sm mt-1">हर सप्ताह तकनीक, conditioning और recovery का संतुलन — जिम, मैट और WHOOP एक साथ।</p></div></div></div><p class="text-neutral-500 text-sm mt-6 text-center">और गहराई में जाना हो तो <a href="/blog/mike-israetel-bjj-black-belt-defence/" class="text-blue-500 hover:text-cyan-400 font-semibold">Mat Science belt debate</a> या <a href="/blog/openclaw-automation/" class="text-blue-500 hover:text-cyan-400 font-semibold">OpenClaw BJJ automation build log</a> देखें।</p></div></div></section><section class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><div class="max-w-5xl mx-auto"><h2 class="text-3xl md:text-4xl font-bold text-white mb-10 text-center">व्यक्तिगत जीवनशैली</h2><div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12"><div class="bg-neutral-900 border border-neutral-800 rounded-2xl overflow-hidden"><img src="/images/about/fishing.jpg" alt="मछली पकड़ने का दृश्य: नदी किनारे रखी रॉड, प्राकृतिक नज़ारा, कोई व्यक्ति नहीं" class="w-full object-contain aspect-video bg-neutral-950" loading="lazy" /><div class="p-4"><p class="text-center text-neutral-300">मछली पकड़ने का दृश्य: नदी किनारे रखी रॉड, प्राकृतिक नज़ारा, कोई व्यक्ति नहीं</p></div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl overflow-hidden"><img src="/images/about/selfie_dbz.jpg" alt="एकल सेल्फ़ी: Dragon Ball Z शर्ट, मुस्कुराते हुए, बाहर पेंटेड खरगोश की मूर्ति के साथ" class="w-full object-contain aspect-video bg-neutral-950" loading="lazy" /><div class="p-4"><p class="text-center text-neutral-300">एकल सेल्फ़ी: Dragon Ball Z शर्ट, मुस्कुराते हुए, बाहर पेंटेड खरगोश की मूर्ति के साथ</p></div></div></div></div></div></section><section class="py-16 border-t border-neutral-900 bg-neutral-950"><div class="container mx-auto px-4"><div class="max-w-5xl mx-auto"><p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-3">BJJ + ट्रांसफ़ॉर्मेशन</p><h2 class="text-3xl md:text-4xl font-bold text-white mb-10">कैसे BJJ ने मेरे परिवर्तन को गति दी</h2><div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12"><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center"><div class="text-4xl font-bold text-white mb-2">242 lbs</div><div class="text-sm text-neutral-400 uppercase tracking-wider">शुरुआती वजन (2023)</div><div class="text-xs text-neutral-600 mt-2">भारी, फिटनेस से दूर</div></div><div class="bg-neutral-900 border border-blue-500/30 rounded-2xl p-6 text-center"><div class="text-4xl font-bold text-blue-500 mb-2">188 lbs</div><div class="text-sm text-neutral-400 uppercase tracking-wider">सबसे कम वजन (जन. 2024)</div><div class="text-xs text-neutral-600 mt-2">54 lbs कम — BJJ ने फ़ैट लॉस को तेज़ किया</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center"><div class="text-4xl font-bold text-white mb-2">218 lbs</div><div class="text-sm text-neutral-400 uppercase tracking-wider">वर्तमान वजन (2026)</div><div class="text-xs text-neutral-600 mt-2">+30 lbs मसल — पहले से अधिक मजबूत</div></div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8 mb-10"><h3 class="text-xl font-bold text-white mb-6 text-center">बेल्ट प्रोग्रेशन टाइमलाइन</h3><div class="flex flex-col md:flex-row justify-between items-center gap-4"><div class="flex flex-col items-center flex-1"><div class="w-16 h-16 rounded-full bg-white border-4 border-neutral-300 flex items-center justify-center mb-3"><span class="text-neutral-800 font-bold text-xs">WHT</span></div><div class="text-center"><div class="text-white font-bold">व्हाइट बेल्ट</div><div class="text-neutral-500 text-sm">BJJ की शुरुआत</div><div class="text-blue-400 text-xs mt-1">2022</div></div></div><div class="hidden md:block text-neutral-600"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></div><div class="flex flex-col items-center flex-1"><div class="w-16 h-16 rounded-full bg-blue-600 border-4 border-blue-400 flex items-center justify-center mb-3"><span class="text-white font-bold text-xs">BLU</span></div><div class="text-center"><div class="text-white font-bold">ब्लू बेल्ट</div><div class="text-neutral-500 text-sm">पहली स्ट्राइप</div><div class="text-blue-400 text-xs mt-1">2023</div></div></div><div class="hidden md:block text-neutral-600"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></div><div class="flex flex-col items-center flex-1"><div class="w-16 h-16 rounded-full bg-purple-600 border-4 border-purple-400 flex items-center justify-center mb-3"><span class="text-white font-bold text-xs">PRP</span></div><div class="text-center"><div class="text-white font-bold">पर्पल बेल्ट</div><div class="text-neutral-500 text-sm">प्रतियोगिता के लिए तैयार</div><div class="text-blue-400 text-xs mt-1">2024</div></div></div><div class="hidden md:block text-neutral-600"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></div><div class="flex flex-col items-center flex-1"><div class="w-16 h-16 rounded-full bg-amber-700 border-4 border-amber-500 flex items-center justify-center mb-3"><span class="text-white font-bold text-xs">BRN</span></div><div class="text-center"><div class="text-white font-bold">ब्राउन बेल्ट</div><div class="text-neutral-500 text-sm">वर्तमान रैंक</div><div class="text-blue-400 text-xs mt-1">2025-वर्तमान</div></div></div></div></div><div class="space-y-6 text-neutral-300 leading-relaxed text-lg"><p><strong class="text-white">BJJ सिर्फ़ मेरे परिवर्तन का हिस्सा नहीं था — वही उसका catalyst था।</strong> जब मैंने 2022 में jiu-jitsu शुरू किया, मेरा वजन 242 lbs था और सच कहूँ तो मैं अपनी ज़िंदगी की सबसे खराब shape में था। लेकिन मैट पर कुछ बदल गया। BJJ की तकनीकी प्रकृति — उन opponents के खिलाफ positional puzzles हल करना जिन्हें आपके बहानों से कोई फर्क नहीं पड़ता — ने मेरी फिटनेस के बारे में सोच बदल दी।</p><p>वजन कम होना मेरी अपेक्षा से तेज़ था। 3-4x/सप्ताह ट्रेनिंग, Cronometer के साथ लगातार कैलोरी deficit और नियमित मैट टाइम से मिलने वाली मानसिक स्पष्टता — इन सबने मिलकर मुझे जनवरी 2024 तक 242 से 188 lbs पर ला दिया। यह सिर्फ़ कार्डियो नहीं था — यह consistency, competition (मैं Gi और No-Gi दोनों में उतरा) और accountability देने वाले समुदाय का संयुक्त प्रभाव था।</p><p>अब 2026 में <strong class="text-white">218 lbs</strong> पर मैं मसल-बिल्डिंग फेज़ में हूँ। फर्क यह है कि अब मैं ज्यादा स्मार्ट तरीके से ट्रेन करता हूँ। WHOOP रिकवरी स्कोर बताते हैं कि कब push करना है और कब आराम। मेरा BJJ “हर राउंड survive करना” से “positions dominate करना” तक विकसित हुआ है। मैं ब्राउन बेल्ट पर Gi और No-Gi दोनों में compete कर चुका हूँ, और बेहतर बनने की वही भूख मुझे रोज़ 6:30 AM पर उठाती है — चाहे बिस्तर गर्म हो और मैट ठंडी।</p><p>BJJ ने मुझे सिखाया कि प्रगति कभी सीधी रेखा में नहीं होती। plateaus आएँगे, injuries आएँगी, और ऐसे राउंड भी होंगे जहाँ आपसे आधा समय ट्रेनिंग करने वाला व्यक्ति आपको submit कर देगा। यही बात है। मैट को आपके बहानों से मतलब नहीं। मुझे भी नहीं। इसलिए मैं सब कुछ दर्ज करता हूँ — लिफ्ट्स, रन, रोल्स, डेटा। क्योंकि जिसे मापा जाता है, उसे मैनेज किया जा सकता है।</p></div><div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-10"><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5 text-center"><div class="text-3xl font-black text-white mb-1">3-4x</div><div class="text-xs text-neutral-500 uppercase tracking-wide">सेशन/सप्ताह</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5 text-center"><div class="text-3xl font-black text-white mb-1">ब्राउन</div><div class="text-xs text-neutral-500 uppercase tracking-wide">वर्तमान बेल्ट</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5 text-center"><div class="text-3xl font-black text-white mb-1">Gi + No-Gi</div><div class="text-xs text-neutral-500 uppercase tracking-wide">प्रतियोगिता</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5 text-center"><div class="text-3xl font-black text-white mb-1">4+</div><div class="text-xs text-neutral-500 uppercase tracking-wide">कमाई गई स्ट्राइप्स</div></div></div></div></div></section><section class="py-24"><div class="container mx-auto px-4 text-center"><h2 class="text-3xl font-bold mb-6">सबूत देखें</h2><p class="text-neutral-400 mb-8 max-w-2xl mx-auto">मैं YouTube पर सब कुछ दर्ज करता हूँ — सफलताएँ, असफलताएँ और कच्चा डेटा।</p><a href="/hi/videos/" class="inline-flex items-center gap-2 px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-full transition-all hover:scale-105">वीडियो लाइब्रेरी देखें</a></div></section></main>
