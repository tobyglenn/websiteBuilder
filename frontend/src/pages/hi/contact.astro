---
import Layout from '../../layouts/Layout.astro';

const siteUrl = "https://tobyonfitnesstech.com";

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": `${siteUrl}/contact/#contactpage`,
  "name": "Toby Glenn Peters से संपर्क करें",
  "description": "स्पॉन्सरशिप, कंसल्टिंग, सहयोग या फिटनेस टेक से जुड़े सवालों के लिए Toby Glenn Peters से संपर्क करें।",
  "url": `${siteUrl}/contact/`,
  "inLanguage": "hi-IN",
  "isPartOf": { "@id": `${siteUrl}/#website` },
  "about": { "@id": `${siteUrl}/#toby` },
  "mainEntity": {
    "@type": "Person",
    "@id": `${siteUrl}/#toby`,
    "name": "Toby Glenn Peters",
    "alternateName": "TobyOnFitnessTech",
    "email": "toby@tobyonfitness.tech",
    "url": siteUrl,
    "sameAs": [
      "https://www.youtube.com/@tobyonfitness",
      "https://www.instagram.com/tobyonfitness"
    ]
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "होम", "item": siteUrl },
      { "@type": "ListItem", "position": 2, "name": "संपर्क", "item": `${siteUrl}/contact/` }
    ]
  }
};

const faqs = [
  {
    q: "क्या आप कोचिंग प्रोग्राम या पर्सनलाइज़्ड प्लान बेचते हैं?",
    a: "नहीं। मैं बस यह दर्ज करता हूँ कि मेरे लिए क्या काम करता है और उसे सार्वजनिक रूप से साझा करता हूँ — बस इतना ही। मैं प्रोग्राम, मील प्लान या 1-on-1 कोचिंग नहीं बेचता। जो कुछ भी मैं करता हूँ, वह YouTube और इस साइट पर मुफ़्त है।"
  },
  {
    q: "क्या मैं आपसे अपने Speediance या फिटनेस टेक सेटअप के बारे में पूछ सकता हूँ?",
    a: "हाँ — मैं इसी के लिए यहाँ हूँ। मुझे विवरण के साथ ईमेल करें। अगर मेरे पास कुछ उपयोगी जोड़ने के लिए होगा, तो मैं जवाब दूँगा। अगर यह आम सवाल है, तो यह किसी वीडियो या ब्लॉग पोस्ट में बदल सकता है।"
  },
  {
    q: "क्या आप स्पॉन्सरशिप स्वीकार करते हैं?",
    a: "चुनिंदा तौर पर। मैं केवल उन्हीं उत्पादों के साथ काम करता हूँ जिन्हें मैं वास्तव में इस्तेमाल करता हूँ। अगर आप Speediance, WHOOP, Garmin, 8Sleep या इसी तरह की फिटनेस टेक के बारे में संपर्क कर रहे हैं — मैं सुन रहा हूँ। प्रोटीन पाउडर और सप्लीमेंट्स के ठंडे पिच आम तौर पर कहीं नहीं पहुँचते।"
  },
  {
    q: "क्या आप फिटनेस टेक स्टैक या ऑटोमेशन पर कंसल्टिंग के लिए उपलब्ध हैं?",
    a: "कभी-कभी। अगर आप कोई कंपनी या व्यक्ति हैं जो डेटा-ड्रिवन ट्रेनिंग सिस्टम बनाना चाहते हैं — खासकर OpenClaw, होम जिम हार्डवेयर या वेयरेबल इंटीग्रेशन के साथ — तो संपर्क करें। मैं ईमानदारी से बताऊँगा कि मैं मदद कर सकता हूँ या नहीं।"
  },
  {
    q: "जवाब मिलने में कितना समय लगता है?",
    a: "आमतौर पर कुछ दिनों में। मैं एक ही व्यक्ति हूँ, मेरा ट्रेनिंग शेड्यूल भरा हुआ है और मेरी डे जॉब भी है। मैं सब कुछ पढ़ता हूँ — बस जल्दी जवाब नहीं देता।"
  },
  {
    q: "क्या मैं कंटेंट पर सहयोग कर सकता हूँ या कुछ साथ में बना सकता हूँ?",
    a: "शायद। मुझे बताइए कि आप क्या बना रहे हैं और आपको क्यों लगता है कि यह फिट बैठता है। मैं सिर्फ़ अपना अपलोड शेड्यूल भरने के लिए नहीं देख रहा हूँ — लेकिन कोई सचमुच दिलचस्प प्रोजेक्ट? उसके लिए मैं खुला हूँ।"
  }
];
---

<Layout
  title="संपर्क — TobyOnFitnessTech"
  description="स्पॉन्सरशिप, कंसल्टिंग, फिटनेस टेक से जुड़े सवालों या सहयोग के लिए Toby Glenn Peters से संपर्क करें।"
  breadcrumbs={[{ name: "होम", url: "/" }, { name: "संपर्क", url: "/contact" }]}
  jsonLd={contactPageSchema}
>
  <main class="min-h-screen bg-neutral-950 text-white">

    {/* Hero */}
    <section class="pt-20 pb-12 md:pt-28 md:pb-16 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-blue-900/10 to-transparent pointer-events-none" />
      <div class="container mx-auto px-4 relative z-10 max-w-4xl">
        <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-4">संपर्क</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          संपर्क करें
        </h1>
        <p class="text-xl text-neutral-400 max-w-2xl leading-relaxed">
          मुझ तक पहुँचना मुश्किल नहीं है। मैं बस इस बात को लेकर चुनिंदा हूँ कि किस चीज़ के लिए हाँ कहूँ। अगर आपके पास बात करने के लिए कुछ वास्तविक है, तो मैं जवाब दूँगा।
        </p>
      </div>
    </section>

    {/* Contact + Social */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="grid md:grid-cols-2 gap-8">

          {/* Email Card */}
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-xl bg-blue-600/20 border border-blue-500/30 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <h2 class="text-xl font-bold text-white">ईमेल</h2>
                <p class="text-neutral-500 text-sm">मुझ तक पहुँचने का सबसे अच्छा तरीका</p>
              </div>
            </div>
            <a
              href="mailto:toby@tobyonfitness.tech"
              class="text-blue-400 hover:text-blue-300 font-mono text-lg font-semibold transition-colors"
            >
              toby@tobyonfitness.tech
            </a>
            <p class="text-neutral-500 text-sm mt-4 leading-relaxed">
              मैं हर ईमेल पढ़ता हूँ। जब मेरे पास कहने के लिए कुछ उपयोगी होता है, तभी जवाब देता हूँ — आमतौर पर कुछ दिनों के भीतर।
            </p>
          </div>

          {/* Social Links */}
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8">
            <h2 class="text-xl font-bold text-white mb-6">जुड़े रहें</h2>
            <div class="space-y-4">
              <a
                href="https://www.youtube.com/@tobyonfitness"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-4 p-4 rounded-xl bg-neutral-950 border border-neutral-800 hover:border-red-500/40 hover:bg-red-950/10 transition-all group"
              >
                <div class="w-10 h-10 rounded-lg bg-red-600/20 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#ef4444"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.54C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon fill="white" points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
                </div>
                <div>
                  <div class="text-white font-semibold group-hover:text-red-400 transition-colors">YouTube</div>
                  <div class="text-neutral-500 text-sm">@tobyonfitness</div>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-auto text-neutral-700 group-hover:text-neutral-400 transition-colors"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>

              <a
                href="https://www.instagram.com/tobyonfitness"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-4 p-4 rounded-xl bg-neutral-950 border border-neutral-800 hover:border-pink-500/40 hover:bg-pink-950/10 transition-all group"
              >
                <div class="w-10 h-10 rounded-lg bg-pink-600/20 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ec4899" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
                </div>
                <div>
                  <div class="text-white font-semibold group-hover:text-pink-400 transition-colors">Instagram</div>
                  <div class="text-neutral-500 text-sm">@tobyonfitness</div>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-auto text-neutral-700 group-hover:text-neutral-400 transition-colors"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    {/* What to Expect */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-5xl">
        <h2 class="text-3xl font-bold text-white mb-3">मैं वास्तव में किन बातों का जवाब देता हूँ</h2>
        <p class="text-neutral-500 mb-10">बिना फ़ालतू बातों के। ये वे चीज़ें हैं जिनके बारे में ईमेल करना ठीक है:</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">🤝</div>
            <h3 class="text-lg font-bold text-white mb-2">स्पॉन्सरशिप</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              सिर्फ़ फिटनेस टेक — ऐसा गियर जिसे मैं वास्तव में इस्तेमाल करूँ। Speediance, WHOOP, Garmin, 8Sleep जैसी चीज़ें। जिन सप्लीमेंट्स को मैंने कभी टेस्ट नहीं किया, उनमें मेरी दिलचस्पी नहीं है।
            </p>
          </div>

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">🔧</div>
            <h3 class="text-lg font-bold text-white mb-2">कंसल्टिंग</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              क्या आप डेटा-ड्रिवन फिटनेस स्टैक बना रहे हैं? वेयरेबल डेटा के साथ ट्रेनिंग फैसलों को ऑटोमेट कर रहे हैं? यह दिलचस्प है। पहले स्कोप पर बात करते हैं।
            </p>
          </div>

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">❓</div>
            <h3 class="text-lg font-bold text-white mb-2">सवाल</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              Speediance, WHOOP, BJJ या मेरे ट्रेनिंग एप्रोच के बारे में वास्तविक सवाल स्वागत योग्य हैं। अगर कोई सवाल ऐसा है जिसका मैं संक्षेप में जवाब नहीं दे सकता, तो मैं साफ़ कह दूँगा।
            </p>
          </div>

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">🎬</div>
            <h3 class="text-lg font-bold text-white mb-2">सहयोग</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              अगर आप फिटनेस टेक या ऑटोमेशन क्षेत्र में कुछ बना रहे हैं और वह सच में मेल खाता है — मैं तैयार हूँ। मुझे अपना आइडिया बताइए।
            </p>
          </div>

        </div>
      </div>
    </section>

    {/* Response Expectations */}
    <section class="py-12 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="bg-neutral-900/50 border border-neutral-800 rounded-2xl p-8 flex flex-col md:flex-row items-start gap-6">
          <div class="text-4xl flex-shrink-0">⏱️</div>
          <div>
            <h3 class="text-xl font-bold text-white mb-2">जवाब का समय</h3>
            <p class="text-neutral-400 leading-relaxed">
              मैं एक ही व्यक्ति हूँ। मैं सुबह 6:30 बजे ट्रेनिंग करता हूँ, पूरा दिन काम करता हूँ, और ज़्यादातर शामों में BJJ करता हूँ। मैं सब कुछ पढ़ता हूँ — लेकिन मैं तभी जवाब देता हूँ जब मेरे पास कुछ उपयोगी कहने के लिए होता है, सिर्फ़ प्राप्ति की पुष्टि करने के लिए नहीं। फॉलो-अप करने से पहले कुछ दिन दें।
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* FAQ */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-4xl">
        <h2 class="text-3xl font-bold text-white mb-3">आम सवाल</h2>
        <p class="text-neutral-500 mb-10">ईमेल करने से पहले यहाँ देख लें — हो सकता है आपका जवाब पहले से यहीं हो।</p>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-neutral-700 transition-all">
              <h3 class="text-white font-semibold mb-3 flex items-start gap-3">
                <span class="text-blue-500 font-bold flex-shrink-0">प्र:</span>
                {faq.q}
              </h3>
              <p class="text-neutral-400 leading-relaxed pl-6">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* CTA */}
    <section class="py-24 border-t border-neutral-900">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-4">संपर्क करने के लिए तैयार हैं?</h2>
        <p class="text-neutral-400 mb-8 max-w-xl mx-auto">
          मुझे एक संदेश भेजें। इसे स्पष्ट रखें और मैं सच में जवाब दूँगा।
        </p>
        <a
          href="mailto:toby@tobyonfitness.tech"
          class="inline-flex items-center gap-2 px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-full transition-all hover:scale-105"
        >
          Toby को ईमेल करें
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
      </div>
    </section>

  </main>
</Layout>
