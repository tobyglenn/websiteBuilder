---
import Layout from '../../layouts/Layout.astro'; import { getHeartRateData } from '../../data/heartRate.js'; const { stats, monthlyTrends, recentActivities } = getHeartRateData(); function fmtDur(seconds) { if (!seconds || seconds === 0) return '0m'; const h = Math.floor(seconds / 3600); const m = Math.floor((seconds % 3600) / 60); if (h > 0) return `${h}h ${m}m`; return `${m}m`; } const zoneNames = { 1: 'रिकवरी', 2: 'एंड्योरेंस', 3: 'टेम्पो', 4: 'थ्रेशोल्ड', 5: 'VO2 Max' }; const zoneColors = { 1: '#60a5fa', 2: '#4ade80', 3: '#facc15', 4: '#fb923c', 5: '#f87171' }; const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [ { "@type": "Question", "name": "हार्ट रेट ज़ोन का क्या मतलब है?", "acceptedAnswer": { "@type": "Answer", "text": "ज़ोन 1 (रिकवरी) बहुत हल्का प्रयास है, ज़ोन 2 (एंड्योरेंस) हल्का एरोबिक ट्रेनिंग है, ज़ोन 3 (टेम्पो) मध्यम एरोबिक ट्रेनिंग है, ज़ोन 4 (थ्रेशोल्ड) कठिन एनएरोबिक ट्रेनिंग है, और ज़ोन 5 (VO2 Max) स्प्रिंट के लिए अधिकतम प्रयास है।" } }, { "@type": "Question", "name": "एरोबिक ट्रेनिंग इफ़ेक्ट क्या है?", "acceptedAnswer": { "@type": "Answer", "text": "Garmin का एरोबिक ट्रेनिंग इफ़ेक्ट यह मापता है कि आपका वर्कआउट शरीर की ऑक्सीजन ले जाने और उपयोग करने की क्षमता को कितना सुधारता है। स्कोर 0.0–5.0 तक जाते हैं, जहाँ 1.0–1.9 वार्म-अप, 2.0–2.9 आसान, 3.0–3.9 एरोबिक, 4.0–4.9 थ्रेशोल्ड और 5.0 ओवररीचिंग है।" } }, { "@type": "Question", "name": "ट्रेनिंग लोड क्या है?", "acceptedAnswer": { "@type": "Answer", "text": "ट्रेनिंग लोड शरीर पर पड़ने वाले कुल व्यायाम तनाव को मापता है। यह वर्कआउट की अवधि और तीव्रता पर आधारित होता है। Garmin सलाह देता है कि सुधार के लिए अपने फिटनेस स्तर के अनुरूप आदर्श लोड रेंज में रहें।" } } ] }; const donutW = 280, donutH = 280, donutR = 100, donutThick = 35; const cx = donutW / 2, cy = donutH / 2; function polarToCartesian(cx, cy, r, angleInDegrees) { const angleInRadians = (angleInDegrees - 90) * Math.PI / 180.0; return { x: cx + (r * Math.cos(angleInRadians)), y: cy + (r * Math.sin(angleInRadians)) }; } function describeArc(cx, cy, r, startAngle, endAngle) { const start = polarToCartesian(cx, cy, r, endAngle); const end = polarToCartesian(cx, cy, r, startAngle); const largeArcFlag = endAngle - startAngle <= 180 ? '0' : '1'; return `M ${start.x} ${start.y} A ${r} ${r} 0 ${largeArcFlag} 0 ${end.x} ${end.y}`; } let currentAngle = 0; const zoneArcs = []; for (let z = 1; z <= 5; z++) { const pct = stats.zonePercentages[z]; if (pct > 0) { const angle = (pct / 100) * 360; const path = describeArc(cx, cy, donutR, currentAngle, currentAngle + angle); zoneArcs.push({ z, pct, path, color: zoneColors[z], startAngle: currentAngle, endAngle: currentAngle + angle }); currentAngle += angle; } } const lineW = 600, lineH = 180, padL = 40, padR = 20, padT = 20, padB = 35; const hrValues = monthlyTrends.map(m => m.avgHR).filter(v => v > 0); const minHR = Math.min(...hrValues, 110); const maxHR = Math.max(...hrValues, 170); const yRange = maxHR - minHR; function hrToY(hr) { return lineH - padB - ((hr - minHR) / yRange) * (lineH - padT - padB); } const scaledLinePoints = monthlyTrends.map((m, i) => { const x = padL + (i / Math.max(1, monthlyTrends.length - 1)) * (lineW - padL - padR); const y = hrToY(m.avgHR); return { ...m, x, y }; }); let linePath = ''; scaledLinePoints.forEach((p, i) => { if (p.avgHR > 0) linePath += (i === 0 ? 'M' : 'L') + `${p.x},${p.y}`; });
---
<Layout title="हार्ट रेट और ट्रेनिंग ज़ोन विश्लेषण — TobyOnFitnessTech" description="हार्ट रेट ज़ोन विश्लेषण के साथ अपनी कार्डियोवैस्कुलर फिटनेस ट्रैक करें। ज़ोन 1–5 में बिताया समय, एरोबिक ट्रेनिंग इफ़ेक्ट और Garmin डेटा से मासिक हार्ट रेट ट्रेंड देखें।" jsonLd={faqSchema}><main class="min-h-screen bg-neutral-950 text-white"><section class="pt-28 pb-14 md:pt-36 md:pb-20 relative overflow-hidden"><div class="absolute inset-0 bg-gradient-to-br from-red-900/10 via-transparent to-transparent pointer-events-none" /><div class="absolute right-0 top-0 w-64 h-64 bg-red-600/5 rounded-full blur-3xl pointer-events-none" /><div class="container mx-auto px-4 relative z-10"><div class="max-w-3xl"><p class="text-xs font-bold tracking-widest text-red-500 uppercase mb-4">Garmin Fenix 7 · फ़र 2025 – फ़र 2026</p><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-5 leading-tight">हार्ट रेट<br /><span class="bg-gradient-to-r from-red-400 to-orange-500 bg-clip-text text-transparent">ज़ोन विश्लेषण.</span></h2><p class="text-lg text-neutral-400 leading-relaxed max-w-2xl mb-8">विस्तृत HR ज़ोन ब्रेकडाउन के साथ अपनी कार्डियोवैस्कुलर फिटनेस ट्रैक करें। देखें कि आप हर ज़ोन में कितना समय बिताते हैं और समय के साथ अपनी एरोबिक प्रगति पर नज़र रखें।</p><div class="flex flex-wrap gap-3"><span class="px-4 py-1.5 rounded-full text-xs font-semibold bg-red-600/20 border border-red-500/30 text-red-400">❤️ {stats.totalActivities} गतिविधियाँ</span><span class="px-4 py-1.5 rounded-full text-xs font-semibold bg-neutral-800 border border-neutral-700 text-neutral-400">अधिकतम HR: {stats.maxHR} bpm</span></div></div></div></section></main></Layout>
