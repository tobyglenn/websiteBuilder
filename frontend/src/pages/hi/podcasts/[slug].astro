---
import { marked } from 'marked';
import Layout from '../../../layouts/Layout.astro';
import EpisodeDetail from '../../../components/EpisodeDetail.jsx';
import StickySubscribeBar from '../../../components/StickySubscribeBar.jsx';
import {
  ensureEpisodeFromFallbackFeed,
  extractAttr,
  extractChannelItems,
  extractTag,
  fetchFirstAvailableText,
  localizedShowNotesCandidates,
  localizedTranscriptCandidates,
  normalizeEpisodeTitle,
  parseEpisodeNumber,
} from '../../../lib/openclawFeed';

export async function getStaticPaths() {
  const langCode = 'hi';
  const feedUrl = `https://raw.githubusercontent.com/grayking-creator/openclaw-podcast/main/translations/feed_${langCode}.xml`;
  
  // 1. Fetch translated RSS
  const rssRes = await fetch(feedUrl);
  const rssText = await rssRes.text();

  // 2. Parse episodes
  let items = extractChannelItems(rssText);
  items = await ensureEpisodeFromFallbackFeed(items, 0);

  const episodes = await Promise.all(items.map(async (item) => {
    const episodeNum = parseEpisodeNumber(item);
    const slug = `episode-${episodeNum}`;
    const title = normalizeEpisodeTitle(extractTag(item, 'title'));
    const description = extractTag(item, 'description');
    const pubDate = extractTag(item, 'pubDate');
    const duration = extractTag(item, 'itunes:duration');
    const audioUrl = extractAttr(item, 'enclosure', 'url');
    const fallbackLink = extractTag(item, 'link');
    let transcriptSourceUrl = fallbackLink;

    // Format date in Hindi
    const dateObj = new Date(pubDate);
    const formattedDate = isNaN(dateObj.getTime()) ? pubDate : dateObj.toLocaleDateString('hi-IN', { month: 'long', day: 'numeric', year: 'numeric' });

    // Fetch translated show notes
    let showNotesHtml = '';
    const showNotesResult = await fetchFirstAvailableText(
      localizedShowNotesCandidates(langCode, episodeNum),
    );
    if (showNotesResult) {
      showNotesHtml = await marked.parse(showNotesResult.text);
    }

    // Fetch translated transcript (for topics/links)
    let transcriptHtml = '';
    const transcriptResult = await fetchFirstAvailableText(
      localizedTranscriptCandidates(langCode, episodeNum),
    );
    if (transcriptResult) {
      transcriptSourceUrl = transcriptResult.url;
      transcriptHtml = await marked.parse(transcriptResult.text);
    } else {
      transcriptHtml = '<p class="text-neutral-500">ट्रांसक्रिप्ट उपलब्ध नहीं है।</p>';
    }

    const baseEpNum = String(episodeNum).padStart(3, '0'); const coverImage = `/images/podcast/episode_${baseEpNum}_cover_hi.png`;

    return {
      params: { slug },
      props: {
        episode: {
          slug,
          number: episodeNum,
          title,
          description,
          date: formattedDate,
          duration,
          audioUrl,
          mdUrl: transcriptSourceUrl,
          coverImage,
          showNotesHtml,
          transcriptHtml,
          topics: [],
          links: [],
        }
      }
    };
  }));

  return episodes;
}

const { episode } = Astro.props;
---

<Layout 
  title={`Episode ${episode.number}: ${episode.title} | OpenClaw Daily`} 
  description={episode.description}
  lang="hi"
  episodeSlug={episode.slug}
>
  <EpisodeDetail episode={episode} rssUrl="https://tobyonfitnesstech.com/hi/podcasts/feed.xml" client:load />
  <StickySubscribeBar client:load />
</Layout>

<style is:global>
  .speaker {
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-right: 0.5rem;
  }
  .speaker.nova { color: #60a5fa; }
  .speaker.alloy { color: #c084fc; }
</style>
