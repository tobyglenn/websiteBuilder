---
import Layout from '../../layouts/Layout.astro';
import { hrZones } from '../../data/hrZones.js';

const zones = [
  { name: 'ज़ोन 1 - रिकवरी', color: '#60a5fa', key: 'z1', desc: '50-60% अधिकतम HR - बहुत हल्का प्रयास, रिकवरी' },
  { name: 'ज़ोन 2 - एरोबिक', color: '#3b82f6', key: 'z2', desc: '60-70% अधिकतम HR - हल्का प्रयास, फैट बर्निंग, बेस बिल्डिंग' },
  { name: 'ज़ोन 3 - टेम्पो', color: '#2563eb', key: 'z3', desc: '70-80% अधिकतम HR - मध्यम प्रयास, एरोबिक सहनशक्ति' },
  { name: 'ज़ोन 4 - थ्रेशहोल्ड', color: '#1d4ed8', key: 'z4', desc: '80-90% अधिकतम HR - कठिन प्रयास, लैक्टेट थ्रेशहोल्ड' },
  { name: 'ज़ोन 5 - अधिकतम', color: '#1e40af', key: 'z5', desc: '90-100% अधिकतम HR - अधिकतम प्रयास, स्प्रिंटिंग' },
];
---
<Layout
  title="हृदय गति ज़ोन विश्लेषण | TobyOnFitnessTech"
  description={`${hrZones.totalRuns} Garmin गतिविधियों के हार्ट रेट ज़ोन ब्रेकडाउन, ज़ोन 1-5 में बिताया गया समय, औसत हार्ट रेट और हाल की रनिंग ट्रेंड्स देखें।`}
>
  <section class="bg-neutral-950 text-white py-16 px-4 text-center"><h1 class="text-4xl md:text-5xl font-bold">हृदय गति ज़ोन विश्लेषण</h1><p class="mt-4 text-lg text-blue-400 max-w-2xl mx-auto">{hrZones.totalRuns} Garmin गतिविधियों से अपनी रनिंग इंटेंसिटी डिस्ट्रीब्यूशन ट्रैक करें</p></section>
  <section class="max-w-6xl mx-auto py-8 px-4"><div class="grid grid-cols-2 md:grid-cols-4 gap-4"><div class="bg-neutral-900 rounded-lg p-6 text-center"><div class="text-3xl font-bold text-blue-500">{hrZones.totalRuns}</div><div class="text-gray-400 text-sm mt-1">कुल रन</div></div><div class="bg-neutral-900 rounded-lg p-6 text-center"><div class="text-3xl font-bold text-blue-500">{hrZones.avgHR}</div><div class="text-gray-400 text-sm mt-1">औसत HR (bpm)</div></div><div class="bg-neutral-900 rounded-lg p-6 text-center"><div class="text-3xl font-bold text-blue-500">{hrZones.totalHours}</div><div class="text-gray-400 text-sm mt-1">ज़ोन में घंटे</div></div><div class="bg-neutral-900 rounded-lg p-6 text-center"><div class="text-3xl font-bold text-blue-500">{hrZones.avgDistance.toFixed(1)}</div><div class="text-gray-400 text-sm mt-1">औसत दूरी (km)</div></div></div></section>
  <section class="max-w-4xl mx-auto py-8 px-4"><h2 class="text-2xl font-bold mb-6 text-white">ज़ोन वितरण</h2><div class="space-y-4">{zones.map((zone, i) => { const pct = hrZones.zonePercentages[zone.key]; const mins = hrZones.totalTimeInMinutes[zone.key]; return (<div class="bg-neutral-900 rounded-lg p-4"><div class="flex justify-between items-center mb-2"><div><span class="font-semibold text-white">{zone.name}</span><p class="text-gray-500 text-xs">{zone.desc}</p></div><div class="text-right"><span class="text-xl font-bold" style={`color: ${zone.color}`}>{pct}%</span><p class="text-gray-500 text-xs">{mins} मिनट</p></div></div><div class="h-3 bg-neutral-800 rounded-full overflow-hidden"><div class="h-full rounded-full transition-all" style={`width: ${pct}%; background-color: ${zone.color}`}></div></div></div>);})}</div></section>
  <section class="max-w-6xl mx-auto py-8 px-4"><h2 class="text-2xl font-bold mb-6 text-white">हाल की रन</h2><div class="overflow-x-auto"><table class="min-w-full divide-y divide-neutral-800 text-sm"><thead class="bg-neutral-900"><tr><th class="px-4 py-3 text-left text-gray-400 font-medium">तारीख</th><th class="px-4 py-3 text-left text-gray-400 font-medium">दूरी</th><th class="px-4 py-3 text-left text-gray-400 font-medium">औसत HR</th><th class="px-4 py-3 text-left text-gray-400 font-medium">Z1</th><th class="px-4 py-3 text-left text-gray-400 font-medium">Z2</th><th class="px-4 py-3 text-left text-gray-400 font-medium">Z3</th><th class="px-4 py-3 text-left text-gray-400 font-medium">Z4</th><th class="px-4 py-3 text-left text-gray-400 font-medium">Z5</th></tr></thead><tbody class="divide-y divide-neutral-800">{hrZones.recentRuns.map((run) => (<tr class="hover:bg-neutral-900"><td class="px-4 py-3 text-white">{run.date?.slice(0, 10)}</td><td class="px-4 py-3 text-white">{run.distance?.toFixed(1)} km</td><td class="px-4 py-3 text-white">{run.avgHR} bpm</td><td class="px-4 py-3 text-blue-400">{run.z1}m</td><td class="px-4 py-3 text-blue-400">{run.z2}m</td><td class="px-4 py-3 text-blue-400">{run.z3}m</td><td class="px-4 py-3 text-blue-400">{run.z4}m</td><td class="px-4 py-3 text-blue-400">{run.z5}m</td></tr>))}</tbody></table></div></section>
  <script type="application/ld+json">{JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"हृदय गति ज़ोन क्या होते हैं?","acceptedAnswer":{"@type":"Answer","text":"हृदय गति ज़ोन वे रेंज हैं जो प्रशिक्षण की तीव्रता दिखाती हैं, रिकवरी (ज़ोन 1) से अधिकतम प्रयास (ज़ोन 5) तक।"}},{"@type":"Question","name":"यह डेटा कैसे गणना किया जाता है?","acceptedAnswer":{"@type":"Answer","text":"यह डेटा Garmin गतिविधियों से एकत्र किया जाता है, हर HR ज़ोन में बिताए गए सेकंड जोड़कर और प्रतिशत निकालकर।"}},{"@type":"Question","name":"इन ज़ोनों का मतलब क्या है?","acceptedAnswer":{"@type":"Answer","text":"ज़ोन 1 रिकवरी है (50-60% अधिकतम HR), ज़ोन 2 एरोबिक (60-70%), ज़ोन 3 टेम्पो (70-80%), ज़ोन 4 थ्रेशहोल्ड (80-90%), और ज़ोन 5 अधिकतम (90-100%) है।"}}]})}</script>
</Layout>
