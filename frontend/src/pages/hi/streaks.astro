---
import Layout from '../layouts/Layout.astro';
import { getStreakData } from '../data/streaks.js';

const siteUrl = "https://tobyonfitnesstech.com";
const streakData = getStreakData();

const streakPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${siteUrl}/streaks#collection`,
  "name": "ट्रेनिंग स्ट्रीक्स - Toby on Fitness Tech",
  "description": `ट्रेनिंग स्ट्रीक ट्रैकर: ${streakData.currentStreak} दिन की मौजूदा स्ट्रीक, ${streakData.longestStreak} दिन की सबसे लंबी स्ट्रीक, ${streakData.totalActiveDays} कुल सक्रिय दिन ${streakData.totalWorkouts} वर्कआउट्स से।`,
  "url": `${siteUrl}/streaks`,
  "inLanguage": "hi",
  "isPartOf": { "@id": `${siteUrl}/#website` },
  "author": { "@id": `${siteUrl}/#toby` },
  "publisher": { "@id": `${siteUrl}/#organization` },
  "mainEntity": {
    "@type": "SportsActivityProfile",
    "name": "ट्रेनिंग स्ट्रीक आँकड़े",
    "athlete": { "@id": `${siteUrl}/#toby` },
    "stats": [
      {"@type": "Stat", "name": "मौजूदा स्ट्रीक", "value": streakData.currentStreak, "unitText": "दिन"},
      {"@type": "Stat", "name": "सबसे लंबी स्ट्रीक", "value": streakData.longestStreak, "unitText": "दिन"},
      {"@type": "Stat", "name": "कुल सक्रिय दिन", "value": streakData.totalActiveDays, "unitText": "दिन"}
    ]
  }
};
---

<Layout 
  title="ट्रेनिंग स्ट्रीक्स - Toby on Fitness Tech"
  description={`ट्रेनिंग स्ट्रीक ट्रैकर: ${streakData.currentStreak} दिन की मौजूदा स्ट्रीक, ${streakData.longestStreak} दिन की सबसे लंबी स्ट्रीक, ${streakData.totalActiveDays} कुल सक्रिय दिन ${streakData.totalWorkouts} वर्कआउट्स से (${streakData.speedianceWorkouts} Speediance वर्कआउट्स + ${streakData.garminRuns} Garmin रन)।`}
  breadcrumbs={[{ name: "होम", url: "/" }, { name: "ट्रेनिंग स्ट्रीक्स", url: "/streaks" }]}
  jsonLd={streakPageSchema}
>
  <main class="min-h-screen bg-neutral-950 text-white">
    <section class="pt-20 pb-16 md:pt-28 md:pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-blue-900/10 to-transparent pointer-events-none" />
      <div class="container mx-auto px-4"><div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4 tracking-tight">ट्रेनिंग <span class="text-blue-500">स्ट्रीक्स</span></h1>
        <p class="text-lg md:text-xl text-gray-400 max-w-2xl mx-auto">Speediance वर्कआउट्स और Garmin रन के बीच निरंतरता को ट्रैक करें। हर दिन एक मजबूत आदत बनाने में मायने रखता है।</p>
        <div class="mt-6 flex flex-wrap justify-center gap-4 text-sm text-gray-500"><span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-green-500"></span>{streakData.speedianceWorkouts} Speediance वर्कआउट्स</span><span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-blue-500"></span>{streakData.garminRuns} Garmin रन</span></div>
      </div></div>
    </section>

    <section class="py-12"><div class="container mx-auto px-4"><div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
      <div class="bg-neutral-900 rounded-2xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-all duration-300"><div class="flex items-center justify-between mb-4"><span class="text-gray-400 text-sm font-medium">मौजूदा स्ट्रीक</span><span class="text-3xl">🔥</span></div><div class="flex items-baseline gap-2"><span class="text-5xl font-bold text-blue-500">{streakData.currentStreak}</span><span class="text-xl text-gray-400">दिन</span></div><p class="mt-2 text-sm text-gray-500">{streakData.currentStreak > 0 ? "इसे जारी रखें!" : "आज ही अपनी स्ट्रीक शुरू करें!"}</p></div>
      <div class="bg-neutral-900 rounded-2xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-all duration-300"><div class="flex items-center justify-between mb-4"><span class="text-gray-400 text-sm font-medium">सबसे लंबी स्ट्रीक</span><span class="text-3xl">🏆</span></div><div class="flex items-baseline gap-2"><span class="text-5xl font-bold text-white">{streakData.longestStreak}</span><span class="text-xl text-gray-400">दिन</span></div><p class="mt-2 text-sm text-gray-500">व्यक्तिगत सर्वश्रेष्ठ हासिल</p></div>
      <div class="bg-neutral-900 rounded-2xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-all duration-300"><div class="flex items-center justify-between mb-4"><span class="text-gray-400 text-sm font-medium">कुल सक्रिय दिन</span><span class="text-3xl">📅</span></div><div class="flex items-baseline gap-2"><span class="text-5xl font-bold text-white">{streakData.totalActiveDays}</span><span class="text-xl text-gray-400">दिन</span></div><p class="mt-2 text-sm text-gray-500">{streakData.totalWorkouts} कुल गतिविधियाँ</p></div>
    </div></div></section>

    <section class="py-12 bg-neutral-900/50"><div class="container mx-auto px-4"><div class="max-w-5xl mx-auto"><h2 class="text-2xl font-bold mb-6 text-center">गतिविधि हीटमैप</h2><p class="text-gray-400 text-center mb-8">समय के साथ आपकी ट्रेनिंग गतिविधि</p><div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800 overflow-x-auto"><div class="flex mb-2 ml-8">{(() => { const months = []; const weekData = streakData.weeklyData; let lastMonth = ''; weekData.forEach((week, idx) => { const month = new Date(week.date).toLocaleString('default', { month: 'short' }); if (month !== lastMonth) { months.push(<span class="text-xs text-gray-500" style={`margin-left: ${idx > 0 ? (idx * 14) - (months.length > 0 ? months[months.length-1].offset : 0) - 20 : 0}px; position: absolute;`}>{month}</span>); lastMonth = month; }}); return null; })()}</div><div class="flex"><div class="flex flex-col text-xs text-gray-500 mr-2 justify-between py-1"><span>रवि</span><span>सोम</span><span>मंगल</span><span>बुध</span><span>गुरु</span><span>शुक्र</span><span>शनि</span></div><div class="flex gap-0.5 flex-1 overflow-x-auto pb-2">{streakData.weeklyData.map((week) => (<div class="flex flex-col gap-0.5">{[0,1,2,3,4,5,6].map((dayIdx) => { const weekStart = new Date(week.date); const cellDate = new Date(weekStart); cellDate.setDate(weekStart.getDate() + dayIdx); const today = new Date(); const isFuture = cellDate > today; const intensity = week.intensity; return (<div class={`w-3 h-3 rounded-sm ${isFuture ? 'bg-neutral-800' : intensity === 0 ? 'bg-neutral-800' : intensity === 1 ? 'bg-blue-900/60' : intensity === 2 ? 'bg-blue-700/80' : intensity === 3 ? 'bg-blue-500' : 'bg-blue-400'}`} title={`${cellDate.toISOString().split('T')[0]}: ${week.activeDays > 0 ? week.activeDays + ' सक्रिय दिन इस सप्ताह' : 'कोई गतिविधि नहीं'}`} />); })}</div>))}</div></div><div class="flex items-center justify-end mt-4 gap-2 text-xs text-gray-500"><span>कम</span><div class="w-3 h-3 rounded-sm bg-neutral-800"></div><div class="w-3 h-3 rounded-sm bg-blue-900/60"></div><div class="w-3 h-3 rounded-sm bg-blue-700/80"></div><div class="w-3 h-3 rounded-sm bg-blue-500"></div><div class="w-3 h-3 rounded-sm bg-blue-400"></div><span>ज़्यादा</span></div></div></div></div></section>

    <section class="py-12"><div class="container mx-auto px-4"><div class="max-w-4xl mx-auto"><h2 class="text-2xl font-bold mb-6 text-center">साप्ताहिक निरंतरता</h2><p class="text-gray-400 text-center mb-8">पिछले 4 हफ्ते एक नज़र में</p><div class="grid grid-cols-2 md:grid-cols-4 gap-4">{streakData.weeklyConsistency.map((week) => (<div class="bg-neutral-900 rounded-xl p-4 border border-neutral-800 text-center"><div class="relative w-24 h-24 mx-auto mb-3"><svg class="w-24 h-24 transform -rotate-90" viewBox="0 0 100 100"><circle cx="50" cy="50" r="40" fill="none" stroke="#262626" stroke-width="10" /><circle cx="50" cy="50" r="40" fill="none" stroke="#3b82f6" stroke-width="10" stroke-linecap="round" stroke-dasharray={`${week.percentage * 2.51} 251`} class="transition-all duration-500" /></svg><div class="absolute inset-0 flex items-center justify-center"><span class="text-2xl font-bold">{week.percentage}%</span></div></div><div class="text-sm font-medium">{week.week}</div><div class="text-xs text-gray-500">{week.activeDays}/7 दिन</div></div>))}</div></div></div></section>

    <section class="py-12 bg-neutral-900/50"><div class="container mx-auto px-4"><div class="max-w-4xl mx-auto"><h2 class="text-2xl font-bold mb-6 text-center">उपलब्धियाँ</h2><p class="text-gray-400 text-center mb-8">आपकी फिटनेस यात्रा के मील के पत्थर</p><div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">{streakData.achievements.map((achievement) => (<div class={`relative bg-neutral-900 rounded-xl p-4 border transition-all duration-300 ${achievement.earned ? 'border-blue-500/50 hover:border-blue-400' : 'border-neutral-800 opacity-60'}`}><div class="text-4xl mb-2 text-center">{achievement.icon}</div><div class={`text-sm font-bold text-center ${achievement.earned ? 'text-white' : 'text-gray-400'}`}>{achievement.name}</div><div class="text-xs text-gray-500 text-center mt-1">{achievement.description}</div><div class="mt-3"><div class="h-1.5 bg-neutral-800 rounded-full overflow-hidden"><div class={`h-full rounded-full transition-all duration-500 ${achievement.earned ? 'bg-blue-500' : 'bg-gray-600'}`} style={`width: ${(achievement.progress / achievement.target) * 100}%`} /></div><div class="text-xs text-gray-500 text-center mt-1">{achievement.progress}/{achievement.target}</div></div>{achievement.earned && (<div class="absolute -top-2 -right-2 text-lg">✅</div>)}</div>))}</div></div></div></section>

    <section class="py-12"><div class="container mx-auto px-4"><div class="max-w-4xl mx-auto"><h2 class="text-2xl font-bold mb-6 text-center">स्ट्रीक इतिहास</h2><p class="text-gray-400 text-center mb-8">आपके सबसे बेहतर प्रदर्शन वाले स्ट्रीक दौर</p>{streakData.streakHistory.length > 0 ? (<div class="bg-neutral-900 rounded-xl border border-neutral-800 overflow-hidden"><div class="overflow-x-auto"><table class="w-full"><thead><tr class="border-b border-neutral-800"><th class="text-left py-3 px-4 text-sm font-medium text-gray-400">#</th><th class="text-left py-3 px-4 text-sm font-medium text-gray-400">शुरुआती तारीख</th><th class="text-left py-3 px-4 text-sm font-medium text-gray-400">अंतिम तारीख</th><th class="text-right py-3 px-4 text-sm font-medium text-gray-400">अवधि</th></tr></thead><tbody>{streakData.streakHistory.map((streak, idx) => (<tr class="border-b border-neutral-800/50 hover:bg-neutral-800/30 transition-colors"><td class="py-3 px-4"><span class={`inline-flex items-center justify-center w-6 h-6 rounded-full text-xs font-bold ${idx === 0 ? 'bg-yellow-500/20 text-yellow-500' : 'bg-neutral-800 text-gray-400'}`}>{idx + 1}</span></td><td class="py-3 px-4 text-sm">{streak.start}</td><td class="py-3 px-4 text-sm">{streak.end}</td><td class="py-3 px-4 text-sm text-right"><span class="inline-flex items-center gap-1">{streak.length >= 7 && <span>🔥</span>}<span class={`font-bold ${idx === 0 ? 'text-yellow-500' : 'text-blue-400'}`}>{streak.length} दिन</span></span></td></tr>))}</tbody></table></div></div>) : (<div class="text-center py-12 text-gray-500"><p>अभी तक कोई स्ट्रीक डेटा उपलब्ध नहीं है।</p><p class="text-sm mt-2">अपनी पहली स्ट्रीक बनाने के लिए आज से वर्कआउट शुरू करें!</p></div>)}</div></div></section>

    <section class="py-12 border-t border-neutral-800"><div class="container mx-auto px-4"><div class="max-w-2xl mx-auto text-center"><p class="text-gray-400">ट्रेनिंग शुरू हुई <span class="text-white font-medium">{streakData.firstActiveDate || 'उपलब्ध नहीं'}</span> से — <span class="text-white font-medium">{streakData.totalWorkouts}</span> कुल गतिविधियाँ, जिनमें <span class="text-green-400"> Speediance</span> और <span class="text-blue-400">Garmin</span> डेटा शामिल है।</p></div></div></section>
  </main>
</Layout>
