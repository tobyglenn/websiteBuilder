---
import Layout from '../../layouts/Layout.astro';
const updated = "फ़रवरी 2026";
---

<Layout 
  title="एफ़िलिएट प्रकटीकरण - Toby on Fitness Tech"
  description="TobyOnFitnessTech.com के लिए एफ़िलिएट प्रकटीकरण — रेफ़रल लिंक और भुगतान के बारे में पारदर्शिता।"
>
  <div class="container mx-auto px-4 py-16 max-w-3xl">
    <div class="mb-12 pb-8 border-b border-neutral-800">
      <h1 class="text-4xl font-bold text-white mb-3">एफ़िलिएट प्रकटीकरण</h1>
      <p class="text-neutral-500 text-sm">अंतिम अपडेट: {updated}</p>
    </div>

    <div class="bg-blue-900/20 border border-blue-500/30 rounded-xl p-6 mb-10">
      <p class="text-blue-200 font-semibold text-lg mb-2">संक्षिप्त संस्करण:</p>
      <p class="text-neutral-300">
        इस समय मैं केवल Amazon Associates प्रोग्राम में भाग लेता हूँ। मैं वर्तमान में किसी अन्य उत्पाद या ब्रांड के लिए रेफ़रल कोड का उपयोग नहीं करता।
      </p>
    </div>

    <div class="space-y-8 text-neutral-300">

      <section>
        <h2 class="text-2xl font-bold text-white mb-4">FTC प्रकटीकरण</h2>
        <p class="leading-relaxed">
          FTC के दिशा-निर्देशों के अनुसार, TobyOnFitnessTech यह स्पष्ट करता है कि इस वेबसाइट पर कुछ लिंक एफ़िलिएट लिंक हैं। इस समय यह केवल Amazon Associates लिंक पर लागू होता है। यदि आप इन लिंक पर क्लिक करते हैं और योग्य खरीदारी करते हैं, तो मुझे बिना किसी अतिरिक्त लागत के भुगतान मिल सकता है।
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-white mb-4">Amazon</h2>
        <p class="leading-relaxed">
          यह साइट Amazon Associates Program में भाग लेती है। Amazon पर उत्पादों के लिंक एफ़िलिएट लिंक हो सकते हैं। एक Amazon Associate के रूप में, मैं योग्य खरीदारी से कमाता हूँ।
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-white mb-4">संपादकीय स्वतंत्रता</h2>
        <p class="leading-relaxed">
          एफ़िलिएट संबंध संपादकीय सामग्री को प्रभावित नहीं करते। मुझे सकारात्मक कवरेज के बदले कोई मुफ्त उत्पाद या भुगतान नहीं मिला है। समीक्षा किए गए सभी उत्पाद मैंने अपने पैसे से खरीदे हैं, जब तक कि स्पष्ट रूप से अन्यथा न कहा गया हो।
        </p>
        <p class="mt-4 leading-relaxed">
          यदि यह कभी बदलता है, तो संबंधित सामग्री में इसे स्पष्ट रूप से बताया जाएगा।
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-white mb-4">प्रश्न</h2>
        <p class="leading-relaxed">
          एफ़िलिएट संबंधों के बारे में प्रश्न हैं? ईमेल करें <a href="mailto:admin@tobyonfitnesstech.com" class="text-blue-400 hover:text-blue-300">admin@tobyonfitnesstech.com</a>.
        </p>
      </section>

    </div>
  </div>
</Layout>
