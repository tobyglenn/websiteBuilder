---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.jsx';
import TrainingFocus from '../../components/TrainingFocus.jsx';
import Newsletter from '../../components/Newsletter.jsx';
import WorkoutHeatmap from '../../components/WorkoutHeatmap.jsx';
import ThisWeekWidget from '../../components/ThisWeekWidget.jsx';
import LatestActivity from '../../components/LatestActivity.jsx';
import YearlyGoals from '../../components/YearlyGoals.jsx';
import NewsletterSignup from '../../components/NewsletterSignup.jsx';
import { CANONICAL_BLOG_POSTS } from '../../lib/blogPosts';
import videosData from '../../data/videos.json';
import { videos as youtube } from '../../data/youtube.js';
import { Play, ArrowRight, Clock, Eye, Video } from 'lucide-react';
import { trainingStreak, lastWorkoutData, thisWeekVolume, thisMonthMiles } from '../../lib/trainingStats.js';
import { lifetimeStats } from '../../data/stats.js';
import { recentActivity } from '../../data/recentActivity.js';
import weeklyProgress from '../../data/weeklyProgress.js';

function readTime(content = '') {
  const words = content.split(/\s+/).filter(Boolean).length;
  return `${Math.max(1, Math.round(words / 200))} मिनट पढ़ने का समय`;
}

function formatBlogDate(value) {
  const timestamp = Date.parse(value || '');
  if (Number.isNaN(timestamp)) return 'तारीख उपलब्ध नहीं';
  return new Date(timestamp).toLocaleDateString('hi-IN', { month: 'short', day: 'numeric', year: 'numeric' });
}

const lastWorkout = lastWorkoutData;
const allVideos = videosData.videos || [];
const channelTotalVideos = allVideos.length;
const channelTotalViews = allVideos.reduce((sum, v) => sum + (v.viewCount || 0), 0);
const channelShortsCount = allVideos.filter(v => v.is_short === true).length;
const channelLiveCount = allVideos.filter(v => v.is_live === true || v.duration === 'LIVE').length;
const channelLatestVideo = [...allVideos].filter(v => v.publishedAt).sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime())[0];
const channelLatestDate = channelLatestVideo ? new Date(channelLatestVideo.publishedAt).toLocaleDateString('hi-IN', { month: 'short', day: 'numeric', year: 'numeric' }) : 'उपलब्ध नहीं';
const channelTotalViewsFormatted = channelTotalViews >= 1000 ? (channelTotalViews / 1000).toFixed(1) + 'K' : channelTotalViews.toString();
const popularVideos = [...allVideos].filter(v => !v.is_live && v.viewCount > 0).sort((a, b) => (b.viewCount || 0) - (a.viewCount || 0)).slice(0, 5);
const recentVideos = allVideos.filter(v => !v.is_live).slice(0, 3);
function formatViews(count) { if (!count) return '0 व्यू'; if (count >= 1000) return (count / 1000).toFixed(1) + 'K व्यू'; return count + ' व्यू'; }
const recentPosts = [...CANONICAL_BLOG_POSTS].sort((a, b) => new Date(b.published_at).getTime() - new Date(a.published_at).getTime()).slice(0, 3);
const formattedLifetimeStats = { lbsLifted: new Intl.NumberFormat('hi-IN').format(lifetimeStats.totalLbsLifted), milesRun: new Intl.NumberFormat('hi-IN', { minimumFractionDigits: 1, maximumFractionDigits: 1 }).format(lifetimeStats.totalMilesRun), workouts: new Intl.NumberFormat('hi-IN').format(lifetimeStats.totalWorkouts) };
const webPageSchema = { "@context": "https://schema.org", "@type": "WebPage", "@id": "https://tobyonfitnesstech.com/hi/#webpage-home", "name": "Toby on Fitness Tech - होम", "description": "फिटनेस टेक की स्वतंत्र समीक्षाएँ: Speediance, Tonal, Whoop, Garmin और बहुत कुछ। एक वास्तविक एथलीट के वास्तविक डेटा के साथ।", "url": "https://tobyonfitnesstech.com/hi/", "inLanguage": "hi", "primaryImageOfPage": { "@type": "ImageObject", "url": "https://tobyonfitnesstech.com/images/og-home.jpg" }, "isPartOf": { "@id": "https://tobyonfitnesstech.com/#website" }, "about": { "@id": "https://tobyonfitnesstech.com/#organization" }, "author": { "@id": "https://tobyonfitnesstech.com/#person" } };
---

<Layout title="Toby on Fitness Tech - रिव्यू, विश्लेषण और लाइव स्ट्रीम" description="एक वास्तविक एथलीट की स्वतंत्र फिटनेस टेक समीक्षाएँ। Speediance बनाम Tonal, Whoop बनाम Garmin, BJJ कमेंट्री और ट्रांसफ़ॉर्मेशन डेटा। बिना फालतू बातों के, सिर्फ़ वास्तविक आँकड़े।" jsonLd={webPageSchema}>
<Hero client:load />
<TrainingFocus client:load lang="hi" />
<section id="this-week" class="py-12 bg-neutral-950"><div class="max-w-6xl mx-auto px-4"><h2 class="text-2xl font-bold text-white mb-8">इस सप्ताह बनाम पिछले सप्ताह</h2><div class="grid grid-cols-2 md:grid-cols-5 gap-4"><div class="bg-neutral-900 rounded-xl p-4 border border-neutral-800"><div class="flex items-center gap-2 mb-2"><span class="text-2xl">🏋️</span><span class="text-neutral-400 text-sm">वर्कआउट</span></div><div class="text-3xl font-bold text-white">{weeklyProgress.workouts.thisWeek}</div><div class="text-sm text-neutral-500">पिछले सप्ताह {weeklyProgress.workouts.lastWeek}</div></div><div class="bg-neutral-900 rounded-xl p-4 border border-neutral-800"><div class="flex items-center gap-2 mb-2"><span class="text-2xl">🏃</span><span class="text-neutral-400 text-sm">रन</span></div><div class="text-3xl font-bold text-white">{weeklyProgress.runs.thisWeek}</div><div class="text-sm text-neutral-500">पिछले सप्ताह {weeklyProgress.runs.lastWeek}</div></div><div class="bg-neutral-900 rounded-xl p-4 border border-neutral-800"><div class="flex items-center gap-2 mb-2"><span class="text-2xl">💪</span><span class="text-neutral-400 text-sm">वॉल्यूम</span></div><div class="text-3xl font-bold text-white">{weeklyProgress.volume.thisWeek.toLocaleString()}</div><div class="text-sm text-neutral-500">पिछले सप्ताह {weeklyProgress.volume.lastWeek.toLocaleString()} lbs</div></div><div class="bg-neutral-900 rounded-xl p-4 border border-neutral-800"><div class="flex items-center gap-2 mb-2"><span class="text-2xl">🗺️</span><span class="text-neutral-400 text-sm">मील</span></div><div class="text-3xl font-bold text-white">{weeklyProgress.miles.thisWeek}</div><div class="text-sm text-neutral-500">पिछले सप्ताह {weeklyProgress.miles.lastWeek} mi</div></div><div class="bg-neutral-900 rounded-xl p-4 border border-neutral-800"><div class="flex items-center gap-2 mb-2"><span class="text-2xl">🥋</span><span class="text-neutral-400 text-sm">BJJ</span></div><div class="text-3xl font-bold text-white">{weeklyProgress.bjj.thisWeek}</div><div class="text-sm text-neutral-500">पिछले सप्ताह {weeklyProgress.bjj.lastWeek}</div></div></div></div></section>
<section id="lifetime-stats" class="py-16 bg-neutral-950 border-y border-neutral-800"><div class="container mx-auto px-4"><div class="text-center mb-10"><span class="text-blue-500 font-bold uppercase tracking-widest text-sm mb-2 block">लाइफ़टाइम कुल</span><h2 class="text-3xl md:text-4xl font-bold text-white">वास्तविक डेटा। वास्तविक परिणाम।</h2><p class="text-neutral-500 mt-3 max-w-xl mx-auto">हर ट्रैक किए गए सेशन और रन का आजीवन सारांश।</p></div><div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6"><div class="bg-neutral-900 rounded-lg p-8 border border-neutral-800"><div class="text-4xl font-bold text-blue-400">🏋️ {formattedLifetimeStats.lbsLifted}</div><div class="text-sm md:text-base font-semibold text-neutral-400 uppercase tracking-wide">कुल उठाए गए lbs</div></div><div class="bg-neutral-900 rounded-lg p-8 border border-neutral-800"><div class="text-4xl font-bold text-blue-400">🏃 {formattedLifetimeStats.milesRun}</div><div class="text-sm md:text-base font-semibold text-neutral-400 uppercase tracking-wide">कुल दौड़े गए मील</div></div><div class="bg-neutral-900 rounded-lg p-8 border border-neutral-800"><div class="text-4xl font-bold text-blue-400">💪 {formattedLifetimeStats.workouts}</div><div class="text-sm md:text-base font-semibold text-neutral-400 uppercase tracking-wide">कुल वर्कआउट</div></div></div></div></section>
<YearlyGoals client:visible lang="hi" />
<section class="py-16 bg-neutral-950 border-t border-neutral-800"><div class="container mx-auto px-4"><WorkoutHeatmap client:load /><ThisWeekWidget client:load /></div></section>
<section id="blog" class="py-16 bg-neutral-950 border-t border-neutral-800"><div class="container mx-auto px-4"><div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10"><div><span class="text-blue-400 font-bold uppercase tracking-widest text-sm mb-2 block">ब्लॉग से नवीनतम</span><h2 class="text-3xl md:text-4xl font-bold text-white">ताज़ा विश्लेषण और रिव्यू</h2><p class="text-neutral-400 mt-3 max-w-2xl">फिटनेस टेक, ट्रेनिंग ट्रेंड्स और डेटा वास्तव में क्या कहता है—इन सब पर सबसे नए पोस्ट।</p></div><a href="/hi/blog/" class="inline-flex items-center gap-2 px-5 py-2.5 bg-neutral-900 border border-neutral-800 rounded-full text-white font-semibold hover:border-blue-500/50 hover:text-blue-400 transition-colors">सभी पोस्ट देखें <ArrowRight size={16} /></a></div><div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">{recentPosts.map((post) => (<a href={`/blog/${post.slug}/`} class="group block bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden hover:border-blue-500/50 transition-all">{post.image && (<div class="aspect-video overflow-hidden bg-neutral-950"><img src={post.image} alt={post.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" /></div>)}<div class="p-5"><span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold uppercase tracking-wide bg-blue-500/10 text-blue-400 border border-blue-500/20">{post.category}</span><h3 class="mt-3 text-lg font-bold text-white leading-snug group-hover:text-blue-400 transition-colors line-clamp-2">{post.title}</h3><div class="mt-2 text-xs text-neutral-500 flex items-center gap-2"><span>{formatBlogDate(post.published_at)}</span><span>•</span><span>{readTime(post.content)}</span></div><p class="mt-3 text-sm text-neutral-400 leading-relaxed">{post.excerpt.length > 100 ? `${post.excerpt.slice(0, 100)}...` : post.excerpt}</p></div></a>))}</div></div></section>
<section id="featured-video" class="py-16 bg-neutral-900"><div class="max-w-4xl mx-auto px-4"><h2 class="text-2xl font-bold mb-6 text-white">फ़ीचर्ड वीडियो</h2><div class="aspect-video rounded-xl overflow-hidden bg-neutral-800"><iframe class="w-full h-full" src="https://www.youtube.com/embed/0C8mQoV-Xpg" title="Speediance V3.1 प्रोग्रेसिव ओवरलोड रिव्यू" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div><p class="mt-4 text-neutral-400">Speediance ने प्रोग्रेसिव ओवरलोड को (ज़्यादातर) ठीक कर दिया — V3.1 अपडेट रिव्यू</p><a href="/hi/videos/" class="inline-block mt-2 text-blue-400 hover:text-blue-300">सभी वीडियो देखें →</a></div></section>
<NewsletterSignup client:visible />
<section id="latest-videos" class="py-16 bg-neutral-950 border-t border-neutral-800"><div class="container mx-auto px-4"><div class="flex items-end justify-between mb-10"><div><span class="text-cyan-400 font-bold uppercase tracking-widest text-sm mb-2 block">YouTube</span><h2 class="text-3xl md:text-4xl font-bold text-white">नवीनतम वीडियो</h2></div><a href="/hi/videos/" class="text-cyan-400 hover:text-cyan-300 font-semibold flex items-center gap-2">सभी वीडियो देखें <ArrowRight size={18} /></a></div><div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">{allVideos.filter(v => !v.is_live).slice(0, 4).map((video) => (<a href={`/video/${video.id}/`} class="group block bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden hover:border-cyan-500/50 transition-all"><div class="aspect-video relative overflow-hidden"><img src={video.thumbnail} alt={video.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />{video.duration_formatted && (<span class="absolute bottom-2 right-2 bg-black/80 text-white text-xs px-2 py-0.5 rounded">{video.duration_formatted}</span>)}</div><div class="p-4"><h3 class="font-semibold text-white text-sm group-hover:text-cyan-400 transition-colors line-clamp-2">{video.title}</h3></div></a>))}</div></div></section>
<LatestActivity client:load lang="hi" />
<section class="py-12 bg-neutral-950 border-t border-neutral-900"><div class="container mx-auto px-4"><div class="bg-neutral-900 rounded-2xl p-6 md:p-8 border border-neutral-800"><div class="flex flex-col md:flex-row items-center justify-between gap-6"><div class="flex items-center gap-3"><div class="w-12 h-12 bg-red-600 rounded-full flex items-center justify-center"><svg class="w-6 h-6 text-white fill-white" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></div><div><div class="text-white font-bold text-lg">Toby on Fitness</div><div class="text-neutral-500 text-sm">YouTube चैनल</div></div></div><div class="flex flex-wrap items-center justify-center gap-6 md:gap-10"><div class="text-center"><div class="text-2xl md:text-3xl font-black text-white">1.2K</div><div class="text-xs text-neutral-500 uppercase tracking-wide">सब्सक्राइबर</div></div><div class="h-10 w-px bg-neutral-700 hidden md:block"></div><div class="text-center"><div class="text-2xl md:text-3xl font-black text-white">9.9K</div><div class="text-xs text-neutral-500 uppercase tracking-wide">कुल व्यू</div></div><div class="h-10 w-px bg-neutral-700 hidden md:block"></div><div class="text-center"><div class="text-2xl md:text-3xl font-black text-white">104</div><div class="text-xs text-neutral-500 uppercase tracking-wide">वीडियो</div></div></div><a href="https://youtube.com/@tobyonfitness" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-full transition-colors text-sm"><svg class="w-4 h-4 fill-white" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>सब्सक्राइब करें</a></div></div></div></section>
<section id="channel-stats" class="py-16 bg-neutral-950 border-t border-neutral-800"><div class="container mx-auto px-4"><div class="text-center mb-10"><span class="text-red-500 font-bold uppercase tracking-widest text-sm mb-2 block">चैनल आँकड़े</span><h2 class="text-3xl md:text-4xl font-bold text-white">आँकड़ों में</h2><p class="text-neutral-500 mt-3 max-w-xl mx-auto">YouTube चैनल के वास्तविक प्रोडक्शन मेट्रिक्स — बिना फालतू भराव के, सिर्फ़ आउटपुट।</p></div><div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6"><div class="bg-neutral-900 rounded-2xl p-6 border border-neutral-800 hover:border-red-500/40 transition-all group text-center"><div class="flex items-center justify-center w-12 h-12 rounded-full bg-red-500/10 border border-red-500/20 mx-auto mb-4"><svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.36a1 1 0 01-1.447.893L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z" /></svg></div><div class="text-3xl md:text-4xl font-black text-white mb-2 group-hover:text-red-400 transition-colors">{channelTotalVideos}</div><div class="text-xs font-semibold text-neutral-500 uppercase tracking-widest">कुल वीडियो</div></div><div class="bg-neutral-900 rounded-2xl p-6 border border-neutral-800 hover:border-blue-500/40 transition-all group text-center"><div class="flex items-center justify-center w-12 h-12 rounded-full bg-blue-500/10 border border-blue-500/20 mx-auto mb-4"><svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg></div><div class="text-3xl md:text-4xl font-black text-white mb-2 group-hover:text-blue-400 transition-colors">{channelTotalViewsFormatted}</div><div class="text-xs font-semibold text-neutral-500 uppercase tracking-widest">कुल व्यू</div></div><div class="bg-neutral-900 rounded-2xl p-6 border border-neutral-800 hover:border-purple-500/40 transition-all group text-center"><div class="flex items-center justify-center w-12 h-12 rounded-full bg-purple-500/10 border border-purple-500/20 mx-auto mb-4"><svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg></div><div class="text-3xl md:text-4xl font-black text-white mb-2 group-hover:text-purple-400 transition-colors">{channelShortsCount}</div><div class="text-xs font-semibold text-neutral-500 uppercase tracking-widest">Shorts</div></div><div class="bg-neutral-900 rounded-2xl p-6 border border-neutral-800 hover:border-green-500/40 transition-all group text-center"><div class="flex items-center justify-center w-12 h-12 rounded-full bg-green-500/10 border border-green-500/20 mx-auto mb-4"><svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg></div><div class="text-lg md:text-xl font-black text-white mb-2 group-hover:text-green-400 transition-colors leading-tight">{channelLatestDate}</div><div class="text-xs font-semibold text-neutral-500 uppercase tracking-widest">सबसे हालिया अपलोड</div></div></div></div></section>
<section class="py-16 bg-neutral-900 border-t border-neutral-800"><div class="container mx-auto px-4"><div class="text-center mb-10"><span class="text-blue-500 font-bold uppercase tracking-widest text-sm mb-2 block">अगला देखें</span><h2 class="text-3xl md:text-4xl font-bold text-white">सबसे लोकप्रिय वीडियो</h2><p class="text-neutral-500 mt-3 max-w-xl mx-auto">चैनल के सबसे अधिक देखे गए वीडियो।</p></div><div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">{popularVideos.map(video => (<a href={`/video/${video.id}/`} class="group block bg-neutral-950 rounded-xl overflow-hidden border border-neutral-800 hover:border-blue-500/50 transition-all"><div class="aspect-video relative overflow-hidden"><img src={video.thumbnail || `https://i.ytimg.com/vi/${video.id}/hqdefault.jpg`} alt={video.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />{video.duration_formatted && video.duration_formatted !== 'Live' && (<span class="absolute bottom-2 right-2 bg-black/80 text-white text-xs px-2 py-0.5 rounded">{video.duration_formatted}</span>)}</div><div class="p-4"><h3 class="font-semibold text-white text-sm mb-2 group-hover:text-blue-400 transition-colors line-clamp-2">{video.title}</h3><div class="flex items-center justify-between text-xs text-neutral-500"><span>{formatViews(video.viewCount)}</span><span>{video.publishedAt ? new Date(video.publishedAt).toLocaleDateString('hi-IN', {month:'short', day:'numeric', year:'numeric'}) : ''}</span></div></div></a>))}</div></div></section>
