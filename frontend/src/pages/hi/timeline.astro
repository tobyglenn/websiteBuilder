---
import Layout from '../../layouts/Layout.astro';
import { trainingStreak } from '../../lib/trainingStats.js';

const siteUrl = "https://tobyonfitnesstech.com";

const milestones = [
  { category: "weight", title: "शुरुआती वजन", date: "2023", description: "242 lbs पर फिटनेस ट्रांसफॉर्मेशन यात्रा की शुरुआत", value: "242 lbs", icon: "scale", color: "orange" },
  { category: "weight", title: "सबसे कम वजन", date: "2023", description: "डेटा-आधारित ट्रेनिंग से लक्ष्य वजन हासिल किया", value: "188 lbs", icon: "scale", color: "orange", highlight: true },
  { category: "weight", title: "मौजूदा वजन", date: "2026", description: "मसल बिल्डिंग चरण - 218 lbs पर पहले से ज़्यादा मजबूत", value: "218 lbs", icon: "scale", color: "orange" },
  { category: "lifting", title: "100K lbs उठाए", date: "2025", description: "पहला बड़ा माइलस्टोन - Speediance पर कुल 100,000 lbs वॉल्यूम", value: "100K lbs", icon: "dumbbell", color: "blue" },
  { category: "lifting", title: "500K lbs उठाए", date: "2025", description: "आधा मिलियन पाउंड - निरंतरता सचमुच ताकत बना रही है", value: "500K lbs", icon: "dumbbell", color: "blue" },
  { category: "lifting", title: "1M lbs उठाए", date: "2025", description: "सात अंकों तक पहुँचे - दस लाख पाउंड की सीमा पार की", value: "1M lbs", icon: "dumbbell", color: "blue" },
  { category: "lifting", title: "मौजूदा कुल वॉल्यूम", date: "2026", description: "सभी Speediance वर्कआउट्स का कुल लाइफटाइम वॉल्यूम", value: "1.29M lbs", icon: "dumbbell", color: "blue", highlight: true },
  { category: "running", title: "पहला 5K", date: "2025-03", description: "ट्रेडमिल पर पहला 5K पूरा किया - 3.1 मील", value: "5K", icon: "running", color: "green" },
  { category: "running", title: "पहला 10K", date: "2025-04", description: "6.2 मील तक बढ़े - स्टैमिना बना रहे हैं", value: "10K", icon: "running", color: "green" },
  { category: "running", title: "100 मील", date: "2025", description: "तीन अंकों तक पहुँचे - Garmin पर कुल 100 मील", value: "100 mi", icon: "running", color: "green" },
  { category: "running", title: "मौजूदा दूरी", date: "2026", description: "Garmin Fenix 7 पर ट्रैक की गई कुल मील", value: "265 mi", icon: "running", color: "green", highlight: true },
  { category: "bjj", title: "व्हाइट बेल्ट", date: "2010 के शुरुआती साल", description: "BJJ यात्रा की शुरुआत - कई मैच हारे, लेकिन बुनियादी बातें सीखीं", value: "व्हाइट बेल्ट", icon: "jiu-jitsu", color: "purple" },
  { category: "bjj", title: "ब्लू बेल्ट", date: "2010 के मध्य", description: "प्रतियोगिताओं में हिस्सा लिया और मेडल जीते - पोज़िशनल डॉमिनेंस गेम विकसित किया", value: "ब्लू बेल्ट", icon: "jiu-jitsu", color: "purple" },
  { category: "bjj", title: "पर्पल बेल्ट", date: "2010 के अंतिम साल", description: "कोचिंग की ओर बढ़े - छात्रों को प्रतियोगिता में सफलता दिलाई", value: "पर्पल बेल्ट", icon: "jiu-jitsu", color: "purple" },
  { category: "bjj", title: "ब्राउन बेल्ट", date: "2023-वर्तमान", description: "फिर से प्रतियोगिता में लौटे - Gi/No-Gi/Absolute में तीसरा स्थान, Gi में ब्लैक बेल्ट को हराया", value: "ब्राउन बेल्ट", icon: "jiu-jitsu", color: "purple", highlight: true },
  { category: "streak", title: "मौजूदा ट्रेनिंग स्ट्रीक", date: "2026", description: `Speediance पर लगातार ट्रेनिंग वाले दिन`, value: `${trainingStreak} दिन`, icon: "flame", color: "amber" },
];
const personSchema = {"@context":"https://schema.org","@type":"Person","@id":`${siteUrl}/#person`,"name":"Toby Glenn Peters","url":siteUrl,"jobTitle":"फिटनेस उत्साही और टेक समीक्षक","description":"Toby Glenn Peters ने डेटा-आधारित ट्रेनिंग, Speediance, Garmin और Brazilian Jiu-Jitsu की मदद से 242 lbs से 188 lbs तक का बदलाव किया।"};
const articleSchema = {"@context":"https://schema.org","@type":"Article","headline":"फिटनेस माइलस्टोन टाइमलाइन - 265 मील, 1.29M lbs, ब्राउन बेल्ट","description":"242 lbs से 188 lbs और फिर 218 lbs तक की फिटनेस यात्रा को ट्रैक करें। 1.29M lbs उठाए, 265 मील दौड़े, BJJ में ब्राउन बेल्ट।","author":personSchema,"datePublished":"2026-03-06","url":`${siteUrl}/timeline`};
const allSchemas = [personSchema, articleSchema];
const iconMap = { scale: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="M7 21h10"/><path d="M12 3v18"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/></svg>`, dumbbell: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6.5 6.5 11 11"/><path d="m21 21-1-1"/><path d="m3 3 1 1"/><path d="m18 22 4-4"/><path d="m2 6 4-4"/><path d="m3 10 7-7"/><path d="m14 21 7-7"/></svg>`, running: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="3"/><path d="M4 17v3a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2v-3"/><path d="m9 14 3-3 3 3"/><path d="M12 12v5"/></svg>`, "jiu-jitsu": `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="3"/><path d="M9 12l3-3 3 3"/><path d="M14 9a2 2 0 0 1-2 2H9"/><path d="M12 14v5"/><path d="M12 19h4a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-4"/></svg>`, flame: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>` };
const colorMap = { blue: { bg: "bg-blue-500/10", border: "border-blue-500", text: "text-blue-400", glow: "shadow-blue-500/20" }, green: { bg: "bg-green-500/10", border: "border-green-500", text: "text-green-400", glow: "shadow-green-500/20" }, purple: { bg: "bg-purple-500/10", border: "border-purple-500", text: "text-purple-400", glow: "shadow-purple-500/20" }, orange: { bg: "bg-orange-500/10", border: "border-orange-500", text: "text-orange-400", glow: "shadow-orange-500/20" }, amber: { bg: "bg-amber-500/10", border: "border-amber-500", text: "text-amber-400", glow: "shadow-amber-500/20" } };
---
<Layout title="फिटनेस टाइमलाइन - माइलस्टोन्स और प्रगति" description="फिटनेस यात्रा ट्रैक करें: 242→188→218 lbs, 1.29M lbs उठाए, 265 मील दौड़े, BJJ ब्राउन बेल्ट। डेटा-आधारित ट्रेनिंग माइलस्टोन्स।" jsonLd={allSchemas}><section class="relative py-20 overflow-hidden"><div class="absolute inset-0 bg-gradient-to-b from-neutral-900/50 to-neutral-950"></div><div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><div class="text-center"><h1 class="text-4xl md:text-6xl font-bold text-white mb-4">फिटनेस <span class="text-blue-400">टाइमलाइन</span></h1><p class="text-xl text-neutral-400 max-w-2xl mx-auto mb-8">242 lbs से ब्राउन बेल्ट तक — हर माइलस्टोन ट्रैक किया गया, हर PR दर्ज किया गया।</p><div class="flex flex-wrap justify-center gap-4"><a href="/running/" class="px-6 py-3 bg-green-500/10 border border-green-500/30 rounded-lg text-green-400 hover:bg-green-500/20 transition-all"><span class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="3"/><path d="M4 17v3a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2v-3"/><path d="m9 14 3-3 3 3"/><path d="M12 12v5"/></svg>दौड़</span></a><a href="/speediance/" class="px-6 py-3 bg-blue-500/10 border border-blue-500/30 rounded-lg text-blue-400 hover:bg-blue-500/20 transition-all"><span class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6.5 6.5 11 11"/><path d="m21 21-1-1"/><path d="m3 3 1 1"/><path d="m18 22 4-4"/><path d="m2 6 4-4"/><path d="m3 10 7-7"/><path d="m14 21 7-7"/></svg>Speediance</span></a><a href="/bjj/" class="px-6 py-3 bg-purple-500/10 border border-purple-500/30 rounded-lg text-purple-400 hover:bg-purple-500/20 transition-all"><span class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="3"/><path d="M9 12l3-3 3 3"/><path d="M14 9a2 2 0 0 1-2 2H9"/><path d="M12 14v5"/><path d="M12 19h4a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-4"/></svg>BJJ</span></a><a href="/prs/" class="px-6 py-3 bg-amber-500/10 border border-amber-500/30 rounded-lg text-amber-400 hover:bg-amber-500/20 transition-all"><span class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4"/><path d="m15.4 4.6-2.8 3.5"/><path d="m8.4 4.6 2.8 3.5"/><path d="m15.4 15.4-2.8-3.5"/><path d="m8.4 15.4 2.8-3.5"/><path d="M12 14v4"/><path d="M4 12h4"/><path d="M16 12h4"/><path d="M8 20v2"/><path d="M16 20v2"/><path d="M8 4v2"/><path d="M16 4v2"/></svg>PRs</span></a></div></div></div></section><section class="py-12 border-y border-neutral-800"><div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><div class="grid grid-cols-2 md:grid-cols-4 gap-6"><div class="text-center"><div class="text-3xl md:text-4xl font-bold text-white mb-1">218</div><div class="text-sm text-neutral-400">मौजूदा lbs</div></div><div class="text-center"><div class="text-3xl md:text-4xl font-bold text-blue-400 mb-1">1.29M</div><div class="text-sm text-neutral-400">उठाए गए lbs</div></div><div class="text-center"><div class="text-3xl md:text-4xl font-bold text-green-400 mb-1">265</div><div class="text-sm text-neutral-400">दौड़ी गई मील</div></div><div class="text-center"><div class="text-3xl md:text-4xl font-bold text-purple-400 mb-1">ब्राउन</div><div class="text-sm text-neutral-400">BJJ बेल्ट</div></div></div></div></section><section class="py-20 bg-neutral-950"><div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><div class="flex flex-wrap justify-center gap-6 mb-16"><div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-orange-500"></div><span class="text-neutral-400 text-sm">वजन यात्रा</span></div><div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-blue-500"></div><span class="text-neutral-400 text-sm">लिफ्टिंग</span></div><div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-green-500"></div><span class="text-neutral-400 text-sm">रनिंग</span></div><div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-purple-500"></div><span class="text-neutral-400 text-sm">BJJ</span></div><div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-amber-500"></div><span class="text-neutral-400 text-sm">स्ट्रीक्स</span></div></div><div class="relative"><div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-neutral-800 via-neutral-700 to-neutral-800 transform md:-translate-x-1/2"></div><div class="space-y-12">{milestones.map((milestone, index) => { const colors = colorMap[milestone.color]; const isEven = index % 2 === 0; return (<div class={`relative flex items-center ${isEven ? 'md:flex-row' : 'md:flex-row-reverse'}`}><div class="absolute left-4 md:left-1/2 w-4 h-4 rounded-full bg-neutral-950 border-2 border-neutral-600 transform -translate-x-1/2 z-10"></div><div class={`ml-12 md:ml-0 md:w-[calc(50%-2rem)] ${isEven ? 'md:mr-auto md:pr-12' : 'md:ml-auto md:pl-12'}`}><div class={`p-6 rounded-xl border ${colors.border} ${colors.bg} backdrop-blur-sm transition-all hover:scale-[1.02] ${milestone.highlight ? `shadow-lg ${colors.glow}` : ''}`}><div class="flex items-start justify-between mb-3"><div class={`p-2 rounded-lg ${colors.bg} ${colors.text}`} set:html={iconMap[milestone.icon]}></div><span class={`text-2xl font-bold ${colors.text}`}>{milestone.value}</span></div><h3 class={`text-lg font-semibold ${colors.text} mb-1`}>{milestone.title}</h3><div class="text-sm text-neutral-500 mb-2">{milestone.date}</div><p class="text-neutral-300 text-sm">{milestone.description}</p></div></div><div class="hidden md:block md:w-[calc(50%-2rem)]"></div></div>); })}</div></div></div></section><section class="py-20 bg-neutral-900"><div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center"><h2 class="text-3xl font-bold text-white mb-4">अपनी खुद की यात्रा शुरू करें</h2><p class="text-neutral-400 mb-8">डेटा के साथ अपनी प्रगति ट्रैक करें। हर रेप, हर मील, हर रोल मायने रखता है।</p><div class="flex flex-wrap justify-center gap-4"><a href="/training/" class="px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-semibold transition-all">ट्रेनिंग ओवरव्यू</a><a href="/transformation/" class="px-8 py-4 bg-neutral-800 hover:bg-neutral-700 text-white rounded-lg font-semibold transition-all">प्रोग्रेस फ़ोटो देखें</a></div></div></section></Layout><style>@keyframes fadeInUp { from { opacity: 0; transform: translateY(20px);} to { opacity: 1; transform: translateY(0);} } .animate-fade-in-up { animation: fadeInUp 0.6s ease-out forwards; }</style>
