---
import Layout from '../layouts/Layout.astro';
import { LISTING_BLOG_POSTS } from '../lib/blogPosts';
import { ArrowRight, BookOpen, Cpu, FileCode2, Headphones, Radio, ServerCog } from 'lucide-react';

const agentPosts = LISTING_BLOG_POSTS
  .filter((post) => /openclaw|agentstack|agent stack|local ai|ai fitness assistant|fitness report connector/i.test([
    post.title,
    post.excerpt,
    post.category,
    ...(post.tags || []),
  ].join(' ')))
  .sort((a, b) => new Date(b.published_at).getTime() - new Date(a.published_at).getTime())
  .slice(0, 6);

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'AgentStack Projects, Podcast and OpenClaw Field Reports',
  description: 'Daily AI systems analysis, OpenClaw fitness integrations, local AI workflows, and implementation field reports from Toby Peters.',
  url: 'https://tobyonfitnesstech.com/agentstack/',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: agentPosts.map((post, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: post.title,
      url: `https://tobyonfitnesstech.com/blog/${post.slug}/`,
    })),
  },
};
---

<Layout
  title="AgentStack: Daily AI Podcast and OpenClaw Projects"
  description="AgentStack Daily episodes, OpenClaw fitness integrations, local AI infrastructure, and practical field reports from systems Toby is actively building."
  image="/images/gear/openclaw-mac-studio.jpg"
  jsonLd={pageSchema}
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'AgentStack', url: '/agentstack/' }]}
>
  <section class="relative flex min-h-[470px] items-end overflow-hidden border-b border-neutral-800">
    <img
      src="/images/gear/openclaw-mac-studio.jpg"
      alt="Local AI hardware used for AgentStack and OpenClaw projects"
      class="absolute inset-0 h-full w-full object-cover"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-black/75"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-neutral-950 via-neutral-950/50 to-transparent"></div>
    <div class="container relative z-10 mx-auto px-4 pb-14 pt-32">
      <div class="max-w-3xl">
        <div class="mb-4 flex items-center gap-2 text-sm font-semibold text-fuchsia-300">
          <Cpu size={18} />
          Built in public
        </div>
        <h1 class="mb-5 text-4xl font-bold leading-tight text-white md:text-6xl">AgentStack</h1>
        <p class="max-w-2xl text-lg leading-relaxed text-neutral-200 md:text-xl">
          The daily AI show and the systems behind it: OpenClaw automations, fitness-data connectors, local models, hardware, evaluations, and honest build notes.
        </p>
      </div>
    </div>
  </section>

  <main class="bg-neutral-950">
    <section class="border-b border-neutral-900 py-12">
      <div class="container mx-auto px-4">
        <div class="grid gap-4 md:grid-cols-3">
          <a href="/podcasts/agentstack/" class="group rounded-lg border border-neutral-800 bg-neutral-900 p-6 hover:border-fuchsia-500/60" data-analytics-event="hub_path_selected" data-analytics-content-type="agentstack" data-analytics-content-slug="podcast" data-analytics-content-title="AgentStack Daily podcast">
            <Headphones size={23} class="mb-5 text-fuchsia-400" />
            <p class="mb-2 text-xs font-semibold uppercase text-fuchsia-400">Listen</p>
            <h2 class="mb-3 text-xl font-bold text-white group-hover:text-fuchsia-300">AgentStack Daily</h2>
            <p class="mb-6 text-sm leading-relaxed text-neutral-400">Daily episodes on models, hardware, evaluations, security, and the systems being built around them.</p>
            <span class="inline-flex items-center gap-2 text-sm font-semibold text-fuchsia-400">Browse episodes <ArrowRight size={15} /></span>
          </a>
          <a href="/blog/openclaw-fitness-reports-garmin-whoop-speediance/" class="group rounded-lg border border-neutral-800 bg-neutral-900 p-6 hover:border-cyan-500/60" data-analytics-event="hub_path_selected" data-analytics-content-type="agentstack" data-analytics-content-slug="fitness-connectors" data-analytics-content-title="fitness connector implementation brief">
            <FileCode2 size={23} class="mb-5 text-cyan-400" />
            <p class="mb-2 text-xs font-semibold uppercase text-cyan-400">Build</p>
            <h2 class="mb-3 text-xl font-bold text-white group-hover:text-cyan-300">Fitness connector brief</h2>
            <p class="mb-6 text-sm leading-relaxed text-neutral-400">An agent-ready architecture for Garmin, WHOOP, Speediance, Cronometer, 8Sleep, and normalized reports.</p>
            <span class="inline-flex items-center gap-2 text-sm font-semibold text-cyan-400">Read the implementation brief <ArrowRight size={15} /></span>
          </a>
          <a href="/blog/how-i-built-my-ai-fitness-assistant-with-openclaw/" class="group rounded-lg border border-neutral-800 bg-neutral-900 p-6 hover:border-emerald-500/60" data-analytics-event="hub_path_selected" data-analytics-content-type="agentstack" data-analytics-content-slug="fitness-assistant" data-analytics-content-title="AI fitness assistant field report">
            <ServerCog size={23} class="mb-5 text-emerald-400" />
            <p class="mb-2 text-xs font-semibold uppercase text-emerald-400">Field report</p>
            <h2 class="mb-3 text-xl font-bold text-white group-hover:text-emerald-300">AI fitness assistant</h2>
            <p class="mb-6 text-sm leading-relaxed text-neutral-400">How the fitness-data assistant was assembled, what it automates, and where the hard edges still are.</p>
            <span class="inline-flex items-center gap-2 text-sm font-semibold text-emerald-400">Read the build story <ArrowRight size={15} /></span>
          </a>
        </div>
      </div>
    </section>

    <section class="border-b border-neutral-900 py-14">
      <div class="container mx-auto px-4">
        <div class="mb-8 flex flex-col justify-between gap-4 md:flex-row md:items-end">
          <div class="max-w-2xl">
            <p class="mb-2 text-xs font-semibold uppercase text-blue-400">Implementation notes</p>
            <h2 class="mb-3 text-2xl font-bold text-white md:text-3xl">OpenClaw and AgentStack field reports</h2>
            <p class="text-neutral-400">The durable written layer behind the daily show: architectures, failure modes, connector decisions, and working systems.</p>
          </div>
          <a href="/blog/" class="inline-flex items-center gap-2 text-sm font-semibold text-blue-400 hover:text-blue-300">All articles <ArrowRight size={15} /></a>
        </div>

        {agentPosts.length > 0 ? (
          <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
            {agentPosts.map((post) => (
              <a
                href={`/blog/${post.slug}/`}
                class="group rounded-lg border border-neutral-800 bg-neutral-900 p-6 hover:border-blue-500/60"
                data-analytics-event="content_card_click"
                data-analytics-content-type="blog"
                data-analytics-content-slug={post.slug}
                data-analytics-content-title={post.title}
              >
                <div class="mb-5 flex items-center justify-between">
                  <BookOpen size={20} class="text-blue-400" />
                  <ArrowRight size={16} class="text-neutral-600 transition-transform group-hover:translate-x-1 group-hover:text-blue-400" />
                </div>
                <p class="mb-2 text-xs font-semibold text-blue-400">{post.category}</p>
                <h3 class="mb-3 line-clamp-3 font-semibold leading-snug text-white group-hover:text-blue-300">{post.title}</h3>
                <p class="line-clamp-3 text-sm leading-relaxed text-neutral-500">{post.excerpt}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="text-neutral-500">New field reports are being organized here.</p>
        )}
      </div>
    </section>

    <section class="py-14">
      <div class="container mx-auto flex flex-col justify-between gap-8 px-4 md:flex-row md:items-center">
        <div class="max-w-2xl">
          <div class="mb-3 flex items-center gap-2 text-sm font-semibold text-rose-400"><Radio size={18} /> Published continuously</div>
          <h2 class="mb-3 text-3xl font-bold text-white">Use the podcast for the moving story and the field reports for the durable one</h2>
          <p class="leading-relaxed text-neutral-400">Daily episodes track what changed. Written reports preserve the architecture, evidence, and implementation details worth finding later.</p>
        </div>
        <a href="/podcasts/agentstack/" class="inline-flex shrink-0 items-center justify-center gap-2 rounded-md bg-fuchsia-600 px-6 py-3 font-semibold text-white hover:bg-fuchsia-500" data-analytics-event="cta_click" data-analytics-content-type="agentstack" data-analytics-content-slug="podcast" data-analytics-content-title="listen to AgentStack Daily">
          Listen to AgentStack Daily <ArrowRight size={17} />
        </a>
      </div>
    </section>
  </main>
</Layout>
