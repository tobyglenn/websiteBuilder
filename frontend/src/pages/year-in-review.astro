---
import Layout from '../layouts/Layout.astro';
import { getYearInReview2025 } from '../data/yearInReview.js';

const yearInReview = getYearInReview2025();
const { garmin, speediance, eightSleep, whoop, combined } = yearInReview;

const pageTitle = "2025 Year In Review | Toby on Fitness Tech";
const pageDescription = "A comprehensive look at 2025 fitness data: running, strength training, sleep, and recovery metrics from Garmin, Speediance, 8Sleep, and WHOOP.";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How many miles did you run in 2025?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `I ran ${garmin.totalMiles} miles across ${garmin.totalRuns} runs in 2025.`
      }
    },
    {
      "@type": "Question",
      "name": "How much volume did you lift on Speediance in 2025?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `I lifted ${speediance.totalVolumeFmt} of volume across ${speediance.totalWorkouts} workouts.`
      }
    },
    {
      "@type": "Question",
      "name": "What was your average sleep score on 8Sleep in 2025?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `My average sleep score was ${eightSleep.avgSleepScore} across ${eightSleep.totalNights} nights tracked.`
      }
    },
    {
      "@type": "Question",
      "name": "What was your average WHOOP recovery in 2025?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `My average recovery score was ${whoop.avgRecovery}% with ${whoop.recoveryRate}% of days in green recovery.`
      }
    }
  ]
};
---

<Layout 
  title={pageTitle} 
  description={pageDescription}
  jsonLd={faqSchema}
>
  <div class="container mx-auto px-4 py-12">
    <!-- Hero Section -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-blue-500/20 text-blue-400 text-sm font-medium rounded-full mb-4">
        2025 Annual Report
      </span>
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-4">
        Year In Review
      </h1>
      <p class="text-xl text-neutral-400 max-w-2xl mx-auto">
        A comprehensive look at my fitness journey across running, strength training, sleep, and recovery.
      </p>
    </div>

    <!-- Combined Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
        <div class="text-3xl md:text-4xl font-bold text-white mb-2">
          {combined.totalWorkouts.toLocaleString()}
        </div>
        <div class="text-neutral-400 text-sm">Total Workouts</div>
        <div class="text-xs text-neutral-500 mt-1">Running + Strength</div>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
        <div class="text-3xl md:text-4xl font-bold text-white mb-2">
          {garmin.totalMiles.toLocaleString()}
        </div>
        <div class="text-neutral-400 text-sm">Miles Run</div>
        <div class="text-xs text-neutral-500 mt-1">{garmin.totalRuns} runs</div>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
        <div class="text-3xl md:text-4xl font-bold text-white mb-2">
          {speediance.totalVolumeFmt}
        </div>
        <div class="text-neutral-400 text-sm">Volume Lifted</div>
        <div class="text-xs text-neutral-500 mt-1">{speediance.totalWorkouts} workouts</div>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
        <div class="text-3xl md:text-4xl font-bold text-white mb-2">
          {eightSleep.avgSleepScore}
        </div>
        <div class="text-neutral-400 text-sm">Avg Sleep Score</div>
        <div class="text-xs text-neutral-500 mt-1">{eightSleep.totalNights} nights</div>
      </div>
    </div>

    <!-- Running Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
        <span class="w-10 h-10 bg-blue-500/20 rounded-xl flex items-center justify-center text-blue-400">🏃</span>
        Running
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{garmin.totalMiles.toLocaleString()}</div>
          <div class="text-neutral-400">Total Miles</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{garmin.totalRuns}</div>
          <div class="text-neutral-400">Total Runs</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{garmin.totalHours}h</div>
          <div class="text-neutral-400">Time Running</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{garmin.avgPace}</div>
          <div class="text-neutral-400">Avg Pace/mi</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{garmin.avgHR}</div>
          <div class="text-neutral-400">Avg HR</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{garmin.totalCalories.toLocaleString()}</div>
          <div class="text-neutral-400">Calories Burned</div>
        </div>
      </div>
      {garmin.longestRun && (
        <div class="mt-4 bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <h3 class="text-lg font-semibold text-white mb-2">Longest Run</h3>
          <p class="text-neutral-300">
            <span class="text-blue-400 font-bold">{garmin.longestRun.miles} miles</span> on {garmin.longestRun.date} 
            (pace: {garmin.longestRun.pace}/mi)
          </p>
        </div>
      )}
    </section>

    <!-- Speediance Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
        <span class="w-10 h-10 bg-blue-500/20 rounded-xl flex items-center justify-center text-blue-400">💪</span>
        Speediance Strength Training
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{speediance.totalVolumeFmt}</div>
          <div class="text-neutral-400">Total Volume</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{speediance.totalWorkouts}</div>
          <div class="text-neutral-400">Total Workouts</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{speediance.totalHours}h</div>
          <div class="text-neutral-400">Time Training</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{speediance.avgVolume.toLocaleString()}</div>
          <div class="text-neutral-400">Avg Volume/Workout</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{speediance.totalCalories.toLocaleString()}</div>
          <div class="text-neutral-400">Calories Burned</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{speediance.highestSession?.volume.toLocaleString() || 0}</div>
          <div class="text-neutral-400">Highest Volume</div>
        </div>
      </div>
      {speediance.topWorkouts.length > 0 && (
        <div class="mt-4 bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <h3 class="text-lg font-semibold text-white mb-4">Top Workouts by Volume</h3>
          <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-4">
            {speediance.topWorkouts.map((workout, i) => (
              <div class="text-center">
                <div class="text-2xl font-bold text-blue-400">#{i + 1}</div>
                <div class="text-white font-medium truncate">{workout.name}</div>
                <div class="text-neutral-400 text-sm">{(workout.volume / 1000).toFixed(0)}K lbs</div>
              </div>
            ))}
          </div>
        </div>
      )}
    </section>

    <!-- Sleep Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
        <span class="w-10 h-10 bg-blue-500/20 rounded-xl flex items-center justify-center text-blue-400">😴</span>
        8Sleep Recovery
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{eightSleep.avgSleepScore}</div>
          <div class="text-neutral-400">Avg Sleep Score</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{eightSleep.avgTotalSleepHrs}h</div>
          <div class="text-neutral-400">Avg Total Sleep</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{eightSleep.totalNights}</div>
          <div class="text-neutral-400">Nights Tracked</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{eightSleep.avgHR}</div>
          <div class="text-neutral-400">Avg Heart Rate</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{eightSleep.avgRHR}</div>
          <div class="text-neutral-400">Avg Resting HR</div>
        </div>
      </div>
    </section>

    <!-- WHOOP Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
        <span class="w-10 h-10 bg-blue-500/20 rounded-xl flex items-center justify-center text-blue-400">💓</span>
        WHOOP Recovery & Strain
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{whoop.avgRecovery}%</div>
          <div class="text-neutral-400">Avg Recovery</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{whoop.avgStrain}</div>
          <div class="text-neutral-400">Avg Strain</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{whoop.avgSleep}h</div>
          <div class="text-neutral-400">Avg Sleep</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{whoop.avgHRV}</div>
          <div class="text-neutral-400">Avg HRV</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{whoop.avgRHR}</div>
          <div class="text-neutral-400">Avg RHR</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{whoop.recoveryRate}%</div>
          <div class="text-neutral-400">Green Recovery Days</div>
        </div>
      </div>
    </section>

    <!-- Navigation Links -->
    <div class="border-t border-neutral-800 pt-12">
      <h3 class="text-xl font-semibold text-white mb-6 text-center">Explore More Stats</h3>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        <a href="/running" class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-blue-500 transition-colors group">
          <div class="text-lg font-semibold text-white group-hover:text-blue-400 transition-colors">Running</div>
          <div class="text-neutral-400 text-sm">Full run log and analytics</div>
        </a>
        <a href="/speediance" class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-blue-500 transition-colors group">
          <div class="text-lg font-semibold text-white group-hover:text-blue-400 transition-colors">Speediance</div>
          <div class="text-neutral-400 text-sm">Strength training data</div>
        </a>
        <a href="/sleep" class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-blue-500 transition-colors group">
          <div class="text-lg font-semibold text-white group-hover:text-blue-400 transition-colors">Sleep</div>
          <div class="text-neutral-400 text-sm">8Sleep analysis</div>
        </a>
        <a href="/whoop" class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-blue-500 transition-colors group">
          <div class="text-lg font-semibold text-white group-hover:text-blue-400 transition-colors">WHOOP</div>
          <div class="text-neutral-400 text-sm">Recovery and strain</div>
        </a>
      </div>
    </div>
  </div>
</Layout>
