---
import Layout from '../../layouts/Layout.astro'; import { getHeartRateData } from '../../data/heartRate.js'; const { stats, monthlyTrends, recentActivities } = getHeartRateData(); function fmtDur(seconds) { if (!seconds || seconds === 0) return '0m'; const h = Math.floor(seconds / 3600); const m = Math.floor((seconds % 3600) / 60); if (h > 0) return `${h}h ${m}m`; return `${m}m`; } const zoneNames = { 1: 'Recuperação', 2: 'Resistência', 3: 'Tempo', 4: 'Limiar', 5: 'VO2 Max' }; const zoneColors = { 1: '#60a5fa', 2: '#4ade80', 3: '#facc15', 4: '#fb923c', 5: '#f87171' }; const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [ { "@type": "Question", "name": "O que significam as zonas de frequência cardíaca?", "acceptedAnswer": { "@type": "Answer", "text": "A zona 1 (Recuperação) é esforço muito leve, a zona 2 (Resistência) é treino aeróbico leve, a zona 3 (Tempo) é treino aeróbico moderado, a zona 4 (Limiar) é treino anaeróbico pesado e a zona 5 (VO2 Max) é esforço máximo para sprints." } }, { "@type": "Question", "name": "O que é efeito aeróbico do treino?", "acceptedAnswer": { "@type": "Answer", "text": "O efeito aeróbico da Garmin mede como seu treino melhora a capacidade do corpo de transportar e usar oxigênio. As pontuações vão de 0,0 a 5,0, em que 1,0–1,9 é aquecimento, 2,0–2,9 é fácil, 3,0–3,9 é aeróbico, 4,0–4,9 é limiar e 5,0 é esforço excessivo." } }, { "@type": "Question", "name": "O que é carga de treino?", "acceptedAnswer": { "@type": "Answer", "text": "A carga de treino mede o estresse total imposto ao corpo durante o exercício. Ela é calculada com base na duração e intensidade dos treinos. A Garmin recomenda permanecer na faixa ideal para evoluir sem entrar em overtraining." } } ] }; const donutW = 280, donutH = 280, donutR = 100, donutThick = 35; const cx = donutW / 2, cy = donutH / 2; function polarToCartesian(cx, cy, r, angleInDegrees) { const angleInRadians = (angleInDegrees - 90) * Math.PI / 180.0; return { x: cx + (r * Math.cos(angleInRadians)), y: cy + (r * Math.sin(angleInRadians)) }; } function describeArc(cx, cy, r, startAngle, endAngle) { const start = polarToCartesian(cx, cy, r, endAngle); const end = polarToCartesian(cx, cy, r, startAngle); const largeArcFlag = endAngle - startAngle <= 180 ? '0' : '1'; return `M ${start.x} ${start.y} A ${r} ${r} 0 ${largeArcFlag} 0 ${end.x} ${end.y}`; } let currentAngle = 0; const zoneArcs = []; for (let z = 1; z <= 5; z++) { const pct = stats.zonePercentages[z]; if (pct > 0) { const angle = (pct / 100) * 360; const path = describeArc(cx, cy, donutR, currentAngle, currentAngle + angle); zoneArcs.push({ z, pct, path, color: zoneColors[z], startAngle: currentAngle, endAngle: currentAngle + angle }); currentAngle += angle; } } const lineW = 600, lineH = 180, padL = 40, padR = 20, padT = 20, padB = 35; const hrValues = monthlyTrends.map(m => m.avgHR).filter(v => v > 0); const minHR = Math.min(...hrValues, 110); const maxHR = Math.max(...hrValues, 170); const yRange = maxHR - minHR; function hrToY(hr) { return lineH - padB - ((hr - minHR) / yRange) * (lineH - padT - padB); } const scaledLinePoints = monthlyTrends.map((m, i) => { const x = padL + (i / Math.max(1, monthlyTrends.length - 1)) * (lineW - padL - padR); const y = hrToY(m.avgHR); return { ...m, x, y }; }); let linePath = ''; scaledLinePoints.forEach((p, i) => { if (p.avgHR > 0) linePath += (i === 0 ? 'M' : 'L') + `${p.x},${p.y}`; });
---
<Layout title="Análise de zonas de frequência cardíaca — TobyOnFitnessTech" description="Acompanhe sua aptidão cardiovascular com uma análise de zonas de frequência cardíaca. Veja o tempo nas zonas 1–5, o efeito aeróbico e as tendências mensais de FC com dados da Garmin." jsonLd={faqSchema}><main class="min-h-screen bg-neutral-950 text-white"><section class="pt-28 pb-14 md:pt-36 md:pb-20 relative overflow-hidden"><div class="absolute inset-0 bg-gradient-to-br from-red-900/10 via-transparent to-transparent pointer-events-none" /><div class="absolute right-0 top-0 w-64 h-64 bg-red-600/5 rounded-full blur-3xl pointer-events-none" /><div class="container mx-auto px-4 relative z-10"><div class="max-w-3xl"><p class="text-xs font-bold tracking-widest text-red-500 uppercase mb-4">Garmin Fenix 7 · Fev 2025 – Fev 2026</p><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-5 leading-tight">Análise de<br /><span class="bg-gradient-to-r from-red-400 to-orange-500 bg-clip-text text-transparent">zonas de frequência cardíaca.</span></h2><p class="text-lg text-neutral-400 leading-relaxed max-w-2xl mb-8">Acompanhe sua aptidão cardiovascular com detalhamentos por zonas de FC. Veja quanto tempo você passa em cada zona e monitore seu progresso aeróbico ao longo do tempo.</p><div class="flex flex-wrap gap-3"><span class="px-4 py-1.5 rounded-full text-xs font-semibold bg-red-600/20 border border-red-500/30 text-red-400">❤️ {stats.totalActivities} atividades</span><span class="px-4 py-1.5 rounded-full text-xs font-semibold bg-neutral-800 border border-neutral-700 text-neutral-400">FC máx: {stats.maxHR} bpm</span></div></div></div></section></main></Layout>
