---
import Layout from '../layouts/Layout.astro';
import { hrZones } from '../data/hrZones.js';

const zones = [
  { name: 'Zona 1 - Recuperação', color: '#60a5fa', key: 'z1', desc: '50-60% FC máx. - Esforço muito leve, recuperação' },
  { name: 'Zona 2 - Aeróbica', color: '#3b82f6', key: 'z2', desc: '60-70% FC máx. - Esforço leve, queima de gordura, base aeróbica' },
  { name: 'Zona 3 - Ritmo', color: '#2563eb', key: 'z3', desc: '70-80% FC máx. - Esforço moderado, resistência aeróbica' },
  { name: 'Zona 4 - Limiar', color: '#1d4ed8', key: 'z4', desc: '80-90% FC máx. - Esforço forte, limiar de lactato' },
  { name: 'Zona 5 - Máxima', color: '#1e40af', key: 'z5', desc: '90-100% FC máx. - Esforço máximo, sprints' },
];
---
<Layout title="Análise das zonas de frequência cardíaca | TobyOnFitnessTech">
  <section class="bg-neutral-950 text-white py-16 px-4 text-center"><h1 class="text-4xl md:text-5xl font-bold">Análise das zonas de frequência cardíaca</h1><p class="mt-4 text-lg text-blue-400 max-w-2xl mx-auto">Acompanhe a distribuição da intensidade das suas corridas em {hrZones.totalRuns} atividades do Garmin</p></section>
  <section class="max-w-6xl mx-auto py-8 px-4"><div class="grid grid-cols-2 md:grid-cols-4 gap-4"><div class="bg-neutral-900 rounded-lg p-6 text-center"><div class="text-3xl font-bold text-blue-500">{hrZones.totalRuns}</div><div class="text-gray-400 text-sm mt-1">Total de corridas</div></div><div class="bg-neutral-900 rounded-lg p-6 text-center"><div class="text-3xl font-bold text-blue-500">{hrZones.avgHR}</div><div class="text-gray-400 text-sm mt-1">FC média (bpm)</div></div><div class="bg-neutral-900 rounded-lg p-6 text-center"><div class="text-3xl font-bold text-blue-500">{hrZones.totalHours}</div><div class="text-gray-400 text-sm mt-1">Horas nas zonas</div></div><div class="bg-neutral-900 rounded-lg p-6 text-center"><div class="text-3xl font-bold text-blue-500">{hrZones.avgDistance.toFixed(1)}</div><div class="text-gray-400 text-sm mt-1">Distância média (km)</div></div></div></section>
  <section class="max-w-4xl mx-auto py-8 px-4"><h2 class="text-2xl font-bold mb-6 text-white">Distribuição por zonas</h2><div class="space-y-4">{zones.map((zone, i) => { const pct = hrZones.zonePercentages[zone.key]; const mins = hrZones.totalTimeInMinutes[zone.key]; return (<div class="bg-neutral-900 rounded-lg p-4"><div class="flex justify-between items-center mb-2"><div><span class="font-semibold text-white">{zone.name}</span><p class="text-gray-500 text-xs">{zone.desc}</p></div><div class="text-right"><span class="text-xl font-bold" style={`color: ${zone.color}`}>{pct}%</span><p class="text-gray-500 text-xs">{mins} min</p></div></div><div class="h-3 bg-neutral-800 rounded-full overflow-hidden"><div class="h-full rounded-full transition-all" style={`width: ${pct}%; background-color: ${zone.color}`}></div></div></div>);})}</div></section>
  <section class="max-w-6xl mx-auto py-8 px-4"><h2 class="text-2xl font-bold mb-6 text-white">Corridas recentes</h2><div class="overflow-x-auto"><table class="min-w-full divide-y divide-neutral-800 text-sm"><thead class="bg-neutral-900"><tr><th class="px-4 py-3 text-left text-gray-400 font-medium">Data</th><th class="px-4 py-3 text-left text-gray-400 font-medium">Distância</th><th class="px-4 py-3 text-left text-gray-400 font-medium">FC média</th><th class="px-4 py-3 text-left text-gray-400 font-medium">Z1</th><th class="px-4 py-3 text-left text-gray-400 font-medium">Z2</th><th class="px-4 py-3 text-left text-gray-400 font-medium">Z3</th><th class="px-4 py-3 text-left text-gray-400 font-medium">Z4</th><th class="px-4 py-3 text-left text-gray-400 font-medium">Z5</th></tr></thead><tbody class="divide-y divide-neutral-800">{hrZones.recentRuns.map((run) => (<tr class="hover:bg-neutral-900"><td class="px-4 py-3 text-white">{run.date?.slice(0, 10)}</td><td class="px-4 py-3 text-white">{run.distance?.toFixed(1)} km</td><td class="px-4 py-3 text-white">{run.avgHR} bpm</td><td class="px-4 py-3 text-blue-400">{run.z1}m</td><td class="px-4 py-3 text-blue-400">{run.z2}m</td><td class="px-4 py-3 text-blue-400">{run.z3}m</td><td class="px-4 py-3 text-blue-400">{run.z4}m</td><td class="px-4 py-3 text-blue-400">{run.z5}m</td></tr>))}</tbody></table></div></section>
  <script type="application/ld+json">{JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"O que são zonas de frequência cardíaca?","acceptedAnswer":{"@type":"Answer","text":"As zonas de frequência cardíaca são faixas que indicam a intensidade do treino, da recuperação (Zona 1) ao esforço máximo (Zona 5)."}},{"@type":"Question","name":"Como esses dados são calculados?","acceptedAnswer":{"@type":"Answer","text":"Os dados são agregados a partir de atividades do Garmin, somando os segundos em cada zona de FC e calculando percentuais."}},{"@type":"Question","name":"O que as zonas significam?","acceptedAnswer":{"@type":"Answer","text":"A Zona 1 é recuperação (50-60% da FC máx.), a Zona 2 é aeróbica (60-70%), a Zona 3 é ritmo (70-80%), a Zona 4 é limiar (80-90%) e a Zona 5 é máxima (90-100%)."}}]})}</script>
</Layout>