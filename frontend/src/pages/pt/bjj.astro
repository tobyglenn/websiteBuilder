---
import Layout from '../../layouts/Layout.astro';
import { CANONICAL_BLOG_POSTS } from '../../lib/blogPosts';
import { ArrowRight } from 'lucide-react';

function readTime(content = '') {
  const words = content.split(/\s+/).filter(Boolean).length;
  return `${Math.max(1, Math.round(words / 200))} min de leitura`;
}

function formatBlogDate(value) {
  const timestamp = Date.parse(value || '');
  if (Number.isNaN(timestamp)) return 'Sem data';
  return new Date(timestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

// Filter blog posts related to BJJ
const bjjPosts = CANONICAL_BLOG_POSTS.filter(post => {
  const category = post.category?.toLowerCase() || '';
  const tags = post.tags?.map(t => t.toLowerCase()) || [];
  const title = post.title?.toLowerCase() || '';
  const excerpt = post.excerpt?.toLowerCase() || '';
  
  return category === 'bjj' || 
    tags.some(tag => tag === 'bjj' || tag === 'jiu-jitsu' || tag === 'jiu jitsu') ||
    title.includes('bjj') || title.includes('jiu-jitsu') || title.includes('jiu jitsu') ||
    excerpt.includes('bjj') || excerpt.includes('jiu-jitsu') || excerpt.includes('jiu jitsu');
}).slice(0, 6);

const totalBjjPosts = CANONICAL_BLOG_POSTS.filter(post => {
  const category = post.category?.toLowerCase() || '';
  const tags = post.tags?.map(t => t.toLowerCase()) || [];
  const title = post.title?.toLowerCase() || '';
  const excerpt = post.excerpt?.toLowerCase() || '';
  
  return category === 'bjj' || 
    tags.some(tag => tag === 'bjj' || tag === 'jiu-jitsu' || tag === 'jiu jitsu') ||
    title.includes('bjj') || title.includes('jiu-jitsu') || title.includes('jiu jitsu') ||
    excerpt.includes('bjj') || excerpt.includes('jiu-jitsu') || excerpt.includes('jiu jitsu');
}).length;

// BJJ Stats
const stats = {
  rank: "Faixa Marrom",
  startedYear: 2023,
  competitions: 1,
  bjjDaysPerWeek: "2-3"
};

// Journey timeline data from /about page
const journeyTimeline = [
  {
    year: "2023",
    title: "Início da jornada no BJJ",
    description: "Começou no Brazilian Jiu-Jitsu como parte de uma transformação de 242→188 lb. Usou o BJJ tanto como válvula de escape física quanto como âncora mental durante a jornada de perda de peso.",
    highlight: true
  },
  {
    year: "2023",
    title: "Faixa Branca",
    description: "Aprendeu fundamentos, hierarquia posicional e finalizações básicas. Foco em sobrevivência e em ficar confortável na guarda.",
    highlight: false
  },
  {
    year: "2024",
    title: "Faixa Azul",
    description: "Promovido a faixa azul. Começou a desenvolver um jogo de guarda mais sofisticado e a competir regularmente.",
    highlight: false
  },
  {
    year: "2024-2025",
    title: "Faixa Roxa",
    description: "Fase intermediária de faixa. Continuou refinando as técnicas enquanto equilibrava com treino de força.",
    highlight: false
  },
  {
    year: "2025",
    title: "Promovido a faixa marrom",
    description: "Conquistou a faixa marrom em um torneio regional com um terceiro lugar e uma finalização de triângulo invertido.",
    highlight: true
  },
  {
    year: "Atual",
    title: "Faixa Marrom - Atual",
    description: "Treinando 2-3x por semana em uma academia dedicada ao BJJ. Foco em retenção de guarda, finalizações e em manter o condicionamento enquanto constrói força.",
    highlight: true
  }
];

// BJJ Philosophy
const philosophy = [
  {
    icon: "🛡️",
    title: "Segurança em primeiro lugar",
    description: "Priorizo a prevenção de lesões acima de vencer rolas. BJJ é uma prática para a vida toda — proteger você mesmo e seus parceiros de treino vem antes de qualquer finalização."
  },
  {
    icon: "🔄",
    title: "Processo acima dos resultados",
    description: "Focar em melhorar em vez de vencer rolas leva a um progresso mais rápido. A faixa vem como subproduto da dedicação à arte."
  },
  {
    icon: "⏳",
    title: "Mentalidade de longevidade",
    description: "Treinar com inteligência hoje significa treinar por décadas. Ajusto a intensidade com base na recuperação e escuto meus dados do WHOOP."
  },
  {
    icon: "🧠",
    title: "Técnica acima do atletismo",
    description: "O BJJ recompensa a técnica acima da força bruta. Mesmo sendo um praticante maior, alavanca e posicionamento corretos vencem a força toda vez."
  }
];

// Notable moments
const notableMoments = [
  { year: "2023", event: "Começou no BJJ - 242 lbs" },
  { year: "2023", event: "Transformação de 54 lb concluída - 188 lbs" },
  { year: "2025", event: "Promoção para faixa marrom" },
  { year: "2025", event: "3º lugar em torneio regional - triângulo invertido" }
];

// JSON-LD Schema
const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Brazilian Jiu-Jitsu - Toby no Fitness Tech",
  "description": "Acompanhe a jornada de Toby no BJJ: começou em 2023, faixa marrom, competiu em torneios regionais, treinando 2-3x por semana. Filosofia de treino, lições aprendidas e progressão.",
  "url": "https://tobyonfitnesstech.com/bjj",
  "inLanguage": "en",
  "isPartOf": {
    "@id": "https://tobyonfitnesstech.com/#website"
  },
  "about": {
    "@type": "Person",
    "name": "Toby Peters",
    "description": "Faixa marrom em Brazilian Jiu-Jitsu, treinando desde 2023"
  },
  "keywords": "BJJ, Brazilian Jiu-Jitsu, jiu-jitsu, faixa marrom, grappling, artes marciais, treino, competição"
};
---

<Layout
  title="Brazilian Jiu-Jitsu - Jornada da faixa marrom | Toby no Fitness Tech"
  description="Acompanhe a jornada de Toby no BJJ: começou em 2023, faixa marrom, competiu em torneios regionais, treinando 2-3x por semana. Filosofia de treino, lições aprendidas e progressão."
  jsonLd={webPageSchema}
>
  <main class="min-h-screen bg-neutral-950 text-white">
    
    {/* ── Hero Section ─────────────────────────────────────────────────────── */}
    <section class="pt-28 pb-14 md:pt-36 md:pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-blue-900/10 via-transparent to-transparent pointer-events-none" />
      <div class="absolute right-0 top-0 w-72 h-72 bg-blue-600/5 rounded-full blur-3xl pointer-events-none" />
      <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-3xl">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-4">🥋 Brazilian Jiu-Jitsu</p>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
            Brazilian<br />
            <span class="text-blue-500">Jiu-Jitsu</span>
          </h2>
          <p class="text-xl text-neutral-400 mb-10 leading-relaxed max-w-2xl">
            Começou em 2023. Faixa marrom. Competiu em torneios regionais.
            A jornada técnica de usar técnica acima da força bruta, com foco em segurança e longevidade.
          </p>

          {/* Belt Display */}
          <div class="flex items-center gap-3 mb-8">
            <div class="text-4xl">🥋</div>
            <div>
              <div class="text-2xl font-bold text-white">{stats.rank}</div>
              <div class="text-sm text-neutral-400">Graduação atual</div>
            </div>
          </div>

          {/* Stat pills */}
          <div class="flex flex-wrap gap-3">
            <div class="flex items-center gap-2 bg-neutral-900 border border-neutral-800 rounded-full px-4 py-2">
              <span class="w-3 h-3 rounded-full bg-blue-500 inline-block flex-shrink-0"></span>
              <span class="text-sm font-semibold text-white">{stats.rank}</span>
            </div>
            <div class="flex items-center gap-2 bg-neutral-900 border border-neutral-800 rounded-full px-4 py-2">
              <span class="text-sm font-semibold text-white">Começou em {stats.startedYear}</span>
            </div>
            <div class="flex items-center gap-2 bg-neutral-900 border border-neutral-800 rounded-full px-4 py-2">
              <span class="text-sm font-semibold text-white">{stats.competitions} competição</span>
            </div>
            <div class="flex items-center gap-2 bg-neutral-900 border border-neutral-800 rounded-full px-4 py-2">
              <span class="text-sm font-semibold text-white">{stats.bjjDaysPerWeek}x / semana</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ── Stats Cards Row ─────────────────────────────────────────────────── */}
    <section class="py-12 bg-neutral-900/40 border-y border-neutral-800">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-colors text-center">
            <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-2">{stats.rank}</div>
            <div class="text-sm font-semibold text-neutral-400 uppercase tracking-wide">FAIXA ATUAL</div>
          </div>
          <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-colors text-center">
            <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-2">{stats.startedYear}</div>
            <div class="text-sm font-semibold text-neutral-400 uppercase tracking-wide">TREINANDO DESDE</div>
          </div>
          <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-colors text-center">
            <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-2">{totalBjjPosts}</div>
            <div class="text-sm font-semibold text-neutral-400 uppercase tracking-wide">POSTS DE BJJ</div>
          </div>
          <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-colors text-center">
            <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-2">3º</div>
            <div class="text-sm font-semibold text-neutral-400 uppercase tracking-wide">MELHOR COLOCAÇÃO</div>
          </div>
        </div>
      </div>
    </section>

    {/* ── Notable Moments ───────────────────────────────────────────────────── */}
    <section class="py-12 bg-neutral-900/20">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-4">Momentos marcantes</p>
          <div class="flex flex-wrap gap-4">
            {notableMoments.map(moment => (
              <div class="flex items-center gap-2 bg-neutral-900 border border-neutral-800 rounded-full px-4 py-2">
                <span class="text-xs font-bold text-blue-400">{moment.year}</span>
                <span class="text-sm text-neutral-300">{moment.event}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* ── Journey Timeline Section ────────────────────────────────────────── */}
    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-2">A jornada</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-10">Progressão no BJJ</h2>

          <div class="space-y-0">
            {journeyTimeline.map((entry, i) => (
              <div class="relative flex gap-6 md:gap-10">
                {/* Vertical line + belt dot */}
                <div class="flex flex-col items-center flex-shrink-0 w-10">
                  <div
                    class={`w-5 h-5 rounded-full border-4 border-neutral-950 flex-shrink-0 mt-1 ${entry.highlight ? 'ring-2 ring-blue-500 ring-offset-2 ring-offset-neutral-950' : ''}`}
                    style={`background-color: ${entry.highlight ? '#3b82f6' : '#4b5563'};`}
                  />
                  {i < journeyTimeline.length - 1 && (
                    <div class="flex-1 w-0.5 bg-neutral-800 mt-1 mb-0 min-h-[60px]" />
                  )}
                </div>

                {/* Content card */}
                <div class={`pb-8 flex-1 ${entry.highlight ? 'border border-blue-700/40 bg-blue-900/5 rounded-xl p-5 -mt-1' : ''}`}>
                  <div class="flex items-center gap-3 mb-1 flex-wrap">
                    <span class="text-xs font-bold uppercase tracking-wider px-2.5 py-0.5 rounded-full bg-blue-500/20 text-blue-400">
                      {entry.year}
                    </span>
                    {entry.highlight && (
                      <span class="text-xs bg-blue-500/20 text-blue-400 px-2 py-0.5 rounded-full font-semibold">Marco</span>
                    )}
                  </div>
                  <h3 class="text-lg font-bold text-white mb-2">{entry.title}</h3>
                  <p class="text-sm text-neutral-400 leading-relaxed">{entry.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* ── Training Schedule ────────────────────────────────────────────────── */}
    <section class="py-16 md:py-20 bg-neutral-900/40 border-y border-neutral-800">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-2">Treino</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Agenda de treino de BJJ</h2>
          <p class="text-neutral-400 mb-8 leading-relaxed max-w-2xl">
            Eu treino BJJ 2-3 vezes por semana em uma academia dedicada ao BJJ. Cada sessão inclui trabalho técnico, drills posicionais e sparring ao vivo (rolling). 
            Meu treino tem prioridade número três na minha hierarquia fitness: <span class="text-blue-400 font-semibold">Corrida &gt; Musculação &gt; BJJ</span>
          </p>
          
          <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
              <div>
                <div class="text-2xl font-bold text-blue-400">2-3x</div>
                <div class="text-sm text-neutral-400">por semana</div>
              </div>
              <div>
                <div class="text-2xl font-bold text-blue-400">Gi & No-Gi</div>
                <div class="text-sm text-neutral-400">estilos</div>
              </div>
              <div>
                <div class="text-2xl font-bold text-blue-400">Técnica</div>
                <div class="text-sm text-neutral-400">+ Rolling</div>
              </div>
              <div>
                <div class="text-2xl font-bold text-blue-400">242</div>
                <div class="text-sm text-neutral-400">sessões registradas</div>
              </div>
            </div>
          </div>

          <div class="mt-6 text-center">
            <a 
              href="/training/" 
              class="inline-flex items-center gap-2 text-sm text-blue-500 hover:text-blue-400 transition-colors font-medium"
            >
              Ver semana completa de treino
              <ArrowRight size={16} />
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* ── BJJ Philosophy Section ────────────────────────────────────────────── */}
    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-2">Filosofia</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-10">Abordagem ao Jiu-Jitsu</h2>

          <div class="grid md:grid-cols-2 gap-4">
            {philosophy.map(item => (
              <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-blue-500/40 transition-colors">
                <div class="text-3xl mb-4">{item.icon}</div>
                <h3 class="font-bold text-white mb-3">{item.title}</h3>
                <p class="text-sm text-neutral-400 leading-relaxed">{item.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* ── Related Blog Posts ───────────────────────────────────────────────── */}
    {bjjPosts.length > 0 && (
      <section class="py-16 md:py-20 bg-neutral-900/40 border-y border-neutral-800">
        <div class="container mx-auto px-4">
          <div class="max-w-4xl mx-auto">
            <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-2">Leia mais</p>
            <h2 class="text-3xl md:text-4xl font-bold mb-4">Posts em destaque sobre BJJ</h2>
            <p class="text-neutral-400 mb-10 max-w-xl">
              Reflexões sobre treino de BJJ, técnica, segurança e a jornada nas artes marciais.
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
              {bjjPosts.map((post) => (
                <a href={`/blog/${post.slug}/`} class="group block bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden hover:border-blue-500/50 transition-all">
                  {post.image && (
                    <div class="aspect-video overflow-hidden bg-neutral-950">
                      <img
                        src={post.image}
                        alt={post.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        loading="lazy"
                      />
                    </div>
                  )}
                  <div class="p-5">
                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold uppercase tracking-wide bg-blue-500/10 text-blue-400 border border-blue-500/20">
                      {post.category || 'BJJ'}
                    </span>
                    <h3 class="mt-3 text-lg font-bold text-white leading-snug group-hover:text-blue-400 transition-colors line-clamp-2">
                      {post.title}
                    </h3>
                    <div class="mt-2 text-xs text-neutral-500 flex items-center gap-2">
                      <span>{formatBlogDate(post.published_at)}</span>
                      <span>•</span>
                      <span>{readTime(post.content)}</span>
                    </div>
                    <p class="mt-3 text-sm text-neutral-400 leading-relaxed line-clamp-2">
                      {post.excerpt}
                    </p>
                  </div>
                </a>
              ))}
            </div>

            <div class="mt-8 text-center">
              <a 
                href="/blog/" 
                class="inline-flex items-center gap-2 text-sm text-blue-500 hover:text-blue-400 transition-colors font-medium"
              >
                Ver todos os posts do blog
                <ArrowRight size={16} />
              </a>
            </div>
          </div>
        </div>
      </section>
    )}

    {/* ── Resources Section ────────────────────────────────────────────────── */}
    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-4">Continue explorando</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Páginas relacionadas</h2>
          <p class="text-neutral-400 mb-8 leading-relaxed max-w-xl mx-auto">
            Explore o dashboard completo de treino, a linha do tempo e outros conteúdos de fitness.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a
              href="/training/"
              class="px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-semibold transition-colors text-sm"
            >
              Dashboard de treino
            </a>
            <a
              href="/timeline/"
              class="px-6 py-3 bg-neutral-800 hover:bg-neutral-700 text-white rounded-xl font-semibold transition-colors text-sm border border-neutral-700"
            >
              Linha do tempo
            </a>
            <a
              href="/running/"
              class="px-6 py-3 bg-neutral-800 hover:bg-neutral-700 text-white rounded-xl font-semibold transition-colors text-sm border border-neutral-700"
            >
              Estatísticas de corrida
            </a>
            <a
              href="/whoop/"
              class="px-6 py-3 bg-neutral-800 hover:bg-neutral-700 text-white rounded-xl font-semibold transition-colors text-sm border border-neutral-700"
            >
              Dados do WHOOP
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>
