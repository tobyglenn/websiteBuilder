---
import Layout from '../layouts/Layout.astro';

const siteUrl = "https://tobyonfitnesstech.com";

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": `${siteUrl}/contact/#contactpage`,
  "name": "Entrar em contato com Toby Glenn Peters",
  "description": "Entre em contato com Toby Glenn Peters para patrocínios, consultoria, colaborações ou perguntas sobre tecnologia fitness.",
  "url": `${siteUrl}/contact/`,
  "inLanguage": "pt-BR",
  "isPartOf": { "@id": `${siteUrl}/#website` },
  "about": { "@id": `${siteUrl}/#toby` },
  "mainEntity": {
    "@type": "Person",
    "@id": `${siteUrl}/#toby`,
    "name": "Toby Glenn Peters",
    "alternateName": "TobyOnFitnessTech",
    "email": "toby@tobyonfitness.tech",
    "url": siteUrl,
    "sameAs": [
      "https://www.youtube.com/@tobyonfitness",
      "https://www.instagram.com/tobyonfitness"
    ]
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Início", "item": siteUrl },
      { "@type": "ListItem", "position": 2, "name": "Contato", "item": `${siteUrl}/contact/` }
    ]
  }
};

const faqs = [
  {
    q: "Você vende programas de coaching ou planos personalizados?",
    a: "Não. Eu documento o que funciona para mim e compartilho publicamente — só isso. Não vendo programas, planos alimentares nem coaching individual. Tudo o que eu faço está no YouTube e neste site, de graça."
  },
  {
    q: "Posso te perguntar sobre minha configuração de Speediance ou tecnologia fitness?",
    a: "Sim — é para isso que estou aqui. Me envie um e-mail com detalhes específicos. Vou responder se tiver algo útil para acrescentar. Se for uma pergunta comum, isso pode virar um vídeo ou post de blog."
  },
  {
    q: "Você aceita patrocínios?",
    a: "Seletivamente. Eu só trabalho com produtos que realmente uso. Se você está entrando em contato sobre Speediance, WHOOP, Garmin, 8Sleep ou tecnologia fitness parecida — estou ouvindo. Abordagens frias sobre whey e suplementos geralmente não levam a lugar nenhum."
  },
  {
    q: "Você está disponível para consultoria sobre stacks de tecnologia fitness ou automação?",
    a: "Às vezes. Se você é uma empresa ou pessoa querendo construir sistemas de treino orientados por dados — especialmente envolvendo OpenClaw, equipamentos de academia em casa ou integração com wearables — entre em contato. Vou te dizer com honestidade se posso ajudar."
  },
  {
    q: "Quanto tempo demora para receber uma resposta?",
    a: "Normalmente em alguns dias. Sou uma pessoa só, com uma agenda cheia de treinos e um trabalho diário. Eu leio tudo — só não respondo rápido."
  },
  {
    q: "Posso colaborar em conteúdo ou cocriar alguma coisa?",
    a: "Talvez. Me diga o que você está construindo e por que acha que combina. Não estou querendo inflar meu calendário de uploads — mas um projeto genuinamente interessante? Estou aberto."
  }
];
---

<Layout
  title="Contato — TobyOnFitnessTech"
  description="Entre em contato com Toby Glenn Peters para patrocínios, consultoria, perguntas sobre tecnologia fitness ou colaborações."
  breadcrumbs={[{ name: "Início", url: "/" }, { name: "Contato", url: "/contact" }]}
  jsonLd={contactPageSchema}
>
  <main class="min-h-screen bg-neutral-950 text-white">

    {/* Hero */}
    <section class="pt-20 pb-12 md:pt-28 md:pb-16 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-blue-900/10 to-transparent pointer-events-none" />
      <div class="container mx-auto px-4 relative z-10 max-w-4xl">
        <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-4">Contato</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Entre em contato
        </h1>
        <p class="text-xl text-neutral-400 max-w-2xl leading-relaxed">
          Não sou difícil de encontrar. Só sou seletivo com aquilo ao que digo sim. Se você tem algo real para discutir, vou responder.
        </p>
      </div>
    </section>

    {/* Contact + Social */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="grid md:grid-cols-2 gap-8">

          {/* Email Card */}
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-xl bg-blue-600/20 border border-blue-500/30 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <h2 class="text-xl font-bold text-white">E-mail</h2>
                <p class="text-neutral-500 text-sm">Melhor forma de falar comigo</p>
              </div>
            </div>
            <a
              href="mailto:toby@tobyonfitness.tech"
              class="text-blue-400 hover:text-blue-300 font-mono text-lg font-semibold transition-colors"
            >
              toby@tobyonfitness.tech
            </a>
            <p class="text-neutral-500 text-sm mt-4 leading-relaxed">
              Eu leio todos os e-mails. Respondo quando tenho algo útil para dizer — normalmente em alguns dias.
            </p>
          </div>

          {/* Social Links */}
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8">
            <h2 class="text-xl font-bold text-white mb-6">Acompanhe</h2>
            <div class="space-y-4">
              <a
                href="https://www.youtube.com/@tobyonfitness"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-4 p-4 rounded-xl bg-neutral-950 border border-neutral-800 hover:border-red-500/40 hover:bg-red-950/10 transition-all group"
              >
                <div class="w-10 h-10 rounded-lg bg-red-600/20 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#ef4444"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.54C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon fill="white" points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
                </div>
                <div>
                  <div class="text-white font-semibold group-hover:text-red-400 transition-colors">YouTube</div>
                  <div class="text-neutral-500 text-sm">@tobyonfitness</div>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-auto text-neutral-700 group-hover:text-neutral-400 transition-colors"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>

              <a
                href="https://www.instagram.com/tobyonfitness"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-4 p-4 rounded-xl bg-neutral-950 border border-neutral-800 hover:border-pink-500/40 hover:bg-pink-950/10 transition-all group"
              >
                <div class="w-10 h-10 rounded-lg bg-pink-600/20 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ec4899" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
                </div>
                <div>
                  <div class="text-white font-semibold group-hover:text-pink-400 transition-colors">Instagram</div>
                  <div class="text-neutral-500 text-sm">@tobyonfitness</div>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-auto text-neutral-700 group-hover:text-neutral-400 transition-colors"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    {/* What to Expect */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-5xl">
        <h2 class="text-3xl font-bold text-white mb-3">Ao que eu realmente respondo</h2>
        <p class="text-neutral-500 mb-10">Sem enrolação. Eis o que vale a pena mandar por e-mail:</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">🤝</div>
            <h3 class="text-lg font-bold text-white mb-2">Patrocínios</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              Só tecnologia fitness — equipamentos que eu realmente usaria. Território de Speediance, WHOOP, Garmin, 8Sleep. Não tenho interesse em suplementos que nunca testei.
            </p>
          </div>

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">🔧</div>
            <h3 class="text-lg font-bold text-white mb-2">Consultoria</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              Está montando uma stack fitness orientada por dados? Automatizando decisões de treino com dados de wearables? Isso é interessante. Vamos falar de escopo primeiro.
            </p>
          </div>

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">❓</div>
            <h3 class="text-lg font-bold text-white mb-2">Perguntas</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              Perguntas genuínas sobre Speediance, WHOOP, BJJ ou minha abordagem de treino são bem-vindas. Se for uma pergunta que eu não consigo responder rapidamente, eu vou dizer isso.
            </p>
          </div>

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">🎬</div>
            <h3 class="text-lg font-bold text-white mb-2">Colaborações</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              Se você está construindo algo no espaço de tecnologia fitness ou automação e isso realmente combina — estou aberto. Me apresente a ideia.
            </p>
          </div>

        </div>
      </div>
    </section>

    {/* Response Expectations */}
    <section class="py-12 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="bg-neutral-900/50 border border-neutral-800 rounded-2xl p-8 flex flex-col md:flex-row items-start gap-6">
          <div class="text-4xl flex-shrink-0">⏱️</div>
          <div>
            <h3 class="text-xl font-bold text-white mb-2">Tempo de resposta</h3>
            <p class="text-neutral-400 leading-relaxed">
              Sou uma pessoa só. Eu treino às 6:30 da manhã, trabalho o dia inteiro e faço BJJ na maioria das noites. Eu leio tudo — mas respondo quando tenho algo útil para dizer, não só para confirmar recebimento. Espere alguns dias antes de insistir.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* FAQ */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-4xl">
        <h2 class="text-3xl font-bold text-white mb-3">Perguntas frequentes</h2>
        <p class="text-neutral-500 mb-10">Confira aqui antes de mandar e-mail — sua resposta talvez já esteja aqui.</p>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-neutral-700 transition-all">
              <h3 class="text-white font-semibold mb-3 flex items-start gap-3">
                <span class="text-blue-500 font-bold flex-shrink-0">P:</span>
                {faq.q}
              </h3>
              <p class="text-neutral-400 leading-relaxed pl-6">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* CTA */}
    <section class="py-24 border-t border-neutral-900">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-4">Pronto para entrar em contato?</h2>
        <p class="text-neutral-400 mb-8 max-w-xl mx-auto">
          Me mande uma mensagem. Seja específico e eu realmente vou responder.
        </p>
        <a
          href="mailto:toby@tobyonfitness.tech"
          class="inline-flex items-center gap-2 px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-full transition-all hover:scale-105"
        >
          Enviar e-mail para Toby
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
      </div>
    </section>

  </main>
</Layout>
