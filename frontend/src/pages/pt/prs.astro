---
import Layout from '../../layouts/Layout.astro';

const siteUrl = "https://tobyonfitnesstech.com";

// Dados de PR extraídos do painel da Speediance
const prsByMuscle = {
  "Costas e dorsais": [
    { name: "Levantamento terra com barra", weight: 388, unit: "lbs" },
    { name: "Puxada na barra ajoelhado", weight: 294, unit: "lbs" },
    { name: "Puxada na barra com pegada invertida ajoelhado", weight: 280, unit: "lbs" },
    { name: "Puxada na barra com pegada invertida sentado", weight: 248, unit: "lbs" },
    { name: "Remada aberta com barra sentado", weight: 202, unit: "lbs" },
    { name: "Remada curvada com barra", weight: 198, unit: "lbs" },
    { name: "Puxada na barra sentado", weight: 192, unit: "lbs" },
    { name: "Remada com barra sentado", weight: 192, unit: "lbs" },
    { name: "Remada com barra em pegada invertida sentado", weight: 170, unit: "lbs" },
    { name: "Pushdown inclinado com braços retos", weight: 168, unit: "lbs" },
    { name: "Remada unilateral meio ajoelhado (L)", weight: 161, unit: "lbs" },
    { name: "Puxada unilateral ajoelhado (L)", weight: 160, unit: "lbs" },
    { name: "Puxada unilateral ajoelhado (R)", weight: 146, unit: "lbs" },
    { name: "Remada unilateral meio ajoelhado (R)", weight: 140, unit: "lbs" },
    { name: "Remada curvada com barra em pegada invertida", weight: 126, unit: "lbs" },
    { name: "Puxada ajoelhado com dupla empunhadura", weight: 125, unit: "lbs" },
  ],
  "Peito e tríceps": [
    { name: "Supino reto com barra", weight: 232, unit: "lbs" },
    { name: "Supino inclinado com barra", weight: 185, unit: "lbs" },
    { name: "Pushdown de tríceps em pé com barra", weight: 170, unit: "lbs" },
  ],
  "Pernas e glúteos": [
    { name: "Hip thrust com barra", weight: 240, unit: "lbs" },
    { name: "Agachamento dividido com barra (L)", weight: 144, unit: "lbs" },
    { name: "Agachamento dividido com barra (R)", weight: 144, unit: "lbs" },
    { name: "Levantamento terra romeno com barra", weight: 140, unit: "lbs" },
  ],
  "Core e braços": [
    { name: "Woodchops em pé de cima para baixo (R)", weight: 170, unit: "lbs" },
    { name: "Woodchops em pé de cima para baixo (L)", weight: 134, unit: "lbs" },
  ],
};

const allPRs = [
  { name: "Levantamento terra com barra", weight: 388, muscle: "Costas e dorsais" },
  { name: "Puxada na barra ajoelhado", weight: 294, muscle: "Costas e dorsais" },
  { name: "Puxada na barra com pegada invertida ajoelhado", weight: 280, muscle: "Costas e dorsais" },
  { name: "Puxada na barra com pegada invertida sentado", weight: 248, muscle: "Costas e dorsais" },
  { name: "Hip thrust com barra", weight: 240, muscle: "Pernas e glúteos" },
  { name: "Supino reto com barra", weight: 232, muscle: "Peito e tríceps" },
  { name: "Remada aberta com barra sentado", weight: 202, muscle: "Costas e dorsais" },
  { name: "Remada curvada com barra", weight: 198, muscle: "Costas e dorsais" },
  { name: "Puxada na barra sentado", weight: 192, muscle: "Costas e dorsais" },
  { name: "Remada com barra sentado", weight: 192, muscle: "Costas e dorsais" },
  { name: "Supino inclinado com barra", weight: 185, muscle: "Peito e tríceps" },
  { name: "Remada com barra em pegada invertida sentado", weight: 170, muscle: "Costas e dorsais" },
  { name: "Pushdown de tríceps em pé com barra", weight: 170, muscle: "Peito e tríceps" },
  { name: "Woodchops em pé de cima para baixo (R)", weight: 170, muscle: "Core e braços" },
  { name: "Pushdown inclinado com braços retos", weight: 168, muscle: "Costas e dorsais" },
];

const totalPRVolume = allPRs.reduce((sum, pr) => sum + pr.weight, 0);
const totalPRs = allPRs.length;

const profilePageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${siteUrl}/pt/prs#collection`,
  "name": "Painel de PR - Toby on Fitness Tech",
  "description": `Recordes pessoais do treino com Speediance: ${totalPRs} PRs somando ${totalPRVolume} lbs. Levantamento terra de 388 lbs, supino de 232 lbs e mais.`,
  "url": `${siteUrl}/pt/prs`,
  "inLanguage": "pt",
  "isPartOf": { "@id": `${siteUrl}/#website` },
  "author": { "@id": `${siteUrl}/#toby` },
  "publisher": { "@id": `${siteUrl}/#organization` },
  "mainEntity": {
    "@type": "ItemList",
    "name": "Recordes pessoais da Speediance",
    "numberOfItems": totalPRs,
    "itemListElement": allPRs.map((pr, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "name": pr.name,
      "description": `${pr.weight} lbs - ${pr.muscle}`
    }))
  }
};
---

<Layout 
  title="Painel de PR - Toby on Fitness Tech"
  description={`Recordes pessoais do treino com Speediance: ${totalPRs} PRs somando ${totalPRVolume} lbs. Levantamento terra de 388 lbs, supino de 232 lbs e mais dados reais de mais de 125 treinos.`}
  breadcrumbs={[{ name: "Início", url: "/pt/" }, { name: "Painel de PR", url: "/pt/prs" }]}
  jsonLd={profilePageSchema}
>
  <main class="min-h-screen bg-neutral-950 text-white">
    <section class="pt-20 pb-16 md:pt-28 md:pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-blue-900/10 to-transparent pointer-events-none" />
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <span class="inline-flex items-center gap-2 bg-yellow-900/30 border border-yellow-500/30 px-4 py-1.5 rounded-full text-yellow-300 text-sm font-semibold mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-yellow-400"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
            Painel de PR
          </span>
          <h1 class="text-4xl md:text-6xl font-bold mb-6 leading-tight">
            Números não mentem.
          </h1>
          <p class="text-xl text-neutral-400 max-w-2xl mx-auto leading-relaxed mb-10">
            {totalPRs} recordes pessoais ao longo de {totalPRVolume.toLocaleString()} lbs de peso total. 
            Cada repetição rastreada, cada PR registrado. É assim que {totalPRVolume.toLocaleString()} lbs de sobrecarga progressiva se parecem.
          </p>
          
          <div class="grid grid-cols-3 gap-4 max-w-lg mx-auto">
            <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-4">
              <div class="text-2xl md:text-3xl font-black text-yellow-400">{totalPRs}</div>
              <div class="text-xs text-neutral-500 uppercase tracking-wider">PRs totais</div>
            </div>
            <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-4">
              <div class="text-2xl md:text-3xl font-black text-yellow-400">{totalPRVolume.toLocaleString()}</div>
              <div class="text-xs text-neutral-500 uppercase tracking-wider">Lbs totais</div>
            </div>
            <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-4">
              <div class="text-2xl md:text-3xl font-black text-yellow-400">388</div>
              <div class="text-xs text-neutral-500 uppercase tracking-wider">Mais pesado</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-12 bg-gradient-to-b from-neutral-950 to-neutral-900 border-t border-neutral-800">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-2xl font-bold mb-8 flex items-center gap-3">
            <span class="w-8 h-8 bg-yellow-500 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="black"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
            </span>
            Hall da fama
          </h2>
          
          <div class="space-y-4">
            {allPRs.slice(0, 5).map((pr, index) => (
              <div class={`flex items-center gap-4 p-5 rounded-2xl border transition-all hover:scale-[1.01] ${
                index === 0 ? 'bg-gradient-to-r from-yellow-900/30 to-neutral-900 border-yellow-500/30' :
                index === 1 ? 'bg-neutral-900 border-neutral-700' :
                index === 2 ? 'bg-neutral-900 border-neutral-700' :
                'bg-neutral-900 border-neutral-800'
              }`}>
                <div class={`w-10 h-10 rounded-full flex items-center justify-center font-black text-lg ${
                  index === 0 ? 'bg-yellow-500 text-black' :
                  index === 1 ? 'bg-neutral-400 text-black' :
                  index === 2 ? 'bg-amber-700 text-white' :
                  'bg-neutral-800 text-neutral-400'
                }`}>
                  {index + 1}
                </div>
                <div class="flex-1">
                  <div class="font-bold text-white text-lg">{pr.name}</div>
                  <div class="text-sm text-neutral-500">{pr.muscle}</div>
                </div>
                <div class="text-right">
                  <div class="text-2xl md:text-3xl font-black text-white">{pr.weight}</div>
                  <div class="text-xs text-neutral-500 uppercase tracking-wider">lbs</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-neutral-900 border-t border-neutral-800">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-bold mb-10 text-center">Todos os recordes por grupo muscular</h2>
          
          <div class="space-y-12">
            {Object.entries(prsByMuscle).map(([muscle, prs]) => (
              <div>
                <h3 class="text-lg font-bold text-blue-400 mb-4 flex items-center gap-2">
                  <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                  {muscle}
                </h3>
                <div class="grid gap-3">
                  {prs.map((pr, index) => (
                    <div class="flex items-center justify-between p-4 bg-neutral-950 rounded-xl border border-neutral-800 hover:border-neutral-700 transition-colors">
                      <div class="flex items-center gap-4">
                        <span class="text-neutral-600 font-mono text-sm w-6">{index + 1}</span>
                        <span class="font-medium text-white">{pr.name}</span>
                      </div>
                      <div class="flex items-center gap-2">
                        <span class="text-xl font-bold text-white">{pr.weight}</span>
                        <span class="text-neutral-500 text-sm">{pr.unit}</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="py-12 border-t border-neutral-800">
      <div class="container mx-auto px-4">
        <div class="max-w-2xl mx-auto text-center">
          <p class="text-neutral-500 text-sm">
            Todos os PRs registrados no <strong class="text-white">Speediance Gym Monster 2S</strong> desde julho de 2025. 
            Volume total: <strong class="text-white">1,296,447 lbs</strong> em <strong class="text-white">125+ treinos</strong>.
          </p>
          <div class="mt-6 flex flex-wrap justify-center gap-3">
            <a href="/pt/speediance/" class="text-blue-400 hover:text-blue-300 text-sm font-medium">Ver dados de volume →</a>
            <span class="text-neutral-700">•</span>
            <a href="/pt/training/" class="text-blue-400 hover:text-blue-300 text-sm font-medium">Tendências de treino →</a>
            <span class="text-neutral-700">•</span>
            <a href="/pt/videos/" class="text-blue-400 hover:text-blue-300 text-sm font-medium">Assistir tentativas de PR →</a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-neutral-900 border-t border-neutral-800">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-2xl font-bold mb-4">Quer ver todos os dados de treino?</h2>
        <p class="text-neutral-400 mb-8 max-w-xl mx-auto">
          Explore cada treino, as tendências mensais de volume e toda a jornada de transformação.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/pt/training/" class="px-8 py-3.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-full transition-all hover:scale-105">
            Painel de treino
          </a>
          <a href="/pt/speediance/" class="px-8 py-3.5 bg-neutral-800 hover:bg-neutral-700 text-white border border-neutral-700 rounded-full transition-all font-medium">
            Estatísticas da Speediance
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
