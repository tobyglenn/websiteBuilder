---
// TODO(pt): EXO translation API unavailable during overnight build; localized key UI strings added, long-form body content still partly English.
import Layout from '../../../layouts/Layout.astro';
import { LISTING_BLOG_POSTS } from '../../../lib/blogPosts';

function readTime(content = '') {
  const words = content.split(/\s+/).filter(Boolean).length;
  return `${Math.max(1, Math.round(words / 200))} min read`;
}

function dateTimestamp(value = '') {
  const timestamp = Date.parse(value);
  return Number.isNaN(timestamp) ? 0 : timestamp;
}

function formatPostDate(
  value = '',
  options: Intl.DateTimeFormatOptions = { year: 'numeric', month: 'long', day: 'numeric' }
) {
  const timestamp = Date.parse(value);
  return Number.isNaN(timestamp)
    ? 'Undated'
    : new Date(timestamp).toLocaleDateString(undefined, options);
}

function hasValidDate(value = '') {
  return dateTimestamp(value) > 0;
}

function placeholderSurfaceClass(category = '') {
  const normalized = category.toLowerCase();
  if (normalized.includes('speediance')) return 'from-sky-500/35 via-blue-600/20 to-neutral-950';
  if (normalized.includes('wear')) return 'from-emerald-500/30 via-teal-500/15 to-neutral-950';
  if (normalized.includes('bjj')) return 'from-orange-500/30 via-amber-500/15 to-neutral-950';
  if (normalized.includes('field')) return 'from-fuchsia-500/30 via-pink-500/15 to-neutral-950';
  if (normalized.includes('train')) return 'from-red-500/25 via-orange-500/15 to-neutral-950';
  return 'from-neutral-700/40 via-neutral-900 to-neutral-950';
}

function placeholderLabel(category = '') {
  const normalized = category.toLowerCase();
  if (normalized.includes('speediance')) return 'Firmware Notes';
  if (normalized.includes('wear')) return 'Recovery Signals';
  if (normalized.includes('bjj')) return 'Mat Notes';
  if (normalized.includes('field')) return 'Field Report';
  if (normalized.includes('train')) return 'Training Notes';
  if (normalized.includes('review')) return 'Independent Review';
  return 'Analysis Log';
}

function placeholderMonogram(title = '') {
  const tokens = title
    .replace(/[^a-z0-9\s]/gi, ' ')
    .split(/\s+/)
    .filter(Boolean)
    .filter((word) => word.length > 2)
    .slice(0, 3);

  const initials = tokens.map((word) => word[0]?.toUpperCase() || '').join('');
  return initials || 'TOFT';
}

const siteUrl = "https://tobyonfitnesstech.com";

// Read category from URL and set activeCategory
const urlCategory = Astro.url.searchParams.get('category');
const CATEGORY_OPTIONS = [
  'All',
  'Speediance',
  'BJJ',
  'Wearables',
  'Training',
  'Field Reports',
  'The Long Game',
];
const activeCategory = CATEGORY_OPTIONS.includes(String(urlCategory || ''))
  ? String(urlCategory)
  : 'All';

// Sort posts by date descending
const sortedPosts = [...LISTING_BLOG_POSTS].sort((a, b) =>
  dateTimestamp(b.published_at) - dateTimestamp(a.published_at)
);

// Filter posts based on activeCategory
const filteredPosts = activeCategory === 'All' ? sortedPosts : sortedPosts.filter(p => p.category === activeCategory);


// Process posts first (needed for schemas below)
const blogListSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${siteUrl}/blog#collection`,
  "name": "O log de análises — Toby on Fitness Tech",
  "description": "Independent analysis of fitness technology. Real data. No affiliate pressure. One athlete's obsession with knowing what's actually working.",
  "url": `${siteUrl}/blog`,
  "inLanguage": "en",
  "isPartOf": { "@id": `${siteUrl}/#website` },
  "author": { "@id": `${siteUrl}/#toby` },
  "hasPart": filteredPosts.slice(0, 10).map((post, index) => ({
    "@type": "BlogPosting",
    "@id": `${siteUrl}/blog/${post.slug}`,
    "position": index + 1,
    "headline": post.title,
    "description": post.excerpt || post.title,
    "url": `${siteUrl}/blog/${post.slug}`,
    ...(hasValidDate(post.published_at) ? { "datePublished": post.published_at } : {}),
    ...(post.image && !post.image.startsWith('data:') ? { "image": post.image.startsWith('http') ? post.image : `${siteUrl}${post.image}` } : {}),
    "author": { "@id": `${siteUrl}/#toby` },
    "publisher": { "@id": `${siteUrl}/#organization` }
  }))
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "@id": `${siteUrl}/blog#itemlist`,
  "name": "Latest Fitness Tech Analysis Posts",
  "description": "Independent fitness technology analysis and reviews",
  "url": `${siteUrl}/blog`,
  "numberOfItems": LISTING_BLOG_POSTS.length,
  "itemListElement": filteredPosts.slice(0, 10).map((post, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "url": `${siteUrl}/blog/${post.slug}`,
    "name": post.title
  }))
};

const CATEGORIES = CATEGORY_OPTIONS;

const featuredPost = filteredPosts[0];
const sidebarPosts = filteredPosts.slice(1, 5);
const gridPosts = filteredPosts.slice(5);

const title = "O log de análises — Toby on Fitness Tech";
const description = "Independent analysis of fitness technology. Real data. No affiliate pressure. One athlete's obsession with knowing what's actually working.";
---

<Layout title={title} description={description} jsonLd={[blogListSchema, itemListSchema]} breadcrumbs={[{ name: "Início", url: "/" }, { name: "Blog", url: "/blog" }]}>

  <!-- ░░ HERO ░░ -->
  <section class="bg-neutral-950 border-b border-neutral-800">
    <div class="container mx-auto px-4 py-10 md:py-14 text-center max-w-3xl">
      <p class="text-blue-500 text-xs font-bold uppercase tracking-widest mb-5">
        THE ANALYSIS LOG
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">
        I don't take anyone's word for it.<br class="hidden md:block" />
        <span class="text-neutral-400">Including the sensors.</span>
      </h1>
      <p class="text-lg text-neutral-300 leading-relaxed mb-8">
        Independent analysis of fitness technology. Real data. No affiliate pressure.
        One athlete's obsession with knowing what's actually working.
      </p>
      <p class="text-xs text-neutral-600 tracking-wide">
        All data is real. All opinions are mine. Nothing is sponsored unless explicitly stated.
      </p>
    </div>
  </section>

  <!-- ░░ SEARCH + CATEGORY FILTER ░░ -->
  <section class="bg-neutral-950 border-b border-neutral-800 sticky top-16 z-40 backdrop-blur">
    <div class="container mx-auto px-4 py-4">
      <!-- Search Input -->
      <div class="max-w-md mx-auto mb-4">
        <div class="relative">
          <input
            type="text"
            id="blog-search"
            placeholder="Buscar posts..."
            class="w-full bg-neutral-800 border border-neutral-700 text-white placeholder-gray-400 px-4 py-2.5 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
          />
          <button
            id="clear-search"
            class="absolute right-2 top-1/2 -translate-y-1/2 text-neutral-500 hover:text-white p-1 hidden"
            aria-label="Clear search"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
      <div class="flex flex-wrap gap-2 justify-center" id="category-filters">
        {CATEGORIES.map(cat => {
          const isActive = activeCategory === cat;
          return (
            <button
              type="button"
              data-cat-btn={cat}
              class={[
                'px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-200 whitespace-nowrap',
                isActive
                  ? 'bg-blue-600 text-white shadow-md shadow-blue-900/40'
                  : 'bg-neutral-800 text-neutral-400 hover:bg-neutral-700 hover:text-white border border-neutral-700',
              ].join(' ')}
            >
              {cat}
            </button>
          );
        })}
      </div>
    </div>
  </section>

  <div class="container mx-auto px-4 py-12">

    <!-- ░░ LEAD STORY LAYOUT ░░ -->
    {featuredPost ? (
      <div id="lead-section" class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-16">

        <!-- Featured Post -->
        <article class="lg:col-span-2 bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden hover:border-blue-800 hover:shadow-2xl hover:shadow-blue-950/30 transition-all duration-300 group border-l-4 border-l-blue-500 flex flex-col"
          data-category={featuredPost.category}
          data-post-card
          data-title={featuredPost.title.toLowerCase()}
          data-excerpt={featuredPost.excerpt?.toLowerCase() || ''}
        >
          <a href={`/blog/${featuredPost.slug}/`} class="block overflow-hidden aspect-[16/8] relative flex-shrink-0">
            <div class="absolute inset-0 z-0 bg-neutral-800" />
            {featuredPost.image && (
              <img
                src={featuredPost.image}
                alt={featuredPost.title}
                class="relative z-10 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="eager"
              />
            )}
            {!featuredPost.image && (
              <div class={`absolute inset-0 z-10 overflow-hidden bg-gradient-to-br ${placeholderSurfaceClass(featuredPost.category)} p-6`}>
                <div class="absolute -right-3 -top-6 text-8xl font-black tracking-tight text-white/8">
                  {placeholderMonogram(featuredPost.title)}
                </div>
                <div class="absolute bottom-0 left-0 h-px w-full bg-white/10" />
                <div class="flex h-full flex-col justify-between">
                  <div class="flex items-start justify-between gap-4">
                    <div class="inline-flex w-fit items-center rounded-full border border-white/15 bg-black/20 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.28em] text-neutral-200">
                      Toby on Fitness Tech
                    </div>
                    <div class="inline-flex w-fit items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.24em] text-white/80">
                      {placeholderLabel(featuredPost.category)}
                    </div>
                  </div>
                  <div class="max-w-2xl">
                    <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-white/60">{featuredPost.category}</p>
                    <p class="mt-3 text-2xl font-black leading-tight text-white">{featuredPost.title}</p>
                    <p class="mt-3 max-w-xl text-sm leading-relaxed text-neutral-200/85 line-clamp-2">{featuredPost.excerpt}</p>
                  </div>
                </div>
              </div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/60 to-transparent" />
            <div class="absolute top-4 left-4">
              <span class="bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg uppercase tracking-wide">
                {featuredPost.category}
              </span>
            </div>
            <div class="absolute top-4 right-4">
              <span class="bg-neutral-900/80 text-neutral-300 text-xs font-medium px-3 py-1 rounded-full border border-neutral-700">
                Featured
              </span>
            </div>
          </a>

          <div class="p-8 flex flex-col flex-1">
            <div class="flex items-center text-xs text-neutral-500 mb-4 space-x-2">
              <span>{formatPostDate(featuredPost.published_at)}</span>
              <span>·</span>
              <span>{readTime(featuredPost.content)}</span>
            </div>

            <h2 class="text-2xl md:text-3xl font-black text-white mb-4 leading-tight group-hover:text-blue-400 transition-colors">
              <a href={`/blog/${featuredPost.slug}/`}>{featuredPost.title}</a>
            </h2>

            <p class="text-neutral-300 leading-relaxed mb-8 flex-grow text-base">
              {featuredPost.excerpt}
            </p>

            <a
              href={`/blog/${featuredPost.slug}/`}
              class="inline-flex items-center gap-2 text-sm font-bold text-blue-400 hover:text-blue-300 transition-colors group/cta"
            >
              Read Full Analysis
              <span class="group-hover/cta:translate-x-1 transition-transform">&rarr;</span>
            </a>
          </div>
        </article>

        <!-- Latest Sidebar -->
        <aside class="lg:col-span-1 flex flex-col gap-0">
          <h3 class="text-xs font-bold text-neutral-500 uppercase tracking-widest mb-4 px-1">
            Latest Posts
          </h3>
          <div class="flex flex-col divide-y divide-neutral-800">
            {sidebarPosts.length > 0 ? sidebarPosts.map(post => (
              <article class="flex gap-4 py-4 group hover:bg-neutral-900/50 rounded-lg px-2 transition-colors"
                data-category={post.category}
                data-post-card
                data-title={post.title.toLowerCase()}
                data-excerpt={post.excerpt?.toLowerCase() || ''}
              >
                <a href={`/blog/${post.slug}/`} class="flex-shrink-0 w-20 h-16 rounded-lg overflow-hidden relative bg-neutral-800">
                  {post.image && (
                    <img
                      src={post.image}
                      alt={post.title}
                      class="relative z-10 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  )}
                  {!post.image && (
                    <div class={`absolute inset-0 overflow-hidden bg-gradient-to-br ${placeholderSurfaceClass(post.category)} p-2`}>
                      <div class="absolute -right-1 -top-2 text-3xl font-black tracking-tight text-white/12">
                        {placeholderMonogram(post.title)}
                      </div>
                      <div class="flex h-full items-end justify-between gap-2">
                        <span class="text-[8px] font-bold uppercase tracking-[0.22em] text-white/75">
                          {placeholderLabel(post.category)}
                        </span>
                        <span class="text-xs font-black text-white/85">
                          {placeholderMonogram(post.title)}
                        </span>
                      </div>
                    </div>
                  )}
                </a>
                <div class="flex flex-col justify-between min-w-0 flex-1">
                  <div>
                    <span class="text-blue-500 text-[10px] font-bold uppercase tracking-wide block mb-1">
                      {post.category}
                    </span>
                    <h4 class="text-sm font-semibold text-white leading-snug group-hover:text-blue-400 transition-colors line-clamp-2">
                      <a href={`/blog/${post.slug}/`}>{post.title}</a>
                    </h4>
                  </div>
                  <span class="text-xs text-neutral-600 mt-1">
                    {formatPostDate(post.published_at, { month: 'short', day: 'numeric', year: 'numeric' })}
                  </span>
                </div>
              </article>
            )) : (
              <p class="text-neutral-600 text-sm py-4 px-2">No other posts in this category.</p>
            )}
          </div>
        </aside>

      </div>
    ) : (
      <div class="py-20 text-center">
        <p class="text-neutral-500 text-lg">No posts found in <strong class="text-neutral-300">{activeCategory}</strong> yet.</p>
        <a href="/blog/" class="mt-4 inline-block text-blue-400 hover:text-blue-300 text-sm font-medium transition-colors">← View all posts</a>
      </div>
    )}

    <!-- ░░ FULL GRID ░░ -->
    <div id="all-grid-section">
      {gridPosts.length > 0 && (
      <div>
        <div class="flex items-center gap-4 mb-8">
          <h2 class="text-xs font-bold text-neutral-500 uppercase tracking-widest whitespace-nowrap">More Analysis</h2>
          <div class="flex-1 border-t border-neutral-800" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {filteredPosts.map(post => (
            <article class="flex flex-col bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden hover:border-neutral-700 hover:shadow-xl hover:shadow-black/30 transition-all duration-300 group"
              data-category={post.category}
              data-post-card
              data-title={post.title.toLowerCase()}
              data-excerpt={post.excerpt?.toLowerCase() || ''}
            >
              <a href={`/blog/${post.slug}/`} class="block aspect-[16/9] overflow-hidden relative flex-shrink-0">
                <div class="absolute inset-0 z-0 bg-neutral-800" />
                {post.image && (
                  <img
                    src={post.image}
                    alt={post.title}
                    class="relative z-10 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                )}
                {!post.image && (
                  <div class={`absolute inset-0 z-10 overflow-hidden bg-gradient-to-br ${placeholderSurfaceClass(post.category)} p-5`}>
                    <div class="absolute -right-2 -top-4 text-6xl font-black tracking-tight text-white/8">
                      {placeholderMonogram(post.title)}
                    </div>
                    <div class="flex h-full flex-col justify-between">
                      <div class="flex items-start justify-between gap-3">
                        <div class="inline-flex w-fit items-center rounded-full border border-white/15 bg-black/20 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.28em] text-neutral-200">
                          Toby on Fitness Tech
                        </div>
                        <div class="inline-flex w-fit items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.22em] text-white/80">
                          {placeholderLabel(post.category)}
                        </div>
                      </div>
                      <div>
                        <p class="text-[10px] font-bold uppercase tracking-[0.24em] text-white/60">{post.category}</p>
                        <p class="mt-2 text-lg font-black leading-tight text-white line-clamp-3">{post.title}</p>
                        <p class="mt-3 text-sm leading-relaxed text-neutral-200/85 line-clamp-2">{post.excerpt}</p>
                      </div>
                    </div>
                  </div>
                )}
                <div class="absolute top-4 left-4">
                  <span class="bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg">
                    {post.category}
                  </span>
                </div>
              </a>

              <div class="p-6 flex flex-col flex-1">
                <div class="flex items-center text-xs text-neutral-500 mb-3 space-x-2">
                  <span>{formatPostDate(post.published_at)}</span>
                  <span>·</span>
                  <span>{readTime(post.content)}</span>
                </div>

                <h2 class="text-xl font-bold mb-3 leading-snug group-hover:text-blue-400 transition-colors text-white">
                  <a href={`/blog/${post.slug}/`}>{post.title}</a>
                </h2>

                <p class="text-neutral-300 text-sm leading-relaxed mb-6 flex-grow line-clamp-2">
                  {post.excerpt}
                </p>

                <a href={`/blog/${post.slug}/`} class="inline-flex items-center gap-1.5 text-sm font-semibold text-blue-400 hover:text-blue-300 transition-colors group/cta">
                  Read Full Analysis
                  <span class="group-hover/cta:translate-x-0.5 transition-transform">&rarr;</span>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    )}
    </div>

  </div>

  <script>
    function updateCategoryUrl(category) {
      const nextCategory = categories.includes(category) ? category : 'All';
      const url = new URL(window.location.href);
      url.searchParams.set('category', nextCategory);
      url.hash = 'category-filters';
      window.history.replaceState({}, '', url);
    }

    function applyFilter(activeCategory = 'All') {
      const searchTerm = (document.getElementById('blog-search')?.value || '').toLowerCase().trim();

      const leadSection = document.getElementById('lead-section');
      const allGridSection = document.getElementById('all-grid-section');
      const noResultsMsg = document.getElementById('no-results-message');

      if (activeCategory === 'All' && !searchTerm) {
        if (leadSection) leadSection.style.display = '';
        if (allGridSection) allGridSection.style.display = '';
        if (noResultsMsg) noResultsMsg.style.display = 'none';
        document.querySelectorAll('[data-post-card]').forEach(c => c.style.display = '');
      } else {
        if (leadSection) leadSection.style.display = 'none';
        if (allGridSection) allGridSection.style.display = '';

        let visibleCount = 0;
        document.querySelectorAll('[data-post-card]').forEach(card => {
          const categoryMatch = activeCategory === 'All' || card.getAttribute('data-category') === activeCategory;
          const title = card.getAttribute('data-title') || '';
          const excerpt = card.getAttribute('data-excerpt') || '';
          const searchMatch = !searchTerm || title.includes(searchTerm) || excerpt.includes(searchTerm);
          
          if (categoryMatch && searchMatch) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        if (noResultsMsg) {
          noResultsMsg.style.display = visibleCount === 0 ? '' : 'none';
        }
      }

      document.querySelectorAll('[data-cat-btn]').forEach(btn => {
        const cat = btn.getAttribute('data-cat-btn');
        if (cat === activeCategory) {
          btn.classList.add('bg-blue-600', 'text-white', 'shadow-md', 'shadow-blue-900/40');
          btn.classList.remove('bg-neutral-800', 'text-neutral-400', 'hover:bg-neutral-700', 'hover:text-white', 'border', 'border-neutral-700');
        } else {
          btn.classList.remove('bg-blue-600', 'text-white', 'shadow-md', 'shadow-blue-900/40');
          btn.classList.add('bg-neutral-800', 'text-neutral-400', 'hover:bg-neutral-700', 'hover:text-white', 'border', 'border-neutral-700');
        }
      });
    }

    // Add no-results message element
    const noResultsHtml = `
      <div id="no-results-message" class="hidden text-center py-16">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-neutral-800 mb-4">
          <svg class="w-8 h-8 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">Nenhum resultado encontrado</h3>
        <p class="text-neutral-400">Tente ajustar sua busca ou o filtro de categoria</p>
      </div>
    `;

    const gridSection = document.getElementById('all-grid-section');
    if (gridSection) {
      gridSection.insertAdjacentHTML('afterend', noResultsHtml);
    }

    const categories = ['All', 'Speediance', 'BJJ', 'Wearables', 'Training', 'Field Reports', 'The Long Game'];
    const initialUrl = new URL(window.location.href);
    const initialCategory = initialUrl.searchParams.get('category');
    let activeCategory = categories.includes(initialCategory) ? initialCategory : '{activeCategory}';

    document.querySelectorAll('[data-cat-btn]').forEach(btn => {
      btn.addEventListener('click', () => {
        const selected = btn.getAttribute('data-cat-btn') || 'All';
        activeCategory = categories.includes(selected) ? selected : 'All';
        updateCategoryUrl(activeCategory);
        applyFilter(activeCategory);
      });
    });

    const searchInput = document.getElementById('blog-search');
    const clearBtn = document.getElementById('clear-search');

    if (searchInput) {
      let debounceTimer;
    const debounce = (func, delay) => {
      return (...args) => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => func.apply(this, args), delay);
      };
    };
    searchInput.addEventListener('input', debounce(() => {
        const hasValue = searchInput.value.length > 0;
        if (clearBtn) clearBtn.classList.toggle('hidden', !hasValue);
        applyFilter(activeCategory);
      }, 300));
    }

    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        if (searchInput) {
          searchInput.value = '';
          clearBtn.classList.add('hidden');
          searchInput.focus();
          applyFilter(activeCategory);
        }
      });
    }

    updateCategoryUrl(activeCategory);
    applyFilter(activeCategory);
  </script>
</Layout>
