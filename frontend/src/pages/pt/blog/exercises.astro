---
import Layout from '../../../layouts/Layout.astro';
import { getExercises } from '../../../data/exercises.js';

const { allExercises, grouped, totalCount } = getExercises();

const pageTitle = "Biblioteca de exercícios";
const pageDescription = "Navegue por todos os exercícios realizados no Speediance com pesos de PR. Filtre por grupo muscular: Costas e dorsais, Peito e tríceps, Pernas e glúteos, Core e braços.";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Qual é o exercício mais pesado no Speediance?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "O levantamento terra com barra tem o PR mais alto com 388 lbs, seguido pelo hip thrust com barra com 240 lbs e pelo supino reto com barra com 232 lbs."
      }
    },
    {
      "@type": "Question",
      "name": "Quantos exercícios únicos existem na biblioteca de exercícios?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `A biblioteca contém ${totalCount} exercícios únicos em todos os programas de treino do Speediance.`
      }
    },
    {
      "@type": "Question",
      "name": "Quais grupos musculares posso treinar com o Speediance?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "O Speediance permite treinar todos os principais grupos musculares: Costas e dorsais, Peito e tríceps, Pernas e glúteos, e Core e braços (incluindo bíceps, ombros e abdômen)."
      }
    },
    {
      "@type": "Question",
      "name": "Qual é o melhor exercício no Speediance para desenvolver um peitoral grande?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "O supino reto com barra tem o maior PR de peito com 232 lbs. Outros exercícios eficazes para peito incluem o supino inclinado com barra (PR de 185 lbs) e o supino com pegada dupla (PR de 90 lbs)."
      }
    },
    {
      "@type": "Question",
      "name": "Posso acompanhar meus recordes pessoais no Speediance?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sim! O Speediance acompanha automaticamente sua repetição máxima (1RM) para cada exercício. Esta página mostra todos os seus PRs, do levantamento terra de 388 lbs até movimentos isolados menores."
      }
    }
  ]
};

const muscleGroups = ['Todos', 'Costas e dorsais', 'Peito e tríceps', 'Pernas e glúteos', 'Core e braços'];
---

<Layout 
  title={`${pageTitle} | Toby on Fitness Tech`}
  description={pageDescription}
  jsonLd={faqSchema}
>
  <section class="py-20 bg-neutral-950 border-b border-neutral-800">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Biblioteca de exercícios</h1>
      <p class="text-lg md:text-xl text-neutral-400 max-w-2xl mx-auto">
        Explore todos os {totalCount} exercícios realizados no Speediance com pesos de recorde pessoal.
      </p>
    </div>
  </section>

  <section class="py-8 bg-neutral-900 border-b border-neutral-800 sticky top-16 z-40">
    <div class="container mx-auto px-4">
      <div class="flex flex-wrap justify-center gap-3">
        {muscleGroups.map((group) => (
          <button
            data-filter={group}
            class={`filter-btn px-5 py-2.5 rounded-full text-sm font-medium transition-all ${
              group === 'Todos' 
                ? 'bg-blue-600 text-white' 
                : 'bg-neutral-800 text-neutral-300 hover:bg-neutral-700 hover:text-white border border-neutral-700'
            }`}
          >
            {group}
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-neutral-950">
    <div class="container mx-auto px-4">
      <div id="exerciseGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {allExercises.map((exercise) => (
          <div 
            data-group={exercise.muscleGroup}
            class="exercise-card bg-neutral-900 rounded-xl p-5 border border-neutral-800 hover:border-blue-500/50 transition-all hover:shadow-lg hover:shadow-blue-500/10"
          >
            <h3 class="text-white font-semibold text-lg mb-3 line-clamp-2">{exercise.name}</h3>
            
            <div class="mb-3">
              <span class={`inline-block px-3 py-1 rounded-full text-xs font-medium ${
                exercise.muscleGroup === 'Back & Lats' ? 'bg-blue-500/20 text-blue-400' :
                exercise.muscleGroup === 'Chest & Triceps' ? 'bg-red-500/20 text-red-400' :
                exercise.muscleGroup === 'Legs & Glutes' ? 'bg-green-500/20 text-green-400' :
                'bg-purple-500/20 text-purple-400'
              }`}>
                {exercise.muscleGroup === 'Back & Lats' ? 'Costas e dorsais' :
                 exercise.muscleGroup === 'Chest & Triceps' ? 'Peito e tríceps' :
                 exercise.muscleGroup === 'Legs & Glutes' ? 'Pernas e glúteos' :
                 'Core e braços'}
              </span>
            </div>
            
            <div class="flex items-baseline gap-2">
              <span class="text-2xl font-bold text-white">{exercise.prWeight || '—'}</span>
              <span class="text-sm text-neutral-400">lbs PR</span>
            </div>
          </div>
        ))}
      </div>
      
      <div id="noResults" class="hidden text-center py-16">
        <div class="text-6xl mb-4">🏋️</div>
        <p class="text-xl text-neutral-400">Nenhum exercício encontrado para esta categoria.</p>
      </div>
    </div>
  </section>

  <section class="py-12 bg-neutral-900 border-t border-neutral-800">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-1">{grouped['Back & Lats']?.length || 0}</div>
          <div class="text-sm text-neutral-400">Costas e dorsais</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-red-400 mb-1">{grouped['Chest & Triceps']?.length || 0}</div>
          <div class="text-sm text-neutral-400">Peito e tríceps</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-green-400 mb-1">{grouped['Legs & Glutes']?.length || 0}</div>
          <div class="text-sm text-neutral-400">Pernas e glúteos</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-purple-400 mb-1">{grouped['Core & Arms']?.length || 0}</div>
          <div class="text-sm text-neutral-400">Core e braços</div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.exercise-card');
    const noResults = document.getElementById('noResults');
    
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');
        
        filterBtns.forEach(b => {
          b.classList.remove('bg-blue-600', 'text-white');
          b.classList.add('bg-neutral-800', 'text-neutral-300', 'border', 'border-neutral-700');
        });
        btn.classList.remove('bg-neutral-800', 'text-neutral-300', 'border', 'border-neutral-700');
        btn.classList.add('bg-blue-600', 'text-white');
        
        let visibleCount = 0;
        cards.forEach(card => {
          const group = card.getAttribute('data-group');
          const normalizedGroup = group === 'Back & Lats' ? 'Costas e dorsais' :
            group === 'Chest & Triceps' ? 'Peito e tríceps' :
            group === 'Legs & Glutes' ? 'Pernas e glúteos' :
            group === 'Core & Arms' ? 'Core e braços' : group;
          if (filter === 'Todos' || normalizedGroup === filter) {
            (card as HTMLElement).style.display = 'block';
            visibleCount++;
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });
        
        if (noResults) {
          if (visibleCount === 0) {
            noResults.classList.remove('hidden');
          } else {
            noResults.classList.add('hidden');
          }
        }
      });
    });
  });
</script>
