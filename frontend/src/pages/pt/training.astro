---
import Layout from '../layouts/Layout.astro';

// Weekly training schedule - full body minus legs, prioritized: Running > Lifting > BJJ
const weeklySchedule = [
  {
    day: "Segunda-feira",
    focus: "Corrida + Musculação",
    icon: "🏃",
    exercises: ["Corrida leve de 5K", "Supino reto", "Puxada na frente", "Desenvolvimento acima da cabeça", "Remada com barra"],
    priority: 1
  },
  {
    day: "Terça-feira",
    focus: "BJJ",
    icon: "🥋",
    exercises: ["Drills com kimono", "Rounds de sparring", "trabalho posicional"],
    priority: 3
  },
  {
    day: "Quarta-feira",
    focus: "Corrida + Musculação",
    icon: "🏃",
    exercises: ["Corrida ritmo de 6K", "Levantamento terra", "Hip thrust", "Barra fixa", "Face pulls"],
    priority: 1
  },
  {
    day: "Quinta-feira",
    focus: "Recuperação ativa",
    icon: "🔄",
    exercises: ["Trote leve de 3K", "trabalho de mobilidade", "alongamento"],
    priority: 0
  },
  {
    day: "Sexta-feira",
    focus: "Corrida + Musculação",
    icon: "🏃",
    exercises: ["Treino de velocidade em intervalos", "Supino inclinado", "Puxada na frente", "Rosca bíceps", "Extensões de tríceps"],
    priority: 1
  },
  {
    day: "Sábado",
    focus: "BJJ",
    icon: "🥋",
    exercises: ["Open mat", "drills técnicos", "rolas ao vivo"],
    priority: 3
  },
  {
    day: "Domingo",
    focus: "Descanso",
    icon: "😴",
    exercises: ["Dia de descanso", "recuperação com sono", "caminhada leve"],
    priority: 0
  }
];

const stats = {
  workoutsPerWeek: 6,
  restDays: 1,
  runningDays: 4,
  liftingDays: 3,
  bjjDays: 2
};

const pageTitle = "Semana de treino";
const pageDescription = "Uma semana típica de treino: corrida, musculação de corpo inteiro (sem pernas) e BJJ. Minha abordagem priorizada de fitness: Corrida > Musculação > BJJ.";

const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "Semana de treino do Toby",
  "description": "Um programa semanal de treino que combina corrida, musculação de corpo inteiro e jiu-jítsu brasileiro.",
  "provider": {
    "@type": "Person",
    "name": "Toby"
  },
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": "https://schema.org/OfflineMode",
    "courseWorkload": "P6D"
  }
};
---

<Layout title={pageTitle} description={pageDescription} jsonLd={courseSchema}>
  <main class="max-w-5xl mx-auto px-4 py-12">
    {/* Hero Section */}
    <section class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Semana de treino</h1>
      <p class="text-lg text-neutral-400 max-w-2xl mx-auto">
        Uma semana típica equilibrando meus três pilares: corrida, musculação de corpo inteiro (sem pernas) e BJJ.
        Tudo é priorizado: <span class="text-blue-400 font-semibold">Corrida &gt; Musculação &gt; BJJ</span>
      </p>
    </section>

    {/* Stats Overview */}
    <section class="mb-12">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-blue-400 mb-1">{stats.workoutsPerWeek}</div>
          <div class="text-sm text-neutral-400">Treinos/semana</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-white mb-1">{stats.restDays}</div>
          <div class="text-sm text-neutral-400">Dias de descanso</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-green-400 mb-1">{stats.runningDays}</div>
          <div class="text-sm text-neutral-400">Dias de corrida</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-purple-400 mb-1">{stats.liftingDays}</div>
          <div class="text-sm text-neutral-400">Dias de musculação</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-orange-400 mb-1">{stats.bjjDays}</div>
          <div class="text-sm text-neutral-400">Dias de BJJ</div>
        </div>
      </div>
    </section>

    {/* Weekly Schedule Grid */}
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
        <span>📅</span> Cronograma semanal
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-7 gap-4">
        {weeklySchedule.map((day) => (
          <div class={`bg-neutral-900 border rounded-xl p-5 transition-all hover:scale-[1.02] ${
            day.priority === 0 
              ? 'border-neutral-800 opacity-70' 
              : day.priority === 1 
                ? 'border-blue-500/30 hover:border-blue-500/60' 
                : day.priority === 2 
                  ? 'border-purple-500/30 hover:border-purple-500/60'
                  : 'border-orange-500/30 hover:border-orange-500/60'
          }`}>
            <div class="flex items-center gap-2 mb-3">
              <span class="text-2xl">{day.icon}</span>
              <h3 class="text-lg font-bold text-white">{day.day}</h3>
            </div>
            <div class={`text-sm font-semibold mb-3 ${
              day.priority === 1 ? 'text-blue-400' : 
              day.priority === 2 ? 'text-purple-400' : 
              day.priority === 3 ? 'text-orange-400' : 'text-neutral-500'
            }`}>
              {day.focus}
            </div>
            <ul class="space-y-1">
              {day.exercises.map((ex) => (
                <li class="text-sm text-neutral-400 flex items-start gap-2">
                  <span class="text-neutral-600 mt-1">•</span>
                  <span>{ex}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    {/* Training Philosophy */}
    <section class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8">
      <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-2">
        <span>🧠</span> Filosofia de treino
      </h2>
      <div class="space-y-4">
        <p class="text-neutral-300 text-lg">
          Meu treino é organizado por prioridade: <span class="text-blue-400 font-bold">Corrida &gt; Musculação &gt; BJJ</span>
        </p>
        <div class="grid md:grid-cols-3 gap-6 mt-6">
          <div class="bg-neutral-950 rounded-xl p-5 border border-blue-500/20">
            <div class="text-3xl mb-2">🏆</div>
            <h3 class="text-blue-400 font-bold mb-2">#1 Corrida</h3>
            <p class="text-neutral-400 text-sm">
              O cardio é a base. Seja com quilômetros leves, corridas em ritmo ou intervalos, a corrida vem primeiro. 
              Uma base aeróbica forte sustenta todo o resto.
            </p>
          </div>
          <div class="bg-neutral-950 rounded-xl p-5 border border-purple-500/20">
            <div class="text-3xl mb-2">💪</div>
            <h3 class="text-purple-400 font-bold mb-2">#2 Musculação</h3>
            <p class="text-neutral-400 text-sm">
              Sessões de corpo inteiro sem pernas (a Speediance cuida dos compostos pesados). 
              Foco em empurrar, puxar e hipertrofia. Três dias por semana.
            </p>
          </div>
          <div class="bg-neutral-950 rounded-xl p-5 border border-orange-500/20">
            <div class="text-3xl mb-2">🥋</div>
            <h3 class="text-orange-400 font-bold mb-2">#3 BJJ</h3>
            <p class="text-neutral-400 text-sm">
              Dois dias por semana para técnica e rola. O jiu-jítsu me mantém humilde e oferece 
              excelente condicionamento anaeróbico e trabalho técnico.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
