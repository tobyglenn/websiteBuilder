---
import Layout from '../../../layouts/Layout.astro';
import { currentGearItems, replacedGearItems } from '../../../data/gearItems';
import speedianceJson from '../../../data/speediance_dashboard_data.json';
import garminJson from '../../../data/garmin_all_activities.json';
import whoopJson from '../../../data/whoop_v2_latest.json';
import csvRawImport from '../../../data/eight_sleep_historical.csv?raw';

let speedianceStats = { totalVolume: 0, totalWorkouts: 0 };
let garminStats = { totalMiles: '0', totalRuns: 0 };
let avgRecovery = 0, avgHRV = 0, avgRHR = 0;
let avgSleepScore = 0, avgSleepHours = 0;

try {
  const speedianceData: any = speedianceJson;
  speedianceStats = {
    totalVolume: speedianceData.totalVolumeLbs || 0,
    totalWorkouts: speedianceData.totalWorkouts || 0,
  };
} catch (e) {}

try {
  const garminActivities: any[] = (garminJson as any).activities || garminJson || [];
  const totalMiles = garminActivities.reduce((sum: number, a: any) => sum + (a.distance_miles || a.distance || 0), 0);
  const totalRuns = garminActivities.filter((a: any) => (a.activityType || a.type || '').toLowerCase().includes('run')).length;
  garminStats = { totalMiles: totalMiles.toFixed(1), totalRuns };
} catch (e) {}

try {
  const whoopData: any = whoopJson;
  const recoveries: any[] = whoopData?.recoveries || whoopData?.data || [];
  const scores: number[] = [], hrvs: number[] = [], rhrs: number[] = [];
  for (const d of recoveries.slice(0, 30)) {
    const score = d.score?.recovery_score ?? d.recovery_score ?? d.score;
    const hrv = d.score?.hrv_rmssd_milli ?? d.hrv_rmssd_milli;
    const rhr = d.score?.resting_heart_rate ?? d.resting_heart_rate;
    if (typeof score === 'number') scores.push(score > 1 ? score : score * 100);
    if (typeof hrv === 'number') hrvs.push(hrv);
    if (typeof rhr === 'number') rhrs.push(rhr);
  }
  if (scores.length) avgRecovery = scores.reduce((a, b) => a + b, 0) / scores.length;
  if (hrvs.length) avgHRV = hrvs.reduce((a, b) => a + b, 0) / hrvs.length;
  if (rhrs.length) avgRHR = rhrs.reduce((a, b) => a + b, 0) / rhrs.length;
} catch (e) {}

try {
  const csvRaw = csvRawImport;
  let records: any[] = [];
  try { records = JSON.parse(csvRaw); } catch {
    const lines = csvRaw.trim().split('\n');
    const headers = lines[0].split(',').map(h => h.trim());
    records = lines.slice(1).map(line => {
      const vals = line.split(',');
      return Object.fromEntries(headers.map((h, i) => [h, vals[i]?.trim()]));
    });
  }
  const recent = records.slice(0, 30);
  const scores = recent.map(r => parseFloat(r.sleep_score || r.score || '0')).filter(n => !isNaN(n));
  const hours = recent.map(r => parseFloat(r.time_slept_hours || r.hours || '0')).filter(n => !isNaN(n));
  if (scores.length) avgSleepScore = scores.reduce((a, b) => a + b, 0) / scores.length;
  if (hours.length) avgSleepHours = hours.reduce((a, b) => a + b, 0) / hours.length;
} catch (e) {}

const gearJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: "Equipamentos de fitness tech do Toby",
  description: 'Lista compacta de equipamentos com links diretos para reviews completos e detalhados.',
  url: 'https://tobyonfitnesstech.com/gear',
  itemListElement: currentGearItems.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: {
      '@type': 'Product',
      name: item.name,
      category: item.category,
      description: item.shortDescription,
      image: `https://tobyonfitnesstech.com${item.image}`,
      url: `https://tobyonfitnesstech.com/gear/${item.slug}`
    }
  }))
};

const verdictClasses: Record<string, string> = {
  'Not Recommended': 'bg-red-500/15 text-red-300 border-red-500/25',
  Good: 'bg-yellow-500/15 text-yellow-300 border-yellow-500/25',
  Great: 'bg-blue-500/15 text-blue-300 border-blue-500/25',
  Essential: 'bg-green-500/15 text-green-300 border-green-500/25'
};
---

<Layout title="Meu equipamento - Toby on Fitness Tech" description="Lista rápida dos equipamentos de fitness tech que eu uso, com resumos curtos e links para reviews detalhados." jsonLd={gearJsonLd}>
  <main class="min-h-screen bg-neutral-950 text-white">
    <section class="pt-32 pb-16 md:pt-40 md:pb-20 border-b border-neutral-900/80">
      <div class="container mx-auto px-4 max-w-5xl">
        <p class="text-xs font-bold tracking-widest text-blue-400 uppercase mb-4">Lista de equipamentos</p>
        <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-5">O que eu uso (lista rápida)</h1>
        <p class="text-lg text-neutral-400 max-w-3xl">
          Esta página agora é um índice rápido. Cada item tem aqui um resumo curto e uma imagem, depois leva para sua própria página de review completa com notas detalhadas, prós, contras e contexto.
        </p>
      </div>
    </section>

    <section class="py-12 md:py-16 border-b border-neutral-900/80">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="flex items-end justify-between mb-8">
          <div>
            <p class="text-xs font-bold tracking-widest text-cyan-400 uppercase mb-2">Estatísticas ao vivo</p>
            <h2 class="text-2xl md:text-3xl font-bold">Dados de desempenho no mundo real</h2>
          </div>
          <p class="text-xs text-neutral-500 hidden md:block">Calculado automaticamente a partir dos conjuntos de dados atuais</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="group rounded-2xl border border-neutral-800 bg-neutral-900/60 hover:border-cyan-500/40 hover:bg-neutral-900 transition-all p-6 md:p-8">
            <div class="flex items-start justify-between mb-4">
              <div class="text-4xl">🏋️</div>
              <span class="text-xs font-semibold px-3 py-1 rounded-full bg-cyan-500/15 text-cyan-300 border border-cyan-500/25">Força</span>
            </div>
            <h3 class="text-xl md:text-2xl font-bold mb-2 group-hover:text-cyan-300 transition-colors">Speediance Gym Monster 2S</h3>
            <p class="text-sm text-neutral-400 mb-6">Academia inteligente residencial com IA e resistência eletrônica.</p>
            <div class="grid grid-cols-2 gap-4">
              <div class="bg-neutral-950 rounded-lg p-4 border border-neutral-800">
                <div class="text-2xl md:text-3xl font-bold text-cyan-400">{new Intl.NumberFormat('pt-BR').format(speedianceStats.totalVolume)}</div>
                <div class="text-xs text-neutral-500 uppercase tracking-wide mt-1">Total de lbs levantadas</div>
              </div>
              <div class="bg-neutral-950 rounded-lg p-4 border border-neutral-800">
                <div class="text-2xl md:text-3xl font-bold text-cyan-400">{speedianceStats.totalWorkouts}</div>
                <div class="text-xs text-neutral-500 uppercase tracking-wide mt-1">Treinos</div>
              </div>
            </div>
          </div>

          <div class="group rounded-2xl border border-neutral-800 bg-neutral-900/60 hover:border-cyan-500/40 hover:bg-neutral-900 transition-all p-6 md:p-8">
            <div class="flex items-start justify-between mb-4">
              <div class="text-4xl">⌚</div>
              <span class="text-xs font-semibold px-3 py-1 rounded-full bg-cyan-500/15 text-cyan-300 border border-cyan-500/25">Multiesporte</span>
            </div>
            <h3 class="text-xl md:text-2xl font-bold mb-2 group-hover:text-cyan-300 transition-colors">Garmin Fenix 7</h3>
            <p class="text-sm text-neutral-400 mb-6">Relógio GPS multiesporte premium para corrida e treino.</p>
            <div class="grid grid-cols-2 gap-4">
              <div class="bg-neutral-950 rounded-lg p-4 border border-neutral-800">
                <div class="text-2xl md:text-3xl font-bold text-cyan-400">{garminStats.totalMiles}</div>
                <div class="text-xs text-neutral-500 uppercase tracking-wide mt-1">Milhas totais</div>
              </div>
              <div class="bg-neutral-950 rounded-lg p-4 border border-neutral-800">
                <div class="text-2xl md:text-3xl font-bold text-cyan-400">{garminStats.totalRuns}</div>
                <div class="text-xs text-neutral-500 uppercase tracking-wide mt-1">Corridas</div>
              </div>
            </div>
          </div>

          <div class="group rounded-2xl border border-neutral-800 bg-neutral-900/60 hover:border-cyan-500/40 hover:bg-neutral-900 transition-all p-6 md:p-8">
            <div class="flex items-start justify-between mb-4">
              <div class="text-4xl">💓</div>
              <span class="text-xs font-semibold px-3 py-1 rounded-full bg-cyan-500/15 text-cyan-300 border border-cyan-500/25">Recuperação</span>
            </div>
            <h3 class="text-xl md:text-2xl font-bold mb-2 group-hover:text-cyan-300 transition-colors">WHOOP 4.0</h3>
            <p class="text-sm text-neutral-400 mb-6">Monitoramento contínuo de saúde com acompanhamento de recuperação.</p>
            <div class="grid grid-cols-3 gap-3">
              <div class="bg-neutral-950 rounded-lg p-3 border border-neutral-800">
                <div class="text-xl md:text-2xl font-bold text-cyan-400">{avgRecovery.toFixed(0)}</div>
                <div class="text-xs text-neutral-500 uppercase tracking-wide mt-1">Recuperação média</div>
              </div>
              <div class="bg-neutral-950 rounded-lg p-3 border border-neutral-800">
                <div class="text-xl md:text-2xl font-bold text-cyan-400">{avgHRV.toFixed(1)}</div>
                <div class="text-xs text-neutral-500 uppercase tracking-wide mt-1">HRV (ms)</div>
              </div>
              <div class="bg-neutral-950 rounded-lg p-3 border border-neutral-800">
                <div class="text-xl md:text-2xl font-bold text-cyan-400">{avgRHR.toFixed(0)}</div>
                <div class="text-xs text-neutral-500 uppercase tracking-wide mt-1">FCR (bpm)</div>
              </div>
            </div>
            <p class="text-xs text-neutral-500 mt-3">Médias de 30 dias</p>
          </div>

          <div class="group rounded-2xl border border-neutral-800 bg-neutral-900/60 hover:border-cyan-500/40 hover:bg-neutral-900 transition-all p-6 md:p-8">
            <div class="flex items-start justify-between mb-4">
              <div class="text-4xl">😴</div>
              <span class="text-xs font-semibold px-3 py-1 rounded-full bg-cyan-500/15 text-cyan-300 border border-cyan-500/25">Sono</span>
            </div>
            <h3 class="text-xl md:text-2xl font-bold mb-2 group-hover:text-cyan-300 transition-colors">8Sleep Pod 4</h3>
            <p class="text-sm text-neutral-400 mb-6">Colchão inteligente com controle de temperatura e rastreamento do sono.</p>
            <div class="grid grid-cols-2 gap-4">
              <div class="bg-neutral-950 rounded-lg p-4 border border-neutral-800">
                <div class="text-2xl md:text-3xl font-bold text-cyan-400">{avgSleepScore.toFixed(0)}</div>
                <div class="text-xs text-neutral-500 uppercase tracking-wide mt-1">Pontuação média de sono</div>
              </div>
              <div class="bg-neutral-950 rounded-lg p-4 border border-neutral-800">
                <div class="text-2xl md:text-3xl font-bold text-cyan-400">{avgSleepHours.toFixed(1)}</div>
                <div class="text-xs text-neutral-500 uppercase tracking-wide mt-1">Horas médias</div>
              </div>
            </div>
            <p class="text-xs text-neutral-500 mt-3">Médias de 30 dias</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-12">
      <div class="container mx-auto px-4 max-w-5xl">
        <h2 class="text-2xl font-bold mb-2">Equipamento atual</h2>
        <p class="text-sm text-neutral-500 mb-8">Equipamentos de uso diário e ferramentas ativas no meu fluxo de trabalho.</p>

        <div class="space-y-4">
          {currentGearItems.map((item) => (
            <a
              href={`/gear/${item.slug}/`}
              class="group block rounded-2xl border border-neutral-800 bg-neutral-900/60 hover:border-blue-500/40 hover:bg-neutral-900 transition-all"
            >
              <article class="p-4 md:p-5 grid gap-4 md:grid-cols-[180px_1fr_auto] md:items-center">
                <img
                  src={item.image}
                  alt={item.name}
                  class="w-full h-32 object-cover rounded-lg border border-neutral-800"
                  loading="lazy"
                />

                <div>
                  <div class="flex flex-wrap items-center gap-2 mb-2">
                    <span class="text-xs text-neutral-400">{item.categoryEmoji} {item.category}</span>
                    <span class={`text-xs px-2 py-0.5 rounded-full border ${verdictClasses[item.verdict]}`}>{item.verdict === 'Not Recommended' ? 'Não recomendado' : item.verdict === 'Good' ? 'Bom' : item.verdict === 'Great' ? 'Ótimo' : 'Essencial'}</span>
                    <span class="text-xs text-neutral-500">{item.location}</span>
                  </div>
                  <h3 class="text-xl font-semibold group-hover:text-blue-300 transition-colors">{item.name}</h3>
                  <p class="text-sm text-neutral-400 mt-2">{item.shortDescription}</p>
                </div>

                <div class="text-sm font-semibold text-blue-300 group-hover:text-blue-200">Detalhes completos →</div>
              </article>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="py-12 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-5xl">
        <h2 class="text-2xl font-bold mb-2">O que eu substituí</h2>
        <p class="text-sm text-neutral-500 mb-8">Dispositivos anteriores e por que saíram do meu stack.</p>

        <div class="grid gap-4 md:grid-cols-2">
          {replacedGearItems.map((item) => (
            <a
              href={`/gear/${item.slug}/`}
              class="group rounded-2xl border border-neutral-800 bg-neutral-900/50 hover:border-red-500/35 transition-colors p-4"
            >
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs text-neutral-400">{item.categoryEmoji} {item.category}</span>
                <span class={`text-xs px-2 py-0.5 rounded-full border ${verdictClasses[item.verdict]}`}>{item.verdict === 'Not Recommended' ? 'Não recomendado' : item.verdict === 'Good' ? 'Bom' : item.verdict === 'Great' ? 'Ótimo' : 'Essencial'}</span>
              </div>
              <h3 class="font-semibold text-lg group-hover:text-red-300 transition-colors">{item.name}</h3>
              <p class="text-sm text-neutral-400 mt-2">{item.shortDescription}</p>
              <p class="text-xs text-neutral-500 mt-3">Ver contexto completo →</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
