---
import Layout from '../layouts/Layout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Comparação Speediance vs Tonal vs academia tradicional",
  "description": "Comparação honesta entre Speediance, Tonal e academia tradicional com base em experiência real: 9M+ lbs no Tonal, 1.29M+ lbs no Speediance.",
  "brand": [
    { "@type": "Brand", "name": "Speediance" },
    { "@type": "Brand", "name": "Tonal" },
    { "@type": "Brand", "name": "Academia tradicional" }
  ],
  "offers": [
    { "@type": "Offer", "name": "Speediance", "price": "4995", "priceCurrency": "USD", "availability": "https://schema.org/InStock" },
    { "@type": "Offer", "name": "Tonal", "price": "2495", "priceCurrency": "USD", "availability": "https://schema.org/InStock" }
  ],
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.5", "reviewCount": "2" }
};

const comparisonFeatures = [
  { feature: "Custo inicial", speediance: "$4,995", tonal: "$2,495 + $39/mês", traditional: "$0-$200 de matrícula" },
  { feature: "Custo mensal", speediance: "$39/mês (opcional)", tonal: "$39/mês obrigatório", traditional: "~$150/mês" },
  { feature: "Custo total em 1 ano", speediance: "$5,463", tonal: "$2,963 + $468 = $3,431", traditional: "$1,800" },
  { feature: "Custo total em 3 anos", speediance: "$6,399", tonal: "$2,963 + $1,404 = $4,367", traditional: "$5,400" },
  { feature: "Custo total em 5 anos", speediance: "$7,335", tonal: "$2,963 + $2,340 = $5,303", traditional: "$9,000" },
  { feature: "Faixa de resistência", speediance: "220 lbs (cabo)", tonal: "200 lbs (digital)", traditional: "Ilimitada" },
  { feature: "Modo excêntrico", speediance: "✓ Sim", tonal: "✓ Sim", traditional: "✓ Sim (com parceiro)" },
  { feature: "Modo spotter", speediance: "✓ IA adaptativa", tonal: "✓ Sim", traditional: "✓ Com spotter humano" },
  { feature: "Qualidade do app", speediance: "Boa (melhorando)", tonal: "Excelente", traditional: "N/A" },
  { feature: "Suporte ao cliente", speediance: "Responsivo", tonal: "Teve problemas", traditional: "Varia" },
  { feature: "Garantia", speediance: "2 anos", tonal: "1 ano", traditional: "N/A" },
  { feature: "Espaço necessário", speediance: "6×4 pés de área", tonal: "Montagem na parede + área no chão", traditional: "Grande área de academia" },
  { feature: "Instalação", speediance: "Autônomo (sem furar)", tonal: "Montagem na parede obrigatória", traditional: "N/A" },
  { feature: "Rastreamento de dados", speediance: "Reps, peso, volume", tonal: "Reps, peso, volume", traditional: "Rastreamento manual" },
];

const speediancePros = ["Não exige assinatura para usar","Design autônomo - sem furar a parede","Maior resistência máxima (220 lbs)","Adaptação de peso por IA em tempo real","Sistema de cabo duplo para exercícios versáteis","Uso offline disponível","Não enfrentei aumentos de preço","O investimento único se paga em ~2 anos vs Tonal"];
const speedianceCons = ["Custo inicial mais alto ($4,995)","Marca mais nova com biblioteca de conteúdo menor","O app ainda está amadurecendo em comparação com concorrentes estabelecidos"];
const tonalPros = ["Marca estabelecida com ampla biblioteca de conteúdo","Excelente qualidade e variedade de coaching","Design elegante de parede economiza espaço no chão","Comunidade forte e variedade de aulas","Histórico comprovado (anos no mercado)"];
const tonalCons = ["Assinatura de $39/mês obrigatória - custo contínuo para sempre","Instalação na parede obrigatória (furação, montagem)","Teve aumentos de preço ao longo do tempo","Menor resistência máxima (200 lbs)","Funcionalidade offline limitada","Problemas de suporte relatados por alguns usuários","Programa de recompra não é como anunciado"];
const traditionalGymPros = ["Resistência ilimitada (pode ir mais pesado do que qualquer smart gym)","Grande variedade de equipamentos disponíveis","Atmosfera social e comunidade","Acesso a aulas, treinadores e comodidades","Sem custo inicial de equipamento","Pode testar antes de se comprometer"];
const traditionalGymCons = ["Tempo e custo de deslocamento (combustível, estacionamento)","O custo mensal se acumula bastante com o tempo","Lotado nos horários de pico","Esperar por equipamentos","Acesso 24/7 limitado em muitas academias","Menos conveniente para treinos rápidos"];
---

<Layout title="Speediance vs Tonal vs academia tradicional | Toby sobre tecnologia fitness" description="Já levantei 9M+ lbs no Tonal e 1.29M+ lbs no Speediance. Aqui está minha comparação honesta entre os 3, incluindo custos de academia tradicional." breadcrumbs={[{ name: "Início", url: "/" }, { name: "Comparar", url: "/compare" }]} jsonLd={jsonLd}>
  <main class="min-h-screen bg-neutral-950 text-white">
    <section class="pt-32 pb-16 md:pt-40 md:pb-24 relative overflow-hidden"><div class="absolute inset-0 bg-gradient-to-b from-blue-900/10 to-transparent pointer-events-none" /><div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(59,130,246,0.08),_transparent_70%)] pointer-events-none" /><div class="container mx-auto px-4 relative z-10"><div class="max-w-3xl"><p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-4">Comparação de equipamentos · Dados reais, sem patrocínio</p><h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">Speediance vs Tonal<br /><span class="bg-gradient-to-r from-blue-500 to-cyan-400 bg-clip-text text-transparent">vs academia tradicional</span></h1><p class="text-xl text-neutral-400 leading-relaxed max-w-2xl mb-8">Já levantei <strong class="text-white">9M+ libras</strong> no Tonal e <strong class="text-blue-400">1.29M+ libras</strong> no Speediance. Aqui está minha comparação honesta entre os três — sem viés de afiliado, apenas dados de anos de uso real.</p><div class="flex flex-wrap gap-4 mt-6"><div class="inline-flex items-center gap-2 px-5 py-2.5 bg-neutral-800/60 border border-neutral-700/50 text-neutral-300 font-medium rounded-full text-sm"><span class="w-2 h-2 rounded-full bg-neutral-400 inline-block"></span>9M+ lbs no Tonal</div><div class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-900/20 border border-blue-500/30 text-blue-300 font-medium rounded-full text-sm"><span class="w-2 h-2 rounded-full bg-blue-400 inline-block"></span>1.29M+ lbs no Speediance</div><div class="inline-flex items-center gap-2 px-5 py-2.5 bg-green-900/20 border border-green-500/30 text-green-300 font-medium rounded-full text-sm"><span class="w-2 h-2 rounded-full bg-green-400 inline-block"></span>Anos em academias tradicionais</div></div></div></div></section>
    <section class="py-16 bg-neutral-900/50"><div class="container mx-auto px-4"><h2 class="text-3xl font-bold mb-2 text-center">Comparação de recursos</h2><p class="text-neutral-400 text-center mb-10">Especificações lado a lado de alguém que já usou os três</p><div class="md:hidden space-y-4 mb-8"><div class="bg-neutral-900 border border-blue-500/30 rounded-2xl p-5"><h3 class="font-bold text-lg mb-3 text-blue-400">Speediance</h3><ul class="space-y-2 text-sm text-neutral-300"><li><span class="text-neutral-500">Inicial:</span> $4,995</li><li><span class="text-neutral-500">Mensal:</span> $39/mês (opcional)</li><li><span class="text-neutral-500">Total em 5 anos:</span> $7,335</li><li><span class="text-neutral-500">Resistência:</span> 220 lbs no cabo</li><li><span class="text-neutral-500">Excêntrico:</span> <span class="text-green-400">✓ Sim</span></li><li><span class="text-neutral-500">Spotter:</span> <span class="text-green-400">✓ IA adaptativa</span></li><li><span class="text-neutral-500">App:</span> Boa (melhorando)</li><li><span class="text-neutral-500">Suporte:</span> Responsivo</li><li><span class="text-neutral-500">Garantia:</span> 2 anos</li><li><span class="text-neutral-500">Instalação:</span> Autônomo</li><li><span class="text-neutral-500">Aumentos de preço:</span> <span class="text-green-400">Nenhum ✓</span></li></ul></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5"><h3 class="font-bold text-lg mb-3 text-neutral-300">Tonal</h3><ul class="space-y-2 text-sm text-neutral-300"><li><span class="text-neutral-500">Inicial:</span> $2,495 + $39/mês</li><li><span class="text-neutral-500">Mensal:</span> <span class="text-red-400">$39/mês obrigatório</span></li><li><span class="text-neutral-500">Total em 5 anos:</span> $5,303</li><li><span class="text-neutral-500">Resistência:</span> 200 lbs digital</li><li><span class="text-neutral-500">Excêntrico:</span> <span class="text-green-400">✓ Sim</span></li><li><span class="text-neutral-500">Spotter:</span> <span class="text-green-400">✓ Sim</span></li><li><span class="text-neutral-500">App:</span> Excelente</li><li><span class="text-neutral-500">Suporte:</span> Teve problemas</li><li><span class="text-neutral-500">Garantia:</span> 1 ano</li><li><span class="text-neutral-500">Instalação:</span> Montagem na parede</li><li><span class="text-neutral-500">Aumentos de preço:</span> <span class="text-red-400">Teve ✗</span></li></ul></div><div class="bg-neutral-900 border border-green-500/30 rounded-2xl p-5"><h3 class="font-bold text-lg mb-3 text-green-400">Academia tradicional</h3><ul class="space-y-2 text-sm text-neutral-300"><li><span class="text-neutral-500">Inicial:</span> $0-$200 de matrícula</li><li><span class="text-neutral-500">Mensal:</span> ~$150/mês</li><li><span class="text-neutral-500">Total em 5 anos:</span> $9,000</li><li><span class="text-neutral-500">Resistência:</span> <span class="text-green-400">Ilimitada</span></li><li><span class="text-neutral-500">Excêntrico:</span> <span class="text-green-400">✓ Com parceiro</span></li><li><span class="text-neutral-500">Spotter:</span> <span class="text-green-400">Com humano</span></li><li><span class="text-neutral-500">App:</span> N/A</li><li><span class="text-neutral-500">Suporte:</span> Varia</li><li><span class="text-neutral-500">Garantia:</span> N/A</li><li><span class="text-neutral-500">Instalação:</span> N/A</li><li><span class="text-neutral-500">Aumentos de preço:</span> Ocasional</li></ul></div></div><div class="hidden md:block overflow-x-auto"><table class="w-full text-sm"><thead><tr class="border-b border-neutral-800"><th class="text-left py-3 px-4 text-neutral-400 font-medium w-1/4">Recurso</th><th class="text-center py-3 px-4 text-blue-400 font-bold w-1/4">Speediance</th><th class="text-center py-3 px-4 text-neutral-300 font-bold w-1/4">Tonal</th><th class="text-center py-3 px-4 text-green-400 font-bold w-1/4">Academia tradicional</th></tr></thead><tbody class="divide-y divide-neutral-800">{comparisonFeatures.map((row, index) => (<tr class={`hover:bg-neutral-900/50 transition-colors ${index % 2 === 0 ? 'bg-neutral-900/30' : ''}`}><td class="py-3 px-4 text-neutral-400">{row.feature}</td><td class="py-3 px-4 text-center text-blue-300">{row.speediance}</td><td class="py-3 px-4 text-center text-neutral-300">{row.tonal}</td><td class="py-3 px-4 text-center text-green-300">{row.traditional}</td></tr>))}</tbody></table></div></div></section>
    <section class="py-16"><div class="container mx-auto px-4"><h2 class="text-3xl font-bold mb-2">Minha experiência</h2><p class="text-neutral-400 mb-10">Números reais de treinos reais — sem adivinhação</p><div class="grid md:grid-cols-3 gap-6"><div class="bg-neutral-900 border border-blue-500/30 rounded-2xl p-6"><div class="flex items-center gap-3 mb-5"><div class="w-10 h-10 rounded-xl bg-blue-900/40 flex items-center justify-center font-bold text-blue-400">S</div><div><h3 class="font-bold text-lg">Speediance</h3><div class="flex items-center gap-2"><p class="text-xs text-neutral-500">Desde ago 2025</p><span class="text-xs bg-blue-500/20 text-blue-400 px-2 py-0.5 rounded-full border border-blue-500/30">Atual</span></div></div></div><div class="grid grid-cols-2 gap-3 mb-5"><div class="bg-blue-900/20 rounded-xl p-3 border border-blue-500/10"><div class="text-2xl font-bold text-blue-300">1.29M+</div><div class="text-xs text-neutral-500 mt-0.5">lbs levantadas</div></div><div class="bg-blue-900/20 rounded-xl p-3 border border-blue-500/10"><div class="text-2xl font-bold text-green-400">$4,995</div><div class="text-xs text-neutral-500 mt-0.5">custo inicial</div></div><div class="bg-blue-900/20 rounded-xl p-3 border border-blue-500/10"><div class="text-2xl font-bold text-green-400">$39/mês</div><div class="text-xs text-neutral-500 mt-0.5">assinatura opcional</div></div><div class="bg-blue-900/20 rounded-xl p-3 border border-blue-500/10"><div class="text-2xl font-bold text-blue-400">220 lbs</div><div class="text-xs text-neutral-500 mt-0.5">resistência máxima</div></div></div><p class="text-neutral-400 text-sm leading-relaxed">Mudar para o Speediance eliminou a ansiedade com assinatura. O design autônomo significou não furar a parede, e as 220 lbs de resistência por cabo cobrem tudo de que preciso. O modo de IA se adapta em tempo real — algo que o Tonal não conseguia igualar.</p></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6"><div class="flex items-center gap-3 mb-5"><div class="w-10 h-10 rounded-xl bg-neutral-800 flex items-center justify-center font-bold text-neutral-300">T</div><div><h3 class="font-bold text-lg">Tonal</h3><p class="text-xs text-neutral-500">Usei por anos</p></div></div><div class="grid grid-cols-2 gap-3 mb-5"><div class="bg-neutral-800/60 rounded-xl p-3"><div class="text-2xl font-bold text-white">9M+</div><div class="text-xs text-neutral-500 mt-0.5">lbs levantadas</div></div><div class="bg-neutral-800/60 rounded-xl p-3"><div class="text-2xl font-bold text-white">$2,495</div><div class="text-xs text-neutral-500 mt-0.5">custo inicial</div></div><div class="bg-neutral-800/60 rounded-xl p-3"><div class="text-2xl font-bold text-red-400">$39/mês</div><div class="text-xs text-neutral-500 mt-0.5">assinatura obrigatória</div></div><div class="bg-neutral-800/60 rounded-xl p-3"><div class="text-2xl font-bold text-neutral-400">200 lbs</div><div class="text-xs text-neutral-500 mt-0.5">resistência máxima</div></div></div><p class="text-neutral-400 text-sm leading-relaxed">O Tonal foi minha primeira smart gym em casa e mudou tudo. Fui um usuário consistente por anos, construindo força de verdade e acompanhando cada repetição. Mas a assinatura nunca caiu bem — e quando os preços começaram a subir, comecei a procurar alternativas.</p></div><div class="bg-neutral-900 border border-green-500/30 rounded-2xl p-6"><div class="flex items-center gap-3 mb-5"><div class="w-10 h-10 rounded-xl bg-green-900/30 flex items-center justify-center font-bold text-green-400">G</div><div><h3 class="font-bold text-lg">Academia tradicional</h3><p class="text-xs text-neutral-500">Antes da era das smart gyms</p></div></div><div class="grid grid-cols-2 gap-3 mb-5"><div class="bg-green-900/20 rounded-xl p-3 border border-green-500/10"><div class="text-2xl font-bold text-green-300">∞</div><div class="text-xs text-neutral-500 mt-0.5">limite de resistência</div></div><div class="bg-green-900/20 rounded-xl p-3 border border-green-500/10"><div class="text-2xl font-bold text-neutral-400">~$0</div><div class="text-xs text-neutral-500 mt-0.5">sem custo de equipamento</div></div><div class="bg-green-900/20 rounded-xl p-3 border border-green-500/10"><div class="text-2xl font-bold text-red-400">~$150/mês</div><div class="text-xs text-neutral-500 mt-0.5">custo da mensalidade</div></div><div class="bg-green-900/20 rounded-xl p-3 border border-green-500/10"><div class="text-2xl font-bold text-green-400">Completo</div><div class="text-xs text-neutral-500 mt-0.5">acesso a comodidades</div></div></div><p class="text-neutral-400 text-sm leading-relaxed">Antes de migrar para o inteligente, passei anos em academias tradicionais. A variedade de equipamentos é imbatível, e há algo na atmosfera da academia que não dá para reproduzir em casa. Dito isso, deslocamento, espera por aparelhos e custos mensais se acumulam.</p></div></div></div></section>
    <section class="py-16 bg-neutral-900/50"><div class="container mx-auto px-4"><h2 class="text-3xl font-bold mb-10 text-center">Prós e contras</h2><div class="grid md:grid-cols-3 gap-6"><div class="bg-neutral-900 border border-blue-500/30 rounded-2xl p-6"><h3 class="font-bold text-lg mb-5 text-blue-400">Speediance</h3><div class="mb-5"><p class="text-xs font-bold tracking-widest text-green-500 uppercase mb-3">Prós</p><ul class="space-y-2">{speediancePros.map(pro => (<li class="flex items-start gap-2 text-sm text-neutral-300"><span class="text-green-400 mt-0.5 flex-shrink-0">✓</span>{pro}</li>))}</ul></div><div><p class="text-xs font-bold tracking-widest text-red-500 uppercase mb-3">Contras</p><ul class="space-y-2">{speedianceCons.map(con => (<li class="flex items-start gap-2 text-sm text-neutral-300"><span class="text-red-400 mt-0.5 flex-shrink-0">✗</span>{con}</li>))}</ul></div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6"><h3 class="font-bold text-lg mb-5 text-neutral-300">Tonal</h3><div class="mb-5"><p class="text-xs font-bold tracking-widest text-green-500 uppercase mb-3">Prós</p><ul class="space-y-2">{tonalPros.map(pro => (<li class="flex items-start gap-2 text-sm text-neutral-300"><span class="text-green-400 mt-0.5 flex-shrink-0">✓</span>{pro}</li>))}</ul></div><div><p class="text-xs font-bold tracking-widest text-red-500 uppercase mb-3">Contras</p><ul class="space-y-2">{tonalCons.map(con => (<li class="flex items-start gap-2 text-sm text-neutral-300"><span class="text-red-400 mt-0.5 flex-shrink-0">✗</span>{con}</li>))}</ul></div></div><div class="bg-neutral-900 border border-green-500/30 rounded-2xl p-6"><h3 class="font-bold text-lg mb-5 text-green-400">Academia tradicional</h3><div class="mb-5"><p class="text-xs font-bold tracking-widest text-green-500 uppercase mb-3">Prós</p><ul class="space-y-2">{traditionalGymPros.map(pro => (<li class="flex items-start gap-2 text-sm text-neutral-300"><span class="text-green-400 mt-0.5 flex-shrink-0">✓</span>{pro}</li>))}</ul></div><div><p class="text-xs font-bold tracking-widest text-red-500 uppercase mb-3">Contras</p><ul class="space-y-2">{traditionalGymCons.map(con => (<li class="flex items-start gap-2 text-sm text-neutral-300"><span class="text-red-400 mt-0.5 flex-shrink-0">✗</span>{con}</li>))}</ul></div></div></div></div></section>
    <section class="py-16"><div class="container mx-auto px-4"><h2 class="text-3xl font-bold mb-2 text-center">Análise de custo no longo prazo</h2><p class="text-neutral-400 text-center mb-10">Os números não mentem — é isso que você realmente vai gastar com o tempo</p><div class="grid md:grid-cols-3 gap-6 mb-10"><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center"><h3 class="text-lg font-bold text-neutral-300 mb-4">Custo total em 1 ano</h3><div class="space-y-3"><div class="flex justify-between items-center py-2 border-b border-neutral-800"><span class="text-blue-400">Speediance</span><span class="font-bold text-white">$5,463</span></div><div class="flex justify-between items-center py-2 border-b border-neutral-800"><span class="text-neutral-300">Tonal</span><span class="font-bold text-white">$3,431</span></div><div class="flex justify-between items-center py-2"><span class="text-green-400">Academia tradicional</span><span class="font-bold text-white">$1,800</span></div></div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center"><h3 class="text-lg font-bold text-neutral-300 mb-4">Custo total em 3 anos</h3><div class="space-y-3"><div class="flex justify-between items-center py-2 border-b border-neutral-800"><span class="text-blue-400">Speediance</span><span class="font-bold text-white">$6,399</span></div><div class="flex justify-between items-center py-2 border-b border-neutral-800"><span class="text-neutral-300">Tonal</span><span class="font-bold text-white">$4,367</span></div><div class="flex justify-between items-center py-2"><span class="text-green-400">Academia tradicional</span><span class="font-bold text-white">$5,400</span></div></div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center"><h3 class="text-lg font-bold text-neutral-300 mb-4">Custo total em 5 anos</h3><div class="space-y-3"><div class="flex justify-between items-center py-2 border-b border-neutral-800"><span class="text-blue-400">Speediance</span><span class="font-bold text-white">$7,335</span></div><div class="flex justify-between items-center py-2 border-b border-neutral-800"><span class="text-neutral-300">Tonal</span><span class="font-bold text-white">$5,303</span></div><div class="flex justify-between items-center py-2"><span class="text-green-400">Academia tradicional</span><span class="font-bold text-white">$9,000</span></div></div></div></div><p class="text-neutral-400 text-sm text-center max-w-2xl mx-auto">* Os custos de Speediance e Tonal incluem assinaturas obrigatórias/opcionais. A academia tradicional assume média de ~$150/mês. Não inclui deslocamento, suplementos ou taxas adicionais.</p></div></section>
    <section class="py-16"><div class="container mx-auto px-4 max-w-3xl"><div class="bg-neutral-900 border border-blue-500/20 rounded-2xl p-8"><p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-3">Minha conclusão</p><h2 class="text-3xl font-bold mb-5">O veredito</h2><p class="text-neutral-300 leading-relaxed mb-4"><strong class="text-white">Para a maioria das pessoas com academia em casa, o Speediance vence em custo-benefício.</strong> O preço único de $4,995 (com assinatura opcional de $39/mês) se paga em comparação ao Tonal após cerca de 2 anos — e em comparação a uma academia tradicional após cerca de 3-4 anos.</p><p class="text-neutral-300 leading-relaxed mb-4">Sem exigir instalação na parede e com 220 lbs de resistência por cabo, o Speediance é a compra mais inteligente para a maioria dos setups de academia em casa. A adaptação por IA é genuinamente impressionante — ela ajusta a resistência no meio da série de um jeito que o Tonal simplesmente não consegue.</p><p class="text-neutral-300 leading-relaxed mb-4"><strong class="text-white">Ainda assim, academias tradicionais continuam fazendo sentido para algumas pessoas:</strong> Se você quer resistência ilimitada (cargas pesadas em agachamento/levantamento terra), manda bem em ambiente social ou quer acesso a aulas e comodidades sem comprar equipamento, uma academia tradicional por ~$150/mês ainda é uma escolha sólida.</p><p class="text-neutral-400 leading-relaxed mb-8">A biblioteca de conteúdo do Tonal e a qualidade do coaching são excepcionais, e tive anos de ótimos treinos nele. Mas a assinatura obrigatória e os aumentos de preço tornaram a venda mais difícil. Depois de 9M+ lbs, estou feliz com minha decisão de mudar para o Speediance.</p><div class="flex flex-wrap gap-4"><a href="/roi/" class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-xl transition-colors">Calcule seu ROI →</a><a href="/gear/" class="inline-flex items-center gap-2 px-6 py-3 bg-neutral-800 hover:bg-neutral-700 text-white font-semibold rounded-xl transition-colors border border-neutral-700">Ver reviews completos de equipamentos →</a></div></div></div></section>
