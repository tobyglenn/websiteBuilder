---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.jsx';
import Footer from '../../components/Footer.jsx';
import {
  NUTRITION_STATS,
  MONTHLY_TRENDS,
  RECENT_RECORDS,
  LAST_SYNCED,
  TOTAL_DAYS_TRACKED,
} from '../../data/nutrition.js';

// SVG bar chart dimensions
const chartWidth = 600;
const chartHeight = 200;
const chartPadding = { top: 10, right: 10, bottom: 40, left: 40 };
const innerWidth = chartWidth - chartPadding.left - chartPadding.right;
const innerHeight = chartHeight - chartPadding.top - chartPadding.bottom;

const maxCalories = Math.max(...MONTHLY_TRENDS.map(d => d.avgCalories), 1);
const barWidth = MONTHLY_TRENDS.length > 0 ? Math.floor(innerWidth / MONTHLY_TRENDS.length) - 4 : 0;

function barX(i) {
  return chartPadding.left + i * (innerWidth / MONTHLY_TRENDS.length) + 2;
}
function barHeight(val) {
  return Math.round((val / maxCalories) * innerHeight);
}
function barY(val) {
  return chartPadding.top + innerHeight - barHeight(val);
}
function monthLabel(m) {
  const [year, month] = m.split('-');
  const date = new Date(parseInt(year), parseInt(month) - 1, 1);
  return date.toLocaleString('default', { month: 'short', year: '2-digit' });
}

// FAQPage JSON-LD
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "O que é o Cronometer e por que usá-lo para acompanhar a nutrição?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cronometer é um aplicativo de acompanhamento nutricional que fornece dados detalhados de micronutrientes além dos macronutrientes. Ele é popular entre entusiastas do fitness por sua precisão e ampla base de dados de alimentos."
      }
    },
    {
      "@type": "Question",
      "name": "Quanta proteína devo consumir por dia para ganhar músculo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A maioria das pesquisas sugere 0,7–1 g de proteína por libra de peso corporal (1,6–2,2 g por kg) para crescimento muscular. Acompanhar com ferramentas como o Cronometer ajuda a garantir que você atinja essas metas com consistência."
      }
    },
    {
      "@type": "Question",
      "name": "Como acompanho a ingestão de água com precisão?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Registre todas as bebidas, incluindo água, café e o conteúdo de água dos alimentos, no Cronometer. Busque pelo menos 2–3 litros por dia, mais se estiver treinando pesado ou em condições de calor."
      }
    }
  ]
};
---

<Layout title="Estatísticas de nutrição | TobyOnFitnessTech" description="Dados reais de acompanhamento alimentar do Cronometer — calorias, proteína, carboidratos, gordura e hidratação ao longo do tempo.">
  <Header client:load />

  <main class="min-h-screen bg-neutral-950 text-white">
    <!-- Hero -->
    <section id="hero" class="pt-24 pb-12 px-4">
      <div class="max-w-5xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 bg-blue-500/10 border border-blue-500/20 rounded-full px-4 py-1.5 mb-6">
          <span class="text-blue-400 text-sm font-medium">Dados do Cronometer</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Estatísticas de nutrição</h1>
        <p class="text-neutral-400 text-lg max-w-2xl mx-auto">
          Acompanhando o que eu como para alimentar meu desempenho
        </p>
        {LAST_SYNCED && (
          <p class="text-neutral-600 text-sm mt-3">Última sincronização: {LAST_SYNCED}</p>
        )}
      </div>
    </section>

    <!-- Stat Cards -->
    <section id="nutrition-stats" class="px-4 pb-12">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          <div class="bg-neutral-900 rounded-xl p-5 border border-neutral-800">
            <p class="text-neutral-400 text-sm mb-1">Média de calorias</p>
            <p class="text-3xl font-bold text-blue-400">{NUTRITION_STATS.avgCalories.toLocaleString()}</p>
            <p class="text-neutral-500 text-xs mt-1">kcal / dia</p>
          </div>
          <div class="bg-neutral-900 rounded-xl p-5 border border-neutral-800">
            <p class="text-neutral-400 text-sm mb-1">Média de proteína</p>
            <p class="text-3xl font-bold text-blue-400">{NUTRITION_STATS.avgProtein}</p>
            <p class="text-neutral-500 text-xs mt-1">gramas / dia</p>
          </div>
          <div class="bg-neutral-900 rounded-xl p-5 border border-neutral-800">
            <p class="text-neutral-400 text-sm mb-1">Média de carboidratos</p>
            <p class="text-3xl font-bold text-blue-400">{NUTRITION_STATS.avgCarbs}</p>
            <p class="text-neutral-500 text-xs mt-1">gramas / dia</p>
          </div>
          <div class="bg-neutral-900 rounded-xl p-5 border border-neutral-800">
            <p class="text-neutral-400 text-sm mb-1">Média de gordura</p>
            <p class="text-3xl font-bold text-blue-400">{NUTRITION_STATS.avgFat}</p>
            <p class="text-neutral-500 text-xs mt-1">gramas / dia</p>
          </div>
          <div class="bg-neutral-900 rounded-xl p-5 border border-neutral-800">
            <p class="text-neutral-400 text-sm mb-1">Média de água</p>
            <p class="text-3xl font-bold text-blue-400">{NUTRITION_STATS.avgWater}</p>
            <p class="text-neutral-500 text-xs mt-1">litros / dia</p>
          </div>
          <div class="bg-neutral-900 rounded-xl p-5 border border-neutral-800">
            <p class="text-neutral-400 text-sm mb-1">Dias registrados</p>
            <p class="text-3xl font-bold text-blue-400">{TOTAL_DAYS_TRACKED}</p>
            <p class="text-neutral-500 text-xs mt-1">dias totais</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Monthly Calorie Trend -->
    {MONTHLY_TRENDS.length > 0 && (
      <section id="monthly-avg-calories" class="px-4 pb-12">
        <div class="max-w-5xl mx-auto">
          <h2 class="text-xl font-semibold mb-4">Média mensal de calorias</h2>
          <div class="bg-neutral-900 rounded-xl border border-neutral-800 p-6 overflow-x-auto">
            <svg
              viewBox={`0 0 ${chartWidth} ${chartHeight}`}
              class="w-full"
              style={`min-width: ${Math.max(300, MONTHLY_TRENDS.length * 60)}px`}
            >
              {/* Y-axis gridlines */}
              {[0, 0.25, 0.5, 0.75, 1].map((pct) => {
                const y = chartPadding.top + innerHeight - pct * innerHeight;
                return (
                  <g>
                    <line
                      x1={chartPadding.left}
                      y1={y}
                      x2={chartPadding.left + innerWidth}
                      y2={y}
                      stroke="#404040"
                      stroke-width="1"
                    />
                    <text
                      x={chartPadding.left - 6}
                      y={y + 4}
                      fill="#737373"
                      font-size="10"
                      text-anchor="end"
                    >
                      {Math.round(maxCalories * pct)}
                    </text>
                  </g>
                );
              })}
              {/* Bars */}
              {MONTHLY_TRENDS.map((d, i) => (
                <g>
                  <rect
                    x={barX(i)}
                    y={barY(d.avgCalories)}
                    width={barWidth}
                    height={barHeight(d.avgCalories)}
                    fill="#3B82F6"
                    rx="2"
                  />
                  <text
                    x={barX(i) + barWidth / 2}
                    y={chartPadding.top + innerHeight + 16}
                    fill="#737373"
                    font-size="9"
                    text-anchor="middle"
                  >
                    {monthLabel(d.month)}
                  </text>
                  <text
                    x={barX(i) + barWidth / 2}
                    y={barY(d.avgCalories) - 4}
                    fill="#93C5FD"
                    font-size="9"
                    text-anchor="middle"
                  >
                    {d.avgCalories.toLocaleString()}
                  </text>
                </g>
              ))}
            </svg>
          </div>
        </div>
      </section>
    )}

    <!-- Recent Entries Table -->
    {RECENT_RECORDS.length > 0 && (
      <section id="recent-entries" class="px-4 pb-16">
        <div class="max-w-5xl mx-auto">
          <h2 class="text-xl font-semibold mb-4">Registros recentes</h2>
          <div class="bg-neutral-900 rounded-xl border border-neutral-800 overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-neutral-800">
                  <th class="text-left text-neutral-400 font-medium px-4 py-3">Data</th>
                  <th class="text-right text-neutral-400 font-medium px-4 py-3">Calorias</th>
                  <th class="text-right text-neutral-400 font-medium px-4 py-3">Proteína</th>
                  <th class="text-right text-neutral-400 font-medium px-4 py-3">Carboidratos</th>
                  <th class="text-right text-neutral-400 font-medium px-4 py-3">Gordura</th>
                  <th class="text-right text-neutral-400 font-medium px-4 py-3">Água</th>
                </tr>
              </thead>
              <tbody>
                {RECENT_RECORDS.map((r, i) => (
                  <tr class={i % 2 === 0 ? 'bg-neutral-900' : 'bg-neutral-800/40'}>
                    <td class="px-4 py-2.5 text-neutral-300">{r.date}</td>
                    {r.tracked ? (
                      <>
                        <td class="px-4 py-2.5 text-right text-blue-400 font-medium">{Math.round(r.calories).toLocaleString()}</td>
                        <td class="px-4 py-2.5 text-right text-neutral-300">{Math.round(r.protein)}g</td>
                        <td class="px-4 py-2.5 text-right text-neutral-300">{Math.round(r.carbs)}g</td>
                        <td class="px-4 py-2.5 text-right text-neutral-300">{Math.round(r.fat)}g</td>
                        <td class="px-4 py-2.5 text-right text-neutral-500">
                          {r.water > 0 ? `${(r.water / 1000).toFixed(2)}L` : '—'}
                        </td>
                      </>
                    ) : (
                      <td colspan="5" class="px-4 py-2.5 text-center text-neutral-600 italic text-xs">Não registrado</td>
                    )}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer client:load />
</Layout>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
