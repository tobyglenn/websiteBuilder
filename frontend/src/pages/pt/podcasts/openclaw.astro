---
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import Layout from '../../../layouts/Layout.astro';
import PodcastSubscribeButtons from '../../../components/PodcastSubscribeButtons.jsx';
import {
  ensureEpisodeFromFallbackFeed,
  extractAttr,
  extractChannelItems,
  extractTag,
  fetchPinnedGitHubRawText,
  normalizeEpisodeTitle,
  parseEpisodeNumber,
} from '../../../lib/openclawFeed';

const LANG = 'pt';
const feedUrl = `https://raw.githubusercontent.com/grayking-creator/openclaw-podcast/main/translations/feed_${LANG}.xml`;
const publicFeedUrl = `https://tobyonfitnesstech.com/${LANG}/podcasts/feed.xml`;

interface Episode {
  episodeNum: number;
  title: string;
  description: string;
  pubDate: string;
  audioUrl: string;
  duration: string;
  showNotesUrl: string;
  coverImage: string;
}

function formatDate(raw: string): string {
  try {
    const d = new Date(raw);
    return d.toLocaleDateString('pt-BR', { month: 'long', day: 'numeric', year: 'numeric' });
  } catch {
    return raw;
  }
}

let episodes: Episode[] = [];
let fetchError = false;

try {
  const xml = await fetchPinnedGitHubRawText(feedUrl);

  let items = extractChannelItems(xml);
  items = await ensureEpisodeFromFallbackFeed(items, 0);

  for (const item of items) {
    const title = normalizeEpisodeTitle(extractTag(item, 'title'));
    const description = extractTag(item, 'description');
    const pubDateRaw = extractTag(item, 'pubDate');
    const audioUrl = extractAttr(item, 'enclosure', 'url');
    const duration = extractTag(item, 'itunes:duration');
    const link = extractTag(item, 'link');
    const showNotesUrl = link;
    const pubDate = formatDate(pubDateRaw);
    const episodeNum = parseEpisodeNumber(item);
    const baseEpNum = String(episodeNum).padStart(3, '0');
    const localeCover = `/images/podcast/episode_${baseEpNum}_cover_pt.png`;
    const fallbackCover = `/images/podcast/episode_${baseEpNum}_cover.png`;
    const localeCoverPath = fileURLToPath(new URL(`../../../../public${localeCover}`, import.meta.url));
    const coverImage = existsSync(localeCoverPath) ? localeCover : fallbackCover;

    episodes.push({ episodeNum, title, description, pubDate, audioUrl, duration, showNotesUrl, coverImage });
  }

  episodes.sort((a, b) => b.episodeNum - a.episodeNum);
} catch (err) {
  fetchError = true;
  console.error('[pt/podcasts/openclaw.astro] RSS fetch failed:', err);
}
---

<Layout
  title="OpenClaw Daily | Toby on Fitness Tech"
  description="Episódios diários de IA sobre tecnologia fitness, IA local, hardware, segurança e o ecossistema OpenClaw."
  lang={LANG}
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <!-- Hero -->
    <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6 mb-12">
      <img src="/images/podcast/show_art_pt.png" alt="OpenClaw Daily" class="w-28 h-28 md:w-36 md:h-36 rounded-2xl border border-neutral-700 shrink-0 shadow-lg shadow-blue-900/20" loading="lazy" />
      <div class="text-center sm:text-left">
        <h2 class="text-4xl md:text-5xl font-bold mb-3 bg-gradient-to-r from-blue-500 to-purple-500 bg-clip-text text-transparent">
          OpenClaw Daily
        </h2>
        <p class="text-neutral-400 text-lg leading-relaxed max-w-2xl">
          Episódios diários de IA sobre tecnologia fitness, IA local, hardware, segurança
        e o ecossistema OpenClaw — novas perspectivas todos os dias.
        </p>
        <div class="mt-3">
          <span class="bg-blue-500/10 border border-blue-500/20 text-blue-300 text-sm px-4 py-1.5 rounded-full inline-block">
            🎤 Anfitriões: Nova &amp; Alloy
          </span>
        </div>
      </div>
    </div>

    <!-- Subscribe Buttons -->
    <div class="mb-10">
      <PodcastSubscribeButtons
        spotifyUrl="https://open.spotify.com/show/3ohlOiRLwQPNMD5JT82vLa"
        appleUrl="https://podcasts.apple.com/us/podcast/openclaw-daily-portugu%C3%AAs/id1879607041"
        pocketcastsUrl="https://pca.st/disimp8x"
        overcastUrl="https://overcast.fm/itunes1879607041"
        amazonUrl="https://music.amazon.com/podcasts/86a6581d-4398-4300-8fe4-94a037722a6f"
        youtubeUrl="https://www.youtube.com/@openclawdailypt"
        client:load
      />
    </div>

    <!-- RSS Feed -->
    <div class="mb-8 bg-blue-500/10 border border-blue-500/30 rounded-xl p-4 flex flex-col sm:flex-row items-start sm:items-center gap-3">
      <div class="flex-1">
        <p class="text-blue-400 text-sm font-semibold mb-1">📡 RSS Feed</p>
        <code class="text-neutral-300 text-xs break-all select-all">{publicFeedUrl}</code>
      </div>
      <a
        href={publicFeedUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="shrink-0 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors"
      >
        Open Feed
      </a>
    </div>

    <!-- Episodes -->
    {fetchError ? (
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
        <p class="text-neutral-400 text-sm">⚠️ Episódios temporariamente indisponíveis. Por favor, volte em breve.</p>
      </div>
    ) : episodes.length === 0 ? (
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
        <p class="text-neutral-400 text-sm">Nenhum episódio encontrado no feed ainda.</p>
      </div>
    ) : (
      <div class="space-y-4">
        {episodes.map((ep) => (
          <article class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:shadow-xl hover:shadow-blue-400/5 hover:border-neutral-700 transition-all">
            <div class="flex gap-4 mb-4">
              <img
                src={ep.coverImage}
                alt={`Episode ${ep.episodeNum} cover art`}
                class="w-20 h-20 sm:w-24 sm:h-24 rounded-xl object-cover shrink-0 border border-neutral-700"
                onerror="this.src=this.src.replace(/_pt.png/,'.png')"
              />
              <div class="flex flex-col justify-center min-w-0">
                <span class="bg-blue-400/10 text-blue-400 text-xs font-bold px-2 py-0.5 rounded-full self-start mb-2">
                  EP {ep.episodeNum}
                </span>
                <h2 class="text-xl font-bold text-white leading-snug">
                  {ep.title}
                </h2>
              </div>
            </div>
            <p class="text-neutral-400 text-sm leading-relaxed mb-3">{ep.description}</p>
            <p class="text-neutral-500 text-xs mb-4 flex items-center gap-2 flex-wrap">
              <span>{ep.pubDate}</span>
              {ep.duration && (
                <>
                  <span>·</span>
                  <span>⏱ {ep.duration}</span>
                </>
              )}
            </p>
            <div class="mt-2">
              <a
                href={ep.audioUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-500 hover:to-purple-500 rounded-xl font-semibold text-white text-sm transition-all duration-200 hover:scale-[1.01] mb-2"
              >
                🎧 Ouvir
              </a>
              <div class="grid grid-cols-2 gap-2">
                <a
                  href={`/pt/podcasts/episode-${ep.episodeNum}/`}
                  class="flex items-center justify-center gap-1.5 px-3 py-2 rounded-lg text-xs font-medium bg-neutral-800 border border-neutral-700 text-neutral-400 hover:text-white hover:border-neutral-500 transition-all"
                >
                  📄 Notas do Programa
                </a>
                <a
                  href={`/pt/podcasts/episode-${ep.episodeNum}/?tab=transcript`}
                  class="flex items-center justify-center gap-1.5 px-3 py-2 rounded-lg text-xs font-medium bg-neutral-800 border border-neutral-700 text-neutral-400 hover:text-white hover:border-neutral-500 transition-all"
                >
                  📝 Transcrição
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    )}

    <!-- Footer note -->
    <p class="text-center text-neutral-600 text-xs mt-12">
      Episódios gerados por OpenClaw AI · Vozes por OpenAI TTS
    </p>
  </div>
</Layout>
