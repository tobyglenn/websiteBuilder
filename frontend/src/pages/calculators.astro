---
import Layout from '../layouts/Layout.astro';

const exercises = [
  {"name":"Barbell Deadlift","best1RM":388,"workout":"Leg Day"},
  {"name":"Kneeling Barbell Lat Pulldown","best1RM":294,"workout":"Back Barbell"},
  {"name":"Kneeling Barbell Reverse-Grip Lat Pulldown","best1RM":280,"workout":"Back Barbell"},
  {"name":"Seated Barbell Reverse-Grip Lat Pulldown","best1RM":248,"workout":"Back Barbell"},
  {"name":"Barbell Hip Thrust","best1RM":240,"workout":"Leg Day"},
  {"name":"Barbell Bench Press","best1RM":232,"workout":"Warrior 3 (bar)"},
  {"name":"Seated Barbell Wide Row","best1RM":202,"workout":"Back Barbell"},
  {"name":"Barbell Bent Over Row","best1RM":198,"workout":"Back Barbell"},
  {"name":"Seated Barbell Lat Pulldown","best1RM":192,"workout":"Back Barbell"},
  {"name":"Seated Barbell Row","best1RM":192,"workout":"Back Barbell"},
  {"name":"Incline Barbell Bench Press","best1RM":185,"workout":"Warrior 3 (bar)"},
  {"name":"Standing Barbell Triceps Push Down","best1RM":170,"workout":"Arms Barbell"},
  {"name":"Seated Barbell Reverse-Grip Row","best1RM":170,"workout":"Back Barbell"},
  {"name":"Incline Barbell Straight Arm Pushdown","best1RM":168,"workout":"Back Barbell"},
  {"name":"Barbell Stiff-Leg Deadlift","best1RM":140,"workout":"Leg Day"},
  {"name":"Bent-Over Reverse-Grip Barbell Row","best1RM":126,"workout":"Back Barbell"},
  {"name":"Kneeling Dual-Handle Lat Pulldown","best1RM":125,"workout":"Warrior 2"},
  {"name":"Incline Barbell Close-Grip Chest Press","best1RM":125,"workout":"Warrior 3 (bar)"},
  {"name":"Tricep Rope Romanian Deadlift","best1RM":120,"workout":"Warrior 4 (rope)"},
  {"name":"Seated Dual-Handle Wide Row","best1RM":110,"workout":"Warrior 1"},
  {"name":"Barbell Squat","best1RM":68,"workout":"Leg Day"},
  {"name":"Barbell Romanian Deadlift","best1RM":52,"workout":"Leg Day"},
];

const workoutCategories = ["Leg Day","Back Barbell","Warrior 3 (bar)","Warrior 1","Warrior 2","Warrior 4 (rope)","Arms Barbell"];
const exercisesByCategory: Record<string, typeof exercises> = {};
workoutCategories.forEach(cat => {
  exercisesByCategory[cat] = exercises.filter(e => e.workout === cat);
});

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Fitness Calculators | Toby on Fitness Tech",
  "description": "Free fitness calculators: TDEE & macro calculator using Mifflin-St Jeor, and a 1RM calculator using Epley & Brzycki formulas.",
  "url": "https://tobyonfitnesstech.com/calculators"
};
---

<Layout
  title="Fitness Calculators | Toby on Fitness Tech"
  description="Free fitness calculators: TDEE & macro calculator and 1RM calculator. Calculate your daily calorie needs, macros, and one-rep max instantly."
  jsonLd={jsonLd}
>
  <main class="min-h-screen bg-neutral-950 text-white py-12 px-4">
    <div class="max-w-3xl mx-auto">

      <!-- Hero -->
      <div class="text-center mb-10">
        <h1 class="text-4xl md:text-5xl font-bold mb-3 bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">
          Fitness Calculators
        </h1>
        <p class="text-neutral-400 text-lg">TDEE, macros, and one-rep max — all in one place</p>
      </div>

      <!-- Tabs -->
      <div class="flex gap-2 mb-8 bg-neutral-900 rounded-xl p-1 border border-neutral-800">
        <button
          id="tab-tdee"
          onclick="switchTab('tdee')"
          class="flex-1 py-2.5 px-4 rounded-lg text-sm font-semibold transition-all bg-blue-600 text-white"
        >
          Calories &amp; Macros
        </button>
        <button
          id="tab-1rm"
          onclick="switchTab('1rm')"
          class="flex-1 py-2.5 px-4 rounded-lg text-sm font-semibold transition-all text-neutral-400 hover:text-white"
        >
          1RM Calculator
        </button>
      </div>

      <!-- TDEE Panel -->
      <div id="panel-tdee">
        <div class="bg-neutral-900/50 border border-neutral-800 rounded-2xl p-6 md:p-8">
          <form id="tdee-form" class="space-y-5">
            <div>
              <label class="block text-sm font-medium text-neutral-300 mb-2">Gender</label>
              <div class="flex gap-4">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="gender" value="male" checked class="w-4 h-4 accent-blue-500" />
                  <span class="text-neutral-200">Male</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="gender" value="female" class="w-4 h-4 accent-blue-500" />
                  <span class="text-neutral-200">Female</span>
                </label>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label for="t-age" class="block text-sm font-medium text-neutral-300 mb-2">Age</label>
                <input type="number" id="t-age" value="35" min="15" max="100"
                  class="w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-xl text-white focus:outline-none focus:border-blue-500" />
              </div>
              <div>
                <label for="t-height" class="block text-sm font-medium text-neutral-300 mb-2">Height (cm)</label>
                <input type="number" id="t-height" value="180" min="100" max="250"
                  class="w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-xl text-white focus:outline-none focus:border-blue-500" />
              </div>
            </div>
            <div>
              <label for="t-weight" class="block text-sm font-medium text-neutral-300 mb-2">Weight (lbs)</label>
              <input type="number" id="t-weight" value="215" min="50" max="500"
                class="w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-xl text-white focus:outline-none focus:border-blue-500" />
            </div>
            <div>
              <label for="t-activity" class="block text-sm font-medium text-neutral-300 mb-2">Activity Level</label>
              <select id="t-activity"
                class="w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-xl text-white focus:outline-none focus:border-blue-500">
                <option value="1.2">Sedentary (little or no exercise)</option>
                <option value="1.375">Lightly Active (1-3 days/week)</option>
                <option value="1.55" selected>Moderately Active (3-5 days/week)</option>
                <option value="1.725">Very Active (6-7 days/week)</option>
                <option value="1.9">Extra Active (very hard exercise)</option>
              </select>
            </div>
            <div>
              <label for="t-goal" class="block text-sm font-medium text-neutral-300 mb-2">Goal</label>
              <select id="t-goal"
                class="w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-xl text-white focus:outline-none focus:border-blue-500">
                <option value="cut">Cut (Lose Fat −20%)</option>
                <option value="maintain" selected>Maintain Weight</option>
                <option value="bulk">Bulk (Build Muscle +10%)</option>
              </select>
            </div>
            <button type="submit"
              class="w-full py-4 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-xl transition-colors">
              Calculate My Macros
            </button>
          </form>

          <div id="tdee-results" class="hidden mt-8 pt-8 border-t border-neutral-800">
            <h2 class="text-xl font-bold text-center mb-6">Your Daily Targets</h2>
            <div class="text-center mb-8">
              <p class="text-neutral-400 text-sm mb-1">Daily Calories</p>
              <p class="text-5xl font-bold text-blue-400" id="t-calories">0</p>
              <p class="text-neutral-500 text-sm mt-1" id="t-calories-breakdown">TDEE: 0</p>
            </div>
            <div class="grid grid-cols-3 gap-4">
              <div class="bg-blue-500/10 border border-blue-500/30 rounded-xl p-4 text-center">
                <p class="text-blue-400 text-sm font-medium mb-1">Protein</p>
                <p class="text-2xl font-bold" id="t-protein">0g</p>
                <p class="text-neutral-500 text-xs mt-1" id="t-protein-pct">0%</p>
              </div>
              <div class="bg-yellow-500/10 border border-yellow-500/30 rounded-xl p-4 text-center">
                <p class="text-yellow-400 text-sm font-medium mb-1">Fat</p>
                <p class="text-2xl font-bold" id="t-fat">0g</p>
                <p class="text-neutral-500 text-xs mt-1" id="t-fat-pct">0%</p>
              </div>
              <div class="bg-green-500/10 border border-green-500/30 rounded-xl p-4 text-center">
                <p class="text-green-400 text-sm font-medium mb-1">Carbs</p>
                <p class="text-2xl font-bold" id="t-carbs">0g</p>
                <p class="text-neutral-500 text-xs mt-1" id="t-carbs-pct">0%</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 1RM Panel -->
      <div id="panel-1rm" class="hidden">
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 md:p-8">
          <div class="mb-5">
            <label for="rm-exercise" class="block text-sm font-medium text-neutral-300 mb-2">Exercise (optional preset)</label>
            <select id="rm-exercise"
              class="w-full bg-neutral-800 border border-neutral-700 text-white rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500">
              <option value="">Custom (enter weight manually)</option>
              {workoutCategories.map(category => (
                <optgroup label={category}>
                  {exercisesByCategory[category].map(ex => (
                    <option value={JSON.stringify(ex)}>{ex.name} ({ex.best1RM} lbs)</option>
                  ))}
                </optgroup>
              ))}
            </select>
          </div>
          <div class="grid grid-cols-2 gap-4 mb-5">
            <div>
              <label for="rm-weight" class="block text-sm font-medium text-neutral-300 mb-2">Weight (lbs)</label>
              <input type="number" id="rm-weight" min="1" placeholder="Enter weight"
                class="w-full bg-neutral-800 border border-neutral-700 text-white rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500" />
            </div>
            <div>
              <label for="rm-reps" class="block text-sm font-medium text-neutral-300 mb-2">Reps (1–15)</label>
              <input type="number" id="rm-reps" min="1" max="15" placeholder="Enter reps"
                class="w-full bg-neutral-800 border border-neutral-700 text-white rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500" />
            </div>
          </div>
          <button id="rm-calculate-btn"
            class="w-full bg-blue-600 hover:bg-blue-500 text-white font-semibold py-4 px-6 rounded-xl transition-colors">
            Calculate 1RM
          </button>

          <div id="rm-results" class="hidden mt-8 pt-8 border-t border-neutral-700">
            <div class="grid grid-cols-3 gap-4 mb-8">
              <div class="bg-neutral-800 rounded-xl p-4 text-center">
                <p class="text-sm text-neutral-400 mb-1">Epley</p>
                <p id="rm-epley" class="text-2xl font-bold text-white">0</p>
                <p class="text-xs text-neutral-500">lbs</p>
              </div>
              <div class="bg-neutral-800 rounded-xl p-4 text-center">
                <p class="text-sm text-neutral-400 mb-1">Brzycki</p>
                <p id="rm-brzycki" class="text-2xl font-bold text-white">0</p>
                <p class="text-xs text-neutral-500">lbs</p>
              </div>
              <div class="bg-blue-500/20 border border-blue-500/30 rounded-xl p-4 text-center">
                <p class="text-sm text-blue-300 mb-1">Average</p>
                <p id="rm-average" class="text-2xl font-bold text-blue-400">0</p>
                <p class="text-xs text-blue-300/70">lbs</p>
              </div>
            </div>
            <h3 class="text-base font-semibold text-white mb-3">Training Percentages</h3>
            <div class="grid grid-cols-4 gap-3">
              {[100, 95, 90, 85, 80, 75, 70, 65].map(pct => (
                <div class="bg-neutral-800 rounded-lg p-3 text-center">
                  <p class="text-xs text-neutral-400 mb-1">{pct}%</p>
                  <p id={`rm-pct-${pct}`} class="text-base font-bold text-white">0</p>
                  <p class="text-xs text-neutral-500">lbs</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>
</Layout>

<script>
  // Tab switching
  function switchTab(tab: string) {
    const tdeePanel = document.getElementById('panel-tdee')!;
    const rmPanel = document.getElementById('panel-1rm')!;
    const tdeeBtn = document.getElementById('tab-tdee')!;
    const rmBtn = document.getElementById('tab-1rm')!;

    if (tab === 'tdee') {
      tdeePanel.classList.remove('hidden');
      rmPanel.classList.add('hidden');
      tdeeBtn.className = 'flex-1 py-2.5 px-4 rounded-lg text-sm font-semibold transition-all bg-blue-600 text-white';
      rmBtn.className = 'flex-1 py-2.5 px-4 rounded-lg text-sm font-semibold transition-all text-neutral-400 hover:text-white';
    } else {
      tdeePanel.classList.add('hidden');
      rmPanel.classList.remove('hidden');
      rmBtn.className = 'flex-1 py-2.5 px-4 rounded-lg text-sm font-semibold transition-all bg-blue-600 text-white';
      tdeeBtn.className = 'flex-1 py-2.5 px-4 rounded-lg text-sm font-semibold transition-all text-neutral-400 hover:text-white';
    }
  }
  (window as any).switchTab = switchTab;

  // TDEE calculator
  document.getElementById('tdee-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const gender = (document.querySelector('input[name="gender"]:checked') as HTMLInputElement)?.value;
    const age = parseInt((document.getElementById('t-age') as HTMLInputElement).value);
    const height = parseInt((document.getElementById('t-height') as HTMLInputElement).value);
    const weightLbs = parseInt((document.getElementById('t-weight') as HTMLInputElement).value);
    const activity = parseFloat((document.getElementById('t-activity') as HTMLSelectElement).value);
    const goal = (document.getElementById('t-goal') as HTMLSelectElement).value;

    const weightKg = weightLbs * 0.453592;
    let bmr = gender === 'male'
      ? (10 * weightKg) + (6.25 * height) - (5 * age) + 5
      : (10 * weightKg) + (6.25 * height) - (5 * age) - 161;
    const tdee = Math.round(bmr * activity);

    let targetCalories: number;
    let proteinPct: number, fatPct: number, carbsPct: number;
    switch (goal) {
      case 'cut':   targetCalories = Math.round(tdee * 0.8);  proteinPct = 40; fatPct = 35; carbsPct = 25; break;
      case 'bulk':  targetCalories = Math.round(tdee * 1.1);  proteinPct = 30; fatPct = 25; carbsPct = 45; break;
      default:      targetCalories = tdee;                     proteinPct = 30; fatPct = 35; carbsPct = 35;
    }

    document.getElementById('t-calories')!.textContent = targetCalories.toLocaleString();
    document.getElementById('t-calories-breakdown')!.textContent = `TDEE: ${tdee.toLocaleString()} cal/day`;
    document.getElementById('t-protein')!.textContent = `${Math.round((targetCalories * proteinPct / 100) / 4)}g`;
    document.getElementById('t-protein-pct')!.textContent = `${proteinPct}%`;
    document.getElementById('t-fat')!.textContent = `${Math.round((targetCalories * fatPct / 100) / 9)}g`;
    document.getElementById('t-fat-pct')!.textContent = `${fatPct}%`;
    document.getElementById('t-carbs')!.textContent = `${Math.round((targetCalories * carbsPct / 100) / 4)}g`;
    document.getElementById('t-carbs-pct')!.textContent = `${carbsPct}%`;
    document.getElementById('tdee-results')!.classList.remove('hidden');
  });

  // 1RM calculator
  const rmExercise = document.getElementById('rm-exercise') as HTMLSelectElement;
  const rmWeight = document.getElementById('rm-weight') as HTMLInputElement;

  rmExercise?.addEventListener('change', () => {
    if (rmExercise.value) {
      const ex = JSON.parse(rmExercise.value);
      rmWeight.value = ex.best1RM.toString();
    }
  });

  document.getElementById('rm-calculate-btn')?.addEventListener('click', () => {
    const weight = parseFloat(rmWeight.value);
    const reps = parseInt((document.getElementById('rm-reps') as HTMLInputElement).value);

    if (!weight || weight < 1 || !reps || reps < 1 || reps > 15) {
      alert('Please enter valid weight (min 1) and reps (1–15)');
      return;
    }

    const epley = weight * (1 + reps / 30);
    const brzycki = weight * (36 / (37 - reps));
    const average = (epley + brzycki) / 2;

    document.getElementById('rm-epley')!.textContent = Math.round(epley).toString();
    document.getElementById('rm-brzycki')!.textContent = Math.round(brzycki).toString();
    document.getElementById('rm-average')!.textContent = Math.round(average).toString();

    [100, 95, 90, 85, 80, 75, 70, 65].forEach(pct => {
      const el = document.getElementById(`rm-pct-${pct}`);
      if (el) el.textContent = Math.round(average * (pct / 100)).toString();
    });

    document.getElementById('rm-results')!.classList.remove('hidden');
  });
</script>
