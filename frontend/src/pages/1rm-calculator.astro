const exercises = Object.keys(exercisePRs).sort();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a One Rep Max (1RM)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A One Rep Max (1RM) is the maximum amount of weight you can lift for a single repetition with proper form. It's used to measure strength and calculate training loads for different rep ranges."
      }
    },
    {
      "@type": "Question",
      "name": "How accurate is the 1RM calculator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The calculator uses two scientifically-validated formulas (Epley and Brzycki) and averages them for more accuracy. These formulas are most accurate for rep ranges of 1-10. Higher rep ranges may yield less precise estimates."
      }
    },
    {
      "@type": "Question",
      "name": "What rep range gives the most accurate 1RM estimate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Rep ranges of 2-5 reps give the most accurate 1RM estimates. The fewer reps performed, the more accurate the calculation. Estimates become less reliable above 10 reps."
      }
    },
    {
      "@type": "Question",
      "name": "How often should I test my 1RM?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Testing your 1RM every 4-6 weeks is recommended for intermediate lifters, while advanced lifters may go 8-12 weeks between tests. Always ensure you're fully recovered and have mastered proper form before attempting a true 1RM."
      }
    },
    {
      "@type": "Question",
      "name": "What's the difference between Epley and Brzycki formulas?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Epley formula (weight × (1 + reps/30)) tends to be more accurate for higher rep sets, while Brzycki (weight × 36/(37-reps)) is often more accurate for lower rep sets. This calculator averages both for the most reliable estimate."
      }
    }
  ]
};
---

<Layout 
  title="1RM Calculator | Toby on Fitness Tech"
  description="Calculate your one rep max (1RM) using Epley and Brzycki formulas. Based on your Speediance workout data for personalized estimates."
  jsonLd={jsonLd}
>
  <!-- Hero Section -->
  <section class="relative py-20 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-blue-900/20 via-neutral-950 to-neutral-950"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-blue-500/10 via-transparent to-transparent"></div>
    
    <div class="relative container mx-auto max-w-4xl text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 bg-gradient-to-r from-white via-blue-100 to-blue-300 bg-clip-text text-transparent">
        1RM Calculator
      </h1>
      <p class="text-lg text-neutral-400 max-w-2xl mx-auto">
        Calculate your one rep max using Epley and Brzycki formulas. 
        Based on your Speediance PRs for personalized estimates.
      </p>
    </div>
  </section>

  <!-- Calculator Section -->
  <section class="px-4 pb-20">
    <div class="container mx-auto max-w-2xl">
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 md:p-8 shadow-2xl shadow-black/40">
        <!-- Exercise Selector -->
        <div class="mb-6">
          <label for="exercise" class="block text-sm font-medium text-neutral-300 mb-2">
            Select Exercise
          </label>
          <select 
            id="exercise" 
            class="w-full bg-neutral-800 border border-neutral-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
          >
            <option value="">-- Select an exercise --</option>
            {exercises.map((exercise) => (
              <option value={exercise} data-pr={exercisePRs[exercise].best1RM}>
                {exercise} ({exercisePRs[exercise].best1RM} lbs PR)
              </option>
            ))}
          </select>
        </div>

        <!-- PR Display -->
        <div id="pr-display" class="mb-6 p-4 bg-blue-500/10 border border-blue-500/20 rounded-xl hidden">
          <p class="text-sm text-blue-400 mb-1">Your PR for this exercise</p>
          <p class="text-2xl font-bold text-white"><span id="pr-value">0</span> lbs</p>
        </div>

        <!-- Weight Input -->
        <div class="mb-6">
          <label for="weight" class="block text-sm font-medium text-neutral-300 mb-2">
            Weight (lbs)
          </label>
          <input 
            type="number" 
            id="weight" 
            placeholder="Enter weight lifted"
            min="0"
            step="0.5"
            class="w-full bg-neutral-800 border border-neutral-700 rounded-xl px-4 py-3 text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
          />
        </div>

        <!-- Reps Input -->
        <div class="mb-6">
          <label for="reps" class="block text-sm font-medium text-neutral-300 mb-2">
            Reps (1-15)
          </label>
          <input 
            type="number" 
            id="reps" 
            placeholder="Enter reps performed"
            min="1"
            max="15"
            class="w-full bg-neutral-800 border border-neutral-700 rounded-xl px-4 py-3 text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
          />
        </div>

        <!-- Calculate Button -->
        <button 
          id="calculate-btn"
          class="w-full bg-gradient-to-r from-blue-600 to-blue-500 hover:from-blue-500 hover:to-blue-400 text-white font-semibold py-3 px-6 rounded-xl transition-all duration-200 transform hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-blue-500/25"
        >
          Calculate 1RM
        </button>

        <!-- Results -->
        <div id="results" class="mt-8 hidden">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
            <!-- Epley Result -->
            <div class="bg-neutral-800/50 border border-neutral-700 rounded-xl p-4 text-center">
              <p class="text-sm text-neutral-400 mb-1">Epley Formula</p>
              <p id="epley-result" class="text-2xl font-bold text-blue-400">0</p>
              <p class="text-xs text-neutral-500">lbs</p>
            </div>

            <!-- Brzycki Result -->
            <div class="bg-neutral-800/50 border border-neutral-700 rounded-xl p-4 text-center">
              <p class="text-sm text-neutral-400 mb-1">Brzycki Formula</p>
              <p id="brzycki-result" class="text-2xl font-bold text-purple-400">0</p>
              <p class="text-xs text-neutral-500">lbs</p>
            </div>

            <!-- Average Result -->
            <div class="bg-neutral-800/50 border border-blue-500/30 rounded-xl p-4 text-center">
              <p class="text-sm text-neutral-400 mb-1">Average</p>
              <p id="average-result" class="text-3xl font-bold text-white">0</p>
              <p class="text-xs text-neutral-500">lbs</p>
            </div>
          </div>

          <!-- Percentage Table -->
          <div class="bg-neutral-800/30 border border-neutral-700 rounded-xl p-4">
            <h3 class="text-lg font-semibold text-white mb-4">Training Percentages</h3>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="text-neutral-400 border-b border-neutral-700">
                    <th class="text-left py-2 px-2">% of 1RM</th>
                    <th class="text-right py-2 px-2">Weight</th>
                    <th class="text-right py-2 px-2">Best For</th>
                  </tr>
                </thead>
                <tbody id="percentage-table" class="text-neutral-300">
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Formula Info -->
        <div class="mt-6 p-4 bg-neutral-800/30 border border-neutral-700 rounded-xl">
          <h4 class="text-sm font-medium text-neutral-300 mb-2">Formulas Used</h4>
          <div class="text-xs text-neutral-500 space-y-1">
            <p><span class="text-blue-400">Epley:</span> 1RM = weight × (1 + reps/30)</p>
            <p><span class="text-purple-400">Brzycki:</span> 1RM = weight × 36 / (37 - reps)</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const exerciseSelect = document.getElementById('exercise') as HTMLSelectElement;
  const weightInput = document.getElementById('weight') as HTMLInputElement;
  const repsInput = document.getElementById('reps') as HTMLInputElement;
  const calculateBtn = document.getElementById('calculate-btn')!;
  const resultsDiv = document.getElementById('results')!;
  const prDisplay = document.getElementById('pr-display')!;
  const prValue = document.getElementById('pr-value')!;

  const epleyResult = document.getElementById('epley-result')!;
  const brzyckiResult = document.getElementById('brzycki-result')!;
  const averageResult = document.getElementById('average-result')!;
  const percentageTable = document.getElementById('percentage-table')!;

  const percentages = [100, 95, 90, 85, 80, 75, 70];

  // Handle exercise selection to show PR
  exerciseSelect.addEventListener('change', () => {
    const selectedOption = exerciseSelect.options[exerciseSelect.selectedIndex];
    const pr = selectedOption.dataset.pr;
    
    if (pr && parseFloat(pr) > 0) {
      prValue.textContent = pr;
      prDisplay.classList.remove('hidden');
      
      // Also pre-fill weight with PR if no weight entered
      if (!weightInput.value) {
        weightInput.value = pr;
      }
    } else {
      prDisplay.classList.add('hidden');
    }
  });

  calculateBtn.addEventListener('click', () => {
    const weight = parseFloat(weightInput.value);
    const reps = parseInt(repsInput.value);

    if (!weight || !reps || reps < 1 || reps > 15) {
      alert('Please enter a valid weight and reps (1-15)');
      return;
    }

    // Epley formula: weight × (1 + reps/30)
    const epley = weight * (1 + reps / 30);

    // Brzycki formula: weight × 36 / (37 - reps)
    const brzycki = weight * (36 / (37 - reps));

    // Average
    const average = (epley + brzycki) / 2;

    // Display results
    epleyResult.textContent = Math.round(epley).toString();
    brzyckiResult.textContent = Math.round(brzycki).toString();
    averageResult.textContent = Math.round(average).toString();

    // Build percentage table
    let tableHTML = '';
    percentages.forEach(pct => {
      const pctWeight = Math.round(average * (pct / 100));
      let bestFor = '';
      
      if (pct === 100) bestFor = '1RM test';
      else if (pct >= 95) bestFor = 'Peaking';
      else if (pct >= 90) bestFor = 'Strength';
      else if (pct >= 85) bestFor = 'Strength/Hypertrophy';
      else if (pct >= 80) bestFor = 'Hypertrophy';
      else if (pct >= 75) bestFor = 'Hypertrophy/Endurance';
      else bestFor = 'Endurance';

      tableHTML += `
        <tr class="border-b border-neutral-700/50">
          <td class="py-2 px-2 text-blue-400 font-medium">${pct}%</td>
          <td class="py-2 px-2 text-right font-semibold">${pctWeight} lbs</td>
          <td class="py-2 px-2 text-right text-neutral-400">${bestFor}</td>
        </tr>
      `;
    });

    percentageTable.innerHTML = tableHTML;
    resultsDiv.classList.remove('hidden');
  });
</script>
