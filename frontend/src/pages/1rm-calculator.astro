---

<Layout title="1RM Calculator | TobyOnFitnessTech">
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a one-rep max (1RM) calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A one-rep max calculator estimates the maximum weight you can lift for a single repetition based on the weight and number of reps you've performed. It uses formulas like Epley and Brzycki to project your 1RM from submaximal lifts."
          }
        },
        {
          "@type": "Question",
          "name": "Which 1RM formula is most accurate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Epley and Brzycki formulas are both widely used and generally accurate for rep ranges of 1-10. The average of both formulas often provides the most reliable estimate."
          }
        },
        {
          "@type": "Question",
          "name": "How should I use my 1RM for training?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Once you know your estimated 1RM, you can calculate training percentages. For strength, train at 70-85% of your 1RM. For power, use 50-70%. Always round down slightly for safety and ensure proper form."
          }
        }
      ]
    }
  </script>

  <main class="min-h-screen bg-neutral-950 py-12 px-4">
    <div class="max-w-3xl mx-auto">
      <!-- Hero -->
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">1RM Calculator</h1>
        <p class="text-xl text-neutral-400">Estimate your one-rep max from any set</p>
      </div>

      <!-- Calculator Card -->
      <div class="bg-neutral-900 rounded-2xl p-6 md:p-8 shadow-xl">
        <!-- Exercise Dropdown -->
        <div class="mb-6">
          <label for="exercise" class="block text-sm font-medium text-neutral-300 mb-2">Exercise</label>
          <select
            id="exercise"
            class="w-full bg-neutral-800 border border-neutral-700 text-white rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          >
            <option value="">Custom (enter weight manually)</option>
            {workoutCategories.map(category => (
              <optgroup label={category}>
                {exercisesByCategory[category].map(ex => (
                  <option value={JSON.stringify(ex)}>{ex.name} ({ex.best1RM} lbs)</option>
                ))}
              </optgroup>
            ))}
          </select>
        </div>

        <!-- Weight and Reps Inputs -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
          <div>
            <label for="weight" class="block text-sm font-medium text-neutral-300 mb-2">Weight (lbs)</label>
            <input
              type="number"
              id="weight"
              min="1"
              placeholder="Enter weight"
              class="w-full bg-neutral-800 border border-neutral-700 text-white rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            />
          </div>
          <div>
            <label for="reps" class="block text-sm font-medium text-neutral-300 mb-2">Reps (1-15)</label>
            <input
              type="number"
              id="reps"
              min="1"
              max="15"
              placeholder="Enter reps"
              class="w-full bg-neutral-800 border border-neutral-700 text-white rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            />
          </div>
        </div>

        <!-- Calculate Button -->
        <button
          id="calculate-btn"
          class="w-full bg-blue-500 hover:bg-blue-600 text-white font-semibold py-3 px-6 rounded-lg transition-colors"
        >
          Calculate 1RM
        </button>

        <!-- Results Section -->
        <div id="results" class="hidden mt-8 pt-8 border-t border-neutral-700">
          <!-- Formula Results -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
            <div class="bg-neutral-800 rounded-xl p-4 text-center">
              <p class="text-sm text-neutral-400 mb-1">Epley Formula</p>
              <p id="epley-result" class="text-2xl font-bold text-white">0</p>
              <p class="text-xs text-neutral-500">lbs</p>
            </div>
            <div class="bg-neutral-800 rounded-xl p-4 text-center">
              <p class="text-sm text-neutral-400 mb-1">Brzycki Formula</p>
              <p id="brzycki-result" class="text-2xl font-bold text-white">0</p>
              <p class="text-xs text-neutral-500">lbs</p>
            </div>
            <div class="bg-blue-500/20 rounded-xl p-4 text-center border border-blue-500/30">
              <p class="text-sm text-blue-300 mb-1">Average</p>
              <p id="average-result" class="text-2xl font-bold text-blue-400">0</p>
              <p class="text-xs text-blue-300/70">lbs</p>
            </div>
          </div>

          <!-- Percentage Breakdown -->
          <div>
            <h3 class="text-lg font-semibold text-white mb-4">Percentage Breakdown</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
              <div class="bg-neutral-800 rounded-lg p-3 text-center">
                <p class="text-xs text-neutral-400 mb-1">100%</p>
                <p id="pct-100" class="text-lg font-bold text-white">0</p>
                <p class="text-xs text-neutral-500">lbs</p>
              </div>
              <div class="bg-neutral-800 rounded-lg p-3 text-center">
                <p class="text-xs text-neutral-400 mb-1">95%</p>
                <p id="pct-95" class="text-lg font-bold text-white">0</p>
                <p class="text-xs text-neutral-500">lbs</p>
              </div>
              <div class="bg-neutral-800 rounded-lg p-3 text-center">
                <p class="text-xs text-neutral-400 mb-1">90%</p>
                <p id="pct-90" class="text-lg font-bold text-white">0</p>
                <p class="text-xs text-neutral-500">lbs</p>
              </div>
              <div class="bg-neutral-800 rounded-lg p-3 text-center">
                <p class="text-xs text-neutral-400 mb-1">85%</p>
                <p id="pct-85" class="text-lg font-bold text-white">0</p>
                <p class="text-xs text-neutral-500">lbs</p>
              </div>
              <div class="bg-neutral-800 rounded-lg p-3 text-center">
                <p class="text-xs text-neutral-400 mb-1">80%</p>
                <p id="pct-80" class="text-lg font-bold text-white">0</p>
                <p class="text-xs text-neutral-500">lbs</p>
              </div>
              <div class="bg-neutral-800 rounded-lg p-3 text-center">
                <p class="text-xs text-neutral-400 mb-1">75%</p>
                <p id="pct-75" class="text-lg font-bold text-white">0</p>
                <p class="text-xs text-neutral-500">lbs</p>
              </div>
              <div class="bg-neutral-800 rounded-lg p-3 text-center">
                <p class="text-xs text-neutral-400 mb-1">70%</p>
                <p id="pct-70" class="text-lg font-bold text-white">0</p>
                <p class="text-xs text-neutral-500">lbs</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  const exerciseSelect = document.getElementById('exercise') as HTMLSelectElement;
  const weightInput = document.getElementById('weight') as HTMLInputElement;
  const repsInput = document.getElementById('reps') as HTMLInputElement;
  const calculateBtn = document.getElementById('calculate-btn');
  const resultsSection = document.getElementById('results');

  // Exercise dropdown handler - pre-fill weight
  exerciseSelect?.addEventListener('change', () => {
    const selectedValue = exerciseSelect.value;
    if (selectedValue) {
      const exercise = JSON.parse(selectedValue);
      weightInput.value = exercise.best1RM.toString();
    }
  });

  // Calculate button handler
  calculateBtn?.addEventListener('click', () => {
    const weight = parseFloat(weightInput.value);
    const reps = parseInt(repsInput.value);

    if (!weight || weight < 1 || !reps || reps < 1 || reps > 15) {
      alert('Please enter valid weight (min 1) and reps (1-15)');
      return;
    }

    // Epley formula: weight × (1 + reps/30)
    const epley = weight * (1 + reps / 30);

    // Brzycki formula: weight × (36 / (37 - reps))
    const brzycki = weight * (36 / (37 - reps));

    // Average
    const average = (epley + brzycki) / 2;

    // Update results
    const epleyResult = document.getElementById('epley-result');
    const brzyckiResult = document.getElementById('brzycki-result');
    const averageResult = document.getElementById('average-result');

    if (epleyResult) epleyResult.textContent = Math.round(epley).toString();
    if (brzyckiResult) brzyckiResult.textContent = Math.round(brzycki).toString();
    if (averageResult) averageResult.textContent = Math.round(average).toString();

    // Update percentage breakdown
    const percentages = [100, 95, 90, 85, 80, 75, 70];
    percentages.forEach(pct => {
      const element = document.getElementById(`pct-${pct}`);
      if (element) {
        element.textContent = Math.round(average * (pct / 100)).toString();
      }
    });

    // Show results
    resultsSection?.classList.remove('hidden');
  });
</script>
