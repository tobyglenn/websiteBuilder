---
import Layout from '../../layouts/Layout.astro';
import { marked } from 'marked';
import { BLOG_POSTS, BLOG_REDIRECTS } from '../../lib/blogPosts';
import ShareButtons from '../../components/ShareButtons.jsx';
import { ArrowLeft, User, Calendar, Tag } from 'lucide-react';

function readTime(content = '') {
  const words = content.split(/\s+/).filter(Boolean).length;
  return `${Math.max(1, Math.round(words / 200))} min read`;
}

export function getStaticPaths() {
  return BLOG_POSTS.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const redirectSlug = BLOG_REDIRECTS[post.slug];

if (redirectSlug) {
  return Astro.redirect(`/blog/${redirectSlug}/`, 301);
}

// Sort posts by date (newest first) for navigation
const sortedPosts = [...BLOG_POSTS].sort((a, b) => 
  new Date(b.published_at).getTime() - new Date(a.published_at).getTime()
);
const currentIndex = sortedPosts.findIndex(p => p.slug === post.slug);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

const currentPostTags = (post.tags || []).map((tag: string) => String(tag).toLowerCase().trim());
const categoryMatches = sortedPosts.filter(p => p.slug !== post.slug && p.category === post.category);
const tagMatches = sortedPosts.filter(p =>
  p.slug !== post.slug &&
  p.category !== post.category &&
  (p.tags || []).some((tag: string) => currentPostTags.includes(String(tag).toLowerCase().trim()))
);

const uniqueRelatedPosts = [...categoryMatches];
for (const candidate of tagMatches) {
  if (!uniqueRelatedPosts.some(p => p.slug === candidate.slug)) {
    uniqueRelatedPosts.push(candidate);
  }
}

let relatedPosts = uniqueRelatedPosts.slice(0, 3);
if (relatedPosts.length < 3) {
  for (const candidate of sortedPosts) {
    if (candidate.slug === post.slug) continue;
    if (relatedPosts.some(p => p.slug === candidate.slug)) continue;
    relatedPosts.push(candidate);
    if (relatedPosts.length === 3) break;
  }
}

const siteUrl = "https://tobyonfitnesstech.com";

// Extract FAQ schema from blog post content (## headings become Q&A pairs)
function extractFAQSchema(content: string): object | null {
  const lines = content.split('\n');
  const qaPairs: Array<{ question: string; answer: string }> = [];

  let i = 0;
  while (i < lines.length) {
    const line = lines[i].trim();
    // Match ## headings (but not # or ###)
    if (line.startsWith('## ') && !line.startsWith('### ')) {
      const question = line.replace(/^##\s+/, '').trim();
      // Collect the following paragraph(s) as the answer (stop at next heading)
      const answerLines: string[] = [];
      i++;
      while (i < lines.length) {
        const nextLine = lines[i].trim();
        if (nextLine.startsWith('#')) break;
        if (nextLine.length > 0) {
          answerLines.push(nextLine);
        }
        i++;
      }
      const answer = answerLines.join(' ').trim();
      if (question.length > 5 && answer.length > 20) {
        qaPairs.push({ question, answer });
      }
      continue;
    }
    i++;
  }

  if (qaPairs.length < 2) return null;

  // Limit to first 5 FAQs (Google recommends not stuffing)
  const limited = qaPairs.slice(0, 5);

  return {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": limited.map(({ question, answer }) => ({
      "@type": "Question",
      "name": question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": answer.slice(0, 1000)
      }
    }))
  };
}

const faqSchema = extractFAQSchema(post.content || '');

const wordCount = (post.content || '').split(/\s+/).filter(Boolean).length;
const articleHtml = marked.parse(post.content || '');

const authorSchema = {
  "@type": "Person",
  "@id": `${siteUrl}/#toby`,
  "name": "Toby Glenn Peters",
  "jobTitle": "Fitness Enthusiast & Tech Builder",
  "url": siteUrl,
  "sameAs": [
    "https://www.youtube.com/@tobyonfitness",
    "https://www.instagram.com/tobyonfitness"
  ],
  "knowsAbout": ["Speediance", "BJJ", "Garmin", "WHOOP", "8Sleep", "Running", "Brazilian Jiu-Jitsu"],
  "award": "242→188 lb transformation",
  "description": "Independent fitness technology reviewer and builder with data-first training, recovery, and tech coverage from Speediance, WHOOP, Garmin, and Garmin-powered running data."
};


const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${siteUrl}/blog/${post.slug}#article`,
  "headline": post.title,
  "description": post.excerpt || post.title,
  "datePublished": post.published_at,
  "dateModified": post.published_at,
  "url": `${siteUrl}/blog/${post.slug}`,
  ...(post.image ? { "image": post.image.startsWith('http') ? post.image : `${siteUrl}${post.image}` } : {}),
  "author": authorSchema,
  "publisher": {
    "@id": `${siteUrl}/#organization`
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteUrl}/blog/${post.slug}`
  },
  "isPartOf": {
    "@id": `${siteUrl}/blog#collection`
  },
  "wordCount": wordCount,
  ...(post.tags && post.tags.length > 0 ? { "keywords": post.tags.join(', ') } : {}),
  ...(post.category ? { "articleSection": post.category } : {})
};
---

<Layout 
  title={`${post.title} - TobyOnFitnessTech`}
  description={post.excerpt?.slice(0, 155) || post.title}
  image={post.image}
  ogType="article"
  jsonLd={faqSchema ? [articleJsonLd, faqSchema] : articleJsonLd}
  publishedTime={post.published_at}
  modifiedTime={post.published_at}
  author="Toby Glenn Peters"
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Blog", url: "/blog" },
    { name: post.title, url: `/blog/${post.slug}/` }
  ]}
>
  <article class="bg-neutral-950 min-h-screen pb-24">
    {/* Header / Hero */}
    <div class="relative bg-neutral-900 border-b border-neutral-800 pb-16 pt-24 md:pt-32">
      <div class="absolute inset-0 bg-gradient-to-b from-blue-900/10 to-transparent pointer-events-none" />
      <div class="container mx-auto px-4 relative z-10 max-w-4xl">
        <a href="/blog/" class="inline-flex items-center text-sm font-semibold text-blue-400 hover:text-blue-300 transition-colors mb-8 group">
          <ArrowLeft size={16} class="mr-2 group-hover:-translate-x-1 transition-transform" /> Back to Analysis
        </a>
        
        <div class="flex items-center gap-4 text-xs font-bold tracking-wider text-blue-500 uppercase mb-4">
            <span class="bg-blue-900/30 px-3 py-1 rounded-full border border-blue-500/30">{post.category}</span>
            <span class="text-neutral-500">•</span>
            <span>{readTime(post.content)}</span>
        </div>
        
        <h1 class="text-3xl md:text-5xl font-bold text-white mb-6 leading-tight">
          {post.title}
        </h1>

        {post.excerpt && (
          <p class="max-w-3xl text-lg md:text-xl leading-relaxed text-neutral-300 mb-8">
            {post.excerpt}
          </p>
        )}
        
        <div class="flex items-center gap-6 text-sm text-neutral-400 border-t border-neutral-800 pt-6">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-neutral-800 flex items-center justify-center text-neutral-500">
                    <User size={16} />
                </div>
                <span class="font-medium text-white">Toby</span>
            </div>
            <div class="flex items-center gap-2">
                <Calendar size={16} />
                <span>{new Date(post.published_at).toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            </div>
        </div>

        <ShareButtons url={Astro.url.href} title={post.title} client:load />
      </div>
    </div>

    {/* Content */}
    <div class="container mx-auto px-4 py-12 max-w-3xl">
      <div class="markdown-shell rounded-3xl border border-neutral-800 bg-neutral-900/55 px-6 py-8 md:px-10 md:py-10 shadow-[0_30px_80px_rgba(0,0,0,0.28)]">
        <div
          class="markdown-article"
          set:html={articleHtml}
        >
        </div>
      </div>
      
      {/* Footer / Tags */}
      {post.tags && post.tags.length > 0 && (
        <div class="mt-16 pt-8 border-t border-neutral-800">
          <div class="flex items-center gap-4 flex-wrap">
            <Tag size={16} class="text-neutral-500" />
            <div class="flex flex-wrap gap-2">
              {post.tags.map(tag => (
                <span class="text-sm bg-neutral-900 border border-neutral-800 px-3 py-1 rounded-full text-neutral-400 hover:text-white transition-colors cursor-pointer">#{tag}</span>
              ))}
            </div>
          </div>
        </div>
      )}

      {/* Next/Previous Post Navigation */}
      {(prevPost || nextPost) && (
        <div class="mt-16 pt-12 border-t border-neutral-800">
          <h3 class="text-lg font-bold text-white mb-8 text-center">Keep Reading</h3>
          <div class="grid md:grid-cols-2 gap-4">
            {prevPost && (
              <a href={`/blog/${prevPost.slug}/`} class="group block bg-neutral-900 hover:bg-neutral-800 border border-neutral-800 hover:border-blue-500/50 rounded-xl p-5 transition-all">
                <div class="flex items-center gap-2 text-xs font-semibold text-blue-400 mb-2">
                  <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
                  Previous
                </div>
                <div class="font-semibold text-white group-hover:text-blue-400 transition-colors line-clamp-2">{prevPost.title}</div>
              </a>
            )}
            {nextPost && (
              <a href={`/blog/${nextPost.slug}/`} class="group block bg-neutral-900 hover:bg-neutral-800 border border-neutral-800 hover:border-blue-500/50 rounded-xl p-5 transition-all text-right md:[&_div:first-child]:justify-end">
                <div class="flex items-center justify-end gap-2 text-xs font-semibold text-blue-400 mb-2">
                  Next
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </div>
                <div class="font-semibold text-white group-hover:text-blue-400 transition-colors line-clamp-2">{nextPost.title}</div>
              </a>
            )}
          </div>
        </div>
      )}

      {/* Related Posts */}
      {relatedPosts.length > 0 && (
        <div class="mt-16 pt-12 border-t border-neutral-800">
          <h3 class="text-lg font-bold text-white mb-8 text-center">Related Posts</h3>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
            {relatedPosts.map(relatedPost => (
              <a href={`/blog/${relatedPost.slug}/`} class="group block bg-neutral-900 border border-neutral-800 hover:border-blue-500/50 rounded-xl overflow-hidden hover:bg-neutral-800 transition-all">
                <div class="relative aspect-[16/9] overflow-hidden">
                  <div class="absolute inset-0 z-0 bg-neutral-800" />
                  {relatedPost.image && (
                    <img
                      src={relatedPost.image}
                      alt={relatedPost.title}
                      class="relative z-10 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  )}
                  <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/50 to-transparent" />
                </div>
                <div class="p-4 space-y-3">
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-[11px] font-bold tracking-wide bg-blue-900/20 text-blue-400 border border-blue-900/40">{relatedPost.category}</span>
                  <h4 class="font-semibold text-white leading-snug group-hover:text-blue-400 transition-colors line-clamp-2">
                    {relatedPost.title}
                  </h4>
                  <div class="flex flex-wrap items-center gap-2 text-xs text-neutral-500">
                    <span>{new Date(relatedPost.published_at).toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                    <span>•</span>
                    <span>{readTime(relatedPost.content)}</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>
</Layout>

<style is:global>
  .markdown-article > h1:first-child {
    display: none;
  }

  .markdown-article {
    color: rgb(212 212 216);
    font-size: 1.075rem;
    line-height: 1.9;
  }

  .markdown-article > p:first-of-type {
    color: rgb(229 229 229);
    font-size: 1.18rem;
    line-height: 1.95;
    padding-left: 1rem;
    border-left: 3px solid rgb(59 130 246);
    margin-bottom: 2.25rem;
  }

  .markdown-article p {
    margin: 0 0 1.35rem;
    color: rgb(212 212 216);
  }

  .markdown-article h2 {
    margin: 3.25rem 0 1.25rem;
    padding-left: 1rem;
    border-left: 4px solid rgb(59 130 246);
    color: rgb(255 255 255);
    font-size: 1.9rem;
    line-height: 1.2;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .markdown-article h3 {
    margin: 2.1rem 0 1rem;
    color: rgb(191 219 254);
    font-size: 1.35rem;
    line-height: 1.35;
    font-weight: 700;
  }

  .markdown-article h4,
  .markdown-article h5,
  .markdown-article h6 {
    margin: 1.8rem 0 0.8rem;
    color: rgb(229 231 235);
    font-size: 1.05rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .markdown-article ul,
  .markdown-article ol {
    margin: 0 0 1.6rem 0;
    padding-left: 1.35rem;
  }

  .markdown-article li {
    margin-bottom: 0.65rem;
    padding-left: 0.2rem;
    color: rgb(212 212 216);
  }

  .markdown-article li::marker {
    color: rgb(96 165 250);
  }

  .markdown-article strong {
    color: rgb(255 255 255);
    font-weight: 700;
  }

  .markdown-article em {
    color: rgb(229 231 235);
  }

  .markdown-article a {
    color: rgb(96 165 250);
    text-decoration: underline;
    text-decoration-color: rgba(96, 165, 250, 0.35);
    text-underline-offset: 0.22em;
    transition: color 160ms ease, text-decoration-color 160ms ease;
  }

  .markdown-article a:hover {
    color: rgb(191 219 254);
    text-decoration-color: rgba(191, 219, 254, 0.7);
  }

  .markdown-article blockquote {
    margin: 2rem 0;
    padding: 1rem 1.2rem;
    border-left: 4px solid rgb(59 130 246);
    background: rgba(15, 23, 42, 0.55);
    color: rgb(229 231 235);
    font-style: italic;
  }

  .markdown-article hr {
    margin: 2.5rem 0;
    border: 0;
    border-top: 1px solid rgba(82, 82, 91, 0.5);
  }

  .markdown-article code {
    font-size: 0.92em;
    color: rgb(224 231 255);
    background: rgba(15, 23, 42, 0.75);
    border: 1px solid rgba(59, 130, 246, 0.18);
    border-radius: 0.45rem;
    padding: 0.12rem 0.38rem;
  }

  .markdown-article pre {
    margin: 1.8rem 0;
    padding: 1rem 1.1rem;
    overflow-x: auto;
    border-radius: 1rem;
    border: 1px solid rgba(63, 63, 70, 0.8);
    background: rgba(10, 10, 10, 0.8);
  }

  .markdown-article pre code {
    padding: 0;
    border: 0;
    background: transparent;
  }

  @media (max-width: 768px) {
    .markdown-article {
      font-size: 1rem;
      line-height: 1.8;
    }

    .markdown-article > p:first-of-type {
      font-size: 1.08rem;
      margin-bottom: 1.8rem;
    }

    .markdown-article h2 {
      font-size: 1.55rem;
      margin-top: 2.6rem;
    }

    .markdown-article h3 {
      font-size: 1.2rem;
    }
  }
</style>
