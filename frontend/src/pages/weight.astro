---
import Layout from '../layouts/Layout.astro';
import { weightData, getStats } from '../data/weight.js';

const stats = getStats();
const siteUrl = "https://tobyonfitnesstech.com";

// FAQPage JSON-LD schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Why did your weight go back up after reaching 188 lbs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Reaching 188 lbs was the weight loss phase. After that, I intentionally transitioned to muscle building. The weight gain from 188 to 218 lbs is mostly lean tissue — I've been prioritizing strength and BJJ performance over scale number. The scale tells one story; body composition and performance tell another."
      }
    },
    {
      "@type": "Question",
      "name": "What's your goal weight now?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "I don't have a specific target weight anymore. My focus is on performance — BJJ, lifting, running — and letting body composition take care of itself. I'm currently sitting around 218 lbs and feeling strong. If anything, I may add a slight cut later this year but haven't decided."
      }
    },
    {
      "@type": "Question",
      "name": "How do you track your weight?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "I weigh in monthly using a standard scale. I don't stress about daily fluctuations — the monthly snapshot gives me enough data to see trends without getting caught up in water weight swings. Consistency in timing (morning, fasted) matters more than the specific device."
      }
    },
    {
      "@type": "Question",
      "name": "Did you lose muscle during weight loss?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "I did my best to preserve it with strength training and Anavar during the cut. Was I optimally lean? Probably not — I got down to ~12% body fat at 188. Some muscle loss is inevitable in a aggressive cut, but I've been able to rebuild and add new tissue during this bulking phase. The 30 lbs gained since then is intentional tissue acquisition."
      }
    }
  ]
};

// Prepare chart data
const chartWidth = 600;
const chartHeight = 300;
const padding = 40;

const weights = weightData.map(d => d.weight);
const minWeight = Math.min(...weights) - 10;
const maxWeight = Math.max(...weights) + 10;
const weightRange = maxWeight - minWeight;

// Generate points for SVG polyline
const points = weightData.map((d, i) => {
  const x = padding + (i / (weightData.length - 1)) * (chartWidth - 2 * padding);
  const y = chartHeight - padding - ((d.weight - minWeight) / weightRange) * (chartHeight - 2 * padding);
  return `${x},${y}`;
}).join(' ');

// Get last 5 entries for table
const recentEntries = weightData.slice(-5).reverse();
---

<Layout title="Weight Journey | TobyOnFitnessTech" description="Track Toby's weight transformation from 242 lbs to 188 lbs and beyond — a data-driven fitness journey.">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  {/* Hero Section */}
  <section className="pt-32 pb-16 px-4">
    <div className="container mx-auto text-center">
      <h1 className="text-4xl md:text-5xl font-bold mb-4 bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">
        Weight Journey
      </h1>
      <p className="text-xl text-neutral-400 max-w-2xl mx-auto">
        Tracking my transformation: 242 → 188 → 218. The scale tells one story; performance tells another.
      </p>
    </div>
  </section>

  {/* Stats Cards */}
  <section className="px-4 pb-16">
    <div className="container mx-auto">
      <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div className="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
          <p className="text-sm text-neutral-400 mb-1">Starting</p>
          <p className="text-3xl font-bold text-white">{stats.start} lbs</p>
        </div>
        <div className="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
          <p className="text-sm text-neutral-400 mb-1">Lowest</p>
          <p className="text-3xl font-bold text-green-400">{stats.lowest} lbs</p>
        </div>
        <div className="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
          <p className="text-sm text-neutral-400 mb-1">Current</p>
          <p className="text-3xl font-bold text-blue-400">{stats.current} lbs</p>
        </div>
        <div className="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
          <p className="text-sm text-neutral-400 mb-1">Change</p>
          <p className={`text-3xl font-bold ${stats.totalChange < 0 ? 'text-green-400' : 'text-purple-400'}`}>
            {stats.totalChange > 0 ? '+' : ''}{stats.totalChange} lbs
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* SVG Line Chart */}
  <section className="px-4 pb-16">
    <div className="container mx-auto max-w-3xl">
      <div className="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
        <h2 className="text-xl font-bold text-white mb-6">Weight Over Time</h2>
        <svg viewBox={`0 0 ${chartWidth} ${chartHeight}`} className="w-full h-auto" preserveAspectRatio="xMidYMid meet">
          {/* Grid lines */}
          {[0, 0.25, 0.5, 0.75, 1].map((ratio) => {
            const y = padding + ratio * (chartHeight - 2 * padding);
            const weight = Math.round(maxWeight - ratio * weightRange);
            return (
              <g key={ratio}>
                <line x1={padding} y1={y} x2={chartWidth - padding} y2={y} stroke="#333" stroke-width="1" stroke-dasharray="4" />
                <text x={padding - 5} y={y + 4} text-anchor="end" fill="#666" font-size="11">{weight}</text>
              </g>
            );
          })}

          {/* X-axis labels */}
          {weightData.filter((_, i) => i % 2 === 0).map((d, i) => {
            const x = padding + ((i * 2) / (weightData.length - 1)) * (chartWidth - 2 * padding);
            const label = new Date(d.date).toLocaleDateString('en-US', { month: 'short', year: '2-digit' });
            return (
              <text key={d.date} x={x} y={chartHeight - 10} text-anchor="middle" fill="#666" font-size="10">{label}</text>
            );
          })}

          {/* Line */}
          <polyline
            points={points}
            fill="none"
            stroke="url(#gradient)"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
          />

          {/* Data points */}
          {weightData.map((d, i) => {
            const x = padding + (i / (weightData.length - 1)) * (chartWidth - 2 * padding);
            const y = chartHeight - padding - ((d.weight - minWeight) / weightRange) * (chartHeight - 2 * padding);
            return (
              <circle key={d.date} cx={x} cy={y} r="5" fill="#3b82f6" stroke="#1e1e1e" stroke-width="2" class="hover:r-6 transition-all cursor-pointer" />
            );
          })}

          {/* Gradient definition */}
          <defs>
            <linearGradient id="gradient" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#3b82f6" />
              <stop offset="100%" stop-color="#8b5cf6" />
            </linearGradient>
          </defs>
        </svg>
      </div>
    </div>
  </section>

  {/* Recent Weigh-ins Table */}
  <section className="px-4 pb-16">
    <div className="container mx-auto max-w-2xl">
      <div className="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
        <h2 className="text-xl font-bold text-white mb-6">Recent Weigh-ins</h2>
        <div className="overflow-x-auto">
          <table className="w-full">
            <thead>
              <tr className="border-b border-neutral-800">
                <th className="text-left py-3 px-4 text-sm font-medium text-neutral-400">Date</th>
                <th className="text-left py-3 px-4 text-sm font-medium text-neutral-400">Weight</th>
                <th className="text-left py-3 px-4 text-sm font-medium text-neutral-400">Note</th>
              </tr>
            </thead>
            <tbody>
              {recentEntries.map((entry) => (
                <tr key={entry.date} className="border-b border-neutral-800/50 hover:bg-neutral-800/30 transition-colors">
                  <td className="py-3 px-4 text-white">{new Date(entry.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</td>
                  <td className="py-3 px-4 text-blue-400 font-medium">{entry.weight} lbs</td>
                  <td className="py-3 px-4 text-neutral-400">{entry.note}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  {/* Context Section */}
  <section className="px-4 pb-24">
    <div className="container mx-auto max-w-2xl">
      <div className="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 md:p-8">
        <h2 className="text-xl font-bold text-white mb-4">The Story Behind the Numbers</h2>
        <div className="space-y-4 text-neutral-300 leading-relaxed">
          <p>
            <strong className="text-white">242 → 188:</strong> From January 2023 to March 2024, I dropped 54 lbs using a combination of 
            pharmaceutical support (GLP-1, TRT, Anavar), aggressive calorie restriction (800-1200 cal/day), and high-volume training. 
            The focus was simple: get lean, build the habit, prove to myself I could do it.
          </p>
          <p>
            <strong className="text-white">188 → 218:</strong> After hitting 188 lbs, I made a conscious pivot. I wanted to be strong. 
            I started eating more, prioritizing protein and progressive overload on the Speediance, and added Brazilian Jiu-Jitsu to the mix. 
            The scale went up 30 lbs — and I'm stronger, more conditioned, and more capable than ever.
          </p>
          <p>
            <strong className="text-white">The lesson:</strong> The scale is a tool, not a judge. At 242 I was overweight. At 188 I was lean. 
            At 218 I'm building. Each phase had purpose. The transformation isn't over — it's just entered a new chapter.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
