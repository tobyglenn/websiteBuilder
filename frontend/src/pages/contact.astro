---
import Layout from '../layouts/Layout.astro';

const siteUrl = "https://tobyonfitnesstech.com";

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": `${siteUrl}/contact/#contactpage`,
  "name": "Contact Toby Glenn Peters",
  "description": "Get in touch with Toby Glenn Peters for sponsorships, consulting, collaborations, or fitness tech questions.",
  "url": `${siteUrl}/contact/`,
  "inLanguage": "en-US",
  "isPartOf": { "@id": `${siteUrl}/#website` },
  "about": { "@id": `${siteUrl}/#toby` },
  "mainEntity": {
    "@type": "Person",
    "@id": `${siteUrl}/#toby`,
    "name": "Toby Glenn Peters",
    "alternateName": "TobyOnFitnessTech",
    "email": "toby@tobyonfitness.tech",
    "url": siteUrl,
    "sameAs": [
      "https://www.youtube.com/@tobyonfitness",
      "https://www.instagram.com/tobyonfitness"
    ]
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
      { "@type": "ListItem", "position": 2, "name": "Contact", "item": `${siteUrl}/contact/` }
    ]
  }
};

const faqs = [
  {
    q: "Do you sell coaching programs or personalized plans?",
    a: "No. I document what works for me and share it publicly — that's it. I don't sell programs, meal plans, or 1-on-1 coaching. Everything I do is on YouTube and this site, free."
  },
  {
    q: "Can I ask you about my Speediance or fitness tech setup?",
    a: "Yes — that's what I'm here for. Email me with specifics. I'll reply if I have something useful to add. If it's a common question, it might become a video or a blog post."
  },
  {
    q: "Do you accept sponsorships?",
    a: "Selectively. I only work with products I actually use. If you're reaching out about Speediance, WHOOP, Garmin, 8Sleep, or similar fitness tech — I'm listening. Cold pitches for protein powder and supplements generally don't go anywhere."
  },
  {
    q: "Are you available for consulting on fitness tech stacks or automation?",
    a: "Sometimes. If you're a company or individual looking to build data-driven training systems — especially involving OpenClaw, home gym hardware, or wearable integration — reach out. I'll tell you honestly if I can help."
  },
  {
    q: "How long does it take to get a reply?",
    a: "Usually within a few days. I'm one person with a full training schedule and a day job. I read everything — I just don't reply fast."
  },
  {
    q: "Can I collaborate on content or co-create something?",
    a: "Maybe. Tell me what you're building and why you think it's a fit. I'm not looking to pad my upload schedule — but a genuinely interesting project? I'm open."
  }
];
---

<Layout
  title="Contact — TobyOnFitnessTech"
  description="Get in touch with Toby Glenn Peters for sponsorships, consulting, fitness tech questions, or collaborations."
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Contact", url: "/contact" }]}
  jsonLd={contactPageSchema}
>
  <main class="min-h-screen bg-neutral-950 text-white">

    {/* Hero */}
    <section class="pt-20 pb-12 md:pt-28 md:pb-16 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-blue-900/10 to-transparent pointer-events-none" />
      <div class="container mx-auto px-4 relative z-10 max-w-4xl">
        <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-4">Contact</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Get in Touch
        </h1>
        <p class="text-xl text-neutral-400 max-w-2xl leading-relaxed">
          I'm not hard to reach. I'm just selective about what I say yes to. If you've got something real to discuss, I'll respond.
        </p>
      </div>
    </section>

    {/* Contact + Social */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="grid md:grid-cols-2 gap-8">

          {/* Email Card */}
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-xl bg-blue-600/20 border border-blue-500/30 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <h2 class="text-xl font-bold text-white">Email</h2>
                <p class="text-neutral-500 text-sm">Best way to reach me</p>
              </div>
            </div>
            <a
              href="mailto:toby@tobyonfitness.tech"
              class="text-blue-400 hover:text-blue-300 font-mono text-lg font-semibold transition-colors"
            >
              toby@tobyonfitness.tech
            </a>
            <p class="text-neutral-500 text-sm mt-4 leading-relaxed">
              I read every email. I reply when I have something useful to say — usually within a few days.
            </p>
          </div>

          {/* Social Links */}
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8">
            <h2 class="text-xl font-bold text-white mb-6">Follow Along</h2>
            <div class="space-y-4">
              <a
                href="https://www.youtube.com/@tobyonfitness"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-4 p-4 rounded-xl bg-neutral-950 border border-neutral-800 hover:border-red-500/40 hover:bg-red-950/10 transition-all group"
              >
                <div class="w-10 h-10 rounded-lg bg-red-600/20 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#ef4444"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.54C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon fill="white" points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
                </div>
                <div>
                  <div class="text-white font-semibold group-hover:text-red-400 transition-colors">YouTube</div>
                  <div class="text-neutral-500 text-sm">@tobyonfitness</div>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-auto text-neutral-700 group-hover:text-neutral-400 transition-colors"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>

              <a
                href="https://www.instagram.com/tobyonfitness"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-4 p-4 rounded-xl bg-neutral-950 border border-neutral-800 hover:border-pink-500/40 hover:bg-pink-950/10 transition-all group"
              >
                <div class="w-10 h-10 rounded-lg bg-pink-600/20 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ec4899" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
                </div>
                <div>
                  <div class="text-white font-semibold group-hover:text-pink-400 transition-colors">Instagram</div>
                  <div class="text-neutral-500 text-sm">@tobyonfitness</div>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-auto text-neutral-700 group-hover:text-neutral-400 transition-colors"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    {/* What to Expect */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-5xl">
        <h2 class="text-3xl font-bold text-white mb-3">What I Actually Respond To</h2>
        <p class="text-neutral-500 mb-10">No fluff. Here's what's worth emailing about:</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">🤝</div>
            <h3 class="text-lg font-bold text-white mb-2">Sponsorships</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              Fitness tech only — gear I'd actually use. Speediance, WHOOP, Garmin, 8Sleep territory. Not interested in supplements I've never tested.
            </p>
          </div>

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">🔧</div>
            <h3 class="text-lg font-bold text-white mb-2">Consulting</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              Building a data-driven fitness stack? Automating training decisions with wearable data? That's interesting. Let's talk scope first.
            </p>
          </div>

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">❓</div>
            <h3 class="text-lg font-bold text-white mb-2">Questions</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              Genuine questions about Speediance, WHOOP, BJJ, or my training approach are welcome. If it's a question I can't answer briefly, I'll say so.
            </p>
          </div>

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">🎬</div>
            <h3 class="text-lg font-bold text-white mb-2">Collaborations</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              If you're building something in the fitness tech or automation space and it's a genuine fit — I'm open. Pitch me the idea.
            </p>
          </div>

        </div>
      </div>
    </section>

    {/* Response Expectations */}
    <section class="py-12 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="bg-neutral-900/50 border border-neutral-800 rounded-2xl p-8 flex flex-col md:flex-row items-start gap-6">
          <div class="text-4xl flex-shrink-0">⏱️</div>
          <div>
            <h3 class="text-xl font-bold text-white mb-2">Response Time</h3>
            <p class="text-neutral-400 leading-relaxed">
              I'm one person. I train at 6:30 AM, work a full day, and roll BJJ most evenings. I read everything — but I reply when I have something useful to say, not just to acknowledge receipt. Give it a few days before following up.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* FAQ */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-4xl">
        <h2 class="text-3xl font-bold text-white mb-3">Common Questions</h2>
        <p class="text-neutral-500 mb-10">Check here before emailing — your answer might already be here.</p>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-neutral-700 transition-all">
              <h3 class="text-white font-semibold mb-3 flex items-start gap-3">
                <span class="text-blue-500 font-bold flex-shrink-0">Q:</span>
                {faq.q}
              </h3>
              <p class="text-neutral-400 leading-relaxed pl-6">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* CTA */}
    <section class="py-24 border-t border-neutral-900">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-4">Ready to reach out?</h2>
        <p class="text-neutral-400 mb-8 max-w-xl mx-auto">
          Drop me a line. Keep it specific and I'll actually reply.
        </p>
        <a
          href="mailto:toby@tobyonfitness.tech"
          class="inline-flex items-center gap-2 px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-full transition-all hover:scale-105"
        >
          Email Toby
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
      </div>
    </section>

  </main>
</Layout>
