---
import Layout from '../layouts/Layout.astro';
import { BLOG_POSTS } from '../data/mock.js';
import { ArrowRight } from 'lucide-react';

// Filter blog posts related to BJJ
const bjjPosts = BLOG_POSTS.filter(post => {
  const category = post.category?.toLowerCase() || '';
  const tags = post.tags?.map(t => t.toLowerCase()) || [];
  const title = post.title?.toLowerCase() || '';
  const excerpt = post.excerpt?.toLowerCase() || '';
  
  return category === 'bjj' || 
    tags.some(tag => tag === 'bjj' || tag === 'jiu-jitsu' || tag === 'jiu jitsu') ||
    title.includes('bjj') || title.includes('jiu-jitsu') || title.includes('jiu jitsu') ||
    excerpt.includes('bjj') || excerpt.includes('jiu-jitsu') || excerpt.includes('jiu jitsu');
}).slice(0, 3);

// BJJ Stats
const stats = {
  sessions: 60,
  rank: "Blue Belt",
  competitions: 2,
  startedYear: 2023
};

// Journey timeline data
const journeyTimeline = [
  {
    year: "2023",
    title: "Started BJJ Journey",
    description: "Began training Brazilian Jiu-Jitsu, immediately hooked by the technical complexity and problem-solving aspect of the art.",
    highlight: true
  },
  {
    year: "2023-2024",
    title: "White Belt",
    description: "Learned fundamentals, positional hierarchy, and basic submissions. Focused on survival and getting comfortable guard.",
    highlight: false
  },
  {
    year: "2024",
    title: "First Competition",
    description: "Entered first tournament at white belt. Gained invaluable experience testing skills against unfamiliar opponents.",
    highlight: false
  },
  {
    year: "2024",
    title: "Promoted to Blue Belt",
    description: "Recognized for consistent training and technical progress. Started developing more sophisticated guard game.",
    highlight: true
  },
  {
    year: "2025",
    title: "Second Competition",
    description: "Competed at blue belt level, facing higher-ranked competitors. Continued to refine offensive and defensive repertoire.",
    highlight: false
  },
  {
    year: "Present",
    title: "Blue Belt - Current",
    description: "Training consistently, ~60 sessions in. Focused on building a complete game with emphasis on guard retention and submissions.",
    highlight: true
  }
];

// Lessons learned data
const lessonsLearned = [
  {
    icon: "🧠",
    title: "Technical Over Athletic",
    description: "BJJ rewards technique over brute strength. Even as a larger practitioner, proper leverage and positioning beat power every time."
  },
  {
    icon: "😤",
    title: "Humility Is Essential",
    description: "Getting submitted by smaller, faster training partners teaches you to check your ego at the door. Everyone taps."
  },
  {
    icon: "⏳",
    title: "Patience Pays Off",
    description: "Rushing leads to mistakes. BJJ taught me to stay calm under pressure and wait for the right opportunity to attack."
  },
  {
    icon: "🔄",
    title: "Process Over Results",
    description: "Focusing on improvement rather than winning rolls leads to faster progress. The belt comes as a byproduct of dedication."
  },
  {
    icon: "💪",
    title: "Physical Intelligence",
    description: "BJJ heightened body awareness dramatically. Understanding weight distribution, balance, and leverage translates to other activities."
  },
  {
    icon: "🤝",
    title: "Community Matters",
    description: "Training partners become collaborators in growth. The BJJ community supports each other's development rather than competing against it."
  }
];

// JSON-LD Schema
const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://tobyonfitnesstech.com/bjj/#webpage",
  "name": "Brazilian Jiu-Jitsu - Toby on Fitness Tech",
  "description": "Follow Toby's BJJ journey: started in 2023, blue belt, competed twice, ~60 training sessions. Training philosophy, lessons learned, and progression.",
  "url": "https://tobyonfitnesstech.com/bjj",
  "inLanguage": "en",
  "isPartOf": {
    "@id": "https://tobyonfitnesstech.com/#website"
  },
  "about": {
    "@type": "Person",
    "name": "Toby Peters",
    "description": "Blue belt in Brazilian Jiu-Jitsu, training since 2023"
  }
};
---

<Layout
  title="Brazilian Jiu-Jitsu - Blue Belt Journey | Toby on Fitness Tech"
  description="Follow Toby's BJJ journey: started in 2023, blue belt, competed twice, ~60 training sessions. Training philosophy, lessons learned, and progression."
  jsonLd={webPageSchema}
>
  <main class="min-h-screen bg-neutral-950 text-white">
    
    {/* ── Hero Section ─────────────────────────────────────────────────────── */}
    <section class="pt-28 pb-14 md:pt-36 md:pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-blue-900/10 via-transparent to-transparent pointer-events-none" />
      <div class="absolute right-0 top-0 w-72 h-72 bg-blue-600/5 rounded-full blur-3xl pointer-events-none" />
      <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-3xl">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-4">🥋 Brazilian Jiu-Jitsu</p>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
            Brazilian<br />
            <span class="text-blue-500">Jiu-Jitsu</span>
          </h2>
          <p class="text-xl text-neutral-400 mb-10 leading-relaxed max-w-2xl">
            Started in 2023. Blue belt. Competed twice. 
            ~60 training sessions in. The technical journey of leveraging technique over raw strength.
          </p>

          {/* Stat pills */}
          <div class="flex flex-wrap gap-3">
            <div class="flex items-center gap-2 bg-neutral-900 border border-neutral-800 rounded-full px-4 py-2">
              <span class="w-3 h-3 rounded-full bg-blue-500 inline-block flex-shrink-0"></span>
              <span class="text-sm font-semibold text-white">Blue Belt</span>
            </div>
            <div class="flex items-center gap-2 bg-neutral-900 border border-neutral-800 rounded-full px-4 py-2">
              <span class="text-sm font-semibold text-white">Started 2023</span>
            </div>
            <div class="flex items-center gap-2 bg-neutral-900 border border-neutral-800 rounded-full px-4 py-2">
              <span class="text-sm font-semibold text-white">2 Competitions</span>
            </div>
            <div class="flex items-center gap-2 bg-neutral-900 border border-neutral-800 rounded-full px-4 py-2">
              <span class="text-sm font-semibold text-white">Gi & No-Gi</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ── Stats Cards Row ─────────────────────────────────────────────────── */}
    <section class="py-12 bg-neutral-900/40 border-y border-neutral-800">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-colors text-center">
            <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-2">~60</div>
            <div class="text-sm font-semibold text-neutral-400 uppercase tracking-wide">BJJ Sessions</div>
          </div>
          <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-colors text-center">
            <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-2">Blue</div>
            <div class="text-sm font-semibold text-neutral-400 uppercase tracking-wide">Belt Rank</div>
          </div>
          <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-colors text-center">
            <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-2">2</div>
            <div class="text-sm font-semibold text-neutral-400 uppercase tracking-wide">Competitions</div>
          </div>
          <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-colors text-center">
            <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-2">2023</div>
            <div class="text-sm font-semibold text-neutral-400 uppercase tracking-wide">Since</div>
          </div>
        </div>
      </div>
    </section>

    {/* ── Journey Timeline Section ────────────────────────────────────────── */}
    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-2">The Journey</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-10">BJJ Progression</h2>

          <div class="space-y-0">
            {journeyTimeline.map((entry, i) => (
              <div class="relative flex gap-6 md:gap-10">
                {/* Vertical line + belt dot */}
                <div class="flex flex-col items-center flex-shrink-0 w-10">
                  <div
                    class={`w-5 h-5 rounded-full border-4 border-neutral-950 flex-shrink-0 mt-1 ${entry.highlight ? 'ring-2 ring-blue-500 ring-offset-2 ring-offset-neutral-950' : ''}`}
                    style={`background-color: ${entry.highlight ? '#3b82f6' : '#4b5563'};`}
                  />
                  {i < journeyTimeline.length - 1 && (
                    <div class="flex-1 w-0.5 bg-neutral-800 mt-1 mb-0 min-h-[60px]" />
                  )}
                </div>

                {/* Content card */}
                <div class={`pb-8 flex-1 ${entry.highlight ? 'border border-blue-700/40 bg-blue-900/5 rounded-xl p-5 -mt-1' : ''}`}>
                  <div class="flex items-center gap-3 mb-1 flex-wrap">
                    <span class="text-xs font-bold uppercase tracking-wider px-2.5 py-0.5 rounded-full bg-blue-500/20 text-blue-400">
                      {entry.year}
                    </span>
                    {entry.highlight && (
                      <span class="text-xs bg-blue-500/20 text-blue-400 px-2 py-0.5 rounded-full font-semibold">Milestone</span>
                    )}
                  </div>
                  <h3 class="text-lg font-bold text-white mb-2">{entry.title}</h3>
                  <p class="text-sm text-neutral-400 leading-relaxed">{entry.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* ── Lessons Learned Section ─────────────────────────────────────────── */}
    <section class="py-16 md:py-20 bg-neutral-900/40 border-y border-neutral-800">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-2">What BJJ Taught Me</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-10">Lessons Learned</h2>

          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
            {lessonsLearned.map(lesson => (
              <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-blue-500/40 transition-colors">
                <div class="text-3xl mb-4">{lesson.icon}</div>
                <h3 class="font-bold text-white mb-3">{lesson.title}</h3>
                <p class="text-sm text-neutral-400 leading-relaxed">{lesson.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* ── Related Blog Posts ───────────────────────────────────────────────── */}
    {bjjPosts.length > 0 && (
      <section class="py-16 md:py-20">
        <div class="container mx-auto px-4">
          <div class="max-w-4xl mx-auto">
            <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-2">Read More</p>
            <h2 class="text-3xl md:text-4xl font-bold mb-4">Related Blog Posts</h2>
            <p class="text-neutral-400 mb-10 max-w-xl">
              Thoughts on BJJ training, technique, and the martial arts journey.
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
              {bjjPosts.map((post) => (
                <a href={`/blog/${post.slug}`} class="group block bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden hover:border-blue-500/50 transition-all">
                  {post.image && (
                    <div class="aspect-video overflow-hidden bg-neutral-950">
                      <img
                        src={post.image}
                        alt={post.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        loading="lazy"
                      />
                    </div>
                  )}
                  <div class="p-5">
                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold uppercase tracking-wide bg-blue-500/10 text-blue-400 border border-blue-500/20">
                      {post.category}
                    </span>
                    <h3 class="mt-3 text-lg font-bold text-white leading-snug group-hover:text-blue-400 transition-colors line-clamp-2">
                      {post.title}
                    </h3>
                    <div class="mt-2 text-xs text-neutral-500 flex items-center gap-2">
                      <span>{new Date(post.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                      {post.readTime && (
                        <>
                          <span>•</span>
                          <span>{post.readTime} min read</span>
                        </>
                      )}
                    </div>
                    <p class="mt-3 text-sm text-neutral-400 leading-relaxed line-clamp-2">
                      {post.excerpt}
                    </p>
                  </div>
                </a>
              ))}
            </div>

            <div class="mt-8 text-center">
              <a 
                href="/blog" 
                class="inline-flex items-center gap-2 text-sm text-blue-500 hover:text-blue-400 transition-colors font-medium"
              >
                View All Blog Posts
                <ArrowRight size={16} />
              </a>
            </div>
          </div>
        </div>
      </section>
    )}

    {/* ── CTA Section ──────────────────────────────────────────────────────── */}
    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-4">Continue Exploring</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-4">More Training Content</h2>
          <p class="text-neutral-400 mb-8 leading-relaxed max-w-xl mx-auto">
            Explore the full training dashboard, running stats, lifting data, and fitness tech reviews.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a
              href="/training"
              class="px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-semibold transition-colors text-sm"
            >
              Training Dashboard
            </a>
            <a
              href="/running"
              class="px-6 py-3 bg-neutral-800 hover:bg-neutral-700 text-white rounded-xl font-semibold transition-colors text-sm border border-neutral-700"
            >
              Running Stats
            </a>
            <a
              href="/blog"
              class="px-6 py-3 bg-neutral-800 hover:bg-neutral-700 text-white rounded-xl font-semibold transition-colors text-sm border border-neutral-700"
            >
              Blog
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>
