---
import Layout from '../layouts/Layout.astro';

const siteUrl = "https://tobyonfitnesstech.com";

// ProfilePage JSON-LD — about page structured data for E-E-A-T signals
const profilePageSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "@id": `${siteUrl}/about/#profilepage`,
  "name": "About Toby Glenn Peters",
  "description": "Toby Glenn Peters is an independent fitness technology reviewer who dropped from 242 to 188 lbs using data-driven training, Speediance, Tonal, WHOOP, Garmin, and Brazilian Jiu-Jitsu.",
  "url": `${siteUrl}/about/`,
  "inLanguage": "en-US",
  "isPartOf": { "@id": `${siteUrl}/#website` },
  "about": { "@id": `${siteUrl}/#toby` },
  "mainEntity": {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": `${siteUrl}/#toby`,
    "name": "Toby Glenn Peters",
    "alternateName": ["TobyOnFitnessTech", "Toby on Fitness Tech"],
    "description": "Independent fitness technology reviewer. Former 242 lb, now 188 lb (cut) building to 218–229 lbs. Testing Speediance, Tonal, WHOOP, Garmin & more with real data. Computer programmer, BJJ practitioner, data nerd.",
    "url": siteUrl,
    "image": [
      {
        "@type": "ImageObject",
        "@id": `${siteUrl}/#toby-image-before`,
        "url": `${siteUrl}/progress/progress_230.jpg`,
        "caption": "Toby Glenn Peters at 230 lbs before fitness transformation — August 4, 2023",
        "width": 400,
        "height": 533
      },
      {
        "@type": "ImageObject",
        "@id": `${siteUrl}/#toby-image-after`,
        "url": `${siteUrl}/progress/progress_188.jpg`,
        "caption": "Toby Glenn Peters at 188 lbs after 54 lb weight loss — January 4, 2024",
        "width": 400,
        "height": 533
      },
      {
        "@type": "ImageObject",
        "@id": `${siteUrl}/#toby-image-current`,
        "url": `${siteUrl}/progress/progress_229.jpg`,
        "caption": "Toby Glenn Peters at 229 lbs muscle building phase — February 3, 2026",
        "width": 400,
        "height": 533
      }
    ],
    "sameAs": [
      "https://www.youtube.com/@tobyonfitness",
      "https://x.com/tobyglenn",
      "https://www.instagram.com/tobyonfitness"
    ],
    "knowsAbout": [
      "Fitness Technology",
      "Smart Home Gym Equipment",
      "Wearable Technology",
      "Strength Training",
      "Brazilian Jiu-Jitsu",
      "Speediance",
      "Tonal",
      "WHOOP",
      "Garmin",
      "GLP-1 Weight Loss",
      "Data-Driven Training",
      "Home Gym Design",
      "Nutrition Tracking",
      "Sleep Optimization",
      "Running",
      "OpenClaw AI"
    ],
    "hasCredential": [
      {
        "@type": "EducationalOccupationalCredential",
        "credentialCategory": "experience",
        "name": "BJJ White Belt — 4 Stripes",
        "description": "Brazilian Jiu-Jitsu white belt with four stripes, approximately 1.5 years training"
      }
    ],
    "achievement": [
      {
        "@type": "Thing",
        "name": "54 lbs Weight Loss",
        "description": "Lost 54 lbs in 6 months (242 → 188 lbs) through data-driven fitness tracking and strength training"
      },
      {
        "@type": "Thing",
        "name": "1 Million+ lbs Lifted on Speediance",
        "description": "Logged over 1,296,447 lbs of lifting volume on Speediance smart gym since July 2025"
      },
      {
        "@type": "Thing",
        "name": "265+ Miles Run",
        "description": "265.1 miles logged across 111 running sessions over the past year"
      }
    ],
    "jobTitle": "Independent Fitness Technology Reviewer",
    "worksFor": { "@id": `${siteUrl}/#organization` },
    "nationality": {
      "@type": "Country",
      "name": "United States"
    }
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
      { "@type": "ListItem", "position": 2, "name": "About", "item": `${siteUrl}/about/` }
    ]
  }
};
---

<Layout 
  title="About Toby Glenn Peters - TobyOnFitnessTech"
  description="Toby Glenn Peters dropped from 242 to 188 lbs using obsessive data tracking, Speediance, Tonal, and Brazilian Jiu-Jitsu. Independent fitness tech reviewer — no programs, no fluff."
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "About", url: "/about" }]}
  jsonLd={profilePageSchema}
>
  <main class="min-h-screen bg-neutral-950 text-white">
    {/* Hero Section */}
    <section class="pt-20 pb-12 md:pt-28 md:pb-16 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-blue-900/10 to-transparent pointer-events-none" />
      <div class="container mx-auto px-4 relative z-10">
        <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
          {/* Left — text */}
          <div class="flex-1 max-w-2xl">
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
              I don't sell programs.<br />
              <span class="bg-gradient-to-r from-blue-500 to-purple-500 bg-clip-text text-transparent">I just document what actually works.</span>
            </h2>
            <p class="text-xl text-neutral-400 mb-8 leading-relaxed">
              Computer Programmer. BJJ Practitioner. Data Nerd. <br/>
              I dropped 54 lbs in 6 months and I'm here to show you exactly how.
            </p>
          </div>

          {/* Right — before/after comparison */}
          <div class="flex-shrink-0 w-full lg:w-auto">
            <div class="flex gap-3 items-end">
              {/* Before */}
              <div class="relative group">
                <div class="w-44 md:w-52 rounded-2xl overflow-hidden border border-neutral-800 shadow-xl">
                  <img
                    src="/progress/progress_230.jpg"
                    alt="Before — 230 lbs"
                    class="w-full aspect-[3/4] object-cover object-top"
                    loading="eager"
                  />
                </div>
                <div class="absolute bottom-3 left-0 right-0 flex justify-center">
                  <span class="bg-black/80 backdrop-blur-sm text-neutral-300 text-xs font-bold px-3 py-1 rounded-full border border-neutral-700">
                    230 lbs
                  </span>
                </div>
              </div>

              {/* Arrow / divider */}
              <div class="flex flex-col items-center gap-1 pb-10 text-neutral-500">
                <div class="h-px w-6 bg-neutral-700"></div>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                <div class="h-px w-6 bg-neutral-700"></div>
              </div>

              {/* After */}
              <div class="relative group">
                <div class="w-44 md:w-52 rounded-2xl overflow-hidden border border-blue-500/40 shadow-xl shadow-blue-900/20">
                  <img
                    src="/progress/progress_188.jpg"
                    alt="After — 188 lbs"
                    class="w-full aspect-[3/4] object-cover object-top"
                    loading="eager"
                  />
                </div>
                <div class="absolute bottom-3 left-0 right-0 flex justify-center">
                  <span class="bg-blue-600/90 backdrop-blur-sm text-white text-xs font-bold px-3 py-1 rounded-full">
                    188 lbs
                  </span>
                </div>
                {/* -54 lbs badge */}
                <div class="absolute -top-3 -right-3 bg-blue-600 text-white text-xs font-black px-2.5 py-1.5 rounded-full shadow-lg rotate-6">
                  −54 lbs
                </div>
              </div>
            </div>
            <p class="text-center text-neutral-600 text-xs mt-4 tracking-wider uppercase">6 months · no excuses</p>
          </div>
        </div>
      </div>
    </section>

    {/* The Transformation */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4">
        <div class="flex flex-col md:flex-row gap-12 items-center">
          <div class="md:w-1/2">
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8">
               <h2 class="text-2xl font-bold mb-6 text-blue-400">The Stats</h2>
               <div class="grid grid-cols-2 gap-6">
                 <div>
                   <div class="text-4xl font-bold text-white mb-1">242</div>
                   <div class="text-sm text-neutral-500 uppercase tracking-wider">Starting Weight</div>
                 </div>
                 <div>
                   <div class="text-4xl font-bold text-blue-500 mb-1">188</div>
                   <div class="text-sm text-neutral-500 uppercase tracking-wider">Achieved Jan 4, 2024</div>
                 </div>
                 <div>
                   <div class="text-4xl font-bold text-white mb-1">6 Months</div>
                   <div class="text-sm text-neutral-500 uppercase tracking-wider">Duration</div>
                 </div>
                 <div>
                   <div class="text-4xl font-bold text-white mb-1">0</div>
                   <div class="text-sm text-neutral-500 uppercase tracking-wider">Excuses Made</div>
                 </div>
                 <div>
                   <div class="text-4xl font-bold text-white mb-1">54 lbs</div>
                   <div class="text-sm text-neutral-500 uppercase tracking-wider">Total Lost</div>
                 </div>
                 <div>
                   <div class="text-4xl font-bold text-white mb-1">1M+</div>
                   <div class="text-sm text-neutral-500 uppercase tracking-wider">Lbs Lifted</div>
                 </div>
               </div>
            </div>
          </div>
          <div class="md:w-1/2 space-y-6 text-neutral-300 leading-relaxed text-lg">
            <h2 class="text-3xl font-bold text-white">The Turnaround</h2>
            <p>
              In late 2024, I was 242 pounds. Traditional cardio — the thing most people lean on to lose weight — wasn't cutting it. 
              I decided to engineer a smarter solution.
            </p>
            <p>
              I chose to to be a computer programmer. I went deep on the data: WHOOP recovery scores, Garmin activity tracking, 8Sleep sleep quality, and meticulous calorie logging via Cronometer. 
              Every variable that I could control, I controlled. Every variable I could, I measured.
            </p>
            <p>
              The anchor of my training became a <strong class="text-white">digital cable machine</strong> — a smart home gym that let me train heavy from home. 
              I've now logged over 1,000,000 lbs of lifting volume on it. No hype — I have the data to prove it.
            </p>
            <p>
              Alongside the machine work, I returned to <strong class="text-white">Brazilian Jiu-Jitsu</strong> as both a physical outlet and a mental anchor. 
              BJJ forced me to stay disciplined, stay humble, and keep showing up — even when the scale wasn't moving the way I wanted.
            </p>
            <p>
              Six months later: 188 lbs. 54 lbs lost.
            </p>
            <div class="pt-2">
              <a href="/videos?category=transformation" class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 font-semibold transition-colors group">
                Watch the transformation videos 
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Running Stats Section */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-8 text-center">Running Stats</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
            <div class="text-4xl font-bold text-white mb-2">111</div>
            <div class="text-sm text-neutral-400 uppercase tracking-wider">Total Runs</div>
          </div>
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
            <div class="text-4xl font-bold text-white mb-2">265.1 mi</div>
            <div class="text-sm text-neutral-400 uppercase tracking-wider">Total Miles</div>
          </div>
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
            <div class="text-4xl font-bold text-white mb-2">67.2 h</div>
            <div class="text-sm text-neutral-400 uppercase tracking-wider">Total Hours</div>
          </div>
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
            <div class="text-4xl font-bold text-white mb-2">15:12/mi</div>
            <div class="text-sm text-neutral-400 uppercase tracking-wider">Avg Pace</div>
          </div>
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
            <div class="text-4xl font-bold text-white mb-2">5 mi</div>
            <div class="text-sm text-neutral-400 uppercase tracking-wider">Longest Run (June 30, 2025)</div>
          </div>
        </div>
      </div>
    </section>

    {/* Chapter 2 — The Build */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-3">Chapter 2</p>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-10">
            188 lbs Was the Starting Line, Not the Finish.
          </h2>

          {/* Stats grid */}
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8 mb-10">
            <h3 class="text-xl font-bold mb-6 text-blue-400">The Build Phase Numbers</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
              <div>
                <div class="text-3xl font-bold text-white mb-1">1,296,447</div>
                <div class="text-xs text-neutral-500 uppercase tracking-wider">lbs Lifted Since July 2025</div>
              </div>
              <div>
                <div class="text-3xl font-bold text-white mb-1">125</div>
                <div class="text-xs text-neutral-500 uppercase tracking-wider">Speediance Sessions</div>
              </div>
              <div>
                <div class="text-3xl font-bold text-white mb-1">265.1 mi</div>
                <div class="text-xs text-neutral-500 uppercase tracking-wider">Miles Run (Past Year)</div>
              </div>
              <div>
                <div class="text-3xl font-bold text-white mb-1">111</div>
                <div class="text-xs text-neutral-500 uppercase tracking-wider">Runs Logged</div>
              </div>
            </div>
          </div>

          {/* Prose */}
          <div class="space-y-6 text-neutral-300 leading-relaxed text-lg">
            <p>
              I hit 188 lbs on January 4, 2024, and immediately understood that the cut was just phase one. 
              Losing weight is a subtraction problem. Building something on top of it is a different challenge entirely — and honestly, 
              the more interesting one. The scale has been climbing since. 188 → 205 → 218-229 lbs as of early 2026. 
              That's not a setback. That's the plan working.
            </p>
            <p>
              The <strong class="text-white">Speediance</strong> became the anchor of phase two. In the seven months between July 2025 and February 2026 alone, 
              I logged 125 sessions and moved <strong class="text-white">1,296,447 lbs</strong> of total volume. My best single session: 
              35,305 lbs in 50 minutes on February 2, 2026. Top lifts tracked by the machine — barbell lat pulldown at a 294 lb 1RM, 
              bent over row at 198 lbs, bench press at 90 lbs via the cable system. These aren't estimates. The machine logs every rep.
            </p>
            <p>
              Running got rebuilt from scratch in parallel. I started with 1-mile sessions — genuinely just trying to not stop. 
              By early 2026 I'm doing 5-mile runs. 111 runs logged over the past year: 84 outdoor, 27 treadmill, 2 open water swims. 
              <strong class="text-white">265.1 miles total.</strong> Not fast. But consistent, progressive, and building. 
              The weight going up isn't something to explain away — muscle weighs something. That's the point.
            </p>
            <p>
              Every training decision now runs through the stack: WHOOP gives me a recovery score each morning, 
              8Sleep tells me how the night actually went, and the AI assistant I built on <strong class="text-white">OpenClaw</strong> reads all of it — 
              Garmin activity, sleep data, HRV trends — and generates a daily readiness recommendation before I decide whether to push or pull back. 
              The system makes the decisions defensible. No guessing, no going on feel when the data says otherwise.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* Progress Photos */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4">
        <div class="mb-10">
          <h2 class="text-3xl font-bold mb-3">Progress Photos</h2>
          <p class="text-neutral-400 text-lg">242 → 188 lbs. Every photo is real, unedited, and timestamped by weight.</p>
        </div>

        {/* Timeline gallery */}
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 mb-8">
          {[
            { src: '/progress/progress_230.jpg', label: '230 lbs', date: 'Aug 4, 2023' },
            { src: '/progress/progress_220.jpg', label: '220 lbs', date: 'Sep 7, 2023' },
            { src: '/progress/progress_200.jpg', label: '200 lbs', date: 'Dec 1, 2023' },
            { src: '/progress/progress_188.jpg', label: '188 lbs', date: 'Jan 4, 2024' },
            { src: '/progress/progress_191.jpg', label: '191 lbs', date: 'Feb 6, 2024' },
            { src: '/progress/progress_211.jpg', label: '211 lbs', date: 'Jun 2, 2024' },
            { src: '/progress/progress_229.jpg', label: '229 lbs', date: 'Feb 3, 2026' },
            { src: '/progress/workout_action.jpg', label: 'Training', date: '' },
          ].map(({ src, label, date }) => (
            <div class="relative group overflow-hidden rounded-xl bg-neutral-900 border border-neutral-800 hover:border-neutral-600 transition-all">
              <div class="aspect-[3/4]">
                <img
                  src={src}
                  alt={label}
                  class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
              <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/85 via-black/40 to-transparent pt-8 pb-2 px-2 text-center pointer-events-none">
    <span class="text-white text-xs font-bold block leading-tight drop-shadow">{label}</span>
    {date && <span class="text-neutral-400 text-[10px] block">{date}</span>}
  </div>
            </div>
          ))}
        </div>

        {/* Data callout */}
        <div class="bg-neutral-900/50 border border-neutral-800 rounded-2xl p-6 flex flex-col md:flex-row items-center gap-6">
          <div class="flex-shrink-0 text-5xl">📊</div>
          <div>
            <h3 class="text-xl font-bold text-white mb-2">Every data point logged</h3>
            <p class="text-neutral-400">
              These photos don't tell the whole story. Behind each one: daily WHOOP recovery scores, Garmin training load, 8Sleep sleep quality data, 
              and Cronometer nutrition logs. The transformation was systematic, not accidental.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* Philosophy / Pillars */}
    <section class="py-16 bg-neutral-900/30 border-y border-neutral-900">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold mb-12 text-center">My Focus</h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="space-y-4">
            <h3 class="text-xl font-bold text-white">Home Gym Tech</h3>
            <p class="text-neutral-400">
              I've lifted over 1,000,000 lbs on my digital cable machine. I test firmware updates, compare modes, and find the bugs 
              so you don't have to. If a machine says it replaces a gym, I verify it.
            </p>
          </div>
          <div class="space-y-4">
            <h3 class="text-xl font-bold text-white">BJJ & Grappling</h3>
            <p class="text-neutral-400">
              Jiu-Jitsu isn't just a sport; it's a system. I analyze match footage, discuss belt culture, and break down the "why" 
              behind the techniques.
            </p>
          </div>
          <div class="space-y-4">
            <h3 class="text-xl font-bold text-white">Data & Automation</h3>
            <p class="text-neutral-400">
              From Whoop recovery scores to building my own AI assistant (OpenClaw) to manage my schedule and training. 
              If it can be measured and automated, I'm interested.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* Training Philosophy - Why I Train at 6:30 AM */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-bold text-white mb-8 text-center">Training Philosophy</h2>
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8 space-y-6">
            <div class="flex gap-4">
              <div class="text-3xl">🌅</div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Why I Train at 6:30 AM</h3>
                <p class="text-neutral-400">
                  Mornings are for training before the day steals your energy. 6:30 AM means I'm done lifting or on the mat 
                  by 8:00, leaving the rest of the day for work, family, and recovery. Training at night has never worked for me — 
                  I get second winds that mess with sleep, and by 9 PM I'm too tired to roll hard.
                </p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="text-3xl">🔄</div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2">BJJ + Lifting + Running = The Stack</h3>
                <p class="text-neutral-400">
                  I don't choose between them — I do all three. BJJ 3-4x/week keeps my grappling sharp and provides cardio. 
                  Speediance lifting 4x/week builds muscle and strength. Running 2-3x/week maintains cardiovascular base. 
                  The key is not doing too much of any one: 10 hours total training/week is my ceiling before recovery suffers.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* BJJ Journey Section */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-10 text-center">My BJJ Journey</h2>
          
          {/* BJJ Comparison Photo */}
          <div class="mb-12">
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl overflow-hidden">
              <img 
                src="/images/about/bjj_comparison.jpg" 
                alt="BJJ Comparison: Year 1 (170lbs) vs Year 2 (185lbs) with 4 stripes"
                class="w-full object-contain aspect-video bg-neutral-950"
              />
              <div class="p-6">
                <p class="text-center text-neutral-300 text-lg">
                  <strong>185lbs Year 2 BJJ</strong> — <strong>Right 170lbs Year 1 BJJ</strong><br/> 
                  <span class="text-neutral-500">All four stripes, About a year and a half in the gym</span>
                </p>
              </div>
            </div>
          </div>

          {/* BJJ Day Photos Gallery */}
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl overflow-hidden">
              <img 
                src="/images/about/bjj_day1.jpg" 
                alt="BJJ Day 1: Belt cutting ceremony"
                class="w-full object-contain aspect-video bg-neutral-950"
              />
              <div class="p-4">
                <p class="text-center text-neutral-300">BJJ Day 1: Belt cutting ceremony, multiple people at academy</p>
              </div>
            </div>
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl overflow-hidden">
              <img 
                src="/images/about/bjj_day2.jpg" 
                alt="BJJ Day 2: Two men posing with medals"
                class="w-full object-contain aspect-video bg-neutral-950"
              />
              <div class="p-4">
                <p class="text-center text-neutral-300">BJJ Day 2: Two men posing with medals at a tournament</p>
              </div>
            </div>
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl overflow-hidden">
              <img 
                src="/images/about/bjj_day4.jpg" 
                alt="BJJ Day 4: Sparring/grappling scene"
                class="w-full object-contain aspect-video bg-neutral-950"
              />
              <div class="p-4">
                <p class="text-center text-neutral-300">BJJ Day 4: Sparring/grappling scene</p>
              </div>
            </div>
          </div>

          {/* BJJ Competition & Training Details */}
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8 mt-8">
