---
import Layout from '../layouts/Layout.astro';

const updated = 'March 2026';

const termsSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://tobyonfitnesstech.com/terms#webpage',
  name: 'Terms of Service | Toby on Fitness Tech',
  description:
    'Terms of Service for Toby on Fitness Tech covering acceptable use, ownership, disclaimers, and limitations of liability.',
  url: 'https://tobyonfitnesstech.com/terms',
  inLanguage: 'en',
  isPartOf: {
    '@id': 'https://tobyonfitnesstech.com/#website',
  },
  about: {
    '@id': 'https://tobyonfitnesstech.com/#organization',
  },
  author: {
    '@id': 'https://tobyonfitnesstech.com/#toby',
  },
};
---

<Layout
  title="Terms of Service | Toby on Fitness Tech"
  description="Review the Terms of Service for TobyOnFitnessTech, including usage rules, content ownership, fitness disclaimers, and liability limits."
  jsonLd={termsSchema}
>
  <section class="bg-neutral-950 text-white border-b border-neutral-800">
    <div class="container mx-auto max-w-4xl px-4 py-16 md:py-20">
      <p class="text-blue-400 font-semibold uppercase tracking-wider text-sm">Legal</p>
      <h1 class="mt-3 text-4xl md:text-5xl font-bold">Terms of Service</h1>
      <p class="mt-4 text-neutral-400 max-w-3xl">
        These terms govern use of TobyOnFitnessTech, including website content, data-driven analysis,
        and fitness technology commentary.
      </p>
      <p class="mt-3 text-sm text-neutral-500">Last updated: {updated}</p>
    </div>
  </section>

  <section class="bg-neutral-950 text-neutral-200">
    <div class="container mx-auto max-w-4xl px-4 py-12 md:py-16 space-y-10 leading-relaxed">
      <section class="rounded-xl border border-neutral-800 bg-neutral-900/40 p-6 md:p-8">
        <h2 class="text-2xl font-bold text-white">1. Acceptance of Terms</h2>
        <p class="mt-4">
          By accessing or using TobyOnFitnessTech, you agree to be bound by these Terms of Service and
          applicable laws. If you do not agree, please discontinue use of the site.
        </p>
      </section>

      <section class="rounded-xl border border-neutral-800 bg-neutral-900/40 p-6 md:p-8">
        <h2 class="text-2xl font-bold text-white">2. User Responsibilities</h2>
        <ul class="mt-4 space-y-3 list-disc pl-6 marker:text-blue-400">
          <li>Use the website lawfully and respectfully.</li>
          <li>Do not attempt to disrupt site operation or access restricted systems.</li>
          <li>Do not copy, scrape, or republish content in a misleading or abusive way.</li>
          <li>Evaluate fitness and product information independently before acting on it.</li>
        </ul>
      </section>

      <section class="rounded-xl border border-neutral-800 bg-neutral-900/40 p-6 md:p-8">
        <h2 class="text-2xl font-bold text-white">3. Content Ownership</h2>
        <p class="mt-4">
          Unless otherwise noted, all original content on TobyOnFitnessTech — including written analysis,
          videos, graphics, and branded materials — is owned by Toby Glenn Peters. You may link to content,
          but you may not reproduce substantial portions without prior written permission.
        </p>
      </section>

      <section class="rounded-xl border border-neutral-800 bg-neutral-900/40 p-6 md:p-8">
        <h2 class="text-2xl font-bold text-white">4. Fitness and Medical Disclaimer</h2>
        <p class="mt-4">
          Content on this site is for informational and educational purposes only. It is not medical,
          diagnostic, or therapeutic advice. Always consult qualified healthcare or fitness professionals
          before starting or changing any training, recovery, nutrition, or health program.
        </p>
      </section>

      <section class="rounded-xl border border-neutral-800 bg-neutral-900/40 p-6 md:p-8">
        <h2 class="text-2xl font-bold text-white">5. Limitation of Liability</h2>
        <p class="mt-4">
          To the fullest extent permitted by law, TobyOnFitnessTech and its operator are not liable for
          indirect, incidental, special, or consequential damages resulting from your use of the site,
          reliance on its content, or inability to access services.
        </p>
      </section>

      <section class="rounded-xl border border-neutral-800 bg-neutral-900/40 p-6 md:p-8">
        <h2 class="text-2xl font-bold text-white">6. Contact Information</h2>
        <p class="mt-4">
          Questions about these terms can be sent to
          <a href="mailto:toby@tobyonfitness.tech" class="text-blue-400 hover:text-blue-300 underline-offset-4 hover:underline">toby@tobyonfitness.tech</a>.
        </p>
      </section>
    </div>
  </section>
</Layout>
