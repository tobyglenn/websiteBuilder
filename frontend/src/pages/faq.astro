  description="Common questions about Toby's training, gear stack, weight loss journey, and how this site works."
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "FAQ", url: "/faq" }]}
  jsonLd={faqSchema}
>
  <main class="min-h-screen bg-neutral-950 text-white">

    {/* Hero */}
    <section class="pt-20 pb-12 md:pt-28 md:pb-16">
      <div class="container mx-auto px-4 text-center">
