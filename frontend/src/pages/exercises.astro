---
import Layout from '../layouts/Layout.astro';
import { getExercises } from '../data/exercises.js';

const { allExercises, grouped, totalCount } = getExercises();

const pageTitle = "Exercise Library";
const pageDescription = "Browse all exercises performed on Speediance with PR weights. Filter by muscle group: Back & Lats, Chest & Triceps, Legs & Glutes, Core & Arms.";

// JSON-LD FAQPage Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the heaviest exercise on Speediance?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Barbell Deadlift has the highest PR at 388 lbs, followed by Barbell Hip Thrust at 240 lbs and Barbell Bench Press at 232 lbs."
      }
    },
    {
      "@type": "Question",
      "name": "How many unique exercises are in the exercise library?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `The library contains ${totalCount} unique exercises across all Speediance workout programs.`
      }
    },
    {
      "@type": "Question",
      "name": "What muscle groups can I train with Speediance?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Speediance allows training all major muscle groups: Back & Lats, Chest & Triceps, Legs & Glutes, and Core & Arms (including biceps, shoulders, and abs)."
      }
    },
    {
      "@type": "Question",
      "name": "What is the best exercise for building a big chest on Speediance?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Barbell Bench Press has the highest chest PR at 232 lbs. Other effective chest exercises include Incline Barbell Bench Press (185 lbs PR) and Dual-Handle Bench Press (90 lbs PR)."
      }
    },
    {
      "@type": "Question",
      "name": "Can I track my personal records on Speediance?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes! Speediance automatically tracks your 1-rep max (1RM) for each exercise. This page displays all your PRs, from the 388 lb deadlift to smaller isolation movements."
      }
    }
  ]
};

const muscleGroups = ['All', 'Back & Lats', 'Chest & Triceps', 'Legs & Glutes', 'Core & Arms'];
---

<Layout 
  title={`${pageTitle} | Toby on Fitness Tech`}
  description={pageDescription}
  jsonLd={faqSchema}
>
  <!-- Hero Section -->
  <section class="py-20 bg-neutral-950 border-b border-neutral-800">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Exercise Library</h1>
      <p class="text-lg md:text-xl text-neutral-400 max-w-2xl mx-auto">
        Explore all {totalCount} exercises performed on Speediance with personal record weights.
      </p>
    </div>
  </section>

  <!-- Filter Section -->
  <section class="py-8 bg-neutral-900 border-b border-neutral-800 sticky top-16 z-40">
    <div class="container mx-auto px-4">
      <div class="flex flex-wrap justify-center gap-3">
        {muscleGroups.map((group) => (
          <button
            data-filter={group}
            class={`filter-btn px-5 py-2.5 rounded-full text-sm font-medium transition-all ${
              group === 'All' 
                ? 'bg-blue-600 text-white' 
                : 'bg-neutral-800 text-neutral-300 hover:bg-neutral-700 hover:text-white border border-neutral-700'
            }`}
          >
            {group}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Exercise Grid -->
  <section class="py-16 bg-neutral-950">
    <div class="container mx-auto px-4">
      <div id="exerciseGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {allExercises.map((exercise) => (
          <div 
            data-group={exercise.muscleGroup}
            class="exercise-card bg-neutral-900 rounded-xl p-5 border border-neutral-800 hover:border-blue-500/50 transition-all hover:shadow-lg hover:shadow-blue-500/10"
          >
            <!-- Exercise Name -->
            <h3 class="text-white font-semibold text-lg mb-3 line-clamp-2">{exercise.name}</h3>
            
            <!-- Muscle Group Badge -->
            <div class="mb-3">
              <span class={`inline-block px-3 py-1 rounded-full text-xs font-medium ${
                exercise.muscleGroup === 'Back & Lats' ? 'bg-blue-500/20 text-blue-400' :
                exercise.muscleGroup === 'Chest & Triceps' ? 'bg-red-500/20 text-red-400' :
                exercise.muscleGroup === 'Legs & Glutes' ? 'bg-green-500/20 text-green-400' :
                'bg-purple-500/20 text-purple-400'
              }`}>
                {exercise.muscleGroup}
              </span>
            </div>
            
            <!-- PR Weight -->
            <div class="flex items-baseline gap-2">
              <span class="text-2xl font-bold text-white">{exercise.prWeight || '—'}</span>
              <span class="text-sm text-neutral-400">lbs PR</span>
            </div>
          </div>
        ))}
      </div>
      
      <!-- No Results Message -->
      <div id="noResults" class="hidden text-center py-16">
        <div class="text-6xl mb-4">🏋️</div>
        <p class="text-xl text-neutral-400">No exercises found for this category.</p>
      </div>
    </div>
  </section>

  <!-- Stats Summary -->
  <section class="py-12 bg-neutral-900 border-t border-neutral-800">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-1">{grouped['Back & Lats']?.length || 0}</div>
          <div class="text-sm text-neutral-400">Back & Lats</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-red-400 mb-1">{grouped['Chest & Triceps']?.length || 0}</div>
          <div class="text-sm text-neutral-400">Chest & Triceps</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-green-400 mb-1">{grouped['Legs & Glutes']?.length || 0}</div>
          <div class="text-sm text-neutral-400">Legs & Glutes</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-purple-400 mb-1">{grouped['Core & Arms']?.length || 0}</div>
          <div class="text-sm text-neutral-400">Core & Arms</div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Client-side filtering
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.exercise-card');
    const noResults = document.getElementById('noResults');
    
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');
        
        // Update button styles
        filterBtns.forEach(b => {
          b.classList.remove('bg-blue-600', 'text-white');
          b.classList.add('bg-neutral-800', 'text-neutral-300', 'border', 'border-neutral-700');
        });
        btn.classList.remove('bg-neutral-800', 'text-neutral-300', 'border', 'border-neutral-700');
        btn.classList.add('bg-blue-600', 'text-white');
        
        // Filter cards
        let visibleCount = 0;
        cards.forEach(card => {
          const group = card.getAttribute('data-group');
          if (filter === 'All' || group === filter) {
            (card as HTMLElement).style.display = 'block';
            visibleCount++;
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });
        
        // Show/hide no results message
        if (noResults) {
          if (visibleCount === 0) {
            noResults.classList.remove('hidden');
          } else {
            noResults.classList.add('hidden');
          }
        }
      });
    });
  });
</script>
