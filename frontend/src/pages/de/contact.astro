---
import Layout from '../../layouts/Layout.astro';

const siteUrl = "https://tobyonfitnesstech.com";

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": `${siteUrl}/contact/#contactpage`,
  "name": "Toby Glenn Peters kontaktieren",
  "description": "Nimm Kontakt mit Toby Glenn Peters auf für Sponsoring, Beratung, Kooperationen oder Fragen zu Fitness-Tech.",
  "url": `${siteUrl}/contact/`,
  "inLanguage": "de-DE",
  "isPartOf": { "@id": `${siteUrl}/#website` },
  "about": { "@id": `${siteUrl}/#toby` },
  "mainEntity": {
    "@type": "Person",
    "@id": `${siteUrl}/#toby`,
    "name": "Toby Glenn Peters",
    "alternateName": "TobyOnFitnessTech",
    "email": "toby@tobyonfitness.tech",
    "url": siteUrl,
    "sameAs": [
      "https://www.youtube.com/@tobyonfitness",
      "https://www.instagram.com/tobyonfitness"
    ]
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": siteUrl },
      { "@type": "ListItem", "position": 2, "name": "Kontakt", "item": `${siteUrl}/contact/` }
    ]
  }
};

const faqs = [
  {
    q: "Verkaufst du Coaching-Programme oder personalisierte Pläne?",
    a: "Nein. Ich dokumentiere, was für mich funktioniert, und teile es öffentlich — das ist alles. Ich verkaufe keine Programme, Ernährungspläne oder 1-zu-1-Coachings. Alles, was ich mache, ist kostenlos auf YouTube und auf dieser Website verfügbar."
  },
  {
    q: "Kann ich dich zu meinem Speediance- oder Fitness-Tech-Setup fragen?",
    a: "Ja — genau dafür bin ich da. Schreib mir mit konkreten Details. Ich antworte, wenn ich etwas Nützliches beitragen kann. Wenn es eine häufige Frage ist, wird daraus vielleicht ein Video oder ein Blogbeitrag."
  },
  {
    q: "Akzeptierst du Sponsorings?",
    a: "Selektiv. Ich arbeite nur mit Produkten, die ich tatsächlich benutze. Wenn du dich wegen Speediance, WHOOP, Garmin, 8Sleep oder ähnlicher Fitness-Tech meldest — ich höre zu. Kalte Pitches für Proteinpulver und Supplements führen meistens nirgendwohin."
  },
  {
    q: "Bist du für Beratung zu Fitness-Tech-Stacks oder Automatisierung verfügbar?",
    a: "Manchmal. Wenn du als Unternehmen oder Privatperson datengetriebene Trainingssysteme aufbauen willst — besonders mit OpenClaw, Home-Gym-Hardware oder Wearable-Integration — melde dich. Ich sage dir ehrlich, ob ich helfen kann."
  },
  {
    q: "Wie lange dauert es, bis ich eine Antwort bekomme?",
    a: "Normalerweise innerhalb weniger Tage. Ich bin eine Person mit vollem Trainingsplan und einem Dayjob. Ich lese alles — ich antworte nur nicht schnell."
  },
  {
    q: "Kann ich bei Inhalten zusammenarbeiten oder etwas gemeinsam entwickeln?",
    a: "Vielleicht. Erzähl mir, woran du arbeitest und warum du denkst, dass es passt. Ich will meinen Upload-Plan nicht künstlich aufblasen — aber ein wirklich interessantes Projekt? Dafür bin ich offen."
  }
];
---

<Layout
  title="Kontakt — TobyOnFitnessTech"
  description="Nimm Kontakt mit Toby Glenn Peters auf für Sponsoring, Beratung, Fragen zu Fitness-Tech oder Kooperationen."
  breadcrumbs={[{ name: "Startseite", url: "/" }, { name: "Kontakt", url: "/contact" }]}
  jsonLd={contactPageSchema}
>
  <main class="min-h-screen bg-neutral-950 text-white">

    {/* Hero */}
    <section class="pt-20 pb-12 md:pt-28 md:pb-16 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-blue-900/10 to-transparent pointer-events-none" />
      <div class="container mx-auto px-4 relative z-10 max-w-4xl">
        <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-4">Kontakt</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Kontakt aufnehmen
        </h1>
        <p class="text-xl text-neutral-400 max-w-2xl leading-relaxed">
          Ich bin nicht schwer zu erreichen. Ich bin nur wählerisch bei dem, wozu ich Ja sage. Wenn du etwas Echtes besprechen willst, antworte ich.
        </p>
      </div>
    </section>

    {/* Contact + Social */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="grid md:grid-cols-2 gap-8">

          {/* Email Card */}
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-xl bg-blue-600/20 border border-blue-500/30 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <h2 class="text-xl font-bold text-white">E-Mail</h2>
                <p class="text-neutral-500 text-sm">Bester Weg, mich zu erreichen</p>
              </div>
            </div>
            <a
              href="mailto:toby@tobyonfitness.tech"
              class="text-blue-400 hover:text-blue-300 font-mono text-lg font-semibold transition-colors"
            >
              toby@tobyonfitness.tech
            </a>
            <p class="text-neutral-500 text-sm mt-4 leading-relaxed">
              Ich lese jede E-Mail. Ich antworte, wenn ich etwas Nützliches zu sagen habe — normalerweise innerhalb weniger Tage.
            </p>
          </div>

          {/* Social Links */}
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8">
            <h2 class="text-xl font-bold text-white mb-6">Mitverfolgen</h2>
            <div class="space-y-4">
              <a
                href="https://www.youtube.com/@tobyonfitness"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-4 p-4 rounded-xl bg-neutral-950 border border-neutral-800 hover:border-red-500/40 hover:bg-red-950/10 transition-all group"
              >
                <div class="w-10 h-10 rounded-lg bg-red-600/20 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#ef4444"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.54C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon fill="white" points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
                </div>
                <div>
                  <div class="text-white font-semibold group-hover:text-red-400 transition-colors">YouTube</div>
                  <div class="text-neutral-500 text-sm">@tobyonfitness</div>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-auto text-neutral-700 group-hover:text-neutral-400 transition-colors"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>

              <a
                href="https://www.instagram.com/tobyonfitness"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-4 p-4 rounded-xl bg-neutral-950 border border-neutral-800 hover:border-pink-500/40 hover:bg-pink-950/10 transition-all group"
              >
                <div class="w-10 h-10 rounded-lg bg-pink-600/20 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ec4899" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
                </div>
                <div>
                  <div class="text-white font-semibold group-hover:text-pink-400 transition-colors">Instagram</div>
                  <div class="text-neutral-500 text-sm">@tobyonfitness</div>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-auto text-neutral-700 group-hover:text-neutral-400 transition-colors"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    {/* What to Expect */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-5xl">
        <h2 class="text-3xl font-bold text-white mb-3">Worauf ich tatsächlich antworte</h2>
        <p class="text-neutral-500 mb-10">Kein Blabla. Darum lohnt es sich, mir zu schreiben:</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">🤝</div>
            <h3 class="text-lg font-bold text-white mb-2">Sponsorings</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              Nur Fitness-Tech — Ausrüstung, die ich wirklich benutzen würde. Speediance, WHOOP, Garmin, 8Sleep und ähnliches. Kein Interesse an Supplements, die ich nie getestet habe.
            </p>
          </div>

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">🔧</div>
            <h3 class="text-lg font-bold text-white mb-2">Beratung</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              Du baust einen datengetriebenen Fitness-Stack? Automatisierst Trainingsentscheidungen mit Wearable-Daten? Das ist interessant. Lass uns zuerst über den Umfang sprechen.
            </p>
          </div>

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">❓</div>
            <h3 class="text-lg font-bold text-white mb-2">Fragen</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              Echte Fragen zu Speediance, WHOOP, BJJ oder meinem Trainingsansatz sind willkommen. Wenn ich eine Frage nicht kurz beantworten kann, sage ich das.
            </p>
          </div>

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">🎬</div>
            <h3 class="text-lg font-bold text-white mb-2">Kooperationen</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              Wenn du etwas im Bereich Fitness-Tech oder Automatisierung baust und es wirklich passt — bin ich offen. Stell mir die Idee vor.
            </p>
          </div>

        </div>
      </div>
    </section>

    {/* Response Expectations */}
    <section class="py-12 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="bg-neutral-900/50 border border-neutral-800 rounded-2xl p-8 flex flex-col md:flex-row items-start gap-6">
          <div class="text-4xl flex-shrink-0">⏱️</div>
          <div>
            <h3 class="text-xl font-bold text-white mb-2">Antwortzeit</h3>
            <p class="text-neutral-400 leading-relaxed">
              Ich bin nur eine Person. Ich trainiere um 6:30 Uhr morgens, arbeite den ganzen Tag und rolle die meisten Abende BJJ. Ich lese alles — aber ich antworte, wenn ich etwas Nützliches zu sagen habe, nicht nur um den Eingang zu bestätigen. Gib mir ein paar Tage, bevor du nachhakst.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* FAQ */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-4xl">
        <h2 class="text-3xl font-bold text-white mb-3">Häufige Fragen</h2>
        <p class="text-neutral-500 mb-10">Schau hier nach, bevor du mir schreibst — vielleicht ist deine Antwort schon hier.</p>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-neutral-700 transition-all">
              <h3 class="text-white font-semibold mb-3 flex items-start gap-3">
                <span class="text-blue-500 font-bold flex-shrink-0">F:</span>
                {faq.q}
              </h3>
              <p class="text-neutral-400 leading-relaxed pl-6">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* CTA */}
    <section class="py-24 border-t border-neutral-900">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-4">Bereit, dich zu melden?</h2>
        <p class="text-neutral-400 mb-8 max-w-xl mx-auto">
          Schreib mir. Halte es konkret, dann antworte ich auch wirklich.
        </p>
        <a
          href="mailto:toby@tobyonfitness.tech"
          class="inline-flex items-center gap-2 px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-full transition-all hover:scale-105"
        >
          Toby eine E-Mail schreiben
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
      </div>
    </section>

  </main>
</Layout>
