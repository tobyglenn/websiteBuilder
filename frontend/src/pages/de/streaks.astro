---
import Layout from '../layouts/Layout.astro';
import { getStreakData } from '../data/streaks.js';

const siteUrl = "https://tobyonfitnesstech.com";
const streakData = getStreakData();

// JSON-LD schema for the page
const streakPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${siteUrl}/streaks#collection`,
  "name": "Trainingsserien - Toby on Fitness Tech",
  "description": `Tracker für Trainingsserien: ${streakData.currentStreak} Tage aktuelle Serie, ${streakData.longestStreak} Tage längste Serie, ${streakData.totalActiveDays} aktive Tage aus insgesamt ${streakData.totalWorkouts} Workouts.`,
  "url": `${siteUrl}/streaks`,
  "inLanguage": "de",
  "isPartOf": { "@id": `${siteUrl}/#website` },
  "author": { "@id": `${siteUrl}/#toby` },
  "publisher": { "@id": `${siteUrl}/#organization` },
  "mainEntity": {
    "@type": "SportsActivityProfile",
    "name": "Statistiken zu Trainingsserien",
    "athlete": { "@id": `${siteUrl}/#toby` },
    "stats": [
      {
        "@type": "Stat",
        "name": "Aktuelle Serie",
        "value": streakData.currentStreak,
        "unitText": "Tage"
      },
      {
        "@type": "Stat",
        "name": "Längste Serie",
        "value": streakData.longestStreak,
        "unitText": "Tage"
      },
      {
        "@type": "Stat",
        "name": "Aktive Tage insgesamt",
        "value": streakData.totalActiveDays,
        "unitText": "Tage"
      }
    ]
  }
};
---

<Layout 
  title="Trainingsserien - Toby on Fitness Tech"
  description={`Tracker für Trainingsserien: ${streakData.currentStreak} Tage aktuelle Serie, ${streakData.longestStreak} Tage längste Serie, ${streakData.totalActiveDays} aktive Tage aus insgesamt ${streakData.totalWorkouts} Workouts (${streakData.speedianceWorkouts} Speediance-Workouts + ${streakData.garminRuns} Garmin-Läufe).`}
  breadcrumbs={[{ name: "Startseite", url: "/" }, { name: "Trainingsserien", url: "/streaks" }]}
  jsonLd={streakPageSchema}
>
  <main class="min-h-screen bg-neutral-950 text-white">
    {/* Hero Section */}
    <section class="pt-20 pb-16 md:pt-28 md:pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-blue-900/10 to-transparent pointer-events-none" />
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4 tracking-tight">
            Trainings-<span class="text-blue-500">serien</span>
          </h1>
          <p class="text-lg md:text-xl text-gray-400 max-w-2xl mx-auto">
            Verfolge deine Beständigkeit bei Speediance-Workouts und Garmin-Läufen. 
            Jeder Tag zählt beim Aufbau einer stärkeren Gewohnheit.
          </p>
          <div class="mt-6 flex flex-wrap justify-center gap-4 text-sm text-gray-500">
            <span class="flex items-center gap-1">
              <span class="w-2 h-2 rounded-full bg-green-500"></span>
              {streakData.speedianceWorkouts} Speediance-Workouts
            </span>
            <span class="flex items-center gap-1">
              <span class="w-2 h-2 rounded-full bg-blue-500"></span>
              {streakData.garminRuns} Garmin-Läufe
            </span>
          </div>
        </div>
      </div>
    </section>

    {/* Main Stats Cards */}
    <section class="py-12">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
          {/* Current Streak */}
          <div class="bg-neutral-900 rounded-2xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-all duration-300">
            <div class="flex items-center justify-between mb-4">
              <span class="text-gray-400 text-sm font-medium">Aktuelle Serie</span>
              <span class="text-3xl">🔥</span>
            </div>
            <div class="flex items-baseline gap-2">
              <span class="text-5xl font-bold text-blue-500">{streakData.currentStreak}</span>
              <span class="text-xl text-gray-400">Tage</span>
            </div>
            <p class="mt-2 text-sm text-gray-500">
              {streakData.currentStreak > 0 ? "Bleib dran!" : "Starte deine Serie noch heute!"}
            </p>
          </div>

          {/* Longest Streak */}
          <div class="bg-neutral-900 rounded-2xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-all duration-300">
            <div class="flex items-center justify-between mb-4">
              <span class="text-gray-400 text-sm font-medium">Längste Serie</span>
              <span class="text-3xl">🏆</span>
            </div>
            <div class="flex items-baseline gap-2">
              <span class="text-5xl font-bold text-white">{streakData.longestStreak}</span>
              <span class="text-xl text-gray-400">Tage</span>
            </div>
            <p class="mt-2 text-sm text-gray-500">
              Persönliche Bestleistung erreicht
            </p>
          </div>

          {/* Total Active Days */}
          <div class="bg-neutral-900 rounded-2xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-all duration-300">
            <div class="flex items-center justify-between mb-4">
              <span class="text-gray-400 text-sm font-medium">Aktive Tage insgesamt</span>
              <span class="text-3xl">📅</span>
            </div>
            <div class="flex items-baseline gap-2">
              <span class="text-5xl font-bold text-white">{streakData.totalActiveDays}</span>
              <span class="text-xl text-gray-400">Tage</span>
            </div>
            <p class="mt-2 text-sm text-gray-500">
              {streakData.totalWorkouts} Aktivitäten insgesamt
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* GitHub-style Streak Visualization */}
    <section class="py-12 bg-neutral-900/50">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
          <h2 class="text-2xl font-bold mb-6 text-center">Aktivitäts-Heatmap</h2>
          <p class="text-gray-400 text-center mb-8">Deine Trainingsaktivität im Zeitverlauf</p>
          
          <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800 overflow-x-auto">
            <!-- Month labels -->
            <div class="flex mb-2 ml-8">
              {(() => {
                const months = [];
                const weekData = streakData.weeklyData;
                let lastMonth = '';
                weekData.forEach((week, idx) => {
                  const month = new Date(week.date).toLocaleString('default', { month: 'short' });
                  if (month !== lastMonth) {
                    months.push(
                      <span class="text-xs text-gray-500" style={`margin-left: ${idx > 0 ? (idx * 14) - (months.length > 0 ? months[months.length-1].offset : 0) - 20 : 0}px; position: absolute;`}>{month}</span>
                    );
                    lastMonth = month;
                  }
                });
                return null;
              })()}
            </div>
            
            <!-- Day labels + grid -->
            <div class="flex">
              <!-- Day labels -->
              <div class="flex flex-col text-xs text-gray-500 mr-2 justify-between py-1">
                <span>So</span>
                <span>Mo</span>
                <span>Di</span>
                <span>Mi</span>
                <span>Do</span>
                <span>Fr</span>
                <span>Sa</span>
              </div>
              
              <!-- Contribution grid -->
              <div class="flex gap-0.5 flex-1 overflow-x-auto pb-2">
                {streakData.weeklyData.map((week) => (
                  <div class="flex flex-col gap-0.5">
                    {[0, 1, 2, 3, 4, 5, 6].map((dayIdx) => {
                      const weekStart = new Date(week.date);
                      const cellDate = new Date(weekStart);
                      cellDate.setDate(weekStart.getDate() + dayIdx);
                      const today = new Date();
                      const isFuture = cellDate > today;
                      const intensity = week.intensity;
                      
                      return (
                        <div 
                          class={`w-3 h-3 rounded-sm ${
                            isFuture 
                              ? 'bg-neutral-800' 
                              : intensity === 0 
                                ? 'bg-neutral-800'
                                : intensity === 1 
                                  ? 'bg-blue-900/60'
                                  : intensity === 2 
                                    ? 'bg-blue-700/80'
                                    : intensity === 3 
                                      ? 'bg-blue-500'
                                      : 'bg-blue-400'
                          }`}
                          title={`${cellDate.toISOString().split('T')[0]}: ${week.activeDays > 0 ? week.activeDays + ' aktive Tage diese Woche' : 'Keine Aktivität'}`}
                        />
                      );
                    })}
                  </div>
                ))}
              </div>
            </div>
            
            <!-- Legend -->
            <div class="flex items-center justify-end mt-4 gap-2 text-xs text-gray-500">
              <span>Weniger</span>
              <div class="w-3 h-3 rounded-sm bg-neutral-800"></div>
              <div class="w-3 h-3 rounded-sm bg-blue-900/60"></div>
              <div class="w-3 h-3 rounded-sm bg-blue-700/80"></div>
              <div class="w-3 h-3 rounded-sm bg-blue-500"></div>
              <div class="w-3 h-3 rounded-sm bg-blue-400"></div>
              <span>Mehr</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Weekly Consistency Ring Chart */}
    <section class="py-12">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-bold mb-6 text-center">Wöchentliche Beständigkeit</h2>
          <p class="text-gray-400 text-center mb-8">Die letzten 4 Wochen auf einen Blick</p>
          
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            {streakData.weeklyConsistency.map((week) => (
              <div class="bg-neutral-900 rounded-xl p-4 border border-neutral-800 text-center">
                <!-- Ring chart -->
                <div class="relative w-24 h-24 mx-auto mb-3">
                  <svg class="w-24 h-24 transform -rotate-90" viewBox="0 0 100 100">
                    <!-- Background circle -->
                    <circle
                      cx="50"
                      cy="50"
                      r="40"
                      fill="none"
                      stroke="#262626"
                      stroke-width="10"
                    />
                    <!-- Progress circle -->
                    <circle
                      cx="50"
                      cy="50"
                      r="40"
                      fill="none"
                      stroke="#3b82f6"
                      stroke-width="10"
                      stroke-linecap="round"
                      stroke-dasharray={`${week.percentage * 2.51} 251`}
                      class="transition-all duration-500"
                    />
                  </svg>
                  <div class="absolute inset-0 flex items-center justify-center">
                    <span class="text-2xl font-bold">{week.percentage}%</span>
                  </div>
                </div>
                
                <div class="text-sm font-medium">{week.week}</div>
                <div class="text-xs text-gray-500">{week.activeDays}/7 Tage</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* Achievements/Badges Section */}
    <section class="py-12 bg-neutral-900/50">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-bold mb-6 text-center">Erfolge</h2>
          <p class="text-gray-400 text-center mb-8">Meilensteine auf deinem Fitnessweg</p>
          
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
            {streakData.achievements.map((achievement) => (
              <div 
                class={`relative bg-neutral-900 rounded-xl p-4 border transition-all duration-300 ${
                  achievement.earned 
                    ? 'border-blue-500/50 hover:border-blue-400' 
                    : 'border-neutral-800 opacity-60'
                }`}
              >
                <div class="text-4xl mb-2 text-center">{achievement.icon}</div>
                <div class={`text-sm font-bold text-center ${achievement.earned ? 'text-white' : 'text-gray-400'}`}>
                  {achievement.name}
                </div>
                <div class="text-xs text-gray-500 text-center mt-1">
                  {achievement.description}
                </div>
                
                {/* Progress bar */}
                <div class="mt-3">
                  <div class="h-1.5 bg-neutral-800 rounded-full overflow-hidden">
                    <div 
                      class={`h-full rounded-full transition-all duration-500 ${
                        achievement.earned ? 'bg-blue-500' : 'bg-gray-600'
                      }`}
                      style={`width: ${(achievement.progress / achievement.target) * 100}%`}
                    />
                  </div>
                  <div class="text-xs text-gray-500 text-center mt-1">
                    {achievement.progress}/{achievement.target}
                  </div>
                </div>
                
                {/* Earned badge */}
                {achievement.earned && (
                  <div class="absolute -top-2 -right-2 text-lg">✅</div>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* Recent Streak History */}
    <section class="py-12">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-bold mb-6 text-center">Serienverlauf</h2>
          <p class="text-gray-400 text-center mb-8">Deine stärksten Serienphasen</p>
          
          {streakData.streakHistory.length > 0 ? (
            <div class="bg-neutral-900 rounded-xl border border-neutral-800 overflow-hidden">
              <div class="overflow-x-auto">
                <table class="w-full">
                  <thead>
                    <tr class="border-b border-neutral-800">
                      <th class="text-left py-3 px-4 text-sm font-medium text-gray-400">#</th>
                      <th class="text-left py-3 px-4 text-sm font-medium text-gray-400">Startdatum</th>
                      <th class="text-left py-3 px-4 text-sm font-medium text-gray-400">Enddatum</th>
                      <th class="text-right py-3 px-4 text-sm font-medium text-gray-400">Dauer</th>
                    </tr>
                  </thead>
                  <tbody>
                    {streakData.streakHistory.map((streak, idx) => (
                      <tr class="border-b border-neutral-800/50 hover:bg-neutral-800/30 transition-colors">
                        <td class="py-3 px-4">
                          <span class={`inline-flex items-center justify-center w-6 h-6 rounded-full text-xs font-bold ${
                            idx === 0 ? 'bg-yellow-500/20 text-yellow-500' : 'bg-neutral-800 text-gray-400'
                          }`}>
                            {idx + 1}
                          </span>
                        </td>
                        <td class="py-3 px-4 text-sm">{streak.start}</td>
                        <td class="py-3 px-4 text-sm">{streak.end}</td>
                        <td class="py-3 px-4 text-sm text-right">
                          <span class="inline-flex items-center gap-1">
                            {streak.length >= 7 && <span>🔥</span>}
                            <span class={`font-bold ${idx === 0 ? 'text-yellow-500' : 'text-blue-400'}`}>
                              {streak.length} Tage
                            </span>
                          </span>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          ) : (
            <div class="text-center py-12 text-gray-500">
              <p>Noch keine Serien-Daten verfügbar.</p>
              <p class="text-sm mt-2">Beginne mit dem Training, um deine erste Serie aufzubauen!</p>
            </div>
          )}
        </div>
      </div>
    </section>

    {/* Summary Footer */}
    <section class="py-12 border-t border-neutral-800">
      <div class="container mx-auto px-4">
        <div class="max-w-2xl mx-auto text-center">
          <p class="text-gray-400">
            Training seit <span class="text-white font-medium">{streakData.firstActiveDate || 'k. A.'}</span> — 
            <span class="text-white font-medium">{streakData.totalWorkouts}</span> Aktivitäten insgesamt aus 
            <span class="text-green-400"> Speediance</span>- und <span class="text-blue-400">Garmin</span>-Daten.
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>
