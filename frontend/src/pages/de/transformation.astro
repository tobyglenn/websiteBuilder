---
import Layout from '../../layouts/Layout.astro';

const transformationData = {
  startWeight: 242,
  lowestWeight: 188,
  currentWeight: 218,
  startDate: "Juli 2023",
  lowestDate: "Januar 2024",
  currentDate: "Februar 2026",
  durationMonths: 6,
  weightLost: 54,
  muscleGained: 30,
  milestones: [
    { date: "Juli 2023", weight: 242, event: "Transformationsreise gestartet" },
    { date: "September 2023", weight: 220, event: "GLP-1-Reise beginnt" },
    { date: "Januar 2024", weight: 188, event: "Zielgewicht erreicht" },
    { date: "Februar 2024", weight: 195, event: "Muskelaufbauphase gestartet" },
    { date: "Februar 2026", weight: 218, event: "Aktuelles Gewicht (Muskeln + Kraft)" }
  ],
  stats: { speedianceVolume: 1296447, totalRuns: 111, totalMiles: 265.1, bjjMonths: 10 }
};

const siteUrl = "https://tobyonfitnesstech.com";
const howToSchema = { "@context": "https://schema.org", "@type": "HowTo", "@id": `${siteUrl}/de/transformation#howto`, "name": "Wie man in 6 Monaten 54 lbs verliert: Tobys datengesteuerte Transformation", "description": "Ein Schritt-für-Schritt-Bericht darüber, wie Toby Peters mit GLP-1-Medikamenten, Speediance-Krafttraining, strategischer Reduktion von Cardio und datengestütztem Ernährungstracking von 242 lbs auf 188 lbs kam.", "totalTime": "P6M", "image": `${siteUrl}/progress/progress_188.jpg`, "author": { "@type": "Person", "@id": `${siteUrl}/#toby`, "name": "Toby Glenn Peters" }, "supply": [ { "@type": "HowToSupply", "name": "GLP-1-Medikament (Semaglutid/Wegovy)" }, { "@type": "HowToSupply", "name": "Speediance Smart-Home-Gym" }, { "@type": "HowToSupply", "name": "Protein-Tracking-App (Cronometer)" }, { "@type": "HowToSupply", "name": "Fitness-Wearable (Garmin oder Whoop)" } ], "tool": [ { "@type": "HowToTool", "name": "Speediance Kabelzugmaschine" }, { "@type": "HowToTool", "name": "Garmin Forerunner 265S" }, { "@type": "HowToTool", "name": "Eight Sleep Pod" } ], "step": [ { "@type": "HowToStep", "position": 1, "name": "Bestimme deinen Ausgangspunkt mit Daten", "text": "Tracke 2 Wochen lang alles, bevor du Änderungen vornimmst. Nutze ein Fitness-Wearable (Garmin, Whoop), um Ruhepuls, HRV und geschätzten Kalorienverbrauch zu messen. Protokolliere alle Lebensmittel in Cronometer. Diese Daten werden deine Grundlage.", "url": `${siteUrl}/de/transformation` }, { "@type": "HowToStep", "position": 2, "name": "Starte GLP-1-Medikamente (falls verschrieben)", "text": "Im September 2023 bei 220 lbs begann Toby unter ärztlicher Aufsicht mit GLP-1-Medikamenten. GLP-1 reduziert Appetit und Food Noise. In Kombination mit einer proteinreichen Ernährung (180 g+ täglich) und Krafttraining ermöglicht es ein nachhaltiges tägliches Defizit von 500–700 Kalorien ohne Muskelverlust.", "url": `${siteUrl}/de/transformation` }, { "@type": "HowToStep", "position": 3, "name": "Ersetze übermäßiges Cardio durch Krafttraining", "text": "Hör auf, stundenlang Zone-2-Cardio zu machen — das zerstört die Regeneration. Stattdessen 4–5 Krafteinheiten pro Woche auf Speediance oder einer ähnlichen Kabelzugmaschine. Fokus auf progressive Überlastung: Füge in jeder Einheit Wiederholungen oder Gewicht hinzu. 8.000+ Schritte pro Tag decken die niedrig intensive Kalorienverbrennung ab, ohne die Regeneration zu beeinträchtigen.", "url": `${siteUrl}/de/transformation` }, { "@type": "HowToStep", "position": 4, "name": "Erreiche dein Zielgewicht und wechsle in den Muskelaufbau", "text": "Toby erreichte im Januar 2024 188 lbs — ein Verlust von 54 lbs in 6 Monaten. Verlage den Fokus von Fettabbau auf mageren Muskelaufbau. Erhöhe die Proteinzufuhr auf 200 g+ täglich. Starte ein Push-Pull-Legs-Programm. Nutze das Wiederholungs-Tracking von Speediance, um in jeder Einheit progressive Überlastung sicherzustellen.", "url": `${siteUrl}/de/transformation`, "image": `${siteUrl}/progress/progress_188.jpg` }, { "@type": "HowToStep", "position": 5, "name": "Füge Brazilian Jiu-Jitsu für nachhaltige Fitness hinzu", "text": "BJJ 3x pro Woche verbrennt 400–600 Kalorien pro Einheit, baut funktionale Muskelausdauer auf und schafft soziale Verbindlichkeit. Nach über 10 Monaten Training erreichte Toby den Braungurt und ging von 188 auf 218 lbs Muskeln.", "url": `${siteUrl}/de/bjj` }, { "@type": "HowToStep", "position": 6, "name": "Nutze Schlafdaten, um die Regeneration zu optimieren", "text": "Der Eight Sleep Pod und das Garmin-Schlaftracking zeigten chronische Unterregeneration (Ø 5,8 Stunden). Priorisiere 7–8 Stunden. HRV (Ziel: 80+) ist der beste Einzelindikator dafür, dass die Regeneration stimmt. Schlechter Schlaf bremst Fettabbau und zerstört Muskelaufbau.", "url": `${siteUrl}/de/transformation` } ] };

const insights = [
  { title: "Die GLP-1-Entscheidung", content: "Ich habe mich für GLP-1-Medikamente entschieden, nachdem ich alles andere ausprobiert hatte. Die Daten zeigten, dass mein Stoffwechsel auf traditionelle Methoden nicht reagierte." },
  { title: "Warum ich mit Cardio aufgehört habe", content: "Cardio verbrannte nicht so viele Kalorien, wie ich dachte. Zone 2 zerstörte meine Regeneration. Stattdessen konzentrierte ich mich auf Krafttraining und Gehen." },
  { title: "Der TRT-Faktor", content: "Die Testosteronersatztherapie half mir, während der Diät mein Energieniveau zu halten und die Muskulatur zu erhalten." },
  { title: "Muskeln aufbauen, ohne fett zu werden", content: "Der Schlüssel war progressive Überlastung mit Speediance. Ich ging von 188 auf 218 lbs bei gleichzeitig schlanker Form. Die Daten lügen nicht." }
];
---

<Layout title="242 → 218: Meine Transformationsreise | TobyOnFitnessTech" description="Von 242 lbs auf 188 lbs und zurück auf 218 lbs Muskelmasse. Keine Abkürzungen. Keine Sponsoren. Nur die Daten hinter meiner Transformation." breadcrumbs={[{ name: "Home", url: "/de/" }, { name: "Transformation", url: "/de/transformation" }]} jsonLd={howToSchema}>
  <main class="min-h-screen bg-neutral-950 text-white">
    <section class="pt-20 pb-16 md:pt-28 md:pb-20 relative overflow-hidden"><div class="absolute inset-0 bg-gradient-to-b from-blue-900/10 to-transparent pointer-events-none" /><div class="container mx-auto px-4 relative z-10"><div class="max-w-4xl mx-auto text-center"><div class="inline-flex items-center gap-2 bg-blue-500/10 border border-blue-500/20 rounded-full px-4 py-1.5 mb-6"><span class="w-2 h-2 bg-blue-500 rounded-full animate-pulse"></span><span class="text-blue-400 text-sm font-medium">Die Daten lügen nicht</span></div><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">242 → 188 → <span class="bg-gradient-to-r from-blue-500 to-purple-500 bg-clip-text text-transparent">218</span></h2><p class="text-xl text-neutral-400 mb-8 leading-relaxed max-w-2xl mx-auto">Von übergewichtig auf unter 190, dann zurück auf 218 — diesmal aber mit Muskeln. So habe ich es genau gemacht.</p><div class="flex flex-wrap justify-center gap-3"><div class="bg-neutral-900 border border-neutral-800 rounded-full px-5 py-2.5"><span class="text-blue-400 font-bold">−54 lbs</span><span class="text-neutral-500 text-sm ml-2">verloren</span></div><div class="bg-neutral-900 border border-neutral-800 rounded-full px-5 py-2.5"><span class="text-purple-400 font-bold">+30 lbs</span><span class="text-neutral-500 text-sm ml-2">Muskeln aufgebaut</span></div><div class="bg-neutral-900 border border-neutral-800 rounded-full px-5 py-2.5"><span class="text-green-400 font-bold">1.29M</span><span class="text-neutral-500 text-sm ml-2">lbs gehoben</span></div><div class="bg-neutral-900 border border-neutral-800 rounded-full px-5 py-2.5"><span class="text-orange-400 font-bold">265</span><span class="text-neutral-500 text-sm ml-2">Meilen gelaufen</span></div></div></div></div></section>
    <section class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><h2 class="text-2xl font-bold mb-8 text-center">Gewicht im Zeitverlauf</h2><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 md:p-8 overflow-x-auto"><svg viewBox="0 0 800 300" class="w-full min-w-[600px]" preserveAspectRatio="xMidYMid meet"><g stroke="#333" stroke-width="1" opacity="0.3"><line x1="80" y1="50" x2="750" y2="50" /><line x1="80" y1="100" x2="750" y2="100" /><line x1="80" y1="150" x2="750" y2="150" /><line x1="80" y1="200" x2="750" y2="200" /><line x1="80" y1="250" x2="750" y2="250" /></g><g fill="#666" font-size="12" font-family="system-ui"><text x="70" y="55" text-anchor="end">250</text><text x="70" y="105" text-anchor="end">225</text><text x="70" y="155" text-anchor="end">200</text><text x="70" y="205" text-anchor="end">175</text><text x="70" y="255" text-anchor="end">150</text></g><g fill="#666" font-size="12" font-family="system-ui"><text x="100" y="280" text-anchor="middle">Jul '23</text><text x="230" y="280" text-anchor="middle">Sep '23</text><text x="360" y="280" text-anchor="middle">Nov '23</text><text x="490" y="280" text-anchor="middle">Jan '24</text><text x="620" y="280" text-anchor="middle">Jun '24</text><text x="720" y="280" text-anchor="middle">Feb '26</text></g><path d="M 100,60 L 165,85 L 230,110 L 295,140 L 360,175 L 425,200 L 490,212 L 555,185 L 620,150 L 685,110 L 720,95" fill="none" stroke="url(#lineGradient)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" /><defs><linearGradient id="lineGradient" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#ef4444" /><stop offset="40%" stop-color="#3b82f6" /><stop offset="100%" stop-color="#a855f7" /></linearGradient></defs><g fill="#fff" stroke="#3b82f6" stroke-width="2"><circle cx="100" cy="60" r="6" /><circle cx="230" cy="110" r="6" /><circle cx="490" cy="212" r="6" /><circle cx="720" cy="95" r="6" /></g><g fill="#fff" font-size="11" font-family="system-ui"><text x="100" y="45" text-anchor="middle">242 lbs</text><text x="230" y="100" text-anchor="middle">~210 lbs</text><text x="490" y="230" text-anchor="middle">188 lbs</text><text x="720" y="80" text-anchor="middle">218 lbs</text></g></svg></div><div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-4"><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5"><div class="text-blue-400 text-sm font-medium mb-1">Phase 1</div><div class="text-xl font-bold mb-1">242 → 188</div><div class="text-neutral-500 text-sm">Juli '23 – Jan '24</div><div class="mt-3 text-neutral-400 text-sm">54 lbs verloren mit GLP-1, Krafttraining und datengestützter Ernährung.</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5"><div class="text-purple-400 text-sm font-medium mb-1">Übergang</div><div class="text-xl font-bold mb-1">188 → 205</div><div class="text-neutral-500 text-sm">Jan '24 – Aug '24</div><div class="mt-3 text-neutral-400 text-sm">Muskelaufbau gestartet. Fokus auf progressive Überlastung mit Speediance.</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5"><div class="text-green-400 text-sm font-medium mb-1">Phase 2</div><div class="text-xl font-bold mb-1">205 → 218</div><div class="text-neutral-500 text-sm">Aug '24 – Feb '26</div><div class="mt-3 text-neutral-400 text-sm">Muskelaufbauphase. 1,29 Mio. lbs gehoben. BJJ-Braungurt erreicht.</div></div></div></div></section>
    <section class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><h2 class="text-2xl font-bold mb-8 text-center">Die Bilder</h2><div class="flex flex-col md:flex-row items-center justify-center gap-8"><div class="relative group"><div class="w-48 md:w-56 rounded-2xl overflow-hidden border border-neutral-800 shadow-xl"><img src="/progress/progress_230.jpg" alt="Startgewicht — 230 lbs" class="w-full aspect-[3/4] object-cover object-top" loading="eager" /></div><div class="absolute bottom-3 left-0 right-0 flex justify-center"><span class="bg-black/80 backdrop-blur-sm text-neutral-300 text-sm font-bold px-4 py-1.5 rounded-full border border-neutral-700">230 lbs</span></div><div class="absolute -top-3 -right-3 bg-red-600 text-white text-xs font-black px-3 py-1.5 rounded-full">START</div></div><div class="flex flex-col items-center text-neutral-500"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-blue-500"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg><span class="text-xs mt-2">−54 lbs</span></div><div class="relative group"><div class="w-48 md:w-56 rounded-2xl overflow-hidden border border-blue-500/40 shadow-xl shadow-blue-900/20"><img src="/progress/progress_188.jpg" alt="Niedrigstes Gewicht — 188 lbs" class="w-full aspect-[3/4] object-cover object-top" loading="eager" /></div><div class="absolute bottom-3 left-0 right-0 flex justify-center"><span class="bg-blue-600/90 backdrop-blur-sm text-white text-sm font-bold px-4 py-1.5 rounded-full">188 lbs</span></div><div class="absolute -top-3 -right-3 bg-blue-600 text-white text-xs font-black px-3 py-1.5 rounded-full">TIEFSTWERT</div></div><div class="flex flex-col items-center text-neutral-500"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-purple-500"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg><span class="text-xs mt-2">+30 lbs</span></div><div class="relative group"><div class="w-48 md:w-56 rounded-2xl overflow-hidden border border-purple-500/40 shadow-xl shadow-purple-900/20"><img src="/progress/progress_229.jpg" alt="Aktuelles Gewicht — 218 lbs" class="w-full aspect-[3/4] object-cover object-top" loading="eager" /></div><div class="absolute bottom-3 left-0 right-0 flex justify-center"><span class="bg-purple-600/90 backdrop-blur-sm text-white text-sm font-bold px-4 py-1.5 rounded-full">229 lbs</span></div><div class="absolute -top-3 -right-3 bg-purple-600 text-white text-xs font-black px-3 py-1.5 rounded-full">JETZT</div></div></div><p class="text-center text-neutral-600 text-sm mt-6">Links: 230 lbs (Juli 2023) · Mitte: 188 lbs (Jan 2024) · Rechts: 229 lbs (Feb 2026)</p></div></section>
    <section class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><h2 class="text-2xl font-bold mb-8 text-center">Was ich gelernt habe</h2><div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">{insights.map((insight, i) => (<div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6"><div class="flex items-center gap-3 mb-3"><div class="w-8 h-8 bg-blue-500/20 rounded-full flex items-center justify-center"><span class="text-blue-400 font-bold">{i + 1}</span></div><h3 class="text-lg font-bold">{insight.title}</h3></div><p class="text-neutral-400 leading-relaxed">{insight.content}</p></div>))}</div></div></section>
    <section class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><h2 class="text-2xl font-bold mb-8 text-center">Die Daten hinter den Fortschritten</h2><div class="grid grid-cols-1 md:grid-cols-3 gap-6"><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center"><div class="text-5xl font-bold text-blue-500 mb-2">1.29M</div><div class="text-neutral-400 mb-1">lbs auf Speediance gehoben</div><div class="text-neutral-600 text-sm">125 Workouts</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center"><div class="text-5xl font-bold text-green-500 mb-2">265</div><div class="text-neutral-400 mb-1">Meilen gelaufen</div><div class="text-neutral-600 text-sm">111 Läufe (84 draußen, 27 Laufband)</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center"><div class="text-5xl font-bold text-yellow-500 mb-2">10+</div><div class="text-neutral-400 mb-1">Monate BJJ-Training</div><div class="text-neutral-600 text-sm">Braungurt erreicht</div></div></div><div class="mt-8 text-center"><a href="/de/speediance/" class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 transition-colors">Vollständige Speediance-Daten ansehen<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a></div></div></section>
    <section class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><h2 class="text-2xl font-bold mb-8 text-center">Wichtige Erkenntnisse</h2><div class="max-w-2xl mx-auto"><ul class="space-y-4"><li class="flex gap-4"><div class="flex-shrink-0 w-6 h-6 bg-blue-500/20 rounded-full flex items-center justify-center mt-0.5"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg></div><div class="text-neutral-300"><strong class="text-white">GLP-1 funktioniert, aber es ist keine Magie.</strong> In Kombination mit Krafttraining und Proteintracking beschleunigt es den Fettabbau und erhält gleichzeitig Muskulatur.</div></li><li class="flex gap-4"><div class="flex-shrink-0 w-6 h-6 bg-blue-500/20 rounded-full flex items-center justify-center mt-0.5"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg></div><div class="text-neutral-300"><strong class="text-white">Zone-2-Cardio zerstörte meine Regeneration.</strong> Gehen und niedrig intensive Bewegung schlagen stundenlanges gleichmäßiges Cardio, wenn du schwer hebst.</div></li><li class="flex gap-4"><div class="flex-shrink-0 w-6 h-6 bg-blue-500/20 rounded-full flex items-center justify-center mt-0.5"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg></div><div class="text-neutral-300"><strong class="text-white">Progressive Überlastung ist alles.</strong> Das wiederholungsbasierte Tracking von Speediance zeigte mir genau, wann ich Gewicht hinzufügen musste. Kein Rätselraten.</div></li><li class="flex gap-4"><div class="flex-shrink-0 w-6 h-6 bg-blue-500/20 rounded-full flex items-center justify-center mt-0.5"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg></div><div class="text-neutral-300"><strong class="text-white">BJJ beschleunigt Transformation.</strong> Dreimal pro Woche Rollen verbrennt Kalorien, baut Muskelausdauer auf und sorgt für Verbindlichkeit in einer Community.</div></li></ul></div></div></section>
    <section class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4 text-center"><h2 class="text-2xl font-bold mb-4">Bereit, deine eigene Reise zu starten?</h2><p class="text-neutral-400 mb-8 max-w-xl mx-auto">Alles, was ich nutze, ist dokumentiert. Keine Geheimnisse. Keine gesponserten Produkte. Nur echte Daten aus echtem Training.</p><div class="flex flex-wrap justify-center gap-4"><a href="/de/gear/" class="bg-blue-600 hover:bg-blue-500 text-white font-semibold px-6 py-3 rounded-full transition-colors">Mein Gear-Stack →</a><a href="/de/day/" class="bg-neutral-800 hover:bg-neutral-700 text-white font-semibold px-6 py-3 rounded-full transition-colors">Einen Tag in den Daten sehen →</a><a href="/de/blog/" class="bg-neutral-800 hover:bg-neutral-700 text-white font-semibold px-6 py-3 rounded-full transition-colors">Die ganze Geschichte lesen →</a></div></div></section>
  </main>
</Layout>
