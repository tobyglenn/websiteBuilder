---
import Layout from '../../layouts/Layout.astro';
import { weightData, getStats } from '../../data/weight.js';

const siteUrl = "https://tobyonfitnesstech.com";
const weightStats = getStats();
const chartWidth = 600;
const chartHeight = 260;
const wPadding = 44;
const weights = weightData.map(d => d.weight);
const minW = Math.min(...weights) - 10;
const maxW = Math.max(...weights) + 10;
const wRange = maxW - minW;
const wPoints = weightData.map((d, i) => {
  const x = wPadding + (i / (weightData.length - 1)) * (chartWidth - 2 * wPadding);
  const y = chartHeight - wPadding - ((d.weight - minW) / wRange) * (chartHeight - 2 * wPadding);
  return `${x},${y}`;
}).join(' ');

const profilePageSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "@id": `${siteUrl}/de/about/#profilepage`,
  "name": "Über Toby Glenn Peters",
  "description": "Toby Glenn Peters ist ein unabhängiger Tester für Fitness-Technologie, der mit datengesteuertem Training, Speediance, Tonal, WHOOP, Garmin und Brazilian Jiu-Jitsu von 242 auf 188 lbs kam.",
  "url": `${siteUrl}/de/about/`,
  "inLanguage": "de-DE",
  "isPartOf": { "@id": `${siteUrl}/#website` },
  "about": { "@id": `${siteUrl}/#toby` },
  "mainEntity": {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": `${siteUrl}/#toby`,
    "name": "Toby Glenn Peters",
    "alternateName": ["TobyOnFitnessTech", "Toby on Fitness Tech"],
    "jobTitle": "Fitness-Enthusiast & Tech-Builder",
    "description": "Toby Glenn Peters reduzierte sein Gewicht mit obsessivem Datentracking, Speediance, Tonal und Brazilian Jiu-Jitsu von 242 auf 188 lbs. Unabhängiger Tester für Fitness-Technologie — keine Programme, kein Hype.",
    "url": siteUrl,
    "image": [
      { "@type": "ImageObject", "@id": `${siteUrl}/#toby-image-before`, "url": `${siteUrl}/progress/progress_230.jpg`, "caption": "Toby Glenn Peters bei 230 lbs vor der Transformation — 4. August 2023", "width": 400, "height": 533 },
      { "@type": "ImageObject", "@id": `${siteUrl}/#toby-image-after`, "url": `${siteUrl}/progress/progress_188.jpg`, "caption": "Toby Glenn Peters bei 188 lbs nach 54 lbs Gewichtsverlust — 4. Januar 2024", "width": 400, "height": 533 },
      { "@type": "ImageObject", "@id": `${siteUrl}/#toby-image-current`, "url": `${siteUrl}/progress/progress_229.jpg`, "caption": "Toby Glenn Peters in der Muskelaufbauphase bei 229 lbs — 3. Februar 2026", "width": 400, "height": 533 }
    ],
    "sameAs": ["https://www.youtube.com/@tobyonfitness", "https://www.instagram.com/tobyonfitness"],
    "knowsAbout": ["Speediance", "BJJ", "Garmin", "WHOOP", "8Sleep", "Laufen", "Brazilian Jiu-Jitsu"],
    "award": "Transformation von 242→188 lbs",
    "worksFor": { "@id": `${siteUrl}/#organization` },
    "nationality": { "@type": "Country", "name": "Vereinigte Staaten" }
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": `${siteUrl}/de/` },
      { "@type": "ListItem", "position": 2, "name": "Über", "item": `${siteUrl}/de/about/` }
    ]
  }
};
---

<Layout title="Über Toby Glenn Peters - TobyOnFitnessTech" description="Toby Glenn Peters reduzierte sein Gewicht mit obsessivem Datentracking, Speediance, Tonal und Brazilian Jiu-Jitsu von 242 auf 188 lbs. Unabhängiger Tester für Fitness-Technologie — keine Programme, kein Hype." breadcrumbs={[{ name: "Startseite", url: "/de/" }, { name: "Über", url: "/de/about" }]} jsonLd={profilePageSchema}>
  <main class="min-h-screen bg-neutral-950 text-white">
    <section id="hero" class="pt-20 pb-12 md:pt-28 md:pb-16 relative overflow-hidden"><div class="absolute inset-0 bg-gradient-to-b from-blue-900/10 to-transparent pointer-events-none" /><div class="container mx-auto px-4 relative z-10"><div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16"><div class="flex-1 max-w-2xl"><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">Ich verkaufe keine Programme.<br /><span class="bg-gradient-to-r from-blue-500 to-purple-500 bg-clip-text text-transparent">Ich dokumentiere nur, was tatsächlich funktioniert.</span></h2><p class="text-xl text-neutral-400 mb-8 leading-relaxed">Programmierer. BJJ-Praktizierender. Daten-Nerd. <br/>Ich habe in 6 Monaten 54 lbs verloren und zeige hier genau, wie.</p></div><div class="flex-shrink-0 w-full lg:w-auto"><div class="flex gap-3 items-end"><div class="relative group"><div class="w-44 md:w-52 rounded-2xl overflow-hidden border border-neutral-800 shadow-xl"><img src="/progress/progress_230.jpg" alt="Vorher — 230 lbs" class="w-full aspect-[3/4] object-cover object-top" loading="eager" /></div><div class="absolute bottom-3 left-0 right-0 flex justify-center"><span class="bg-black/80 backdrop-blur-sm text-neutral-300 text-xs font-bold px-3 py-1 rounded-full border border-neutral-700">230 lbs</span></div></div><div class="flex flex-col items-center gap-1 pb-10 text-neutral-500"><div class="h-px w-6 bg-neutral-700"></div><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg><div class="h-px w-6 bg-neutral-700"></div></div><div class="relative group"><div class="w-44 md:w-52 rounded-2xl overflow-hidden border border-blue-500/40 shadow-xl shadow-blue-900/20"><img src="/progress/progress_188.jpg" alt="Nachher — 188 lbs" class="w-full aspect-[3/4] object-cover object-top" loading="eager" /></div><div class="absolute bottom-3 left-0 right-0 flex justify-center"><span class="bg-blue-600/90 backdrop-blur-sm text-white text-xs font-bold px-3 py-1 rounded-full">188 lbs</span></div><div class="absolute -top-3 -right-3 bg-blue-600 text-white text-xs font-black px-2.5 py-1.5 rounded-full shadow-lg rotate-6">−54 lbs</div></div></div><p class="text-center text-neutral-600 text-xs mt-4 tracking-wider uppercase">6 Monate · keine Ausreden</p></div></div></div></section>

    <section id="stats" class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><div class="flex flex-col md:flex-row gap-12 items-center"><div class="md:w-1/2"><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8"><h2 class="text-2xl font-bold mb-6 text-blue-400">Die Zahlen</h2><div class="grid grid-cols-2 gap-6"><div><div class="text-4xl font-bold text-white mb-1">242</div><div class="text-sm text-neutral-500 uppercase tracking-wider">Startgewicht</div></div><div><div class="text-4xl font-bold text-blue-500 mb-1">188</div><div class="text-sm text-neutral-500 uppercase tracking-wider">Erreicht am 4. Jan. 2024</div></div><div><div class="text-4xl font-bold text-white mb-1">6 Monate</div><div class="text-sm text-neutral-500 uppercase tracking-wider">Dauer</div></div><div><div class="text-4xl font-bold text-white mb-1">0</div><div class="text-sm text-neutral-500 uppercase tracking-wider">Gemachte Ausreden</div></div><div><div class="text-4xl font-bold text-white mb-1">54 lbs</div><div class="text-sm text-neutral-500 uppercase tracking-wider">Insgesamt verloren</div></div><div><div class="text-4xl font-bold text-white mb-1">1 Mio.+</div><div class="text-sm text-neutral-500 uppercase tracking-wider">Gehobene lbs</div></div></div></div></div><div class="md:w-1/2 space-y-6 text-neutral-300 leading-relaxed text-lg"><h2 class="text-3xl font-bold text-white">Der Wendepunkt</h2><p>Ende 2024 wog ich 242 Pfund. Herkömmliches Cardio — das Mittel, auf das die meisten zum Abnehmen setzen — brachte mich nicht weiter. Also entschied ich mich, eine intelligentere Lösung zu entwickeln.</p><p>Ich bin Programmierer. Also bin ich tief in die Daten eingestiegen: WHOOP-Erholungswerte, Garmin-Aktivitätstracking, 8Sleep-Schlafqualität und akribisches Kalorientracking mit Cronometer. Jede Variable, die ich kontrollieren konnte, habe ich kontrolliert. Alles, was ich messen konnte, habe ich gemessen.</p><p>Der Anker meines Trainings wurde eine <strong class="text-white">digitale Kabelzugmaschine</strong> — ein smartes Home-Gym, mit dem ich zu Hause schwer trainieren konnte. Inzwischen habe ich darauf über 1.000.000 lbs Trainingsvolumen protokolliert. Kein Hype — ich habe die Daten dazu.</p><p>Neben dem Training an der Maschine kehrte ich zum <strong class="text-white">Brazilian Jiu-Jitsu</strong> zurück — als körperliches Ventil und mentale Verankerung. BJJ zwang mich dazu, diszipliniert zu bleiben, demütig zu bleiben und weiter anzutreten — selbst wenn die Waage sich nicht so bewegte, wie ich es wollte.</p><p>Sechs Monate später: 188 lbs. 54 lbs verloren.</p><div class="pt-2"><a href="/de/videos/?category=transformation" class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 font-semibold transition-colors group">Transformation-Videos ansehen <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a><span class="mx-2 text-neutral-600">|</span><a href="/de/fitness-age/" class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 font-semibold transition-colors group">Ihr Fitnessalter berechnen</a></div></div></div></div></section>

    <section id="weight-journey" class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><div class="max-w-3xl mx-auto"><h2 class="text-3xl font-bold text-white mb-8 text-center">Gewichtsverlauf</h2><div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8"><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5 text-center"><p class="text-sm text-neutral-400 mb-1">Start</p><p class="text-3xl font-bold text-white">{weightStats.start} lbs</p></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5 text-center"><p class="text-sm text-neutral-400 mb-1">Niedrigster Wert</p><p class="text-3xl font-bold text-green-400">{weightStats.lowest} lbs</p></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5 text-center"><p class="text-sm text-neutral-400 mb-1">Aktuell</p><p class="text-3xl font-bold text-blue-400">{weightStats.current} lbs</p></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5 text-center"><p class="text-sm text-neutral-400 mb-1">Veränderung</p><p class={`text-3xl font-bold ${weightStats.totalChange < 0 ? 'text-green-400' : 'text-purple-400'}`}>{weightStats.totalChange > 0 ? '+' : ''}{weightStats.totalChange} lbs</p></div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6"><h3 class="text-lg font-semibold text-white mb-4">Gewicht im Zeitverlauf</h3><svg viewBox={`0 0 ${chartWidth} ${chartHeight}`} class="w-full h-auto" preserveAspectRatio="xMidYMid meet"><defs><linearGradient id="wGradient" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#3b82f6" /><stop offset="100%" stop-color="#8b5cf6" /></linearGradient></defs>{[0, 0.25, 0.5, 0.75, 1].map((ratio) => { const y = wPadding + ratio * (chartHeight - 2 * wPadding); const w = Math.round(maxW - ratio * wRange); return (<g><line x1={wPadding} y1={y} x2={chartWidth - wPadding} y2={y} stroke="#262626" stroke-width="1" stroke-dasharray="4" /><text x={wPadding - 6} y={y + 4} text-anchor="end" fill="#525252" font-size="11">{w}</text></g>); })}{weightData.filter((_, i) => i % 2 === 0).map((d, i) => { const x = wPadding + ((i * 2) / (weightData.length - 1)) * (chartWidth - 2 * wPadding); const label = new Date(d.date).toLocaleDateString('de-DE', { month: 'short', year: '2-digit' }); return <text x={x} y={chartHeight - 8} text-anchor="middle" fill="#525252" font-size="10">{label}</text>; })}<polyline points={wPoints} fill="none" stroke="url(#wGradient)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />{weightData.map((d, i) => { const x = wPadding + (i / (weightData.length - 1)) * (chartWidth - 2 * wPadding); const y = chartHeight - wPadding - ((d.weight - minW) / wRange) * (chartHeight - 2 * wPadding); return <circle cx={x} cy={y} r="5" fill="#3b82f6" stroke="#171717" stroke-width="2" />; })}</svg></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 mt-6 space-y-4 text-neutral-300 leading-relaxed"><p><strong class="text-white">242 → 188:</strong> Von Januar 2023 bis März 2024 verlor ich mit pharmakologischer Unterstützung (GLP-1, TRT, Anavar), aggressiver Kalorienreduktion und hohem Trainingsvolumen 54 lbs. Der Fokus: schlank werden, Gewohnheiten aufbauen, mir selbst beweisen, dass ich es kann.</p><p><strong class="text-white">188 → 218:</strong> Nachdem ich 188 lbs erreicht hatte, wechselte ich in den Aufbau. Ich aß mehr, priorisierte Protein und progressive Überlastung auf dem Speediance und ergänzte BJJ. Die Waage stieg um 30 lbs — und ich bin stärker, besser konditioniert und leistungsfähiger denn je.</p><p><strong class="text-white">Die Lehre:</strong> Die Waage ist ein Werkzeug, kein Richter. Jede Phase hatte einen Zweck. Die Transformation ist nicht vorbei — sie ist nur in ein neues Kapitel eingetreten.</p></div></div></div></section>

    <section id="running-stats" class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><h2 class="text-3xl md:text-4xl font-bold text-white mb-8 text-center">Laufstatistiken</h2><div class="grid grid-cols-2 md:grid-cols-3 gap-6"><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center"><div class="text-4xl font-bold text-white mb-2">111</div><div class="text-sm text-neutral-400 uppercase tracking-wider">Läufe insgesamt</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center"><div class="text-4xl font-bold text-white mb-2">265.1 mi</div><div class="text-sm text-neutral-400 uppercase tracking-wider">Meilen insgesamt</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center"><div class="text-4xl font-bold text-white mb-2">67.2 h</div><div class="text-sm text-neutral-400 uppercase tracking-wider">Gesamtstunden</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center"><div class="text-4xl font-bold text-white mb-2">15:12/mi</div><div class="text-sm text-neutral-400 uppercase tracking-wider">Durchschnittstempo</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center"><div class="text-4xl font-bold text-white mb-2">5 mi</div><div class="text-sm text-neutral-400 uppercase tracking-wider">Längster Lauf (30. Juni 2025)</div></div></div></div></section>

    <section id="build-phase" class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><div class="max-w-5xl mx-auto"><p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-3">Kapitel 2</p><h2 class="text-3xl md:text-4xl font-bold text-white mb-10">188 lbs waren die Startlinie, nicht das Ziel.</h2><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8 mb-10"><h3 class="text-xl font-bold mb-6 text-blue-400">Die Zahlen der Aufbauphase</h3><div class="grid grid-cols-2 md:grid-cols-4 gap-6"><div><div class="text-3xl font-bold text-white mb-1">1,296,447</div><div class="text-xs text-neutral-500 uppercase tracking-wider">Seit Juli 2025 gehobene lbs</div></div><div><div class="text-3xl font-bold text-white mb-1">125</div><div class="text-xs text-neutral-500 uppercase tracking-wider">Speediance-Sessions</div></div><div><div class="text-3xl font-bold text-white mb-1">265.1 mi</div><div class="text-xs text-neutral-500 uppercase tracking-wider">Gelaufene Meilen (letztes Jahr)</div></div><div><div class="text-3xl font-bold text-white mb-1">111</div><div class="text-xs text-neutral-500 uppercase tracking-wider">Protokollierte Läufe</div></div></div></div><div class="space-y-6 text-neutral-300 leading-relaxed text-lg"><p>Ich erreichte 188 lbs am 4. Januar 2024 und verstand sofort, dass der Cut nur Phase eins war. Gewicht zu verlieren ist ein Subtraktionsproblem. Etwas darauf aufzubauen ist eine völlig andere — und ehrlich gesagt interessantere — Herausforderung. Die Waage ist seitdem gestiegen: 188 → 205 → 218-229 lbs Anfang 2026. Das ist kein Rückschritt. Das ist der Plan in Aktion.</p><p><strong class="text-white">Speediance</strong> wurde zum Anker von Phase zwei. Allein in den sieben Monaten zwischen Juli 2025 und Februar 2026 protokollierte ich 125 Sessions und bewegte <strong class="text-white">1,296,447 lbs</strong> Gesamtvolumen. Meine beste Einzelsession: 35,305 lbs in 50 Minuten am 2. Februar 2026. Höchste von der Maschine erfasste Lifts — Latziehen mit Langhantel bei 294 lb 1RM, vorgebeugtes Rudern bei 198 lbs, Bankdrücken bei 90 lbs über das Kabelsystem. Das sind keine Schätzungen. Die Maschine protokolliert jede Wiederholung.</p><p>Parallel dazu habe ich das Laufen komplett neu aufgebaut. Ich begann mit Ein-Meilen-Sessions — ehrlich gesagt einfach mit dem Ziel, nicht anzuhalten. Anfang 2026 laufe ich 5 Meilen. 111 protokollierte Läufe im vergangenen Jahr: 84 draußen, 27 auf dem Laufband, 2 Freiwasserschwimmen. <strong class="text-white">265.1 Meilen insgesamt.</strong> Nicht schnell. Aber konstant, progressiv und mit Aufbau. Dass das Gewicht steigt, ist nichts, das man wegreden muss — Muskeln wiegen eben etwas. Genau darum geht es.</p><p>Jede Trainingsentscheidung läuft inzwischen durch den Stack: WHOOP gibt mir jeden Morgen einen Erholungswert, 8Sleep sagt mir, wie die Nacht tatsächlich lief, und der KI-Assistent, den ich mit <strong class="text-white">OpenClaw</strong> gebaut habe, liest alles — Garmin-Aktivität, Schlafdaten, HRV-Trends — und erstellt eine tägliche Bereitschaftsempfehlung, bevor ich entscheide, ob ich Gas gebe oder zurücknehme. Das System macht die Entscheidungen nachvollziehbar. Kein Raten, kein Bauchgefühl, wenn die Daten etwas anderes sagen.</p></div></div></div></section>

    <section id="progress-photos" class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><div class="mb-10"><h2 class="text-3xl font-bold mb-3">Fortschrittsfotos</h2><p class="text-neutral-400 text-lg">242 → 188 lbs. Jedes Foto ist echt, unbearbeitet und mit dem jeweiligen Gewicht versehen.</p></div><div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 mb-8">{[{ src: '/progress/progress_230.jpg', label: '230 lbs', date: '4. Aug. 2023' },{ src: '/progress/progress_220.jpg', label: '220 lbs', date: '7. Sep. 2023' },{ src: '/progress/progress_200.jpg', label: '200 lbs', date: '1. Dez. 2023' },{ src: '/progress/progress_188.jpg', label: '188 lbs', date: '4. Jan. 2024' },{ src: '/progress/progress_191.jpg', label: '191 lbs', date: '6. Feb. 2024' },{ src: '/progress/progress_211.jpg', label: '211 lbs', date: '2. Juni 2024' },{ src: '/progress/progress_229.jpg', label: '229 lbs', date: '3. Feb. 2026' },{ src: '/progress/workout_action.jpg', label: 'Training', date: '' },].map(({ src, label, date }) => (<div class="relative group overflow-hidden rounded-xl bg-neutral-900 border border-neutral-800 hover:border-neutral-600 transition-all"><div class="aspect-[3/4]"><img src={src} alt={label} class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" loading="lazy" /></div><div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/85 via-black/40 to-transparent pt-8 pb-2 px-2 text-center pointer-events-none"><span class="text-white text-xs font-bold block leading-tight drop-shadow">{label}</span>{date && <span class="text-neutral-400 text-[10px] block">{date}</span>}</div></div>))}</div><div class="bg-neutral-900/50 border border-neutral-800 rounded-2xl p-6 flex flex-col md:flex-row items-center gap-6"><div class="flex-shrink-0 text-5xl">📊</div><div><h3 class="text-xl font-bold text-white mb-2">Jeder Datenpunkt protokolliert</h3><p class="text-neutral-400">Diese Fotos erzählen nicht die ganze Geschichte. Hinter jedem Bild stehen tägliche WHOOP-Erholungswerte, Garmin-Trainingsbelastung, 8Sleep-Schlafqualitätsdaten und Cronometer-Ernährungsprotokolle. Die Transformation war systematisch, nicht zufällig.</p></div></div></div></section>

    <section id="focus" class="py-16 bg-neutral-900/30 border-y border-neutral-900"><div class="container mx-auto px-4"><h2 class="text-3xl font-bold mb-12 text-center">Mein Fokus</h2><div class="grid md:grid-cols-3 gap-8"><div class="space-y-4"><h3 class="text-xl font-bold text-white">Home-Gym-Technologie</h3><p class="text-neutral-400">Ich habe auf meiner digitalen Kabelzugmaschine über 1.000.000 lbs bewegt. Ich teste Firmware-Updates, vergleiche Modi und finde die Fehler, damit Sie es nicht müssen. Wenn eine Maschine behauptet, ein Fitnessstudio zu ersetzen, überprüfe ich das.</p></div><div class="space-y-4"><h3 class="text-xl font-bold text-white">BJJ & Grappling</h3><p class="text-neutral-400">Jiu-Jitsu ist nicht nur ein Sport; es ist ein System. Ich analysiere Kampfaufnahmen, spreche über Gurtkultur und erkläre das „Warum“ hinter Techniken.</p></div><div class="space-y-4"><h3 class="text-xl font-bold text-white">Daten & Automatisierung</h3><p class="text-neutral-400">Von Whoop-Erholungswerten bis zum Bau meines eigenen KI-Assistenten (OpenClaw), der meinen Zeitplan und mein Training verwaltet. Wenn es messbar und automatisierbar ist, interessiert es mich.</p></div></div></div></section>

    <section class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><div class="max-w-4xl mx-auto"><h2 class="text-3xl font-bold text-white mb-8 text-center">Trainingsphilosophie</h2><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8 space-y-6"><div class="flex gap-4"><div class="text-3xl">🌅</div><div><h3 class="text-xl font-bold text-white mb-2">Warum ich um 6:30 Uhr trainiere</h3><p class="text-neutral-400">Der Morgen ist zum Trainieren da, bevor der Tag Ihre Energie stiehlt. 6:30 Uhr bedeutet, dass ich bis 8:00 Uhr mit dem Heben fertig oder auf der Matte bin, sodass der Rest des Tages für Arbeit, Familie und Erholung bleibt. Abends zu trainieren hat für mich nie funktioniert — ich bekomme einen zweiten Energieschub, der den Schlaf stört, und um 21 Uhr bin ich zu müde, um hart zu rollen.</p></div></div><div class="flex gap-4"><div class="text-3xl">🔄</div><div><h3 class="text-xl font-bold text-white mb-2">BJJ + Heben + Laufen = der Stack</h3><p class="text-neutral-400">Ich entscheide mich nicht zwischen ihnen — ich mache alle drei. BJJ 3-4x/Woche hält mein Grappling scharf und liefert Cardio. Speediance-Lifting 4x/Woche baut Muskeln und Kraft auf. Laufen 2-3x/Woche erhält die kardiovaskuläre Basis. Der Schlüssel ist, nicht zu viel von einem einzelnen Bereich zu machen: 10 Stunden Gesamttraining pro Woche ist meine Obergrenze, bevor die Erholung leidet.</p></div></div></div></div></div></section>

    <section class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><div class="max-w-5xl mx-auto"><div class="text-center mb-10"><span class="text-blue-500 font-bold uppercase tracking-widest text-sm mb-2 block">Die Meilen</span><h2 class="text-3xl md:text-4xl font-bold text-white">Laufprotokoll</h2><p class="text-neutral-500 mt-3 max-w-xl mx-auto">Während des 54-lb-Gewichtsverlusts bin ich nicht gelaufen. Das Laufen kam später — und vielleicht hat es mir das Leben gerettet.</p></div><div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8"><div class="bg-neutral-900 rounded-xl p-5 border border-neutral-800 text-center"><div class="text-3xl font-black text-white mb-1">266</div><div class="text-xs text-neutral-500 uppercase tracking-wide">Meilen gesamt</div></div><div class="bg-neutral-900 rounded-xl p-5 border border-neutral-800 text-center"><div class="text-3xl font-black text-white mb-1">113</div><div class="text-xs text-neutral-500 uppercase tracking-wide">Protokollierte Läufe</div></div><div class="bg-neutral-900 rounded-xl p-5 border border-neutral-800 text-center"><div class="text-3xl font-black text-white mb-1">67h</div><div class="text-xs text-neutral-500 uppercase tracking-wide">Gesamtzeit</div></div><div class="bg-neutral-900 rounded-xl p-5 border border-neutral-800 text-center"><div class="text-3xl font-black text-white mb-1">15:12</div><div class="text-xs text-neutral-500 uppercase tracking-wide">Ø Tempo /mi</div></div><div class="bg-neutral-900 rounded-xl p-5 border border-neutral-800 text-center"><div class="text-3xl font-black text-white mb-1">5.0</div><div class="text-xs text-neutral-500 uppercase tracking-wide">Längster Lauf (mi)</div></div><div class="bg-neutral-900 rounded-xl p-5 border border-neutral-800 text-center"><div class="text-3xl font-black text-white mb-1">76.8</div><div class="text-xs text-neutral-500 uppercase tracking-wide">Stärkster Monat (mi)</div></div></div><div class="text-center"><a href="/de/running/" class="inline-flex items-center gap-2 text-blue-500 hover:text-blue-400 font-semibold transition-colors text-sm">Vollständiges Running-Dashboard ansehen →</a></div></div></div></section>

    <section class="py-16 border-t border-neutral-900 bg-neutral-950"><div class="container mx-auto px-4"><div class="max-w-5xl mx-auto"><h2 class="text-3xl md:text-4xl font-bold text-white mb-6 text-center">Meine BJJ-Reise</h2><p class="text-neutral-300 text-base md:text-lg mb-4">Als BJJ-Praktizierender mit Braungurt ist die Matte der Ort, an dem ich neu starte. Das Training in einem dedizierten BJJ-Gym bedeutet 3-4 Kurse pro Woche, regelmäßige Roll-Sessions und eine Routine aus Positionsdrills, die mein Spiel scharf hält, selbst wenn der Rest des Lebens hektisch ist. Diese Kurse sind ein Ritual — Technik, Live-Sparring und Fehlerkorrektur mit Trainingspartnern, die Einsatz erwarten.</p><p class="text-neutral-300 text-base md:text-lg mb-4">Die Geschichte, die mich hierher gebracht hat, begann 2023 mit einem Cut von 242 auf 188 lbs, der stark auf Jiu-Jitsu, WHOOP-Erholungssignale und kalkulierte Kalorienkontrolle setzte. Seitdem hat sich der Fokus gedreht: 2024 und 2025 habe ich damit verbracht, Kraft und Muskeln wieder aufzubauen und mich von 205 auf 218 lbs hochzuarbeiten, während ich weiter auf der Matte erschien und BJJ meine Kondition ehrlich hielt.</p><p class="text-neutral-300 text-base md:text-lg mb-4">Wettkampf war dabei ein Kompass. Mit Braungurt erreichte ich bei einem regionalen Turnier mit einem Reverse Triangle den dritten Platz — eine Erinnerung daran, dass Entschlossenheit Perfektion schlägt. Dieser Abend ist detailliert in meinem <a href="/blog/speediance-customization-why-it-breaks-settings/" class="text-blue-500 hover:text-cyan-400 font-semibold">Turnier-Rückblick</a> festgehalten, und die Lehren aus diesem Scramble beeinflussen noch heute, wie ich Krafttraining mit Rollen kombiniere.</p><p class="text-neutral-300 text-base md:text-lg mb-4">Die Matte hört nie auf zu lehren. Für mehr Kontext dazu, wie ich diese Reise mit breiterer BJJ-Kommentierung verbinde, lesen Sie den <a href="/blog/mike-israetel-bjj-black-belt-defence/" class="text-blue-500 hover:text-cyan-400 font-semibold">Mat Science-Beitrag zur Gurtkultur</a> oder verfolgen Sie, wie mein OpenClaw-BJJ-Buddy-Projekt Trainingsdaten in jeden Bericht integriert (<a href="/blog/openclaw-automation/" class="text-blue-500 hover:text-cyan-400 font-semibold">Build-Log zur BJJ-Automatisierung</a>).</p><div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-8"><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6"><span class="text-xs uppercase tracking-widest text-blue-500">2023 Fettverlust</span><p class="text-3xl font-black text-white mt-3">242→188 lbs</p><p class="text-neutral-400 text-sm mt-2">Definiert, diszipliniert und von Jiu-Jitsu getragen. WHOOP-Erholung hielt das Defizit ehrlich.</p></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6"><span class="text-xs uppercase tracking-widest text-blue-500">Aktueller Aufbau</span><p class="text-3xl font-black text-white mt-3">205→218 lbs</p><p class="text-neutral-400 text-sm mt-2">Muskelaufbauphase, die das BJJ-Volumen respektiert — Krafttraining, Laufen und Rollen im Einklang.</p></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6"><span class="text-xs uppercase tracking-widest text-blue-500">Wöchentliche Mattenzeit</span><p class="text-3xl font-black text-white mt-3">3-4 Kurse</p><p class="text-neutral-400 text-sm mt-2">Technikrunden, strukturierte Drills und Open-Mat-Rollen mit Partnern, die jede Session ehrlich halten.</p></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6"><span class="text-xs uppercase tracking-widest text-blue-500">Wettkampf</span><p class="text-3xl font-black text-white mt-3">Braungurt</p><p class="text-neutral-400 text-sm mt-2">Turniere, Ranglistenkämpfe und die Demut von Overtime-Bouts, die mich daran erinnern, weiter zu wachsen.</p></div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8 mt-10"><div class="flex items-center justify-between text-xs text-neutral-500 uppercase tracking-widest"><span>Gurt- & Matten-Zeitlinie</span><span class="text-blue-500">Noch im Aufstieg</span></div><div class="grid mt-6 gap-4 md:grid-cols-4"><div class="rounded-lg border border-neutral-800 bg-neutral-950/50 p-4"><p class="text-xs uppercase tracking-widest text-neutral-500">Fundament</p><p class="text-base font-semibold text-white mt-3">Weißgurt</p><p class="text-neutral-400 text-sm mt-1">Die Grundlagen mit stündlichen Guard-Retention-Drills im Gym gelegt.</p></div><div class="rounded-lg border border-neutral-800 bg-neutral-950/50 p-4"><p class="text-xs uppercase tracking-widest text-neutral-500">Momentum</p><p class="text-base font-semibold text-white mt-3">Blau → Lila</p><p class="text-neutral-400 text-sm mt-1">Pressure Passing aufgebaut und den Turnierbetrieb genutzt, um zu testen, was wirklich funktioniert.</p></div><div class="rounded-lg border border-neutral-800 bg-neutral-950/50 p-4"><p class="text-xs uppercase tracking-widest text-neutral-500">Anerkennung</p><p class="text-base font-semibold text-white mt-3">Lila → Braun</p><p class="text-neutral-400 text-sm mt-1">Braungurt verdient, Platz drei erreicht und ein Reverse Triangle, der immer noch in den Logs lebt.</p></div><div class="rounded-lg border border-neutral-800 bg-neutral-950/50 p-4"><p class="text-xs uppercase tracking-widest text-neutral-500">Tägliche Arbeit</p><p class="text-base font-semibold text-white mt-3">Jetzt Braungurt</p><p class="text-neutral-400 text-sm mt-1">Jede Woche balanciert Technik, Kondition und Erholung — Gym, Matte und WHOOP im Gleichklang.</p></div></div></div><p class="text-neutral-500 text-sm mt-6 text-center">Tauchen Sie tiefer in die Reise ein mit der <a href="/blog/mike-israetel-bjj-black-belt-defence/" class="text-blue-500 hover:text-cyan-400 font-semibold">Mat Science-Debatte zur Gurtkultur</a> oder dem <a href="/blog/openclaw-automation/" class="text-blue-500 hover:text-cyan-400 font-semibold">OpenClaw-Build-Log zur BJJ-Automatisierung</a>.</p></div></div></section>

    <section class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><div class="max-w-5xl mx-auto"><h2 class="text-3xl md:text-4xl font-bold text-white mb-10 text-center">Persönlicher Lebensstil</h2><div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12"><div class="bg-neutral-900 border border-neutral-800 rounded-2xl overflow-hidden"><img src="/images/about/fishing.jpg" alt="Angel-Landschaft: Rute am Flussufer, malerisch, ohne Menschen" class="w-full object-contain aspect-video bg-neutral-950" loading="lazy" /><div class="p-4"><p class="text-center text-neutral-300">Angel-Landschaft: Rute am Flussufer, malerisch, ohne Menschen</p></div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl overflow-hidden"><img src="/images/about/selfie_dbz.jpg" alt="Solo-Selfie: Dragon-Ball-Z-Shirt, lächelnd, draußen mit bemalter Hasen-Skulptur" class="w-full object-contain aspect-video bg-neutral-950" loading="lazy" /><div class="p-4"><p class="text-center text-neutral-300">Solo-Selfie: Dragon-Ball-Z-Shirt, lächelnd, draußen mit bemalter Hasen-Skulptur</p></div></div></div></div></div></section>

    <section class="py-16 border-t border-neutral-900 bg-neutral-950"><div class="container mx-auto px-4"><div class="max-w-5xl mx-auto"><p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-3">BJJ + Transformation</p><h2 class="text-3xl md:text-4xl font-bold text-white mb-10">Wie BJJ meine Transformation angetrieben hat</h2><div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12"><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center"><div class="text-4xl font-bold text-white mb-2">242 lbs</div><div class="text-sm text-neutral-400 uppercase tracking-wider">Startgewicht (2023)</div><div class="text-xs text-neutral-600 mt-2">Schwer, außer Form</div></div><div class="bg-neutral-900 border border-blue-500/30 rounded-2xl p-6 text-center"><div class="text-4xl font-bold text-blue-500 mb-2">188 lbs</div><div class="text-sm text-neutral-400 uppercase tracking-wider">Niedrigstes Gewicht (Jan. 2024)</div><div class="text-xs text-neutral-600 mt-2">54 lbs verloren — BJJ beschleunigte den Fettverlust</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center"><div class="text-4xl font-bold text-white mb-2">218 lbs</div><div class="text-sm text-neutral-400 uppercase tracking-wider">Aktuelles Gewicht (2026)</div><div class="text-xs text-neutral-600 mt-2">+30 lbs Muskeln — stärker denn je</div></div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8 mb-10"><h3 class="text-xl font-bold text-white mb-6 text-center">Zeitlinie der Gurtentwicklung</h3><div class="flex flex-col md:flex-row justify-between items-center gap-4"><div class="flex flex-col items-center flex-1"><div class="w-16 h-16 rounded-full bg-white border-4 border-neutral-300 flex items-center justify-center mb-3"><span class="text-neutral-800 font-bold text-xs">WHT</span></div><div class="text-center"><div class="text-white font-bold">Weißgurt</div><div class="text-neutral-500 text-sm">Mit BJJ begonnen</div><div class="text-blue-400 text-xs mt-1">2022</div></div></div><div class="hidden md:block text-neutral-600"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></div><div class="flex flex-col items-center flex-1"><div class="w-16 h-16 rounded-full bg-blue-600 border-4 border-blue-400 flex items-center justify-center mb-3"><span class="text-white font-bold text-xs">BLU</span></div><div class="text-center"><div class="text-white font-bold">Blaugurt</div><div class="text-neutral-500 text-sm">Ersten Streifen verdient</div><div class="text-blue-400 text-xs mt-1">2023</div></div></div><div class="hidden md:block text-neutral-600"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></div><div class="flex flex-col items-center flex-1"><div class="w-16 h-16 rounded-full bg-purple-600 border-4 border-purple-400 flex items-center justify-center mb-3"><span class="text-white font-bold text-xs">PRP</span></div><div class="text-center"><div class="text-white font-bold">Lilagurt</div><div class="text-neutral-500 text-sm">Wettkampfbereit</div><div class="text-blue-400 text-xs mt-1">2024</div></div></div><div class="hidden md:block text-neutral-600"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></div><div class="flex flex-col items-center flex-1"><div class="w-16 h-16 rounded-full bg-amber-700 border-4 border-amber-500 flex items-center justify-center mb-3"><span class="text-white font-bold text-xs">BRN</span></div><div class="text-center"><div class="text-white font-bold">Braungurt</div><div class="text-neutral-500 text-sm">Aktueller Rang</div><div class="text-blue-400 text-xs mt-1">2025-heute</div></div></div></div></div><div class="space-y-6 text-neutral-300 leading-relaxed text-lg"><p><strong class="text-white">BJJ war nicht nur Teil meiner Transformation — es war der Auslöser.</strong> Als ich 2022 mit Jiu-Jitsu anfing, wog ich 242 Pfund und war ehrlich gesagt in der schlechtesten Form meines Lebens. Aber auf der Matte hat etwas Klick gemacht. Die technische Natur des BJJ — Positionsrätsel gegen Gegner zu lösen, denen Ihre Ausreden egal sind — hat meinen gesamten Blick auf Fitness verändert.</p><p>Der Gewichtsverlust kam schneller, als ich erwartet hatte. Zwischen 3-4 Trainingseinheiten pro Woche, dem konsequenten Kaloriendefizit über Cronometer und der mentalen Klarheit durch regelmäßige Mattenzeit fiel ich bis Januar 2024 von 242 auf 188 Pfund. Das ist nicht nur Cardio — das ist der kumulative Effekt aus Konstanz, Wettkampf (ich startete sowohl im Gi als auch No-Gi) und einer Community, die mich verantwortlich hielt.</p><p>Jetzt, mit <strong class="text-white">218 Pfund</strong> im Jahr 2026, befinde ich mich in der Muskelaufbauphase. Der Unterschied diesmal: Ich trainiere intelligenter. WHOOP-Erholungswerte sagen mir, wann ich pushen und wann ich pausieren sollte. Mein BJJ-Training hat sich von „jede Runde überleben“ zu „Positionen dominieren“ entwickelt. Ich habe mit Braungurt sowohl im Gi als auch No-Gi gekämpft, und der Drang, besser zu werden, bringt mich weiterhin um 6:30 Uhr auf die Matte — selbst wenn das Bett warm und die Matte kalt ist.</p><p>BJJ hat mich gelehrt, dass Fortschritt nicht linear ist. Es wird Plateaus geben, Verletzungen und Runden, in denen man von jemandem submitted wird, der nur halb so lange trainiert hat. Genau darum geht es. Der Matte sind Ihre Ausreden egal. Mir auch. Deshalb dokumentiere ich alles — die Lifts, die Läufe, die Rollen, die Daten. Denn was gemessen wird, kann gesteuert werden.</p></div><div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-10"><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5 text-center"><div class="text-3xl font-black text-white mb-1">3-4x</div><div class="text-xs text-neutral-500 uppercase tracking-wide">Sessions/Woche</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5 text-center"><div class="text-3xl font-black text-white mb-1">Braun</div><div class="text-xs text-neutral-500 uppercase tracking-wide">Aktueller Gurt</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5 text-center"><div class="text-3xl font-black text-white mb-1">Gi + No-Gi</div><div class="text-xs text-neutral-500 uppercase tracking-wide">Wettkampf</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5 text-center"><div class="text-3xl font-black text-white mb-1">4+</div><div class="text-xs text-neutral-500 uppercase tracking-wide">Verdiente Streifen</div></div></div></div></div></section>

