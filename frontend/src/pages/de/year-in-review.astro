---
import Layout from '../../layouts/Layout.astro';
import { getYearInReview2025 } from '../../data/yearInReview.js';

const yearInReview = getYearInReview2025();
const { garmin, speediance, eightSleep, whoop, combined } = yearInReview;

const pageTitle = "Jahresrückblick 2025 | Toby über Fitness-Tech";
const pageDescription = "Ein umfassender Blick auf meine Fitnessdaten 2025: Laufen, Krafttraining, Schlaf und Erholungsmetriken von Garmin, Speediance, 8Sleep und WHOOP.";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wie viele Meilen bist du 2025 gelaufen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Ich bin 2025 ${garmin.totalMiles} Meilen in ${garmin.totalRuns} Läufen gelaufen.`
      }
    },
    {
      "@type": "Question",
      "name": "Wie viel Trainingsvolumen hast du 2025 auf Speediance absolviert?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Ich habe ${speediance.totalVolumeFmt} Volumen über ${speediance.totalWorkouts} Workouts bewegt.`
      }
    },
    {
      "@type": "Question",
      "name": "Wie hoch war dein durchschnittlicher Schlafscore auf 8Sleep im Jahr 2025?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Mein durchschnittlicher Schlafscore lag bei ${eightSleep.avgSleepScore} über ${eightSleep.totalNights} erfasste Nächte.`
      }
    },
    {
      "@type": "Question",
      "name": "Wie hoch war deine durchschnittliche WHOOP-Erholung im Jahr 2025?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Mein durchschnittlicher Erholungsscore lag bei ${whoop.avgRecovery}% und an ${whoop.recoveryRate}% der Tage war ich im grünen Erholungsbereich.`
      }
    }
  ]
};
---

<Layout 
  title={pageTitle} 
  description={pageDescription}
  jsonLd={faqSchema}
>
  <div class="container mx-auto px-4 py-12">
    <!-- Hero Section -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-blue-500/20 text-blue-400 text-sm font-medium rounded-full mb-4">
        Jahresbericht 2025
      </span>
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-4">
        Jahresrückblick
      </h1>
      <p class="text-xl text-neutral-400 max-w-2xl mx-auto">
        Ein umfassender Blick auf meine Fitnessreise in den Bereichen Laufen, Krafttraining, Schlaf und Erholung.
      </p>
    </div>

    <!-- Combined Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
        <div class="text-3xl md:text-4xl font-bold text-white mb-2">
          {combined.totalWorkouts.toLocaleString()}
        </div>
        <div class="text-neutral-400 text-sm">Workouts insgesamt</div>
        <div class="text-xs text-neutral-500 mt-1">Laufen + Kraft</div>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
        <div class="text-3xl md:text-4xl font-bold text-white mb-2">
          {garmin.totalMiles.toLocaleString()}
        </div>
        <div class="text-neutral-400 text-sm">Gelaufene Meilen</div>
        <div class="text-xs text-neutral-500 mt-1">{garmin.totalRuns} Läufe</div>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
        <div class="text-3xl md:text-4xl font-bold text-white mb-2">
          {speediance.totalVolumeFmt}
        </div>
        <div class="text-neutral-400 text-sm">Bewegtes Volumen</div>
        <div class="text-xs text-neutral-500 mt-1">{speediance.totalWorkouts} Workouts</div>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 text-center">
        <div class="text-3xl md:text-4xl font-bold text-white mb-2">
          {eightSleep.avgSleepScore}
        </div>
        <div class="text-neutral-400 text-sm">Durchschn. Schlafscore</div>
        <div class="text-xs text-neutral-500 mt-1">{eightSleep.totalNights} Nächte</div>
      </div>
    </div>

    <!-- Running Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
        <span class="w-10 h-10 bg-blue-500/20 rounded-xl flex items-center justify-center text-blue-400">🏃</span>
        Laufen
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{garmin.totalMiles.toLocaleString()}</div>
          <div class="text-neutral-400">Meilen insgesamt</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{garmin.totalRuns}</div>
          <div class="text-neutral-400">Läufe insgesamt</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{garmin.totalHours}h</div>
          <div class="text-neutral-400">Laufzeit</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{garmin.avgPace}</div>
          <div class="text-neutral-400">Durchschn. Pace/mi</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{garmin.avgHR}</div>
          <div class="text-neutral-400">Durchschn. HF</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{garmin.totalCalories.toLocaleString()}</div>
          <div class="text-neutral-400">Verbrannte Kalorien</div>
        </div>
      </div>
      {garmin.longestRun && (
        <div class="mt-4 bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <h3 class="text-lg font-semibold text-white mb-2">Längster Lauf</h3>
          <p class="text-neutral-300">
            <span class="text-blue-400 font-bold">{garmin.longestRun.miles} Meilen</span> am {garmin.longestRun.date} 
            (Pace: {garmin.longestRun.pace}/mi)
          </p>
        </div>
      )}
    </section>

    <!-- Speediance Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
        <span class="w-10 h-10 bg-blue-500/20 rounded-xl flex items-center justify-center text-blue-400">💪</span>
        Speediance-Krafttraining
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{speediance.totalVolumeFmt}</div>
          <div class="text-neutral-400">Gesamtvolumen</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{speediance.totalWorkouts}</div>
          <div class="text-neutral-400">Workouts insgesamt</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{speediance.totalHours}h</div>
          <div class="text-neutral-400">Trainingszeit</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{speediance.avgVolume.toLocaleString()}</div>
          <div class="text-neutral-400">Durchschn. Volumen/Workout</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{speediance.totalCalories.toLocaleString()}</div>
          <div class="text-neutral-400">Verbrannte Kalorien</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{speediance.highestSession?.volume.toLocaleString() || 0}</div>
          <div class="text-neutral-400">Höchstes Volumen</div>
        </div>
      </div>
      {speediance.topWorkouts.length > 0 && (
        <div class="mt-4 bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <h3 class="text-lg font-semibold text-white mb-4">Top-Workouts nach Volumen</h3>
          <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-4">
            {speediance.topWorkouts.map((workout, i) => (
              <div class="text-center">
                <div class="text-2xl font-bold text-blue-400">#{i + 1}</div>
                <div class="text-white font-medium truncate">{workout.name}</div>
                <div class="text-neutral-400 text-sm">{(workout.volume / 1000).toFixed(0)}K lbs</div>
              </div>
            ))}
          </div>
        </div>
      )}
    </section>

    <!-- Sleep Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
        <span class="w-10 h-10 bg-blue-500/20 rounded-xl flex items-center justify-center text-blue-400">😴</span>
        8Sleep-Erholung
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{eightSleep.avgSleepScore}</div>
          <div class="text-neutral-400">Durchschn. Schlafscore</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{eightSleep.avgTotalSleepHrs}h</div>
          <div class="text-neutral-400">Durchschn. Gesamtschlaf</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{eightSleep.totalNights}</div>
          <div class="text-neutral-400">Erfasste Nächte</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{eightSleep.avgHR}</div>
          <div class="text-neutral-400">Durchschn. Herzfrequenz</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{eightSleep.avgRHR}</div>
          <div class="text-neutral-400">Durchschn. Ruhepuls</div>
        </div>
      </div>
    </section>

    <!-- WHOOP Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
        <span class="w-10 h-10 bg-blue-500/20 rounded-xl flex items-center justify-center text-blue-400">💓</span>
        WHOOP-Erholung & Belastung
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{whoop.avgRecovery}%</div>
          <div class="text-neutral-400">Durchschn. Erholung</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{whoop.avgStrain}</div>
          <div class="text-neutral-400">Durchschn. Belastung</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{whoop.avgSleep}h</div>
          <div class="text-neutral-400">Durchschn. Schlaf</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{whoop.avgHRV}</div>
          <div class="text-neutral-400">Durchschn. HRV</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{whoop.avgRHR}</div>
          <div class="text-neutral-400">Durchschn. RHR</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
          <div class="text-4xl font-bold text-white mb-2">{whoop.recoveryRate}%</div>
          <div class="text-neutral-400">Tage mit grüner Erholung</div>
        </div>
      </div>
    </section>

    <!-- Navigation Links -->
    <div class="border-t border-neutral-800 pt-12">
      <h3 class="text-xl font-semibold text-white mb-6 text-center">Mehr Statistiken entdecken</h3>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        <a href="/running/" class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-blue-500 transition-colors group">
          <div class="text-lg font-semibold text-white group-hover:text-blue-400 transition-colors">Laufen</div>
          <div class="text-neutral-400 text-sm">Vollständiges Laufprotokoll und Analysen</div>
        </a>
        <a href="/speediance/" class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-blue-500 transition-colors group">
          <div class="text-lg font-semibold text-white group-hover:text-blue-400 transition-colors">Speediance</div>
          <div class="text-neutral-400 text-sm">Krafttrainingsdaten</div>
        </a>
        <a href="/sleep/" class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-blue-500 transition-colors group">
          <div class="text-lg font-semibold text-white group-hover:text-blue-400 transition-colors">Schlaf</div>
          <div class="text-neutral-400 text-sm">8Sleep-Analyse</div>
        </a>
        <a href="/whoop/" class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-blue-500 transition-colors group">
          <div class="text-lg font-semibold text-white group-hover:text-blue-400 transition-colors">WHOOP</div>
          <div class="text-neutral-400 text-sm">Erholung und Belastung</div>
        </a>
      </div>
    </div>
  </div>
</Layout>
