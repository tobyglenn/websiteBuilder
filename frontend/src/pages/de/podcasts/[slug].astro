---
import { marked } from 'marked';
import Layout from '../../../layouts/Layout.astro';
import EpisodeDetail from '../../../components/EpisodeDetail.jsx';
import StickySubscribeBar from '../../../components/StickySubscribeBar.jsx';

export async function getStaticPaths() {
  const langCode = 'de';
  const feedUrl = `https://raw.githubusercontent.com/grayking-creator/openclaw-podcast/main/translations/feed_${langCode}.xml`;
  
  // 1. Fetch translated RSS
  const rssRes = await fetch(feedUrl);
  const rssText = await rssRes.text();

  // 2. Parse episodes using helper functions
  const getTag = (xml: string, tag: string): string => {
    const cdataRe = new RegExp(`<${tag}[^>]*><!\\[CDATA\\[([\\s\\S]*?)\\]\\]><\\/${tag}>`, 'i');
    const cdataM = xml.match(cdataRe);
    if (cdataM) return cdataM[1].trim();
    const plainRe = new RegExp(`<${tag}[^>]*>([\\s\\S]*?)<\\/${tag}>`, 'i');
    const plainM = xml.match(plainRe);
    return plainM ? plainM[1].trim() : '';
  };

  const getAttr = (xml: string, tag: string, attr: string): string => {
    const re = new RegExp(`<${tag}[^>]*\\s${attr}="([^"]+)"`, 'i');
    const m = xml.match(re);
    return m ? m[1] : '';
  };

  const items = rssText.match(/<item>([\s\S]*?)<\/item>/g) ?? [];

  const episodes = await Promise.all(items.map(async (item) => {
    const episodeNum = parseInt(getTag(item, 'itunes:episode') || '0');
    const slug = `episode-${episodeNum}`;
    const title = getTag(item, 'title').replace(/^Episode \d+:\s*/, '');
    const description = getTag(item, 'description');
    const pubDate = getTag(item, 'pubDate');
    const duration = getTag(item, 'itunes:duration');

    // Format date in German
    const dateObj = new Date(pubDate);
    const formattedDate = isNaN(dateObj.getTime()) ? pubDate : dateObj.toLocaleDateString('de-DE', { month: 'long', day: 'numeric', year: 'numeric' });

    // Fetch translated show notes
    let showNotesHtml = '';
    const snUrl = `https://raw.githubusercontent.com/grayking-creator/openclaw-podcast/main/translations/de/show_notes_episode_${String(episodeNum).padStart(3, '0')}_de.md`;
    try {
      const snRes = await fetch(snUrl);
      if (snRes.ok) {
        const showNotesMd = await snRes.text();
        showNotesHtml = await marked.parse(showNotesMd);
      }
    } catch {
      // No show notes file - graceful fallback
    }

    // Fetch translated transcript (for topics/links)
    let transcriptHtml = '';
    const transcriptUrl = `https://raw.githubusercontent.com/grayking-creator/openclaw-podcast/main/translations/de/episode_${String(episodeNum).padStart(3, '0')}_de.md`;
    try {
      const mdRes = await fetch(transcriptUrl);
      if (mdRes.ok) {
        const rawMd = await mdRes.text();
        // Extract topics from section headings
        const topics = [...rawMd.matchAll(/^## SECTION \d+:\s*(.+)$/gm)].map(m => m[1].trim());
        if (!topics.length) {
          const sectionTopics = [...rawMd.matchAll(/^## (.+)$/gm)]
            .map(m => m[1].trim())
            .filter(t => !t.match(/^(SHOW NOTES|Full Story|Episode)/i));
          topics.push(...sectionTopics);
        }
        
        // Render markdown for display
        transcriptHtml = await marked.parse(rawMd);
      }
    } catch {
      transcriptHtml = '<p class="text-neutral-500">Transkript nicht verfügbar.</p>';
    }

    // Build translated audio URL
    const audioUrl = `https://raw.githubusercontent.com/grayking-creator/openclaw-podcast/main/translations/de/episode_${String(episodeNum).padStart(3, '0')}_de.mp3`;
    const coverImage = `/images/podcast/episode_${String(episodeNum).padStart(3, '0')}_cover.png`;

    return {
      params: { slug },
      props: {
        episode: {
          slug,
          number: episodeNum,
          title,
          description,
          date: formattedDate,
          duration,
          audioUrl,
          coverImage,
          showNotesHtml,
          transcriptHtml,
          topics: [],
          links: [],
        }
      }
    };
  }));

  return episodes;
}

const { episode } = Astro.props;
---

<Layout 
  title={`Episode ${episode.number}: ${episode.title} | OpenClaw Daily`} 
  description={episode.description}
  lang="de"
  episodeSlug={episode.slug}
>
  <EpisodeDetail episode={episode} client:load />
  <StickySubscribeBar client:load />
</Layout>

<style is:global>
  .speaker {
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-right: 0.5rem;
  }
  .speaker.nova { color: #60a5fa; }
  .speaker.alloy { color: #c084fc; }
</style>
