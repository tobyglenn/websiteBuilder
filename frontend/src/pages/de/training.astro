---
import Layout from '../layouts/Layout.astro';

// Weekly training schedule - full body minus legs, prioritized: Running > Lifting > BJJ
const weeklySchedule = [
  {
    day: "Montag",
    focus: "Laufen + Krafttraining",
    icon: "🏃",
    exercises: ["Leichter 5K-Lauf", "Bankdrücken", "Latzug", "Schulterdrücken", "Langhantelrudern"],
    priority: 1
  },
  {
    day: "Dienstag",
    focus: "BJJ",
    icon: "🥋",
    exercises: ["Gi-Drills", "Sparringsrunden", "Positionsarbeit"],
    priority: 3
  },
  {
    day: "Mittwoch",
    focus: "Laufen + Krafttraining",
    icon: "🏃",
    exercises: ["6K-Tempolauf", "Kreuzheben", "Hip Thrust", "Klimmzüge", "Face Pulls"],
    priority: 1
  },
  {
    day: "Donnerstag",
    focus: "Aktive Erholung",
    icon: "🔄",
    exercises: ["Leichter 3K-Jog", "Mobilitätsarbeit", "Dehnen"],
    priority: 0
  },
  {
    day: "Freitag",
    focus: "Laufen + Krafttraining",
    icon: "🏃",
    exercises: ["Intervall-Speedwork", "Schrägbankdrücken", "Latzug", "Bizepscurls", "Trizepsextensions"],
    priority: 1
  },
  {
    day: "Samstag",
    focus: "BJJ",
    icon: "🥋",
    exercises: ["Open Mat", "technische Drills", "freies Rollen"],
    priority: 3
  },
  {
    day: "Sonntag",
    focus: "Ruhe",
    icon: "😴",
    exercises: ["Ruhetag", "Erholungsschlaf", "leichtes Spazierengehen"],
    priority: 0
  }
];

const stats = {
  workoutsPerWeek: 6,
  restDays: 1,
  runningDays: 4,
  liftingDays: 3,
  bjjDays: 2
};

const pageTitle = "Trainingswoche";
const pageDescription = "Eine typische Trainingswoche: Laufen, Ganzkörper-Krafttraining (ohne Beine) und BJJ. Mein priorisierter Fitness-Ansatz: Laufen > Krafttraining > BJJ.";

const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "Tobys Trainingswoche",
  "description": "Ein wöchentliches Trainingsprogramm, das Laufen, Ganzkörper-Krafttraining und Brazilian Jiu-Jitsu kombiniert.",
  "provider": {
    "@type": "Person",
    "name": "Toby"
  },
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": "https://schema.org/OfflineMode",
    "courseWorkload": "P6D"
  }
};
---

<Layout title={pageTitle} description={pageDescription} jsonLd={courseSchema}>
  <main class="max-w-5xl mx-auto px-4 py-12">
    {/* Hero Section */}
    <section class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Trainingswoche</h1>
      <p class="text-lg text-neutral-400 max-w-2xl mx-auto">
        Eine typische Woche, in der ich meine drei Säulen ausbalanciere: Laufen, Ganzkörper-Krafttraining (ohne Beine) und BJJ.
        Alles ist priorisiert: <span class="text-blue-400 font-semibold">Laufen &gt; Krafttraining &gt; BJJ</span>
      </p>
    </section>

    {/* Stats Overview */}
    <section class="mb-12">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-blue-400 mb-1">{stats.workoutsPerWeek}</div>
          <div class="text-sm text-neutral-400">Workouts/Woche</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-white mb-1">{stats.restDays}</div>
          <div class="text-sm text-neutral-400">Ruhetage</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-green-400 mb-1">{stats.runningDays}</div>
          <div class="text-sm text-neutral-400">Lauftage</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-purple-400 mb-1">{stats.liftingDays}</div>
          <div class="text-sm text-neutral-400">Krafttrainingstage</div>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-orange-400 mb-1">{stats.bjjDays}</div>
          <div class="text-sm text-neutral-400">BJJ-Tage</div>
        </div>
      </div>
    </section>

    {/* Weekly Schedule Grid */}
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
        <span>📅</span> Wochenplan
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-7 gap-4">
        {weeklySchedule.map((day) => (
          <div class={`bg-neutral-900 border rounded-xl p-5 transition-all hover:scale-[1.02] ${
            day.priority === 0 
              ? 'border-neutral-800 opacity-70' 
              : day.priority === 1 
                ? 'border-blue-500/30 hover:border-blue-500/60' 
                : day.priority === 2 
                  ? 'border-purple-500/30 hover:border-purple-500/60'
                  : 'border-orange-500/30 hover:border-orange-500/60'
          }`}>
            <div class="flex items-center gap-2 mb-3">
              <span class="text-2xl">{day.icon}</span>
              <h3 class="text-lg font-bold text-white">{day.day}</h3>
            </div>
            <div class={`text-sm font-semibold mb-3 ${
              day.priority === 1 ? 'text-blue-400' : 
              day.priority === 2 ? 'text-purple-400' : 
              day.priority === 3 ? 'text-orange-400' : 'text-neutral-500'
            }`}>
              {day.focus}
            </div>
            <ul class="space-y-1">
              {day.exercises.map((ex) => (
                <li class="text-sm text-neutral-400 flex items-start gap-2">
                  <span class="text-neutral-600 mt-1">•</span>
                  <span>{ex}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    {/* Training Philosophy */}
    <section class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8">
      <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-2">
        <span>🧠</span> Trainingsphilosophie
      </h2>
      <div class="space-y-4">
        <p class="text-neutral-300 text-lg">
          Mein Training ist nach Priorität organisiert: <span class="text-blue-400 font-bold">Laufen &gt; Krafttraining &gt; BJJ</span>
        </p>
        <div class="grid md:grid-cols-3 gap-6 mt-6">
          <div class="bg-neutral-950 rounded-xl p-5 border border-blue-500/20">
            <div class="text-3xl mb-2">🏆</div>
            <h3 class="text-blue-400 font-bold mb-2">#1 Laufen</h3>
            <p class="text-neutral-400 text-sm">
              Ausdauer ist die Grundlage. Ob lockere Kilometer, Tempoläufe oder Intervalle – Laufen kommt zuerst. 
              Eine starke aerobe Basis unterstützt alles andere.
            </p>
          </div>
          <div class="bg-neutral-950 rounded-xl p-5 border border-purple-500/20">
            <div class="text-3xl mb-2">💪</div>
            <h3 class="text-purple-400 font-bold mb-2">#2 Krafttraining</h3>
            <p class="text-neutral-400 text-sm">
              Ganzkörpereinheiten ohne Beine (Speediance übernimmt die schweren Grundübungen). 
              Fokus auf Drücken, Ziehen und Hypertrophie. Drei Tage pro Woche.
            </p>
          </div>
          <div class="bg-neutral-950 rounded-xl p-5 border border-orange-500/20">
            <div class="text-3xl mb-2">🥋</div>
            <h3 class="text-orange-400 font-bold mb-2">#3 BJJ</h3>
            <p class="text-neutral-400 text-sm">
              Zwei Tage pro Woche für Technik und Rollen. Jiu-Jitsu hält mich demütig und sorgt für 
              hervorragende anaerobe Kondition und Technikarbeit.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
