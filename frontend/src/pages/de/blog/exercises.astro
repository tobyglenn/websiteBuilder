---
import Layout from '../../../layouts/Layout.astro';
import { getExercises } from '../../../data/exercises.js';

const { allExercises, grouped, totalCount } = getExercises();

const pageTitle = "Übungsbibliothek";
const pageDescription = "Durchsuche alle auf Speediance ausgeführten Übungen mit PR-Gewichten. Filtere nach Muskelgruppe: Rücken & Lat, Brust & Trizeps, Beine & Gesäß, Core & Arme.";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Welche Übung ist auf Speediance die schwerste?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Das Barbell Deadlift hat den höchsten PR mit 388 lbs, gefolgt vom Barbell Hip Thrust mit 240 lbs und dem Barbell Bench Press mit 232 lbs."
      }
    },
    {
      "@type": "Question",
      "name": "Wie viele einzigartige Übungen gibt es in der Übungsbibliothek?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Die Bibliothek enthält ${totalCount} einzigartige Übungen aus allen Speediance-Workout-Programmen.`
      }
    },
    {
      "@type": "Question",
      "name": "Welche Muskelgruppen kann ich mit Speediance trainieren?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Mit Speediance kannst du alle großen Muskelgruppen trainieren: Rücken & Lat, Brust & Trizeps, Beine & Gesäß sowie Core & Arme (einschließlich Bizeps, Schultern und Bauch)."
      }
    },
    {
      "@type": "Question",
      "name": "Welche Übung ist auf Speediance am besten für einen großen Brustaufbau?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Das Barbell Bench Press hat mit 232 lbs den höchsten Brust-PR. Weitere effektive Brustübungen sind Incline Barbell Bench Press (185 lbs PR) und Dual-Handle Bench Press (90 lbs PR)."
      }
    },
    {
      "@type": "Question",
      "name": "Kann ich meine persönlichen Rekorde auf Speediance verfolgen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ja! Speediance verfolgt automatisch dein 1-Rep-Maximum (1RM) für jede Übung. Diese Seite zeigt alle deine PRs, vom 388-lb-Deadlift bis zu kleineren Isolationsübungen."
      }
    }
  ]
};

const muscleGroups = ['Alle', 'Rücken & Lat', 'Brust & Trizeps', 'Beine & Gesäß', 'Core & Arme'];
---

<Layout 
  title={`${pageTitle} | Toby on Fitness Tech`}
  description={pageDescription}
  jsonLd={faqSchema}
>
  <section class="py-20 bg-neutral-950 border-b border-neutral-800">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Übungsbibliothek</h1>
      <p class="text-lg md:text-xl text-neutral-400 max-w-2xl mx-auto">
        Entdecke alle {totalCount} auf Speediance ausgeführten Übungen mit persönlichen Rekordgewichten.
      </p>
    </div>
  </section>

  <section class="py-8 bg-neutral-900 border-b border-neutral-800 sticky top-16 z-40">
    <div class="container mx-auto px-4">
      <div class="flex flex-wrap justify-center gap-3">
        {muscleGroups.map((group) => (
          <button
            data-filter={group}
            class={`filter-btn px-5 py-2.5 rounded-full text-sm font-medium transition-all ${
              group === 'Alle' 
                ? 'bg-blue-600 text-white' 
                : 'bg-neutral-800 text-neutral-300 hover:bg-neutral-700 hover:text-white border border-neutral-700'
            }`}
          >
            {group}
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-neutral-950">
    <div class="container mx-auto px-4">
      <div id="exerciseGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {allExercises.map((exercise) => (
          <div 
            data-group={exercise.muscleGroup}
            class="exercise-card bg-neutral-900 rounded-xl p-5 border border-neutral-800 hover:border-blue-500/50 transition-all hover:shadow-lg hover:shadow-blue-500/10"
          >
            <h3 class="text-white font-semibold text-lg mb-3 line-clamp-2">{exercise.name}</h3>
            
            <div class="mb-3">
              <span class={`inline-block px-3 py-1 rounded-full text-xs font-medium ${
                exercise.muscleGroup === 'Back & Lats' ? 'bg-blue-500/20 text-blue-400' :
                exercise.muscleGroup === 'Chest & Triceps' ? 'bg-red-500/20 text-red-400' :
                exercise.muscleGroup === 'Legs & Glutes' ? 'bg-green-500/20 text-green-400' :
                'bg-purple-500/20 text-purple-400'
              }`}>
                {exercise.muscleGroup === 'Back & Lats' ? 'Rücken & Lat' :
                 exercise.muscleGroup === 'Chest & Triceps' ? 'Brust & Trizeps' :
                 exercise.muscleGroup === 'Legs & Glutes' ? 'Beine & Gesäß' :
                 'Core & Arme'}
              </span>
            </div>
            
            <div class="flex items-baseline gap-2">
              <span class="text-2xl font-bold text-white">{exercise.prWeight || '—'}</span>
              <span class="text-sm text-neutral-400">lbs PR</span>
            </div>
          </div>
        ))}
      </div>
      
      <div id="noResults" class="hidden text-center py-16">
        <div class="text-6xl mb-4">🏋️</div>
        <p class="text-xl text-neutral-400">Keine Übungen für diese Kategorie gefunden.</p>
      </div>
    </div>
  </section>

  <section class="py-12 bg-neutral-900 border-t border-neutral-800">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-1">{grouped['Back & Lats']?.length || 0}</div>
          <div class="text-sm text-neutral-400">Rücken & Lat</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-red-400 mb-1">{grouped['Chest & Triceps']?.length || 0}</div>
          <div class="text-sm text-neutral-400">Brust & Trizeps</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-green-400 mb-1">{grouped['Legs & Glutes']?.length || 0}</div>
          <div class="text-sm text-neutral-400">Beine & Gesäß</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-purple-400 mb-1">{grouped['Core & Arms']?.length || 0}</div>
          <div class="text-sm text-neutral-400">Core & Arme</div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.exercise-card');
    const noResults = document.getElementById('noResults');
    
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');
        
        filterBtns.forEach(b => {
          b.classList.remove('bg-blue-600', 'text-white');
          b.classList.add('bg-neutral-800', 'text-neutral-300', 'border', 'border-neutral-700');
        });
        btn.classList.remove('bg-neutral-800', 'text-neutral-300', 'border', 'border-neutral-700');
        btn.classList.add('bg-blue-600', 'text-white');
        
        let visibleCount = 0;
        cards.forEach(card => {
          const group = card.getAttribute('data-group');
          const normalizedGroup = group === 'Back & Lats' ? 'Rücken & Lat' :
            group === 'Chest & Triceps' ? 'Brust & Trizeps' :
            group === 'Legs & Glutes' ? 'Beine & Gesäß' :
            group === 'Core & Arms' ? 'Core & Arme' : group;
          if (filter === 'Alle' || normalizedGroup === filter) {
            (card as HTMLElement).style.display = 'block';
            visibleCount++;
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });
        
        if (noResults) {
          if (visibleCount === 0) {
            noResults.classList.remove('hidden');
          } else {
            noResults.classList.add('hidden');
          }
        }
      });
    });
  });
</script>
