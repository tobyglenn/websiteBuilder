---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.jsx';
import { getHeatmapData } from '../../lib/trainingHeatmap.js';

const { heatmapData, stats, monthlyData } = getHeatmapData();
const CELL_SIZE = 12;
const GAP = 3;
const weeks = Math.ceil(heatmapData.length / 7);
const monthStarts = [];
let lastMonth = '';
heatmapData.forEach((d, i) => {
  const month = d.date.slice(0, 7);
  if (month !== lastMonth && d.dow === 0) {
    const weekIndex = Math.floor(i / 7);
    monthStarts.push({ label: d.date.slice(0, 7), x: weekIndex * (CELL_SIZE + GAP) });
    lastMonth = month;
  }
});
const BAR_GAP = 4;
const BAR_MAX_HEIGHT = 120;
const maxCount = Math.max(...monthlyData.map(m => m.count), 1);
const monthLabels = { '01': 'Jan', '02': 'Feb', '03': 'Mär', '04': 'Apr', '05': 'Mai', '06': 'Jun', '07': 'Jul', '08': 'Aug', '09': 'Sep', '10': 'Okt', '11': 'Nov', '12': 'Dez' };
const formattedMonthly = monthlyData.map(m => ({ ...m, label: `${monthLabels[m.month.slice(5)]} '${m.month.slice(2, 4)}`, height: (m.count / maxCount) * BAR_MAX_HEIGHT }));
const chartWidth = formattedMonthly.length * 40 + 20;
---

<Layout title="Trainingsprotokoll — Workout-Beständigkeit" description="Verfolge deine Trainingsbeständigkeit mit einer Heatmap zur Workout-Häufigkeit. Sieh dir deine Serien, Gesamt-Workouts und monatliche Aktivität an." canonicalPath="/training-log">
  <Header client:load currentPath="/training-log" />
  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12"><h1 class="text-4xl font-black tracking-tight mb-4">Trainings-<span class="text-blue-500">Beständigkeit</span></h1><p class="text-neutral-400 text-lg max-w-xl mx-auto">Deine Heatmap zur Workout-Häufigkeit. Jedes blaue Quadrat ist ein Tag, an dem du dich bewegt hast.</p></div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12"><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center"><div class="text-3xl font-black text-blue-500 mb-1">{stats.currentStreak}</div><div class="text-sm text-neutral-400">Aktuelle Serie</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center"><div class="text-3xl font-black text-blue-500 mb-1">{stats.longestStreak}</div><div class="text-sm text-neutral-400">Längste Serie</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center"><div class="text-3xl font-black text-blue-500 mb-1">{stats.totalDays}</div><div class="text-sm text-neutral-400">Gesamttage</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center"><div class="text-3xl font-black text-blue-500 mb-1">{stats.thisYear}</div><div class="text-sm text-neutral-400">Dieses Jahr</div></div></div>
    <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 mb-12"><h2 class="text-lg font-bold mb-6">Workout-Häufigkeit</h2><div class="overflow-x-auto"><div class="inline-grid gap-1" style={`grid-template-columns: repeat(${weeks}, ${CELL_SIZE}px); grid-template-rows: repeat(7, ${CELL_SIZE}px);`}>{heatmapData.map((day, i) => { const weekIndex = Math.floor(i / 7); const col = weekIndex; const row = day.dow; return (<div class={`rounded-sm transition-all hover:ring-2 hover:ring-blue-400/50 ${day.count > 0 ? 'bg-blue-500' : 'bg-neutral-800'}`} style={`width: ${CELL_SIZE}px; height: ${CELL_SIZE}px; grid-column: ${col + 1}; grid-row: ${row + 1};`} title={`${day.date}: ${day.count > 0 ? 'Workout' : 'Ruhetag'}`} />); })}</div></div><div class="mt-4 flex text-xs text-neutral-500">{monthStarts.map(m => (<span style={`margin-left: ${m.x * (CELL_SIZE + GAP) / (CELL_SIZE + GAP)}px;`}>{m.label.slice(5)}-{m.label.slice(2, 4)}</span>))}</div><div class="mt-6 flex items-center gap-2 text-xs text-neutral-500"><span>Weniger</span><div class="w-3 h-3 bg-neutral-800 rounded-sm"></div><div class="w-3 h-3 bg-blue-500 rounded-sm"></div><span>Mehr</span></div></div>
    <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6"><h2 class="text-lg font-bold mb-6">Monatliche Aktivität</h2><div class="flex items-end gap-1 h-32">{formattedMonthly.map(m => (<div class="flex-1 flex flex-col items-center"><div class="w-full bg-blue-500/80 hover:bg-blue-500 rounded-t transition-all" style={`height: ${m.height}px; max-width: 40px;`} title={`${m.label}: ${m.count} Workouts`}></div><span class="text-xs text-neutral-500 mt-2">{m.label}</span></div>))}</div></div>
    <div class="mt-8 text-center text-sm text-neutral-600">Daten von Garmin, Tonal und der vereinheitlichten Trainings-Zeitleiste</div>
  </main>
</Layout>
