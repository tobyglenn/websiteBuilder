---
import Layout from '../../layouts/Layout.astro';
import { CANONICAL_BLOG_POSTS } from '../../lib/blogPosts';
import { ArrowRight } from 'lucide-react';

function readTime(content = '') {
  const words = content.split(/\s+/).filter(Boolean).length;
  return `${Math.max(1, Math.round(words / 200))} Min. Lesezeit`;
}

function formatBlogDate(value) {
  const timestamp = Date.parse(value || '');
  if (Number.isNaN(timestamp)) return 'Ohne Datum';
  return new Date(timestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

// Filter blog posts related to BJJ
const bjjPosts = CANONICAL_BLOG_POSTS.filter(post => {
  const category = post.category?.toLowerCase() || '';
  const tags = post.tags?.map(t => t.toLowerCase()) || [];
  const title = post.title?.toLowerCase() || '';
  const excerpt = post.excerpt?.toLowerCase() || '';
  
  return category === 'bjj' || 
    tags.some(tag => tag === 'bjj' || tag === 'jiu-jitsu' || tag === 'jiu jitsu') ||
    title.includes('bjj') || title.includes('jiu-jitsu') || title.includes('jiu jitsu') ||
    excerpt.includes('bjj') || excerpt.includes('jiu-jitsu') || excerpt.includes('jiu jitsu');
}).slice(0, 6);

const totalBjjPosts = CANONICAL_BLOG_POSTS.filter(post => {
  const category = post.category?.toLowerCase() || '';
  const tags = post.tags?.map(t => t.toLowerCase()) || [];
  const title = post.title?.toLowerCase() || '';
  const excerpt = post.excerpt?.toLowerCase() || '';
  
  return category === 'bjj' || 
    tags.some(tag => tag === 'bjj' || tag === 'jiu-jitsu' || tag === 'jiu jitsu') ||
    title.includes('bjj') || title.includes('jiu-jitsu') || title.includes('jiu jitsu') ||
    excerpt.includes('bjj') || excerpt.includes('jiu-jitsu') || excerpt.includes('jiu jitsu');
}).length;

// BJJ Stats
const stats = {
  rank: "Braungurt",
  startedYear: 2023,
  competitions: 1,
  bjjDaysPerWeek: "2-3"
};

// Journey timeline data from /about page
const journeyTimeline = [
  {
    year: "2023",
    title: "BJJ-Reise begonnen",
    description: "Begann mit Brazilian Jiu-Jitsu als Teil einer Transformation von 242 auf 188 lb. Nutzte BJJ sowohl als körperlichen Ausgleich als auch als mentalen Anker während der Gewichtsabnahme.",
    highlight: true
  },
  {
    year: "2023",
    title: "Weißgurt",
    description: "Lernte die Grundlagen, Positionshierarchie und Basis-Submissions. Fokus auf Überleben und darauf, mich in der Guard wohlzufühlen.",
    highlight: false
  },
  {
    year: "2024",
    title: "Blaugurt",
    description: "Zum Blaugurt befördert. Begann, ein ausgefeilteres Guard-Spiel zu entwickeln und regelmäßig Wettkämpfe zu bestreiten.",
    highlight: false
  },
  {
    year: "2024-2025",
    title: "Lila Gurt",
    description: "Phase des fortgeschrittenen Zwischengurts. Verfeinerte weiter die Techniken und balancierte das Training mit Krafttraining.",
    highlight: false
  },
  {
    year: "2025",
    title: "Zum Braungurt befördert",
    description: "Erhielt den Braungurt bei einem regionalen Turnier mit einem dritten Platz und einer Reverse-Triangle-Submission.",
    highlight: true
  },
  {
    year: "Heute",
    title: "Braungurt - Aktuell",
    description: "Training 2-3x pro Woche in einer spezialisierten BJJ-Schule. Fokus auf Guard Retention, Submissions und darauf, die Kondition zu halten und gleichzeitig Kraft aufzubauen.",
    highlight: true
  }
];

// BJJ Philosophy
const philosophy = [
  {
    icon: "🛡️",
    title: "Sicherheit zuerst",
    description: "Ich priorisiere Verletzungsprävention über das Gewinnen von Runden. BJJ ist eine lebenslange Praxis — der Schutz von dir selbst und deinen Trainingspartnern steht vor jeder Submission."
  },
  {
    icon: "🔄",
    title: "Prozess vor Ergebnissen",
    description: "Sich auf Verbesserung statt auf das Gewinnen von Runden zu konzentrieren, führt zu schnellerem Fortschritt. Der Gürtel kommt als Nebenprodukt der Hingabe an das Handwerk."
  },
  {
    icon: "⏳",
    title: "Langfristige Denkweise",
    description: "Heute klug zu trainieren bedeutet, noch Jahrzehnte trainieren zu können. Ich passe die Intensität an die Regeneration an und höre auf meine WHOOP-Daten."
  },
  {
    icon: "🧠",
    title: "Technik vor Athletik",
    description: "BJJ belohnt Technik mehr als rohe Kraft. Selbst als größerer Praktizierender schlagen richtige Hebelwirkung und Positionierung jedes Mal die reine Stärke."
  }
];

// Notable moments
const notableMoments = [
  { year: "2023", event: "Mit BJJ begonnen - 242 lbs" },
  { year: "2023", event: "54-lb-Transformation abgeschlossen - 188 lbs" },
  { year: "2025", event: "Braungurt-Beförderung" },
  { year: "2025", event: "3. Platz regionales Turnier - Reverse Triangle" }
];

// JSON-LD Schema
const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Brazilian Jiu-Jitsu - Toby über Fitness Tech",
  "description": "Verfolge Tobys BJJ-Reise: Start 2023, Braungurt, Teilnahme an regionalen Turnieren, Training 2-3x pro Woche. Trainingsphilosophie, gelernte Lektionen und Fortschritt.",
  "url": "https://tobyonfitnesstech.com/bjj",
  "inLanguage": "en",
  "isPartOf": {
    "@id": "https://tobyonfitnesstech.com/#website"
  },
  "about": {
    "@type": "Person",
    "name": "Toby Peters",
    "description": "Braungurt im Brazilian Jiu-Jitsu, Training seit 2023"
  },
  "keywords": "BJJ, Brazilian Jiu-Jitsu, Jiu-Jitsu, Braungurt, Grappling, Kampfsport, Training, Wettkampf"
};
---

<Layout
  title="Brazilian Jiu-Jitsu - Braungurt-Reise | Toby über Fitness Tech"
  description="Verfolge Tobys BJJ-Reise: Start 2023, Braungurt, Teilnahme an regionalen Turnieren, Training 2-3x pro Woche. Trainingsphilosophie, gelernte Lektionen und Fortschritt."
  jsonLd={webPageSchema}
>
  <main class="min-h-screen bg-neutral-950 text-white">
    
    {/* ── Hero Section ─────────────────────────────────────────────────────── */}
    <section class="pt-28 pb-14 md:pt-36 md:pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-blue-900/10 via-transparent to-transparent pointer-events-none" />
      <div class="absolute right-0 top-0 w-72 h-72 bg-blue-600/5 rounded-full blur-3xl pointer-events-none" />
      <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-3xl">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-4">🥋 Brazilian Jiu-Jitsu</p>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
            Brazilian<br />
            <span class="text-blue-500">Jiu-Jitsu</span>
          </h2>
          <p class="text-xl text-neutral-400 mb-10 leading-relaxed max-w-2xl">
            Begonnen im Jahr 2023. Braungurt. Teilnahme an regionalen Turnieren.
            Die technische Reise, bei der Technik statt roher Kraft genutzt wird — mit Fokus auf Sicherheit und Langlebigkeit.
          </p>

          {/* Belt Display */}
          <div class="flex items-center gap-3 mb-8">
            <div class="text-4xl">🥋</div>
            <div>
              <div class="text-2xl font-bold text-white">{stats.rank}</div>
              <div class="text-sm text-neutral-400">Aktueller Rang</div>
            </div>
          </div>

          {/* Stat pills */}
          <div class="flex flex-wrap gap-3">
            <div class="flex items-center gap-2 bg-neutral-900 border border-neutral-800 rounded-full px-4 py-2">
              <span class="w-3 h-3 rounded-full bg-blue-500 inline-block flex-shrink-0"></span>
              <span class="text-sm font-semibold text-white">{stats.rank}</span>
            </div>
            <div class="flex items-center gap-2 bg-neutral-900 border border-neutral-800 rounded-full px-4 py-2">
              <span class="text-sm font-semibold text-white">Begonnen {stats.startedYear}</span>
            </div>
            <div class="flex items-center gap-2 bg-neutral-900 border border-neutral-800 rounded-full px-4 py-2">
              <span class="text-sm font-semibold text-white">{stats.competitions} Wettkampf</span>
            </div>
            <div class="flex items-center gap-2 bg-neutral-900 border border-neutral-800 rounded-full px-4 py-2">
              <span class="text-sm font-semibold text-white">{stats.bjjDaysPerWeek}x / Woche</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ── Stats Cards Row ─────────────────────────────────────────────────── */}
    <section class="py-12 bg-neutral-900/40 border-y border-neutral-800">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-colors text-center">
            <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-2">{stats.rank}</div>
            <div class="text-sm font-semibold text-neutral-400 uppercase tracking-wide">AKTUELLER GURT</div>
          </div>
          <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-colors text-center">
            <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-2">{stats.startedYear}</div>
            <div class="text-sm font-semibold text-neutral-400 uppercase tracking-wide">TRAINING SEIT</div>
          </div>
          <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-colors text-center">
            <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-2">{totalBjjPosts}</div>
            <div class="text-sm font-semibold text-neutral-400 uppercase tracking-wide">BJJ-BEITRÄGE</div>
          </div>
          <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800 hover:border-blue-500/50 transition-colors text-center">
            <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-2">3.</div>
            <div class="text-sm font-semibold text-neutral-400 uppercase tracking-wide">BESTE PLATZIERUNG</div>
          </div>
        </div>
      </div>
    </section>

    {/* ── Notable Moments ───────────────────────────────────────────────────── */}
    <section class="py-12 bg-neutral-900/20">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-4">Besondere Momente</p>
          <div class="flex flex-wrap gap-4">
            {notableMoments.map(moment => (
              <div class="flex items-center gap-2 bg-neutral-900 border border-neutral-800 rounded-full px-4 py-2">
                <span class="text-xs font-bold text-blue-400">{moment.year}</span>
                <span class="text-sm text-neutral-300">{moment.event}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* ── Journey Timeline Section ────────────────────────────────────────── */}
    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-2">Die Reise</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-10">BJJ-Fortschritt</h2>

          <div class="space-y-0">
            {journeyTimeline.map((entry, i) => (
              <div class="relative flex gap-6 md:gap-10">
                {/* Vertical line + belt dot */}
                <div class="flex flex-col items-center flex-shrink-0 w-10">
                  <div
                    class={`w-5 h-5 rounded-full border-4 border-neutral-950 flex-shrink-0 mt-1 ${entry.highlight ? 'ring-2 ring-blue-500 ring-offset-2 ring-offset-neutral-950' : ''}`}
                    style={`background-color: ${entry.highlight ? '#3b82f6' : '#4b5563'};`}
                  />
                  {i < journeyTimeline.length - 1 && (
                    <div class="flex-1 w-0.5 bg-neutral-800 mt-1 mb-0 min-h-[60px]" />
                  )}
                </div>

                {/* Content card */}
                <div class={`pb-8 flex-1 ${entry.highlight ? 'border border-blue-700/40 bg-blue-900/5 rounded-xl p-5 -mt-1' : ''}`}>
                  <div class="flex items-center gap-3 mb-1 flex-wrap">
                    <span class="text-xs font-bold uppercase tracking-wider px-2.5 py-0.5 rounded-full bg-blue-500/20 text-blue-400">
                      {entry.year}
                    </span>
                    {entry.highlight && (
                      <span class="text-xs bg-blue-500/20 text-blue-400 px-2 py-0.5 rounded-full font-semibold">Meilenstein</span>
                    )}
                  </div>
                  <h3 class="text-lg font-bold text-white mb-2">{entry.title}</h3>
                  <p class="text-sm text-neutral-400 leading-relaxed">{entry.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* ── Training Schedule ────────────────────────────────────────────────── */}
    <section class="py-16 md:py-20 bg-neutral-900/40 border-y border-neutral-800">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-2">Training</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-4">BJJ-Trainingsplan</h2>
          <p class="text-neutral-400 mb-8 leading-relaxed max-w-2xl">
            Ich trainiere BJJ 2-3 Mal pro Woche in einer spezialisierten BJJ-Schule. Jede Einheit umfasst Technikarbeit, Positionsdrills und Live-Sparring (Rolling). 
            Mein Training hat in meiner Fitness-Hierarchie die dritte Priorität: <span class="text-blue-400 font-semibold">Laufen &gt; Krafttraining &gt; BJJ</span>
          </p>
          
          <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
              <div>
                <div class="text-2xl font-bold text-blue-400">2-3x</div>
                <div class="text-sm text-neutral-400">pro Woche</div>
              </div>
              <div>
                <div class="text-2xl font-bold text-blue-400">Gi & No-Gi</div>
                <div class="text-sm text-neutral-400">Stile</div>
              </div>
              <div>
                <div class="text-2xl font-bold text-blue-400">Technik</div>
                <div class="text-sm text-neutral-400">+ Rolling</div>
              </div>
              <div>
                <div class="text-2xl font-bold text-blue-400">242</div>
                <div class="text-sm text-neutral-400">protokollierte Einheiten</div>
              </div>
            </div>
          </div>

          <div class="mt-6 text-center">
            <a 
              href="/training/" 
              class="inline-flex items-center gap-2 text-sm text-blue-500 hover:text-blue-400 transition-colors font-medium"
            >
              Komplette Trainingswoche ansehen
              <ArrowRight size={16} />
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* ── BJJ Philosophy Section ────────────────────────────────────────────── */}
    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-2">Philosophie</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-10">Ansatz für Jiu-Jitsu</h2>

          <div class="grid md:grid-cols-2 gap-4">
            {philosophy.map(item => (
              <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 hover:border-blue-500/40 transition-colors">
                <div class="text-3xl mb-4">{item.icon}</div>
                <h3 class="font-bold text-white mb-3">{item.title}</h3>
                <p class="text-sm text-neutral-400 leading-relaxed">{item.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* ── Related Blog Posts ───────────────────────────────────────────────── */}
    {bjjPosts.length > 0 && (
      <section class="py-16 md:py-20 bg-neutral-900/40 border-y border-neutral-800">
        <div class="container mx-auto px-4">
          <div class="max-w-4xl mx-auto">
            <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-2">Weiterlesen</p>
            <h2 class="text-3xl md:text-4xl font-bold mb-4">Ausgewählte BJJ-Beiträge</h2>
            <p class="text-neutral-400 mb-10 max-w-xl">
              Gedanken zu BJJ-Training, Technik, Sicherheit und der Reise in den Kampfkünsten.
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
              {bjjPosts.map((post) => (
                <a href={`/blog/${post.slug}/`} class="group block bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden hover:border-blue-500/50 transition-all">
                  {post.image && (
                    <div class="aspect-video overflow-hidden bg-neutral-950">
                      <img
                        src={post.image}
                        alt={post.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        loading="lazy"
                      />
                    </div>
                  )}
                  <div class="p-5">
                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold uppercase tracking-wide bg-blue-500/10 text-blue-400 border border-blue-500/20">
                      {post.category || 'BJJ'}
                    </span>
                    <h3 class="mt-3 text-lg font-bold text-white leading-snug group-hover:text-blue-400 transition-colors line-clamp-2">
                      {post.title}
                    </h3>
                    <div class="mt-2 text-xs text-neutral-500 flex items-center gap-2">
                      <span>{formatBlogDate(post.published_at)}</span>
                      <span>•</span>
                      <span>{readTime(post.content)}</span>
                    </div>
                    <p class="mt-3 text-sm text-neutral-400 leading-relaxed line-clamp-2">
                      {post.excerpt}
                    </p>
                  </div>
                </a>
              ))}
            </div>

            <div class="mt-8 text-center">
              <a 
                href="/blog/" 
                class="inline-flex items-center gap-2 text-sm text-blue-500 hover:text-blue-400 transition-colors font-medium"
              >
                Alle Blogbeiträge ansehen
                <ArrowRight size={16} />
              </a>
            </div>
          </div>
        </div>
      </section>
    )}

    {/* ── Resources Section ────────────────────────────────────────────────── */}
    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-4">Weiter erkunden</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Verwandte Seiten</h2>
          <p class="text-neutral-400 mb-8 leading-relaxed max-w-xl mx-auto">
            Entdecke das vollständige Trainings-Dashboard, die Zeitleiste und weitere Fitness-Inhalte.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a
              href="/training/"
              class="px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-semibold transition-colors text-sm"
            >
              Trainings-Dashboard
            </a>
            <a
              href="/timeline/"
              class="px-6 py-3 bg-neutral-800 hover:bg-neutral-700 text-white rounded-xl font-semibold transition-colors text-sm border border-neutral-700"
            >
              Zeitleiste
            </a>
            <a
              href="/running/"
              class="px-6 py-3 bg-neutral-800 hover:bg-neutral-700 text-white rounded-xl font-semibold transition-colors text-sm border border-neutral-700"
            >
              Laufstatistiken
            </a>
            <a
              href="/whoop/"
              class="px-6 py-3 bg-neutral-800 hover:bg-neutral-700 text-white rounded-xl font-semibold transition-colors text-sm border border-neutral-700"
            >
              WHOOP-Daten
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>
