---
import Layout from '../../layouts/Layout.astro';
import { getHeartRateData } from '../../data/heartRate.js';
const { stats, monthlyTrends, recentActivities } = getHeartRateData();
function fmtDur(seconds) { if (!seconds || seconds === 0) return '0m'; const h = Math.floor(seconds / 3600); const m = Math.floor((seconds % 3600) / 60); if (h > 0) return `${h}h ${m}m`; return `${m}m`; }
const zoneNames = { 1: 'Erholung', 2: 'Ausdauer', 3: 'Tempo', 4: 'Schwelle', 5: 'VO2 Max' };
const zoneColors = { 1: '#60a5fa', 2: '#4ade80', 3: '#facc15', 4: '#fb923c', 5: '#f87171' };
const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [ { "@type": "Question", "name": "Was bedeuten Herzfrequenzzonen?", "acceptedAnswer": { "@type": "Answer", "text": "Zone 1 (Erholung) ist sehr leichte Belastung, Zone 2 (Ausdauer) ist leichtes aerobes Training, Zone 3 (Tempo) ist moderates aerobes Training, Zone 4 (Schwelle) ist hartes anaerobes Training und Zone 5 (VO2 Max) ist maximale Belastung für Sprints." } }, { "@type": "Question", "name": "Was ist der aerobe Trainingseffekt?", "acceptedAnswer": { "@type": "Answer", "text": "Der aerobe Trainingseffekt von Garmin misst, wie dein Workout die Fähigkeit deines Körpers verbessert, Sauerstoff zu transportieren und zu nutzen. Werte reichen von 0,0 bis 5,0, wobei 1,0–1,9 Aufwärmen, 2,0–2,9 leicht, 3,0–3,9 aerob, 4,0–4,9 Schwelle und 5,0 Überlastung bedeutet." } }, { "@type": "Question", "name": "Was ist Trainingsbelastung?", "acceptedAnswer": { "@type": "Answer", "text": "Trainingsbelastung misst die Gesamtbeanspruchung deines Körpers während des Trainings. Sie wird anhand von Dauer und Intensität der Workouts berechnet. Garmin empfiehlt, im optimalen Bereich für dein Fitnessniveau zu bleiben, um dich zu verbessern, ohne zu übertrainieren." } } ] };
const donutW = 280, donutH = 280, donutR = 100, donutThick = 35; const cx = donutW / 2, cy = donutH / 2;
function polarToCartesian(cx, cy, r, angleInDegrees) { const angleInRadians = (angleInDegrees - 90) * Math.PI / 180.0; return { x: cx + (r * Math.cos(angleInRadians)), y: cy + (r * Math.sin(angleInRadians)) }; }
function describeArc(cx, cy, r, startAngle, endAngle) { const start = polarToCartesian(cx, cy, r, endAngle); const end = polarToCartesian(cx, cy, r, startAngle); const largeArcFlag = endAngle - startAngle <= 180 ? '0' : '1'; return `M ${start.x} ${start.y} A ${r} ${r} 0 ${largeArcFlag} 0 ${end.x} ${end.y}`; }
let currentAngle = 0; const zoneArcs = []; for (let z = 1; z <= 5; z++) { const pct = stats.zonePercentages[z]; if (pct > 0) { const angle = (pct / 100) * 360; const path = describeArc(cx, cy, donutR, currentAngle, currentAngle + angle); zoneArcs.push({ z, pct, path, color: zoneColors[z], startAngle: currentAngle, endAngle: currentAngle + angle }); currentAngle += angle; } }
const lineW = 600, lineH = 180, padL = 40, padR = 20, padT = 20, padB = 35; const hrValues = monthlyTrends.map(m => m.avgHR).filter(v => v > 0); const minHR = Math.min(...hrValues, 110); const maxHR = Math.max(...hrValues, 170); const yRange = maxHR - minHR; function hrToY(hr) { return lineH - padB - ((hr - minHR) / yRange) * (lineH - padT - padB); } const scaledLinePoints = monthlyTrends.map((m, i) => { const x = padL + (i / Math.max(1, monthlyTrends.length - 1)) * (lineW - padL - padR); const y = hrToY(m.avgHR); return { ...m, x, y }; }); let linePath = ''; scaledLinePoints.forEach((p, i) => { if (p.avgHR > 0) linePath += (i === 0 ? 'M' : 'L') + `${p.x},${p.y}`; });
---
<Layout title="Herzfrequenzzonen-Analyse — TobyOnFitnessTech" description="Verfolge deine kardiovaskuläre Fitness mit einer Analyse der Herzfrequenzzonen. Sieh Zeit in Zone 1–5, aeroben Trainingseffekt und monatliche HF-Trends aus Garmin-Daten." jsonLd={faqSchema}><main class="min-h-screen bg-neutral-950 text-white"><section class="pt-28 pb-14 md:pt-36 md:pb-20 relative overflow-hidden"><div class="absolute inset-0 bg-gradient-to-br from-red-900/10 via-transparent to-transparent pointer-events-none" /><div class="absolute right-0 top-0 w-64 h-64 bg-red-600/5 rounded-full blur-3xl pointer-events-none" /><div class="container mx-auto px-4 relative z-10"><div class="max-w-3xl"><p class="text-xs font-bold tracking-widest text-red-500 uppercase mb-4">Garmin Fenix 7 · Feb 2025 – Feb 2026</p><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-5 leading-tight">Herzfrequenz-<br /><span class="bg-gradient-to-r from-red-400 to-orange-500 bg-clip-text text-transparent">Zonenanalyse.</span></h2><p class="text-lg text-neutral-400 leading-relaxed max-w-2xl mb-8">Verfolge deine kardiovaskuläre Fitness mit detaillierten HF-Zonen-Aufschlüsselungen. Sieh, wie viel Zeit du in jeder Zone verbringst, und überwache deinen aeroben Trainingsfortschritt im Zeitverlauf.</p><div class="flex flex-wrap gap-3"><span class="px-4 py-1.5 rounded-full text-xs font-semibold bg-red-600/20 border border-red-500/30 text-red-400">❤️ {stats.totalActivities} Aktivitäten</span><span class="px-4 py-1.5 rounded-full text-xs font-semibold bg-neutral-800 border border-neutral-700 text-neutral-400">Max HF: {stats.maxHR} bpm</span></div></div></div></section><section class="py-10 border-t border-neutral-900"><div class="container mx-auto px-4"><div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3"><div class="bg-gradient-to-br from-red-900/30 to-red-900/10 border border-red-800/30 rounded-2xl p-5"><div class="text-3xl font-black text-red-400 mb-1">{stats.avgHR}</div><div class="text-xs text-neutral-500 uppercase tracking-wider font-semibold">Durchschnitts-HF</div><div class="text-xs text-neutral-600 mt-1">bpm</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5"><div class="text-3xl font-black text-white mb-1">{stats.maxHR}</div><div class="text-xs text-neutral-500 uppercase tracking-wider font-semibold">Max HF</div><div class="text-xs text-neutral-600 mt-1">aufgezeichnet</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5"><div class="text-3xl font-black text-white mb-1">{stats.avgAerobic}</div><div class="text-xs text-neutral-500 uppercase tracking-wider font-semibold">Ø Aerob</div><div class="text-xs text-neutral-600 mt-1">Trainingseffekt</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5"><div class="text-3xl font-black text-green-400 mb-1">{fmtDur(stats.zoneTotals[2])}</div><div class="text-xs text-neutral-500 uppercase tracking-wider font-semibold">Zone 2</div><div class="text-xs text-neutral-600 mt-1">Ausdauer</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5"><div class="text-3xl font-black text-yellow-400 mb-1">{fmtDur(stats.zoneTotals[3])}</div><div class="text-xs text-neutral-500 uppercase tracking-wider font-semibold">Zone 3</div><div class="text-xs text-neutral-600 mt-1">Tempo</div></div><div class="bg-gradient-to-br from-orange-900/30 to-orange-900/10 border border-orange-800/30 rounded-2xl p-5"><div class="text-3xl font-black text-orange-400 mb-1">{stats.totalTrainingLoad}</div><div class="text-xs text-neutral-500 uppercase tracking-wider font-semibold">Trainingsbelastung</div><div class="text-xs text-neutral-600 mt-1">gesamt</div></div></div></div></section><section class="py-14 border-t border-neutral-900"><div class="container mx-auto px-4"><h2 class="text-2xl font-bold mb-1">Verteilung der HF-Zonen</h2><p class="text-neutral-500 text-sm mb-8">Prozentualer Zeitanteil in jeder Herzfrequenzzone</p><div class="grid md:grid-cols-2 gap-8 items-center"><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 flex justify-center"><svg width={donutW} height={donutH} viewBox={`0 0 ${donutW} ${donutH}`} aria-label="Donut-Diagramm zur HF-Zonen-Verteilung"><circle cx={cx} cy={cy} r={donutR} fill="none" stroke="#262626" stroke-width={donutThick} />{zoneArcs.map(arc => (<path key={arc.z} d={arc.path} fill="none" stroke={arc.color} stroke-width={donutThick} stroke-linecap="round" />))}<text x={cx} y={cy - 10} text-anchor="middle" fill="#fff" font-size="28" font-weight="800">{stats.totalActivities}</text><text x={cx} y={cy + 15} text-anchor="middle" fill="#737373" font-size="12">Aktivitäten</text></svg></div><div class="space-y-4">{[5, 4, 3, 2, 1].map(z => (<div key={z} class="flex items-center justify-between bg-neutral-900 border border-neutral-800 rounded-xl p-4"><div class="flex items-center gap-3"><div class="w-4 h-4 rounded-full" style={`background-color: ${zoneColors[z]}`}></div><div><div class="font-semibold text-white">Zone {z}: {zoneNames[z]}</div><div class="text-xs text-neutral-500">{fmtDur(stats.zoneTotals[z])}</div></div></div><div class="text-xl font-black" style={`color: ${zoneColors[z]}`}>{stats.zonePercentages[z]}%</div></div>))}</div></div></div></section><section class="py-14 border-t border-neutral-900"><div class="container mx-auto px-4"><h2 class="text-2xl font-bold mb-1">Monatlicher HF-Trend</h2><p class="text-neutral-500 text-sm mb-8">Durchschnittliche Herzfrequenz im Zeitverlauf (2025–2026)</p><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 overflow-x-auto"><svg width={lineW} height={lineH} viewBox={`0 0 ${lineW} ${lineH}`} class="min-w-full" aria-label="Monatlicher Durchschnitts-HF-Trend">{[0,25,50,75,100].map(pct => { const y = lineH - padB - (pct / 100) * (lineH - padT - padB); const hr = Math.round(minHR + (pct / 100) * yRange); return (<g key={pct}><line x1={padL} y1={y} x2={lineW - padR} y2={y} stroke="#262626" stroke-width="1" /><text x={padL - 8} y={y + 3} fill="#525252" font-size="10" text-anchor="end">{hr}</text></g>); })}<path d={linePath} fill="none" stroke="#f87171" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" /><defs><linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#f87171" stop-opacity="0.3" /><stop offset="100%" stop-color="#f87171" stop-opacity="0" /></linearGradient></defs><path d={`${linePath} L${scaledLinePoints[scaledLinePoints.length - 1]?.x || 0},${lineH - padB} L${padL},${lineH - padB} Z`} fill="url(#areaGrad)" />{scaledLinePoints.map((p, i) => (<g key={p.month}><circle cx={p.x} cy={p.y} r="4" fill="#f87171" stroke="#1a1a1a" stroke-width="2" /><text x={p.x} y={lineH - 8} fill="#737373" font-size="9" text-anchor="middle">{p.label}</text></g>))}</svg></div><div class="flex gap-6 mt-4 text-xs text-neutral-500"><span><span class="inline-block w-3 h-3 rounded-full bg-red-400 mr-1.5 align-middle"></span>Durchschnitts-HF (bpm)</span></div></div></section><section class="py-14 border-t border-neutral-900"><div class="container mx-auto px-4"><h2 class="text-2xl font-bold mb-1">Letzte Aktivitäten</h2><p class="text-neutral-500 text-sm mb-8">Neueste Läufe mit Aufschlüsselung der Herzfrequenzzonen</p><div class="bg-neutral-900 border border-neutral-800 rounded-2xl overflow-hidden"><div class="hidden md:block overflow-x-auto"><table class="w-full text-sm"><thead><tr class="border-b border-neutral-800 text-xs text-neutral-500 uppercase tracking-wider"><th class="px-4 py-3 text-left">Datum</th><th class="px-4 py-3 text-left">Aktivität</th><th class="px-4 py-3 text-right">Distanz</th><th class="px-4 py-3 text-right">Zeit</th><th class="px-4 py-3 text-right">Ø HF</th><th class="px-4 py-3 text-right">Max HF</th><th class="px-4 py-3 text-left w-40">Zone %</th><th class="px-4 py-3 text-right">ATE</th><th class="px-4 py-3 text-right">Belastung</th></tr></thead><tbody>{recentActivities.map((r, i) => (<tr key={r.date + i} class="border-b border-neutral-800/50 hover:bg-neutral-800/30 transition-colors"><td class="px-4 py-3.5 text-neutral-400 whitespace-nowrap">{r.date}</td><td class="px-4 py-3.5"><span class="text-white font-medium">{r.name}</span></td><td class="px-4 py-3.5 text-right font-semibold">{r.distance}mi</td><td class="px-4 py-3.5 text-right text-neutral-400">{r.duration}</td><td class="px-4 py-3.5 text-right"><span class="text-red-400 font-semibold">{r.avgHR}</span></td><td class="px-4 py-3.5 text-right text-neutral-400">{r.maxHR}</td><td class="px-4 py-3.5"><div class="flex h-3 rounded-full overflow-hidden gap-px w-32">{r.zonePcts.z1 > 0 && <div class="bg-blue-400/80" style={`width:${r.zonePcts.z1}%`} title={`Z1: ${r.zonePcts.z1}%`}></div>}{r.zonePcts.z2 > 0 && <div class="bg-green-400/80" style={`width:${r.zonePcts.z2}%`} title={`Z2: ${r.zonePcts.z2}%`}></div>}{r.zonePcts.z3 > 0 && <div class="bg-yellow-400/80" style={`width:${r.zonePcts.z3}%`} title={`Z3: ${r.zonePcts.z3}%`}></div>}{r.zonePcts.z4 > 0 && <div class="bg-orange-400/80" style={`width:${r.zonePcts.z4}%`} title={`Z4: ${r.zonePcts.z4}%`}></div>}{r.zonePcts.z5 > 0 && <div class="bg-red-500/80" style={`width:${r.zonePcts.z5}%`} title={`Z5: ${r.zonePcts.z5}%`}></div>}</div></td><td class="px-4 py-3.5 text-right"><span class={`font-semibold ${r.aerobicEffect >= 3 ? 'text-green-400' : r.aerobicEffect >= 2 ? 'text-yellow-400' : 'text-neutral-400'}`}>{r.aerobicEffect}</span></td><td class="px-4 py-3.5 text-right text-neutral-400">{r.trainingLoad}</td></tr>))}</tbody></table></div><div class="md:hidden divide-y divide-neutral-800">{recentActivities.map((r, i) => (<div key={r.date + 'm' + i} class="p-4"><div class="flex justify-between items-start mb-2"><div><div class="font-semibold text-white">{r.name}</div><div class="text-xs text-neutral-500">{r.date}</div></div><div class="text-right"><div class="font-black text-lg text-white">{r.distance}mi</div><div class="text-xs text-neutral-400">{r.duration}</div></div></div><div class="flex gap-4 text-xs text-neutral-500 mb-2"><span>❤️ {r.avgHR} / {r.maxHR} bpm</span><span>ATE: {r.aerobicEffect}</span><span>Belastung: {r.trainingLoad}</span></div><div class="flex h-2 rounded-full overflow-hidden gap-px">{r.zonePcts.z1 > 0 && <div class="bg-blue-400/80" style={`width:${r.zonePcts.z1}%`}></div>}{r.zonePcts.z2 > 0 && <div class="bg-green-400/80" style={`width:${r.zonePcts.z2}%`}></div>}{r.zonePcts.z3 > 0 && <div class="bg-yellow-400/80" style={`width:${r.zonePcts.z3}%`}></div>}{r.zonePcts.z4 > 0 && <div class="bg-orange-400/80" style={`width:${r.zonePcts.z4}%`}></div>}{r.zonePcts.z5 > 0 && <div class="bg-red-500/80" style={`width:${r.zonePcts.z5}%`}></div>}</div></div>))}</div></div><div class="flex flex-wrap gap-4 mt-4 text-xs text-neutral-500"><span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-blue-400/80"></span>Z1 Erholung</span><span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-green-400/80"></span>Z2 Ausdauer</span><span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-yellow-400/80"></span>Z3 Tempo</span><span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-orange-400/80"></span>Z4 Schwelle</span><span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-red-500/80"></span>Z5 VO2 Max</span><span class="text-neutral-600 ml-auto">ATE = Aerober Trainingseffekt</span></div></div></section><section class="py-14 border-t border-neutral-900"><div class="container mx-auto px-4 text-center"><h2 class="text-2xl font-bold mb-3">Sieh dir deine vollständigen Laufdaten an</h2><p class="text-neutral-400 mb-8 max-w-lg mx-auto">Herzfrequenz ist nur eine Kennzahl. Sieh dir deinen kompletten Laufweg mit Pace, Distanz und PRs an.</p><div class="flex flex-wrap justify-center gap-4"><a href="/de/running/" class="px-6 py-3 bg-red-600 hover:bg-red-500 text-white font-semibold rounded-xl transition-colors">Vollständiges Laufprotokoll →</a><a href="/de/training/" class="px-6 py-3 bg-neutral-800 hover:bg-neutral-700 text-white font-semibold rounded-xl transition-colors">Trainingsübersicht →</a></div></div></section></main></Layout>
