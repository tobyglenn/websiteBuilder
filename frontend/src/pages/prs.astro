---
import Layout from '../layouts/Layout.astro';

const siteUrl = "https://tobyonfitnesstech.com";

// PR data extracted from Speediance dashboard
const prsByMuscle = {
  "Back & Lats": [
    { name: "Barbell Deadlift", weight: 388, unit: "lbs" },
    { name: "Kneeling Barbell Lat Pulldown", weight: 294, unit: "lbs" },
    { name: "Kneeling Barbell Reverse-Grip Lat Pulldown", weight: 280, unit: "lbs" },
    { name: "Seated Barbell Reverse-Grip Lat Pulldown", weight: 248, unit: "lbs" },
    { name: "Seated Barbell Wide Row", weight: 202, unit: "lbs" },
    { name: "Barbell Bent Over Row", weight: 198, unit: "lbs" },
    { name: "Seated Barbell Lat Pulldown", weight: 192, unit: "lbs" },
    { name: "Seated Barbell Row", weight: 192, unit: "lbs" },
    { name: "Seated Barbell Reverse-Grip Row", weight: 170, unit: "lbs" },
    { name: "Incline Barbell Straight Arm Pushdown", weight: 168, unit: "lbs" },
    { name: "Half Kneeling Single-Arm Row (L)", weight: 161, unit: "lbs" },
    { name: "Kneeling Single-Arm Lat Pulldown (L)", weight: 160, unit: "lbs" },
    { name: "Kneeling Single-Arm Lat Pulldown (R)", weight: 146, unit: "lbs" },
    { name: "Half Kneeling Single-Arm Row (R)", weight: 140, unit: "lbs" },
    { name: "Bent-Over Reverse-Grip Barbell Row", weight: 126, unit: "lbs" },
    { name: "Kneeling Dual-Handle Lat Pulldown", weight: 125, unit: "lbs" },
  ],
  "Chest & Triceps": [
    { name: "Barbell Bench Press", weight: 232, unit: "lbs" },
    { name: "Incline Barbell Bench Press", weight: 185, unit: "lbs" },
    { name: "Standing Barbell Triceps Push Down", weight: 170, unit: "lbs" },
  ],
  "Legs & Glutes": [
    { name: "Barbell Hip Thrust", weight: 240, unit: "lbs" },
    { name: "Barbell Split Squat (L)", weight: 144, unit: "lbs" },
    { name: "Barbell Split Squat (R)", weight: 144, unit: "lbs" },
    { name: "Barbell Stiff-Leg Deadlift", weight: 140, unit: "lbs" },
  ],
  "Core & Arms": [
    { name: "Standing High-to-Low Woodchops (R)", weight: 170, unit: "lbs" },
    { name: "Standing High-to-Low Woodchops (L)", weight: 134, unit: "lbs" },
  ],
};

const allPRs = [
  { name: "Barbell Deadlift", weight: 388, muscle: "Back & Lats" },
  { name: "Kneeling Barbell Lat Pulldown", weight: 294, muscle: "Back & Lats" },
  { name: "Kneeling Barbell Reverse-Grip Lat Pulldown", weight: 280, muscle: "Back & Lats" },
  { name: "Seated Barbell Reverse-Grip Lat Pulldown", weight: 248, muscle: "Back & Lats" },
  { name: "Barbell Hip Thrust", weight: 240, muscle: "Legs & Glutes" },
  { name: "Barbell Bench Press", weight: 232, muscle: "Chest & Triceps" },
  { name: "Seated Barbell Wide Row", weight: 202, muscle: "Back & Lats" },
  { name: "Barbell Bent Over Row", weight: 198, muscle: "Back & Lats" },
  { name: "Seated Barbell Lat Pulldown", weight: 192, muscle: "Back & Lats" },
  { name: "Seated Barbell Row", weight: 192, muscle: "Back & Lats" },
  { name: "Incline Barbell Bench Press", weight: 185, muscle: "Chest & Triceps" },
  { name: "Seated Barbell Reverse-Grip Row", weight: 170, muscle: "Back & Lats" },
  { name: "Standing Barbell Triceps Push Down", weight: 170, muscle: "Chest & Triceps" },
  { name: "Standing High-to-Low Woodchops (R)", weight: 170, muscle: "Core & Arms" },
  { name: "Incline Barbell Straight Arm Pushdown", weight: 168, muscle: "Back & Lats" },
];

const totalPRVolume = allPRs.reduce((sum, pr) => sum + pr.weight, 0);
const totalPRs = allPRs.length;

const profilePageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${siteUrl}/prs#collection`,
  "name": "PR Board - Toby on Fitness Tech",
  "description": `Personal records from Speediance training: ${totalPRs} PRs totaling ${totalPRVolume} lbs. Deadlift 388 lbs, Bench Press 232 lbs, and more.`,
  "url": `${siteUrl}/prs`,
  "inLanguage": "en",
  "isPartOf": { "@id": `${siteUrl}/#website` },
  "author": { "@id": `${siteUrl}/#toby` },
  "publisher": { "@id": `${siteUrl}/#organization` },
  "mainEntity": {
    "@type": "ItemList",
    "name": "Speediance Personal Records",
    "numberOfItems": totalPRs,
    "itemListElement": allPRs.map((pr, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "name": pr.name,
      "description": `${pr.weight} lbs - ${pr.muscle}`
    }))
  }
};
---

<Layout 
  title="PR Board - Toby on Fitness Tech"
  description={`Personal records from Speediance training: ${totalPRs} PRs totaling ${totalPRVolume} lbs. Deadlift 388 lbs, Bench Press 232 lbs, and more real data from 125+ workouts.`}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "PR Board", url: "/prs" }]}
  jsonLd={profilePageSchema}
>
  <main class="min-h-screen bg-neutral-950 text-white">
    {/* Hero */}
    <section class="pt-20 pb-16 md:pt-28 md:pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-blue-900/10 to-transparent pointer-events-none" />
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <span class="inline-flex items-center gap-2 bg-yellow-900/30 border border-yellow-500/30 px-4 py-1.5 rounded-full text-yellow-300 text-sm font-semibold mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-yellow-400"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
            PR Board
          </span>
          <h1 class="text-4xl md:text-6xl font-bold mb-6 leading-tight">
            Numbers Don't Lie.
          </h1>
          <p class="text-xl text-neutral-400 max-w-2xl mx-auto leading-relaxed mb-10">
            {totalPRs} personal records across {totalPRVolume.toLocaleString()} lbs of total weight. 
            Every rep tracked, every PR logged. Here's what {totalPRVolume.toLocaleString()} lbs of progressive overload looks like.
          </p>
          
          {/* Quick Stats */}
          <div class="grid grid-cols-3 gap-4 max-w-lg mx-auto">
            <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-4">
              <div class="text-2xl md:text-3xl font-black text-yellow-400">{totalPRs}</div>
              <div class="text-xs text-neutral-500 uppercase tracking-wider">Total PRs</div>
            </div>
            <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-4">
              <div class="text-2xl md:text-3xl font-black text-yellow-400">{totalPRVolume.toLocaleString()}</div>
              <div class="text-xs text-neutral-500 uppercase tracking-wider">Lbs Total</div>
            </div>
            <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-4">
              <div class="text-2xl md:text-3xl font-black text-yellow-400">388</div>
              <div class="text-xs text-neutral-500 uppercase tracking-wider">Heaviest</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Top 5 PRs - Hall of Fame */}
    <section class="py-12 bg-gradient-to-b from-neutral-950 to-neutral-900 border-t border-neutral-800">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-2xl font-bold mb-8 flex items-center gap-3">
            <span class="w-8 h-8 bg-yellow-500 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="black"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
            </span>
            Hall of Fame
          </h2>
          
          <div class="space-y-4">
            {allPRs.slice(0, 5).map((pr, index) => (
              <div class={`flex items-center gap-4 p-5 rounded-2xl border transition-all hover:scale-[1.01] ${
                index === 0 ? 'bg-gradient-to-r from-yellow-900/30 to-neutral-900 border-yellow-500/30' :
                index === 1 ? 'bg-neutral-900 border-neutral-700' :
                index === 2 ? 'bg-neutral-900 border-neutral-700' :
                'bg-neutral-900 border-neutral-800'
              }`}>
                <div class={`w-10 h-10 rounded-full flex items-center justify-center font-black text-lg ${
                  index === 0 ? 'bg-yellow-500 text-black' :
                  index === 1 ? 'bg-neutral-400 text-black' :
                  index === 2 ? 'bg-amber-700 text-white' :
                  'bg-neutral-800 text-neutral-400'
                }`}>
                  {index + 1}
                </div>
                <div class="flex-1">
                  <div class="font-bold text-white text-lg">{pr.name}</div>
                  <div class="text-sm text-neutral-500">{pr.muscle}</div>
                </div>
                <div class="text-right">
                  <div class="text-2xl md:text-3xl font-black text-white">{pr.weight}</div>
                  <div class="text-xs text-neutral-500 uppercase tracking-wider">lbs</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* All PRs by Category */}
    <section class="py-16 bg-neutral-900 border-t border-neutral-800">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-bold mb-10 text-center">All Records by Muscle Group</h2>
          
          <div class="space-y-12">
            {Object.entries(prsByMuscle).map(([muscle, prs]) => (
              <div>
                <h3 class="text-lg font-bold text-blue-400 mb-4 flex items-center gap-2">
                  <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                  {muscle}
                </h3>
                <div class="grid gap-3">
                  {prs.map((pr, index) => (
                    <div class="flex items-center justify-between p-4 bg-neutral-950 rounded-xl border border-neutral-800 hover:border-neutral-700 transition-colors">
                      <div class="flex items-center gap-4">
                        <span class="text-neutral-600 font-mono text-sm w-6">{index + 1}</span>
                        <span class="font-medium text-white">{pr.name}</span>
                      </div>
                      <div class="flex items-center gap-2">
                        <span class="text-xl font-bold text-white">{pr.weight}</span>
                        <span class="text-neutral-500 text-sm">{pr.unit}</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* Data Source */}
    <section class="py-12 border-t border-neutral-800">
      <div class="container mx-auto px-4">
        <div class="max-w-2xl mx-auto text-center">
          <p class="text-neutral-500 text-sm">
            All PRs tracked on <strong class="text-white">Speediance Gym Monster 2S</strong> since July 2025. 
            Total volume: <strong class="text-white">1,296,447 lbs</strong> across <strong class="text-white">125+ workouts</strong>.
          </p>
          <div class="mt-6 flex flex-wrap justify-center gap-3">
            <a href="/speediance" class="text-blue-400 hover:text-blue-300 text-sm font-medium">View Volume Data →</a>
            <span class="text-neutral-700">•</span>
            <a href="/training" class="text-blue-400 hover:text-blue-300 text-sm font-medium">Training Trends →</a>
            <span class="text-neutral-700">•</span>
            <a href="/videos" class="text-blue-400 hover:text-blue-300 text-sm font-medium">Watch PR Attempts →</a>
          </div>
        </div>
      </div>
    </section>

    {/* CTA */}
    <section class="py-16 bg-neutral-900 border-t border-neutral-800">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-2xl font-bold mb-4">Want to See the Full Training Data?</h2>
        <p class="text-neutral-400 mb-8 max-w-xl mx-auto">
          Explore every workout, monthly volume trends, and the complete transformation journey.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/training" class="px-8 py-3.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-full transition-all hover:scale-105">
            Training Dashboard
          </a>
          <a href="/speediance" class="px-8 py-3.5 bg-neutral-800 hover:bg-neutral-700 text-white border border-neutral-700 rounded-full transition-all font-medium">
            Speediance Stats
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
