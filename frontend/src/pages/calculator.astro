---
import Layout from '../layouts/Layout.astro';

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Calculate Your Daily Calories and Macros",
  "step": [
    {"@type": "HowToStep", "name": "Select gender", "text": "Choose male or female - this affects the BMR calculation"},
    {"@type": "HowToStep", "name": "Enter age", "text": "Input your age in years"},
    {"@type": "HowToStep", "name": "Enter height", "text": "Input your height in centimeters"},
    {"@type": "HowToStep", "name": "Enter weight", "text": "Input your weight in pounds"},
    {"@type": "HowToStep", "name": "Select activity level", "text": "Choose your activity level from sedentary to extra active"},
    {"@type": "HowToStep", "name": "Choose goal", "text": "Select Cut (lose fat), Maintain, or Bulk (build muscle)"},
    {"@type": "HowToStep", "name": "Calculate", "text": "Click the button to see your daily calorie target and macro breakdown"}
  ]
};
---

<Layout 
  title="Calorie & Macro Calculator | Toby on Fitness Tech"
  description="Calculate your daily calorie needs and macronutrient breakdown using the Mifflin-St Jeor equation. Perfect for cutting, maintaining, or bulking."
  jsonLd={howToSchema}
>
  <div class="min-h-screen bg-neutral-950 text-white py-12 px-4">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-bold text-center mb-2 bg-gradient-to-r from-blue-400 to-blue-600 bg-clip-text text-transparent">
        Calorie & Macro Calculator
      </h1>
      <p class="text-neutral-400 text-center mb-8">
        Calculate your TDEE and macros using the Mifflin-St St Jeor equation
      </p>
      
      <div class="text-center mb-4">
        <a href="/fitness-age" class="text-blue-400 hover:text-blue-300 text-sm underline underline-offset-4">
          Or calculate your Fitness Age →
        </a>
      </div>

      <div class="bg-neutral-900/50 border border-neutral-800 rounded-2xl p-6 md:p-8">
        <form id="calculator-form" class="space-y-6">
          <!-- Gender -->
          <div>
            <label class="block text-sm font-medium text-neutral-300 mb-2">Gender</label>
            <div class="flex gap-4">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="gender" value="male" checked class="w-4 h-4 accent-blue-500" />
                <span class="text-neutral-200">Male</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="gender" value="female" class="w-4 h-4 accent-blue-500" />
                <span class="text-neutral-200">Female</span>
              </label>
            </div>
          </div>

          <!-- Age -->
          <div>
            <label for="age" class="block text-sm font-medium text-neutral-300 mb-2">Age</label>
            <input 
              type="number" 
              id="age" 
              name="age" 
              value="35" 
              min="15" 
              max="100"
              class="w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-xl text-white focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
            />
          </div>

          <!-- Height -->
          <div>
            <label for="height" class="block text-sm font-medium text-neutral-300 mb-2">Height (cm)</label>
            <input 
              type="number" 
              id="height" 
              name="height" 
              value="180" 
              min="100" 
              max="250"
              class="w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-xl text-white focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
            />
          </div>

          <!-- Weight -->
          <div>
            <label for="weight" class="block text-sm font-medium text-neutral-300 mb-2">Weight (lbs)</label>
            <input 
              type="number" 
              id="weight" 
              name="weight" 
              value="215" 
              min="50" 
              max="500"
              class="w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-xl text-white focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
            />
          </div>

          <!-- Activity Level -->
          <div>
            <label for="activity" class="block text-sm font-medium text-neutral-300 mb-2">Activity Level</label>
            <select 
              id="activity" 
              name="activity"
              class="w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-xl text-white focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
            >
              <option value="1.2">Sedentary (little or no exercise)</option>
              <option value="1.375">Lightly Active (1-3 days/week)</option>
              <option value="1.55" selected>Moderately Active (3-5 days/week)</option>
              <option value="1.725">Very Active (6-7 days/week)</option>
              <option value="1.9">Extra Active (very hard exercise)</option>
            </select>
          </div>

          <!-- Goal -->
          <div>
            <label for="goal" class="block text-sm font-medium text-neutral-300 mb-2">Goal</label>
            <select 
              id="goal" 
              name="goal"
              class="w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-xl text-white focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
            >
              <option value="cut">Cut (Lose Fat -20%)</option>
              <option value="maintain" selected>Maintain Weight</option>
              <option value="bulk">Bulk (Build Muscle +10%)</option>
            </select>
          </div>

          <!-- Submit Button -->
          <button 
            type="submit"
            class="w-full py-4 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-xl transition-colors"
          >
            Calculate My Macros
          </button>
        </form>

        <!-- Results -->
        <div id="results" class="hidden mt-8 pt-8 border-t border-neutral-800">
          <h2 class="text-2xl font-bold text-center mb-6">Your Daily Targets</h2>
          
          <!-- Calories -->
          <div class="text-center mb-8">
            <p class="text-neutral-400 text-sm mb-1">Daily Calories</p>
            <p class="text-5xl font-bold text-blue-400" id="calories">0</p>
            <p class="text-neutral-500 text-sm mt-1" id="calories-breakdown">TDEE: 0</p>
          </div>

          <!-- Macros Grid -->
          <div class="grid grid-cols-3 gap-4">
            <!-- Protein -->
            <div class="bg-blue-500/10 border border-blue-500/30 rounded-xl p-4 text-center">
              <p class="text-blue-400 text-sm font-medium mb-1">Protein</p>
              <p class="text-2xl font-bold" id="protein">0g</p>
              <p class="text-neutral-500 text-xs mt-1" id="protein-pct">0%</p>
            </div>
            
            <!-- Fat -->
            <div class="bg-yellow-500/10 border border-yellow-500/30 rounded-xl p-4 text-center">
              <p class="text-yellow-400 text-sm font-medium mb-1">Fat</p>
              <p class="text-2xl font-bold" id="fat">0g</p>
              <p class="text-neutral-500 text-xs mt-1" id="fat-pct">0%</p>
            </div>
            
            <!-- Carbs -->
            <div class="bg-green-500/10 border border-green-500/30 rounded-xl p-4 text-center">
              <p class="text-green-400 text-sm font-medium mb-1">Carbs</p>
              <p class="text-2xl font-bold" id="carbs">0g</p>
              <p class="text-neutral-500 text-xs mt-1" id="carbs-pct">0%</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  document.getElementById('calculator-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);
    
    const gender = formData.get('gender') as string;
    const age = parseInt(formData.get('age') as string);
    const height = parseInt(formData.get('height') as string);
    const weightLbs = parseInt(formData.get('weight') as string);
    const activity = parseFloat(formData.get('activity') as string);
    const goal = formData.get('goal') as string;
    
    // Convert weight to kg
    const weightKg = weightLbs * 0.453592;
    
    // Calculate BMR using Mifflin-St Jeor
    let bmr: number;
    if (gender === 'male') {
      bmr = (10 * weightKg) + (6.25 * height) - (5 * age) + 5;
    } else {
      bmr = (10 * weightKg) + (6.25 * height) - (5 * age) - 161;
    }
    
    // Calculate TDEE
    const tdee = Math.round(bmr * activity);
    
    // Adjust for goal
    let targetCalories: number;
    let proteinPct: number, fatPct: number, carbsPct: number;
    
    switch (goal) {
      case 'cut':
        targetCalories = Math.round(tdee * 0.8); // 20% deficit
        proteinPct = 40;
        fatPct = 35;
        carbsPct = 25;
        break;
      case 'bulk':
        targetCalories = Math.round(tdee * 1.1); // 10% surplus
        proteinPct = 30;
        fatPct = 25;
        carbsPct = 45;
        break;
      default: // maintain
        targetCalories = tdee;
        proteinPct = 30;
        fatPct = 35;
        carbsPct = 35;
    }
    
    // Calculate macros (protein = 4 cal/g, fat = 9 cal/g, carbs = 4 cal/g)
    const proteinGrams = Math.round((targetCalories * proteinPct / 100) / 4);
    const fatGrams = Math.round((targetCalories * fatPct / 100) / 9);
    const carbsGrams = Math.round((targetCalories * carbsPct / 100) / 4);
    
    // Update UI
    document.getElementById('calories')!.textContent = targetCalories.toLocaleString();
    document.getElementById('calories-breakdown')!.textContent = `TDEE: ${tdee.toLocaleString()} cal/day`;
    document.getElementById('protein')!.textContent = `${proteinGrams}g`;
    document.getElementById('protein-pct')!.textContent = `${proteinPct}%`;
    document.getElementById('fat')!.textContent = `${fatGrams}g`;
    document.getElementById('fat-pct')!.textContent = `${fatPct}%`;
    document.getElementById('carbs')!.textContent = `${carbsGrams}g`;
    document.getElementById('carbs-pct')!.textContent = `${carbsPct}%`;
    
    // Show results
    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
