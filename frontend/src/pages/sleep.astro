---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.jsx';
import Footer from '../components/Footer.jsx';
import { Moon, Activity, Clock, Heart, Waves, BedDouble } from 'lucide-react';
import {
  getEightSleepData,
  LAST_30_NIGHTS,
  RECENT_NIGHTS,
  AVG_SLEEP_SCORE,
  AVG_SLEEP_QUALITY,
  AVG_HOURS_SLEPT,
  AVG_HRV,
  AVG_HEART_RATE,
  TOTAL_NIGHTS_TRACKED,
  LATEST_SLEEP_SCORE,
} from '../data/eightsleep.js';

const sleepData = getEightSleepData();

const chartWidth = 760;
const chartHeight = 240;
const chartPadding = 32;

function linePoints(data, key, maxVal = 100) {
  if (!data.length) return '';
  if (data.length === 1) {
    const x = chartPadding;
    const y = chartHeight - chartPadding - ((data[0][key] ?? 0) / maxVal) * (chartHeight - chartPadding * 2);
    return `${x},${y}`;
  }

  return data
    .map((d, i) => {
      const x = chartPadding + (i / (data.length - 1)) * (chartWidth - chartPadding * 2);
      const y = chartHeight - chartPadding - ((d[key] ?? 0) / maxVal) * (chartHeight - chartPadding * 2);
      return `${x},${y}`;
    })
    .join(' ');
}

const trendScorePoints = linePoints(LAST_30_NIGHTS, 'sleepScore', 100);
const qualityPoints = linePoints(LAST_30_NIGHTS, 'sleepQuality', 100);
const durationPoints = linePoints(LAST_30_NIGHTS, 'hoursSlept', 10);
---

<Layout
  title="Sleep Analytics | TobyOnFitnessTech"
  description="Real 8Sleep analytics: sleep scores, sleep quality, duration, HRV, and heart rate trends from Toby's historical sleep data."
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Sleep Analytics', url: '/sleep' }]}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: '8Sleep Pod',
    description: 'Sleep analytics dashboard based on historical 8Sleep data including sleep score, quality, duration, HRV, and heart rate trends.',
    brand: { '@type': 'Brand', name: '8Sleep' },
    category: 'Sleep Technology',
    url: 'https://tobyonfitnesstech.com/sleep',
  }}
>
  <Header client:load />

  <main class="bg-neutral-950 min-h-screen text-white pb-20">
    <section class="pt-24 pb-10 px-4">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-center gap-3 mb-4">
          <span class="px-3 py-1 bg-blue-500/20 text-blue-400 text-sm font-medium rounded-full flex items-center gap-2">
            <Moon class="w-4 h-4" />
            8Sleep Data
          </span>
          <span class="text-neutral-500 text-sm">{TOTAL_NIGHTS_TRACKED} nights tracked</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Sleep Analytics</h1>
        <p class="text-lg text-neutral-400 max-w-2xl">
          Historical 8Sleep metrics with score, quality, duration, HRV, and heart-rate trends from real nightly data.
        </p>
      </div>
    </section>

    <section class="px-4 pb-10">
      <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800">
          <div class="flex items-center gap-2 text-neutral-400 text-sm mb-2"><Activity class="w-4 h-4" />Avg Sleep Score</div>
          <div class="text-3xl font-bold text-white">{AVG_SLEEP_SCORE}<span class="text-lg text-neutral-500">/100</span></div>
        </div>
        <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800">
          <div class="flex items-center gap-2 text-neutral-400 text-sm mb-2"><Waves class="w-4 h-4" />Avg Sleep Quality</div>
          <div class="text-3xl font-bold text-white">{AVG_SLEEP_QUALITY}<span class="text-lg text-neutral-500">/100</span></div>
        </div>
        <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800">
          <div class="flex items-center gap-2 text-neutral-400 text-sm mb-2"><Clock class="w-4 h-4" />Avg Hours</div>
          <div class="text-3xl font-bold text-white">{AVG_HOURS_SLEPT}<span class="text-lg text-neutral-500">h</span></div>
        </div>
        <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800">
          <div class="flex items-center gap-2 text-neutral-400 text-sm mb-2"><Heart class="w-4 h-4" />Avg HRV</div>
          <div class="text-3xl font-bold text-white">{AVG_HRV}<span class="text-lg text-neutral-500">ms</span></div>
        </div>
        <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800">
          <div class="flex items-center gap-2 text-neutral-400 text-sm mb-2"><Heart class="w-4 h-4" />Avg Heart Rate</div>
          <div class="text-3xl font-bold text-white">{AVG_HEART_RATE}<span class="text-lg text-neutral-500">bpm</span></div>
        </div>
        <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800">
          <div class="flex items-center gap-2 text-neutral-400 text-sm mb-2"><BedDouble class="w-4 h-4" />Total Nights</div>
          <div class="text-3xl font-bold text-blue-400">{TOTAL_NIGHTS_TRACKED}</div>
          <div class="text-xs text-neutral-500 mt-1">Latest score: {LATEST_SLEEP_SCORE}</div>
        </div>
      </div>
    </section>

    <section class="px-4 pb-10">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-6">
        <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800">
          <h2 class="text-xl font-bold mb-5">Sleep Score Trend (Last 30 Days)</h2>
          {LAST_30_NIGHTS.length > 0 ? (
            <svg viewBox={`0 0 ${chartWidth} ${chartHeight}`} class="w-full h-auto">
              <line x1={chartPadding} y1={chartHeight - chartPadding} x2={chartWidth - chartPadding} y2={chartHeight - chartPadding} stroke="#333" stroke-width="1" />
              <line x1={chartPadding} y1={chartPadding} x2={chartPadding} y2={chartHeight - chartPadding} stroke="#333" stroke-width="1" />
              <polyline points={trendScorePoints} fill="none" stroke="#3B82F6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
              {LAST_30_NIGHTS.map((d, i) => {
                const x = chartPadding + (i / Math.max(LAST_30_NIGHTS.length - 1, 1)) * (chartWidth - chartPadding * 2);
                const y = chartHeight - chartPadding - ((d.sleepScore ?? 0) / 100) * (chartHeight - chartPadding * 2);
                return <circle cx={x} cy={y} r="2.5" fill="#3B82F6" />;
              })}
            </svg>
          ) : <p class="text-neutral-400">No data available.</p>}
        </div>

        <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800">
          <h2 class="text-xl font-bold mb-5">Sleep Quality vs Duration</h2>
          {LAST_30_NIGHTS.length > 0 ? (
            <svg viewBox={`0 0 ${chartWidth} ${chartHeight}`} class="w-full h-auto">
              <line x1={chartPadding} y1={chartHeight - chartPadding} x2={chartWidth - chartPadding} y2={chartHeight - chartPadding} stroke="#333" stroke-width="1" />
              <line x1={chartPadding} y1={chartPadding} x2={chartPadding} y2={chartHeight - chartPadding} stroke="#333" stroke-width="1" />
              <polyline points={qualityPoints} fill="none" stroke="#60A5FA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              <polyline points={durationPoints} fill="none" stroke="#22D3EE" stroke-width="2" stroke-dasharray="4 4" stroke-linecap="round" stroke-linejoin="round" />
              <text x={chartWidth - 170} y={chartPadding + 2} fill="#60A5FA" font-size="11">Sleep Quality</text>
              <text x={chartWidth - 170} y={chartPadding + 18} fill="#22D3EE" font-size="11">Duration (hours)</text>
            </svg>
          ) : <p class="text-neutral-400">No data available.</p>}
        </div>
      </div>
    </section>

    <section class="px-4 pb-10">
      <div class="max-w-6xl mx-auto bg-neutral-900 rounded-xl p-6 border border-neutral-800">
        <h2 class="text-xl font-bold mb-6">Recent Nights</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-neutral-800 text-neutral-400">
                <th class="text-left py-2 px-2">Date</th>
                <th class="text-left py-2 px-2">Score</th>
                <th class="text-left py-2 px-2">Quality</th>
                <th class="text-left py-2 px-2">Hours</th>
                <th class="text-left py-2 px-2">HRV</th>
              </tr>
            </thead>
            <tbody>
              {RECENT_NIGHTS.map((n) => (
                <tr class="border-b border-neutral-800/60">
                  <td class="py-2 px-2">{new Date(n.date + 'T12:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</td>
                  <td class="py-2 px-2 text-blue-400 font-semibold">{n.sleepScore ?? '—'}</td>
                  <td class="py-2 px-2">{n.sleepQuality ?? '—'}</td>
                  <td class="py-2 px-2">{n.hoursSlept != null ? `${n.hoursSlept.toFixed(2)}h` : '—'}</td>
                  <td class="py-2 px-2">{n.hrv != null ? `${n.hrv.toFixed(1)} ms` : '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
