import Layout from '../../layouts/Layout.astro';
const transformationData = { startWeight: 242, lowestWeight: 188, currentWeight: 218, startDate: "Julio 2023", lowestDate: "Enero 2024", currentDate: "Febrero 2026", durationMonths: 6, weightLost: 54, muscleGained: 30, milestones: [ { date: "Julio 2023", weight: 242, event: "Comenzó el viaje de transformación" }, { date: "Septiembre 2023", weight: 220, event: "Empieza la etapa con GLP-1" }, { date: "Enero 2024", weight: 188, event: "Se alcanzó el peso objetivo" }, { date: "Febrero 2024", weight: 195, event: "Comenzó la fase de ganancia muscular" }, { date: "Febrero 2026", weight: 218, event: "Peso actual (músculo + fuerza)" } ], stats: { speedianceVolume: 1296447, totalRuns: 111, totalMiles: 265.1, bjjMonths: 10 } };
const siteUrl = "https://tobyonfitnesstech.com";
const howToSchema = { "@context": "https://schema.org", "@type": "HowTo", "@id": `${siteUrl}/es/transformation#howto`, "name": "Cómo perder 54 lb en 6 meses: la transformación guiada por datos de Toby", "description": "Un relato paso a paso de cómo Toby Peters pasó de 242 lb a 188 lb usando medicación GLP-1, entrenamiento de fuerza con Speediance, reducción estratégica del cardio y seguimiento nutricional basado en datos.", "totalTime": "P6M", "image": `${siteUrl}/progress/progress_188.jpg`, "author": { "@type": "Person", "@id": `${siteUrl}/#toby`, "name": "Toby Glenn Peters" }, "supply": [ { "@type": "HowToSupply", "name": "Medicación GLP-1 (Semaglutida/Wegovy)" }, { "@type": "HowToSupply", "name": "Gimnasio inteligente en casa Speediance" }, { "@type": "HowToSupply", "name": "App de seguimiento de proteínas (Cronometer)" }, { "@type": "HowToSupply", "name": "Wearable fitness (Garmin o Whoop)" } ], "tool": [ { "@type": "HowToTool", "name": "Máquina de cable Speediance" }, { "@type": "HowToTool", "name": "Garmin Forerunner 265S" }, { "@type": "HowToTool", "name": "Eight Sleep Pod" } ], "step": [ { "@type": "HowToStep", "position": 1, "name": "Establece tu punto de partida con datos", "text": "Haz seguimiento de todo durante 2 semanas antes de hacer cambios. Usa un wearable fitness (Garmin, Whoop) para medir frecuencia cardíaca en reposo, HRV y gasto calórico estimado. Registra toda la comida en Cronometer. Esos datos serán tu base.", "url": `${siteUrl}/es/transformation` }, { "@type": "HowToStep", "position": 2, "name": "Empieza la medicación GLP-1 (si fue prescrita)", "text": "En septiembre de 2023, con 220 lb, Toby comenzó la medicación GLP-1 bajo supervisión médica. GLP-1 reduce el apetito y el ruido alimentario. Combinado con una dieta alta en proteína (180 g+ al día) y entrenamiento de resistencia, permite un déficit sostenible de 500-700 calorías diarias sin pérdida muscular.", "url": `${siteUrl}/es/transformation` }, { "@type": "HowToStep", "position": 3, "name": "Sustituye el cardio excesivo por entrenamiento de fuerza", "text": "Deja de hacer horas de cardio en zona 2: destruye la recuperación. En su lugar, haz 4-5 sesiones de fuerza por semana en Speediance o una máquina de cable similar. Enfócate en la sobrecarga progresiva: añade repeticiones o peso en cada sesión. Caminar más de 8.000 pasos al día cubre la quema calórica de baja intensidad sin afectar la recuperación.", "url": `${siteUrl}/es/transformation` }, { "@type": "HowToStep", "position": 4, "name": "Alcanza el peso objetivo y pasa a la ganancia muscular", "text": "Toby alcanzó 188 lb en enero de 2024, una pérdida de 54 lb en 6 meses. Cambia la estrategia de pérdida de grasa a ganancia muscular magra. Aumenta la proteína a 200 g+ al día. Empieza un programa push-pull-legs. Usa el seguimiento de repeticiones de Speediance para asegurar sobrecarga progresiva en cada sesión.", "url": `${siteUrl}/es/transformation`, "image": `${siteUrl}/progress/progress_188.jpg` }, { "@type": "HowToStep", "position": 5, "name": "Añade Brazilian Jiu-Jitsu para una condición física sostenible", "text": "BJJ 3 veces por semana quema 400-600 calorías por sesión, construye resistencia muscular funcional y aporta responsabilidad comunitaria. Después de más de 10 meses de entrenamiento, Toby alcanzó el cinturón marrón y pasó de 188 a 218 lb de músculo.", "url": `${siteUrl}/es/bjj` }, { "@type": "HowToStep", "position": 6, "name": "Usa los datos del sueño para optimizar la recuperación", "text": "El Eight Sleep Pod y el seguimiento de sueño de Garmin revelaron una recuperación crónicamente insuficiente (promedio de 5,8 horas). Prioriza 7-8 horas. El HRV (objetivo: 80+) es el mejor indicador único de que la recuperación va bien. Dormir mal frena la pérdida de grasa y mata la ganancia muscular.", "url": `${siteUrl}/es/transformation` } ] };
const insights = [ { title: "La decisión de usar GLP-1", content: "Tomé la decisión de usar medicación GLP-1 después de probar todo lo demás. Los datos mostraban que mi metabolismo no respondía a los métodos tradicionales." }, { title: "Por qué dejé el cardio", content: "El cardio no quemaba tantas calorías como pensaba. La zona 2 estaba destruyendo mi recuperación. En su lugar me enfoqué en fuerza y caminar." }, { title: "El factor TRT", content: "La terapia de reemplazo de testosterona me ayudó a mantener los niveles de energía durante el corte y a conservar músculo." }, { title: "Cómo ganar músculo sin engordar", content: "La clave fue la sobrecarga progresiva con Speediance. Pasé de 188 a 218 lb manteniéndome magro. Los datos no mienten." } ];
---
<Layout title="242 → 218: Mi viaje de transformación | TobyOnFitnessTech" description="De 242 lb a 188 lb y de vuelta a 218 lb de músculo. Sin atajos. Sin patrocinadores. Solo los datos detrás de mi transformación." breadcrumbs={[{ name: 'Inicio', url: '/es/' }, { name: 'Transformación', url: '/es/transformation' }]} jsonLd={howToSchema}><main class="min-h-screen bg-neutral-950 text-white"><section class="pt-20 pb-16 md:pt-28 md:pb-20 relative overflow-hidden"><div class="absolute inset-0 bg-gradient-to-b from-blue-900/10 to-transparent pointer-events-none" /><div class="container mx-auto px-4 relative z-10"><div class="max-w-4xl mx-auto text-center"><div class="inline-flex items-center gap-2 bg-blue-500/10 border border-blue-500/20 rounded-full px-4 py-1.5 mb-6"><span class="w-2 h-2 bg-blue-500 rounded-full animate-pulse"></span><span class="text-blue-400 text-sm font-medium">Los datos no mienten</span></div><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">242 → 188 → <span class="bg-gradient-to-r from-blue-500 to-purple-500 bg-clip-text text-transparent">218</span></h2><p class="text-xl text-neutral-400 mb-8 leading-relaxed max-w-2xl mx-auto">De sobrepeso a menos de 190, y luego de vuelta a 218, pero esta vez con músculo. Así fue exactamente como lo hice.</p><div class="flex flex-wrap justify-center gap-3"><div class="bg-neutral-900 border border-neutral-800 rounded-full px-5 py-2.5"><span class="text-blue-400 font-bold">−54 lb</span><span class="text-neutral-500 text-sm ml-2">perdidas</span></div><div class="bg-neutral-900 border border-neutral-800 rounded-full px-5 py-2.5"><span class="text-purple-400 font-bold">+30 lb</span><span class="text-neutral-500 text-sm ml-2">de músculo ganado</span></div><div class="bg-neutral-900 border border-neutral-800 rounded-full px-5 py-2.5"><span class="text-green-400 font-bold">1.29M</span><span class="text-neutral-500 text-sm ml-2">lb levantadas</span></div><div class="bg-neutral-900 border border-neutral-800 rounded-full px-5 py-2.5"><span class="text-orange-400 font-bold">265</span><span class="text-neutral-500 text-sm ml-2">millas corridas</span></div></div></div></div></section><section class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><h2 class="text-2xl font-bold mb-8 text-center">Peso a lo largo del tiempo</h2><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 md:p-8 overflow-x-auto"><svg viewBox="0 0 800 300" class="w-full min-w-[600px]" preserveAspectRatio="xMidYMid meet"><g stroke="#333" stroke-width="1" opacity="0.3"><line x1="80" y1="50" x2="750" y2="50" /><line x1="80" y1="100" x2="750" y2="100" /><line x1="80" y1="150" x2="750" y2="150" /><line x1="80" y1="200" x2="750" y2="200" /><line x1="80" y1="250" x2="750" y2="250" /></g><g fill="#666" font-size="12" font-family="system-ui"><text x="70" y="55" text-anchor="end">250</text><text x="70" y="105" text-anchor="end">225</text><text x="70" y="155" text-anchor="end">200</text><text x="70" y="205" text-anchor="end">175</text><text x="70" y="255" text-anchor="end">150</text></g><g fill="#666" font-size="12" font-family="system-ui"><text x="100" y="280" text-anchor="middle">Jul '23</text><text x="230" y="280" text-anchor="middle">Sep '23</text><text x="360" y="280" text-anchor="middle">Nov '23</text><text x="490" y="280" text-anchor="middle">Jan '24</text><text x="620" y="280" text-anchor="middle">Jun '24</text><text x="720" y="280" text-anchor="middle">Feb '26</text></g><path d="M 100,60 L 165,85 L 230,110 L 295,140 L 360,175 L 425,200 L 490,212 L 555,185 L 620,150 L 685,110 L 720,95" fill="none" stroke="url(#lineGradient)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" /><defs><linearGradient id="lineGradient" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#ef4444" /><stop offset="40%" stop-color="#3b82f6" /><stop offset="100%" stop-color="#a855f7" /></linearGradient></defs><g fill="#fff" stroke="#3b82f6" stroke-width="2"><circle cx="100" cy="60" r="6" /><circle cx="230" cy="110" r="6" /><circle cx="490" cy="212" r="6" /><circle cx="720" cy="95" r="6" /></g><g fill="#fff" font-size="11" font-family="system-ui"><text x="100" y="45" text-anchor="middle">242 lb</text><text x="230" y="100" text-anchor="middle">~210 lb</text><text x="490" y="230" text-anchor="middle">188 lb</text><text x="720" y="80" text-anchor="middle">218 lb</text></g></svg></div><div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-4"><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5"><div class="text-blue-400 text-sm font-medium mb-1">Fase 1</div><div class="text-xl font-bold mb-1">242 → 188</div><div class="text-neutral-500 text-sm">Julio '23 – Ene '24</div><div class="mt-3 text-neutral-400 text-sm">Perdí 54 lb usando GLP-1, entrenamiento de fuerza y nutrición guiada por datos.</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5"><div class="text-purple-400 text-sm font-medium mb-1">Transición</div><div class="text-xl font-bold mb-1">188 → 205</div><div class="text-neutral-500 text-sm">Ene '24 – Ago '24</div><div class="mt-3 text-neutral-400 text-sm">Empezó la ganancia muscular. Enfoque en sobrecarga progresiva con Speediance.</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5"><div class="text-green-400 text-sm font-medium mb-1">Fase 2</div><div class="text-xl font-bold mb-1">205 → 218</div><div class="text-neutral-500 text-sm">Ago '24 – Feb '26</div><div class="mt-3 text-neutral-400 text-sm">Fase de ganancia muscular. 1.29M lb levantadas. Cinturón marrón de BJJ alcanzado.</div></div></div></div></section><section class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><h2 class="text-2xl font-bold mb-8 text-center">Las imágenes</h2><div class="flex flex-col md:flex-row items-center justify-center gap-8"><div class="relative group"><div class="w-48 md:w-56 rounded-2xl overflow-hidden border border-neutral-800 shadow-xl"><img src="/progress/progress_230.jpg" alt="Peso inicial — 230 lb" class="w-full aspect-[3/4] object-cover object-top" loading="eager" /></div><div class="absolute bottom-3 left-0 right-0 flex justify-center"><span class="bg-black/80 backdrop-blur-sm text-neutral-300 text-sm font-bold px-4 py-1.5 rounded-full border border-neutral-700">230 lb</span></div><div class="absolute -top-3 -right-3 bg-red-600 text-white text-xs font-black px-3 py-1.5 rounded-full">INICIO</div></div><div class="flex flex-col items-center text-neutral-500"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-blue-500"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg><span class="text-xs mt-2">−54 lb</span></div><div class="relative group"><div class="w-48 md:w-56 rounded-2xl overflow-hidden border border-blue-500/40 shadow-xl shadow-blue-900/20"><img src="/progress/progress_188.jpg" alt="Peso más bajo — 188 lb" class="w-full aspect-[3/4] object-cover object-top" loading="eager" /></div><div class="absolute bottom-3 left-0 right-0 flex justify-center"><span class="bg-blue-600/90 backdrop-blur-sm text-white text-sm font-bold px-4 py-1.5 rounded-full">188 lb</span></div><div class="absolute -top-3 -right-3 bg-blue-600 text-white text-xs font-black px-3 py-1.5 rounded-full">MÍNIMO</div></div><div class="flex flex-col items-center text-neutral-500"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-purple-500"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg><span class="text-xs mt-2">+30 lb</span></div><div class="relative group"><div class="w-48 md:w-56 rounded-2xl overflow-hidden border border-purple-500/40 shadow-xl shadow-purple-900/20"><img src="/progress/progress_229.jpg" alt="Peso actual — 218 lb" class="w-full aspect-[3/4] object-cover object-top" loading="eager" /></div><div class="absolute bottom-3 left-0 right-0 flex justify-center"><span class="bg-purple-600/90 backdrop-blur-sm text-white text-sm font-bold px-4 py-1.5 rounded-full">229 lb</span></div><div class="absolute -top-3 -right-3 bg-purple-600 text-white text-xs font-black px-3 py-1.5 rounded-full">AHORA</div></div></div><p class="text-center text-neutral-600 text-sm mt-6">Izquierda: 230 lb (Julio 2023) · Centro: 188 lb (Ene 2024) · Derecha: 229 lb (Feb 2026)</p></div></section><section class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><h2 class="text-2xl font-bold mb-8 text-center">Lo que aprendí</h2><div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">{insights.map((insight, i) => (<div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6"><div class="flex items-center gap-3 mb-3"><div class="w-8 h-8 bg-blue-500/20 rounded-full flex items-center justify-center"><span class="text-blue-400 font-bold">{i + 1}</span></div><h3 class="text-lg font-bold">{insight.title}</h3></div><p class="text-neutral-400 leading-relaxed">{insight.content}</p></div>))}</div></div></section><section class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><h2 class="text-2xl font-bold mb-8 text-center">Los datos detrás de las ganancias</h2><div class="grid grid-cols-1 md:grid-cols-3 gap-6"><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center"><div class="text-5xl font-bold text-blue-500 mb-2">1.29M</div><div class="text-neutral-400 mb-1">lb levantadas en Speediance</div><div class="text-neutral-600 text-sm">125 entrenamientos</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center"><div class="text-5xl font-bold text-green-500 mb-2">265</div><div class="text-neutral-400 mb-1">millas corridas</div><div class="text-neutral-600 text-sm">111 carreras (84 al aire libre, 27 en cinta)</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center"><div class="text-5xl font-bold text-yellow-500 mb-2">10+</div><div class="text-neutral-400 mb-1">meses de entrenamiento de BJJ</div><div class="text-neutral-600 text-sm">Cinturón marrón alcanzado</div></div></div><div class="mt-8 text-center"><a href="/es/speediance/" class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 transition-colors">Ver todos los datos de Speediance<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a></div></div></section><section class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4"><h2 class="text-2xl font-bold mb-8 text-center">Conclusiones clave</h2><div class="max-w-2xl mx-auto"><ul class="space-y-4"><li class="flex gap-4"><div class="flex-shrink-0 w-6 h-6 bg-blue-500/20 rounded-full flex items-center justify-center mt-0.5"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg></div><div class="text-neutral-300"><strong class="text-white">GLP-1 funciona, pero no es magia.</strong> Combinado con fuerza y seguimiento de proteína, acelera la pérdida de grasa mientras preserva músculo.</div></li><li class="flex gap-4"><div class="flex-shrink-0 w-6 h-6 bg-blue-500/20 rounded-full flex items-center justify-center mt-0.5"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg></div><div class="text-neutral-300"><strong class="text-white">El cardio de zona 2 destruyó mi recuperación.</strong> Caminar y el movimiento de baja intensidad superan horas de cardio constante cuando levantas pesado.</div></li><li class="flex gap-4"><div class="flex-shrink-0 w-6 h-6 bg-blue-500/20 rounded-full flex items-center justify-center mt-0.5"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg></div><div class="text-neutral-300"><strong class="text-white">La sobrecarga progresiva lo es todo.</strong> El seguimiento por repeticiones de Speediance me mostró exactamente cuándo subir peso. Sin adivinar.</div></li><li class="flex gap-4"><div class="flex-shrink-0 w-6 h-6 bg-blue-500/20 rounded-full flex items-center justify-center mt-0.5"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg></div><div class="text-neutral-300"><strong class="text-white">El BJJ acelera la transformación.</strong> Rodar 3 veces por semana quema calorías, desarrolla resistencia muscular y te hace rendir cuentas ante una comunidad.</div></li></ul></div></div></section><section class="py-16 border-t border-neutral-900"><div class="container mx-auto px-4 text-center"><h2 class="text-2xl font-bold mb-4">¿Listo para empezar tu propio viaje?</h2><p class="text-neutral-400 mb-8 max-w-xl mx-auto">Todo lo que uso está documentado. Sin secretos. Sin productos patrocinados. Solo datos reales de entrenamiento real.</p><div class="flex flex-wrap justify-center gap-4"><a href="/es/gear/" class="bg-blue-600 hover:bg-blue-500 text-white font-semibold px-6 py-3 rounded-full transition-colors">Ver mi stack de equipo →</a><a href="/es/day/" class="bg-neutral-800 hover:bg-neutral-700 text-white font-semibold px-6 py-3 rounded-full transition-colors">Ver un día en los datos →</a><a href="/es/blog/" class="bg-neutral-800 hover:bg-neutral-700 text-white font-semibold px-6 py-3 rounded-full transition-colors">Leer la historia completa →</a></div></div></section></main></Layout>
