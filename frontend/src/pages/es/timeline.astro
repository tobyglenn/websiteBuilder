---
import Layout from '../../layouts/Layout.astro';
import { trainingStreak } from '../lib/trainingStats.js';

const siteUrl = "https://tobyonfitnesstech.com";

const milestones = [
  { category: "weight", title: "Peso inicial", date: "2023", description: "Comienzo del viaje de transformación fitness con 242 lbs", value: "242 lbs", icon: "scale", color: "orange" },
  { category: "weight", title: "Peso más bajo", date: "2023", description: "Se alcanzó el peso objetivo mediante entrenamiento guiado por datos", value: "188 lbs", icon: "scale", color: "orange", highlight: true },
  { category: "weight", title: "Peso actual", date: "2026", description: "Fase de ganancia muscular - más fuerte que nunca con 218 lbs", value: "218 lbs", icon: "scale", color: "orange" },
  { category: "lifting", title: "100K lbs levantadas", date: "2025", description: "Primer gran hito - 100.000 lbs de volumen total en Speediance", value: "100K lbs", icon: "dumbbell", color: "blue" },
  { category: "lifting", title: "500K lbs levantadas", date: "2025", description: "Medio millón de libras - la constancia está construyendo una fuerza seria", value: "500K lbs", icon: "dumbbell", color: "blue" },
  { category: "lifting", title: "1M lbs levantadas", date: "2025", description: "Siete cifras - se superó el umbral del millón de libras", value: "1M lbs", icon: "dumbbell", color: "blue" },
  { category: "lifting", title: "Volumen total actual", date: "2026", description: "Volumen total de por vida en todos los entrenamientos de Speediance", value: "1.29M lbs", icon: "dumbbell", color: "blue", highlight: true },
  { category: "running", title: "Primer 5K", date: "2025-03", description: "Primer 5K completado en cinta - 3.1 millas", value: "5K", icon: "running", color: "green" },
  { category: "running", title: "Primer 10K", date: "2025-04", description: "Subiendo a 6.2 millas - construyendo resistencia", value: "10K", icon: "running", color: "green" },
  { category: "running", title: "100 millas", date: "2025", description: "Tres cifras alcanzadas - 100 millas totales en Garmin", value: "100 mi", icon: "running", color: "green" },
  { category: "running", title: "Distancia actual", date: "2026", description: "Millas totales registradas en Garmin Fenix 7", value: "265 mi", icon: "running", color: "green", highlight: true },
  { category: "bjj", title: "Cinturón blanco", date: "Principios de 2010", description: "Comenzó el viaje en BJJ - se perdieron muchas luchas, pero se aprendieron los fundamentos", value: "Cinturón blanco", icon: "jiu-jitsu", color: "purple" },
  { category: "bjj", title: "Cinturón azul", date: "Mediados de 2010", description: "Compitió y ganó medallas - desarrolló un juego de dominio posicional", value: "Cinturón azul", icon: "jiu-jitsu", color: "purple" },
  { category: "bjj", title: "Cinturón morado", date: "Finales de 2010", description: "Pasó a entrenar a otros - guió a alumnos al éxito en competición", value: "Cinturón morado", icon: "jiu-jitsu", color: "purple" },
  { category: "bjj", title: "Cinturón marrón", date: "2023-Presente", description: "Volvió a competir - 3.er lugar en Gi/No-Gi/Absoluto, venció a cinturón negro en Gi", value: "Cinturón marrón", icon: "jiu-jitsu", color: "purple", highlight: true },
  { category: "streak", title: "Racha actual de entrenamiento", date: "2026", description: `Días consecutivos entrenando en Speediance`, value: `${trainingStreak} días`, icon: "flame", color: "amber" },
];

const personSchema = { "@context": "https://schema.org", "@type": "Person", "@id": `${siteUrl}/#person`, "name": "Toby Glenn Peters", "url": siteUrl, "jobTitle": "Entusiasta del fitness y reseñador de tecnología", "description": "Toby Glenn Peters pasó de 242 lbs a 188 lbs usando entrenamiento guiado por datos, Speediance, Garmin y Brazilian Jiu-Jitsu." };
const articleSchema = { "@context": "https://schema.org", "@type": "Article", "headline": "Cronología de hitos fitness - 265 millas, 1.29M lbs, cinturón marrón", "description": "Sigue el viaje fitness de 242 lbs a 188 lbs y luego a 218 lbs. 1.29M lbs levantadas, 265 millas corridas, cinturón marrón en BJJ.", "author": personSchema, "datePublished": "2026-03-06", "url": `${siteUrl}/timeline` };
const allSchemas = [personSchema, articleSchema];
const iconMap = { scale: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="M7 21h10"/><path d="M12 3v18"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/></svg>`, dumbbell: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6.5 6.5 11 11"/><path d="m21 21-1-1"/><path d="m3 3 1 1"/><path d="m18 22 4-4"/><path d="m2 6 4-4"/><path d="m3 10 7-7"/><path d="m14 21 7-7"/></svg>`, running: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="3"/><path d="M4 17v3a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2v-3"/><path d="m9 14 3-3 3 3"/><path d="M12 12v5"/></svg>`, "jiu-jitsu": `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="3"/><path d="M9 12l3-3 3 3"/><path d="M14 9a2 2 0 0 1-2 2H9"/><path d="M12 14v5"/><path d="M12 19h4a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-4"/></svg>`, flame: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>` };
const colorMap = { blue: { bg: "bg-blue-500/10", border: "border-blue-500", text: "text-blue-400", glow: "shadow-blue-500/20" }, green: { bg: "bg-green-500/10", border: "border-green-500", text: "text-green-400", glow: "shadow-green-500/20" }, purple: { bg: "bg-purple-500/10", border: "border-purple-500", text: "text-purple-400", glow: "shadow-purple-500/20" }, orange: { bg: "bg-orange-500/10", border: "border-orange-500", text: "text-orange-400", glow: "shadow-orange-500/20" }, amber: { bg: "bg-amber-500/10", border: "border-amber-500", text: "text-amber-400", glow: "shadow-amber-500/20" } };
---
<Layout title="Cronología fitness - Hitos y progreso" description="Sigue el viaje fitness: 242→188→218 lbs, 1.29M lbs levantadas, 265 millas corridas, cinturón marrón en BJJ. Hitos de entrenamiento guiado por datos." jsonLd={allSchemas}><section class="relative py-20 overflow-hidden"><div class="absolute inset-0 bg-gradient-to-b from-neutral-900/50 to-neutral-950"></div><div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><div class="text-center"><h1 class="text-4xl md:text-6xl font-bold text-white mb-4">Cronología <span class="text-blue-400">fitness</span></h1><p class="text-xl text-neutral-400 max-w-2xl mx-auto mb-8">De 242 lbs a cinturón marrón — cada hito registrado, cada PR anotado.</p><div class="flex flex-wrap justify-center gap-4"><a href="/running/" class="px-6 py-3 bg-green-500/10 border border-green-500/30 rounded-lg text-green-400 hover:bg-green-500/20 transition-all"><span class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="3"/><path d="M4 17v3a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2v-3"/><path d="m9 14 3-3 3 3"/><path d="M12 12v5"/></svg>Correr</span></a><a href="/speediance/" class="px-6 py-3 bg-blue-500/10 border border-blue-500/30 rounded-lg text-blue-400 hover:bg-blue-500/20 transition-all"><span class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6.5 6.5 11 11"/><path d="m21 21-1-1"/><path d="m3 3 1 1"/><path d="m18 22 4-4"/><path d="m2 6 4-4"/><path d="m3 10 7-7"/><path d="m14 21 7-7"/></svg>Speediance</span></a><a href="/bjj/" class="px-6 py-3 bg-purple-500/10 border border-purple-500/30 rounded-lg text-purple-400 hover:bg-purple-500/20 transition-all"><span class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="3"/><path d="M9 12l3-3 3 3"/><path d="M14 9a2 2 0 0 1-2 2H9"/><path d="M12 14v5"/><path d="M12 19h4a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-4"/></svg>BJJ</span></a><a href="/prs/" class="px-6 py-3 bg-amber-500/10 border border-amber-500/30 rounded-lg text-amber-400 hover:bg-amber-500/20 transition-all"><span class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4"/><path d="m15.4 4.6-2.8 3.5"/><path d="m8.4 4.6 2.8 3.5"/><path d="m15.4 15.4-2.8-3.5"/><path d="m8.4 15.4 2.8-3.5"/><path d="M12 14v4"/><path d="M4 12h4"/><path d="M16 12h4"/><path d="M8 20v2"/><path d="M16 20v2"/><path d="M8 4v2"/><path d="M16 4v2"/></svg>PRs</span></a></div></div></div></section><section class="py-12 border-y border-neutral-800"><div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><div class="grid grid-cols-2 md:grid-cols-4 gap-6"><div class="text-center"><div class="text-3xl md:text-4xl font-bold text-white mb-1">218</div><div class="text-sm text-neutral-400">lbs actuales</div></div><div class="text-center"><div class="text-3xl md:text-4xl font-bold text-blue-400 mb-1">1.29M</div><div class="text-sm text-neutral-400">lbs levantadas</div></div><div class="text-center"><div class="text-3xl md:text-4xl font-bold text-green-400 mb-1">265</div><div class="text-sm text-neutral-400">Millas corridas</div></div><div class="text-center"><div class="text-3xl md:text-4xl font-bold text-purple-400 mb-1">Marrón</div><div class="text-sm text-neutral-400">Cinturón BJJ</div></div></div></div></section><section class="py-20 bg-neutral-950"><div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><div class="flex flex-wrap justify-center gap-6 mb-16"><div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-orange-500"></div><span class="text-neutral-400 text-sm">Viaje de peso</span></div><div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-blue-500"></div><span class="text-neutral-400 text-sm">Levantamiento</span></div><div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-green-500"></div><span class="text-neutral-400 text-sm">Running</span></div><div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-purple-500"></div><span class="text-neutral-400 text-sm">BJJ</span></div><div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-amber-500"></div><span class="text-neutral-400 text-sm">Rachas</span></div></div><div class="relative"><div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-neutral-800 via-neutral-700 to-neutral-800 transform md:-translate-x-1/2"></div><div class="space-y-12">{milestones.map((milestone, index) => { const colors = colorMap[milestone.color]; const isEven = index % 2 === 0; return (<div class={`relative flex items-center ${isEven ? 'md:flex-row' : 'md:flex-row-reverse'}`}><div class="absolute left-4 md:left-1/2 w-4 h-4 rounded-full bg-neutral-950 border-2 border-neutral-600 transform -translate-x-1/2 z-10"></div><div class={`ml-12 md:ml-0 md:w-[calc(50%-2rem)] ${isEven ? 'md:mr-auto md:pr-12' : 'md:ml-auto md:pl-12'}`}><div class={`p-6 rounded-xl border ${colors.border} ${colors.bg} backdrop-blur-sm transition-all hover:scale-[1.02] ${milestone.highlight ? `shadow-lg ${colors.glow}` : ''}`}><div class="flex items-start justify-between mb-3"><div class={`p-2 rounded-lg ${colors.bg} ${colors.text}`} set:html={iconMap[milestone.icon]}></div><span class={`text-2xl font-bold ${colors.text}`}>{milestone.value}</span></div><h3 class={`text-lg font-semibold ${colors.text} mb-1`}>{milestone.title}</h3><div class="text-sm text-neutral-500 mb-2">{milestone.date}</div><p class="text-neutral-300 text-sm">{milestone.description}</p></div></div><div class="hidden md:block md:w-[calc(50%-2rem)]"></div></div>); })}</div></div></div></section><section class="py-20 bg-neutral-900"><div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center"><h2 class="text-3xl font-bold text-white mb-4">Comienza tu propio viaje</h2><p class="text-neutral-400 mb-8">Haz seguimiento de tu progreso con datos. Cada repetición, cada milla, cada roll cuenta.</p><div class="flex flex-wrap justify-center gap-4"><a href="/training/" class="px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-semibold transition-all">Resumen de entrenamiento</a><a href="/transformation/" class="px-8 py-4 bg-neutral-800 hover:bg-neutral-700 text-white rounded-lg font-semibold transition-all">Ver fotos de progreso</a></div></div></section></Layout><style>@keyframes fadeInUp { from { opacity: 0; transform: translateY(20px);} to { opacity: 1; transform: translateY(0);} } .animate-fade-in-up { animation: fadeInUp 0.6s ease-out forwards; }</style>
