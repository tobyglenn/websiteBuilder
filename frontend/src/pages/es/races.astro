---
import Layout from '../../layouts/Layout.astro';
import { getRaceData, getPRs, getStats } from '../../data/races.js';

const races = getRaceData();
const prs = getPRs();
const stats = getStats();

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "¿Cuáles son las distancias de carrera de Toby?", "acceptedAnswer": { "@type": "Answer", "text": "Toby registra carreras de 5K, 10K, media maratón y maratón mediante Garmin Fenix 7. Los datos actuales incluyen carreras de entrenamiento de distancia 5K." } },
    { "@type": "Question", "name": "¿Cuál es el PR de 5K de Toby?", "acceptedAnswer": { "@type": "Answer", "text": prs['5K'] ? `La carrera más rápida de Toby en distancia 5K se completó a un ritmo de ${prs['5K'].pace}/milla el ${prs['5K'].date}.` : "Aún no hay datos de 5K registrados." } },
    { "@type": "Question", "name": "¿Toby corre carreras oficiales?", "acceptedAnswer": { "@type": "Answer", "text": "Estas entradas representan carreras de entrenamiento registradas por Garmin a distancias de carrera, no eventos oficiales. Reflejan datos reales de rendimiento de sesiones al aire libre y en cinta." } }
  ]
};
const distanceCategories = ['5K', '10K', 'Half Marathon', 'Marathon'];
const categoryIcons: Record<string, string> = { '5K': '🏃', '10K': '⚡', 'Half Marathon': '🎯', 'Marathon': '🏆' };
const categoryDistances: Record<string, string> = { '5K': '3.1 mi', '10K': '6.2 mi', 'Half Marathon': '13.1 mi', 'Marathon': '26.2 mi' };
---
<Layout title="Resultados de carreras — TobyOnFitnessTech" description="Carreras de distancia registradas con Garmin Fenix 7. PRs de ritmo en 5K, 10K, media maratón e historial completo con datos de FC." jsonLd={faqSchema}><main class="min-h-screen bg-neutral-950 text-white"><section class="pt-28 pb-14 md:pt-36 md:pb-20 relative overflow-hidden"><div class="absolute inset-0 bg-gradient-to-br from-blue-900/10 via-transparent to-transparent pointer-events-none" /><div class="absolute right-0 top-0 w-64 h-64 bg-blue-600/5 rounded-full blur-3xl pointer-events-none" /><div class="container mx-auto px-4 relative z-10"><div class="max-w-3xl"><p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-4">Garmin Fenix 7 · Distancias de carrera</p><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-5 leading-tight">Resultados de carrera.<br /><span class="bg-gradient-to-r from-blue-400 to-purple-500 bg-clip-text text-transparent">Cada milla registrada.</span></h2><p class="text-lg text-neutral-400 leading-relaxed max-w-2xl mb-8">Todas las carreras de distancia registradas con GPS de Garmin. Ritmo real, FC real — sin cherry-picking.</p><div class="flex flex-wrap gap-3"><span class="px-4 py-1.5 rounded-full text-xs font-semibold bg-blue-600/20 border border-blue-500/30 text-blue-400">🏃 {stats.totalRaces} carreras de distancia</span><span class="px-4 py-1.5 rounded-full text-xs font-semibold bg-neutral-800 border border-neutral-700 text-neutral-400">5K: {stats.byCategory['5K']}</span><span class="px-4 py-1.5 rounded-full text-xs font-semibold bg-neutral-800 border border-neutral-700 text-neutral-400">10K: {stats.byCategory['10K']}</span><span class="px-4 py-1.5 rounded-full text-xs font-semibold bg-neutral-800 border border-neutral-700 text-neutral-400">Media: {stats.byCategory['Half Marathon']}</span></div></div></div></section>{Object.keys(prs).length > 0 && (<section class="py-12 border-t border-neutral-800"><div class="container mx-auto px-4"><h2 class="text-2xl font-bold mb-8 flex items-center gap-2">🥇 <span>Récords personales</span></h2><div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">{distanceCategories.map(cat => prs[cat] && (<div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5 hover:border-blue-500/40 transition-colors"><div class="flex items-center justify-between mb-3"><span class="text-2xl">{categoryIcons[cat]}</span><span class="text-xs font-semibold text-blue-400 bg-blue-600/10 border border-blue-500/20 px-2 py-0.5 rounded-full">{categoryDistances[cat]}</span></div><p class="text-xs text-neutral-500 uppercase tracking-widest mb-1">PR de {cat}</p><p class="text-3xl font-bold text-white mb-1">{prs[cat].pace}<span class="text-sm font-normal text-neutral-400">/mi</span></p><p class="text-sm text-neutral-400 mb-2">Final: {prs[cat].duration}</p><p class="text-xs text-neutral-500 truncate" title={prs[cat].name}>{prs[cat].name}</p><p class="text-xs text-neutral-600 mt-1">{prs[cat].date} · {prs[cat].type}</p></div>))}</div></div></section>)}<section class="py-12 border-t border-neutral-800"><div class="container mx-auto px-4"><h2 class="text-2xl font-bold mb-8 flex items-center gap-2">📋 <span>Historial de carreras</span><span class="text-sm font-normal text-neutral-500 ml-2">({races.length} entradas)</span></h2>{races.length === 0 ? (<p class="text-neutral-500 text-center py-12">Aún no se encontraron carreras de distancia.</p>) : (<div class="overflow-x-auto rounded-xl border border-neutral-800"><table class="w-full text-sm"><thead><tr class="bg-neutral-900 text-neutral-400 text-xs uppercase tracking-wider"><th class="px-4 py-3 text-left">Fecha</th><th class="px-4 py-3 text-left">Nombre</th><th class="px-4 py-3 text-center">Dist</th><th class="px-4 py-3 text-center">Categoría</th><th class="px-4 py-3 text-center">Tiempo</th><th class="px-4 py-3 text-center">Ritmo</th><th class="px-4 py-3 text-center">FC prom.</th><th class="px-4 py-3 text-center">Tipo</th></tr></thead><tbody>{races.map((race, i) => (<tr class={`border-t border-neutral-800 hover:bg-neutral-900/60 transition-colors ${i % 2 === 0 ? 'bg-neutral-950' : 'bg-neutral-900/30'}`}><td class="px-4 py-3 text-neutral-400 whitespace-nowrap">{race.date}</td><td class="px-4 py-3 text-white max-w-[180px] truncate" title={race.name}>{race.name}</td><td class="px-4 py-3 text-center text-neutral-300">{race.distance.toFixed(2)} mi</td><td class="px-4 py-3 text-center"><span class="text-xs font-semibold text-blue-400 bg-blue-600/10 border border-blue-500/20 px-2 py-0.5 rounded-full">{race.distanceCategory}</span></td><td class="px-4 py-3 text-center text-white font-mono">{race.durationFormatted}</td><td class="px-4 py-3 text-center text-blue-400 font-mono font-semibold">{race.paceFormatted}/mi</td><td class="px-4 py-3 text-center text-neutral-400">{race.hr ? `${Math.round(race.hr)} bpm` : '—'}</td><td class="px-4 py-3 text-center"><span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${race.type === 'Treadmill' ? 'bg-neutral-800 text-neutral-400' : 'bg-green-900/20 text-green-400 border border-green-500/20'}`}>{race.type}</span></td></tr>))}</tbody></table></div>)}<p class="text-xs text-neutral-600 mt-6 text-center">Nota: estas son carreras de entrenamiento registradas por Garmin a distancias de carrera, no eventos oficiales.</p></div></section></main></Layout>
