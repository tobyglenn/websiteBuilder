---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.jsx';
import { getHeatmapData } from '../../lib/trainingHeatmap.js';

// ─── Compute all data at build time ──────────────────────────────────────────
const { heatmapData, stats, monthlyData } = getHeatmapData();

// ─── Heatmap configuration ───────────────────────────────────────────────────
const CELL_SIZE = 12;
const GAP = 3;
const weeks = Math.ceil(heatmapData.length / 7);

// Month label positions
const monthStarts = [];
let lastMonth = '';
heatmapData.forEach((d, i) => {
  const month = d.date.slice(0, 7);
  if (month !== lastMonth && d.dow === 0) {
    const weekIndex = Math.floor(i / 7);
    monthStarts.push({
      label: d.date.slice(0, 7),
      x: weekIndex * (CELL_SIZE + GAP),
    });
    lastMonth = month;
  }
});

// ─── Monthly bar chart config ─────────────────────────────────────────────────
const BAR_GAP = 4;
const BAR_MAX_HEIGHT = 120;
const maxCount = Math.max(...monthlyData.map(m => m.count), 1);

const monthLabels = {
  '01': 'Jan', '02': 'Feb', '03': 'Mar', '04': 'Apr',
  '05': 'May', '06': 'Jun', '07': 'Jul', '08': 'Aug',
  '09': 'Sep', '10': 'Oct', '11': 'Nov', '12': 'Dec',
};

const formattedMonthly = monthlyData.map(m => ({
  ...m,
  label: `${monthLabels[m.month.slice(5)]} '${m.month.slice(2, 4)}`,
  height: (m.count / maxCount) * BAR_MAX_HEIGHT,
}));

const chartWidth = formattedMonthly.length * 40 + 20;
---

<Layout
  title="Training Log — Workout Consistency"
  description="Track your training consistency with a workout frequency heatmap. See your streaks, total workouts, and monthly activity."
  canonicalPath="/training-log"
>
  <Header client:load currentPath="/training-log" />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Hero -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-black tracking-tight mb-4">
        Training <span class="text-blue-500">Consistency</span>
      </h1>
      <p class="text-neutral-400 text-lg max-w-xl mx-auto">
        Your workout frequency heatmap. Every blue square is a day you moved.
      </p>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
        <div class="text-3xl font-black text-blue-500 mb-1">{stats.currentStreak}</div>
        <div class="text-sm text-neutral-400">Current Streak</div>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
        <div class="text-3xl font-black text-blue-500 mb-1">{stats.longestStreak}</div>
        <div class="text-sm text-neutral-400">Longest Streak</div>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
        <div class="text-3xl font-black text-blue-500 mb-1">{stats.totalDays}</div>
        <div class="text-sm text-neutral-400">Total Days</div>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
        <div class="text-3xl font-black text-blue-500 mb-1">{stats.thisYear}</div>
        <div class="text-sm text-neutral-400">This Year</div>
      </div>
    </div>

    <!-- Heatmap -->
    <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 mb-12">
      <h2 class="text-lg font-bold mb-6">Workout Frequency</h2>
      
      <div class="overflow-x-auto">
        <div 
          class="inline-grid gap-1"
          style={`grid-template-columns: repeat(${weeks}, ${CELL_SIZE}px); grid-template-rows: repeat(7, ${CELL_SIZE}px);`}
        >
          {heatmapData.map((day, i) => {
            const weekIndex = Math.floor(i / 7);
            const col = weekIndex;
            const row = day.dow;
            
            return (
              <div
                class={`rounded-sm transition-all hover:ring-2 hover:ring-blue-400/50 ${
                  day.count > 0 
                    ? 'bg-blue-500' 
                    : 'bg-neutral-800'
                }`}
                style={`width: ${CELL_SIZE}px; height: ${CELL_SIZE}px; grid-column: ${col + 1}; grid-row: ${row + 1};`}
                title={`${day.date}: ${day.count > 0 ? 'Workout' : 'Rest'}`}
              />
            );
          })}
        </div>
      </div>

      <!-- Month labels -->
      <div class="mt-4 flex text-xs text-neutral-500">
        {monthStarts.map(m => (
          <span style={`margin-left: ${m.x * (CELL_SIZE + GAP) / (CELL_SIZE + GAP)}px;`}>
            {m.label.slice(5)}-{m.label.slice(2, 4)}
          </span>
        ))}
      </div>

      <!-- Legend -->
      <div class="mt-6 flex items-center gap-2 text-xs text-neutral-500">
        <span>Less</span>
        <div class="w-3 h-3 bg-neutral-800 rounded-sm"></div>
        <div class="w-3 h-3 bg-blue-500 rounded-sm"></div>
        <span>More</span>
      </div>
    </div>

    <!-- Monthly Bar Chart -->
    <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
      <h2 class="text-lg font-bold mb-6">Monthly Activity</h2>
      
      <div class="flex items-end gap-1 h-32">
        {formattedMonthly.map(m => (
          <div class="flex-1 flex flex-col items-center">
            <div 
              class="w-full bg-blue-500/80 hover:bg-blue-500 rounded-t transition-all"
              style={`height: ${m.height}px; max-width: 40px;`}
              title={`${m.label}: ${m.count} workouts`}
            ></div>
            <span class="text-xs text-neutral-500 mt-2">{m.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Footer note -->
    <div class="mt-8 text-center text-sm text-neutral-600">
      Data from Garmin, Tonal, and unified training timeline
    </div>
  </main>
</Layout>
