---
import Layout from '../../layouts/Layout.astro';
import { getHeartRateData } from '../../data/heartRate.js';
const { stats, monthlyTrends, recentActivities } = getHeartRateData();
function fmtDur(seconds) { if (!seconds || seconds === 0) return '0m'; const h = Math.floor(seconds / 3600); const m = Math.floor((seconds % 3600) / 60); if (h > 0) return `${h}h ${m}m`; return `${m}m`; }
const zoneNames = { 1: 'Recuperación', 2: 'Resistencia', 3: 'Tempo', 4: 'Umbral', 5: 'VO2 Max' };
const zoneColors = { 1: '#60a5fa', 2: '#4ade80', 3: '#facc15', 4: '#fb923c', 5: '#f87171' };
const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"¿Qué significan las zonas de frecuencia cardíaca?","acceptedAnswer":{"@type":"Answer","text":"La zona 1 (Recuperación) es esfuerzo muy ligero, la zona 2 (Resistencia) es entrenamiento aeróbico ligero, la zona 3 (Tempo) es entrenamiento aeróbico moderado, la zona 4 (Umbral) es entrenamiento anaeróbico duro y la zona 5 (VO2 Max) es esfuerzo máximo para sprints."}},{"@type":"Question","name":"¿Qué es el efecto aeróbico del entrenamiento?","acceptedAnswer":{"@type":"Answer","text":"El efecto aeróbico de Garmin mide cómo tu entrenamiento mejora la capacidad del cuerpo para transportar y usar oxígeno. Las puntuaciones van de 0,0 a 5,0."}},{"@type":"Question","name":"¿Qué es la carga de entrenamiento?","acceptedAnswer":{"@type":"Answer","text":"La carga de entrenamiento mide el esfuerzo total que el ejercicio impone a tu cuerpo según la duración y la intensidad de tus entrenamientos."}}]};
const donutW = 280, donutH = 280, donutR = 100, donutThick = 35; const cx = donutW / 2, cy = donutH / 2;
function polarToCartesian(cx, cy, r, angleInDegrees) { const angleInRadians = (angleInDegrees - 90) * Math.PI / 180.0; return { x: cx + (r * Math.cos(angleInRadians)), y: cy + (r * Math.sin(angleInRadians)) }; }
function describeArc(cx, cy, r, startAngle, endAngle) { const start = polarToCartesian(cx, cy, r, endAngle); const end = polarToCartesian(cx, cy, r, startAngle); const largeArcFlag = endAngle - startAngle <= 180 ? '0' : '1'; return `M ${start.x} ${start.y} A ${r} ${r} 0 ${largeArcFlag} 0 ${end.x} ${end.y}`; }
let currentAngle = 0; const zoneArcs = []; for (let z = 1; z <= 5; z++) { const pct = stats.zonePercentages[z]; if (pct > 0) { const angle = (pct / 100) * 360; const path = describeArc(cx, cy, donutR, currentAngle, currentAngle + angle); zoneArcs.push({ z, pct, path, color: zoneColors[z], startAngle: currentAngle, endAngle: currentAngle + angle }); currentAngle += angle; } }
const lineW = 600, lineH = 180, padL = 40, padR = 20, padT = 20, padB = 35; const hrValues = monthlyTrends.map(m => m.avgHR).filter(v => v > 0); const minHR = Math.min(...hrValues, 110); const maxHR = Math.max(...hrValues, 170); const yRange = maxHR - minHR; function hrToY(hr) { return lineH - padB - ((hr - minHR) / yRange) * (lineH - padT - padB); } const scaledLinePoints = monthlyTrends.map((m, i) => { const x = padL + (i / Math.max(1, monthlyTrends.length - 1)) * (lineW - padL - padR); const y = hrToY(m.avgHR); return { ...m, x, y }; }); let linePath = ''; scaledLinePoints.forEach((p, i) => { if (p.avgHR > 0) linePath += (i === 0 ? 'M' : 'L') + `${p.x},${p.y}`; });
---
<Layout title="Análisis de zonas de frecuencia cardíaca — TobyOnFitnessTech" description="Sigue tu condición cardiovascular con un análisis de zonas de frecuencia cardíaca. Mira tiempo en zonas 1-5, efecto aeróbico y tendencias mensuales." jsonLd={faqSchema}><main class="min-h-screen bg-neutral-950 text-white"><section class="pt-28 pb-14 md:pt-36 md:pb-20 relative overflow-hidden"><div class="absolute inset-0 bg-gradient-to-br from-red-900/10 via-transparent to-transparent pointer-events-none" /><div class="absolute right-0 top-0 w-64 h-64 bg-red-600/5 rounded-full blur-3xl pointer-events-none" /><div class="container mx-auto px-4 relative z-10"><div class="max-w-3xl"><p class="text-xs font-bold tracking-widest text-red-500 uppercase mb-4">Garmin Fenix 7 · Feb 2025 – Feb 2026</p><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-5 leading-tight">Análisis de<br /><span class="bg-gradient-to-r from-red-400 to-orange-500 bg-clip-text text-transparent">zonas de frecuencia cardíaca.</span></h2><p class="text-lg text-neutral-400 leading-relaxed max-w-2xl mb-8">Sigue tu condición cardiovascular con desgloses detallados por zonas de FC. Ve cuánto tiempo pasas en cada zona y monitorea tu progreso aeróbico con el tiempo.</p><div class="flex flex-wrap gap-3"><span class="px-4 py-1.5 rounded-full text-xs font-semibold bg-red-600/20 border border-red-500/30 text-red-400">❤️ {stats.totalActivities} actividades</span><span class="px-4 py-1.5 rounded-full text-xs font-semibold bg-neutral-800 border border-neutral-700 text-neutral-400">FC máx: {stats.maxHR} bpm</span></div></div></div></section><section class="py-10 border-t border-neutral-900"><div class="container mx-auto px-4"><div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3"><div class="bg-gradient-to-br from-red-900/30 to-red-900/10 border border-red-800/30 rounded-2xl p-5"><div class="text-3xl font-black text-red-400 mb-1">{stats.avgHR}</div><div class="text-xs text-neutral-500 uppercase tracking-wider font-semibold">FC promedio</div><div class="text-xs text-neutral-600 mt-1">bpm</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5"><div class="text-3xl font-black text-white mb-1">{stats.maxHR}</div><div class="text-xs text-neutral-500 uppercase tracking-wider font-semibold">FC máx</div><div class="text-xs text-neutral-600 mt-1">registrada</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5"><div class="text-3xl font-black text-white mb-1">{stats.avgAerobic}</div><div class="text-xs text-neutral-500 uppercase tracking-wider font-semibold">Prom. aeróbico</div><div class="text-xs text-neutral-600 mt-1">efecto de entrenamiento</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5"><div class="text-3xl font-black text-green-400 mb-1">{fmtDur(stats.zoneTotals[2])}</div><div class="text-xs text-neutral-500 uppercase tracking-wider font-semibold">Zona 2</div><div class="text-xs text-neutral-600 mt-1">Resistencia</div></div><div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5"><div class="text-3xl font-black text-yellow-400 mb-1">{fmtDur(stats.zoneTotals[3])}</div><div class="text-xs text-neutral-500 uppercase tracking-wider font-semibold">Zona 3</div><div class="text-xs text-neutral-600 mt-1">Tempo</div></div><div class="bg-gradient-to-br from-orange-900/30 to-orange-900/10 border border-orange-800/30 rounded-2xl p-5"><div class="text-3xl font-black text-orange-400 mb-1">{stats.totalTrainingLoad}</div><div class="text-xs text-neutral-500 uppercase tracking-wider font-semibold">Carga de entrenamiento</div><div class="text-xs text-neutral-600 mt-1">total</div></div></div></div></section></main></Layout>
