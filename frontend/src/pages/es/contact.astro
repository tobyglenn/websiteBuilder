---
import Layout from '../layouts/Layout.astro';

const siteUrl = "https://tobyonfitnesstech.com";

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": `${siteUrl}/contact/#contactpage`,
  "name": "Contactar a Toby Glenn Peters",
  "description": "Ponte en contacto con Toby Glenn Peters para patrocinios, consultoría, colaboraciones o preguntas sobre tecnología fitness.",
  "url": `${siteUrl}/contact/`,
  "inLanguage": "es-LATAM",
  "isPartOf": { "@id": `${siteUrl}/#website` },
  "about": { "@id": `${siteUrl}/#toby` },
  "mainEntity": {
    "@type": "Person",
    "@id": `${siteUrl}/#toby`,
    "name": "Toby Glenn Peters",
    "alternateName": "TobyOnFitnessTech",
    "email": "toby@tobyonfitness.tech",
    "url": siteUrl,
    "sameAs": [
      "https://www.youtube.com/@tobyonfitness",
      "https://www.instagram.com/tobyonfitness"
    ]
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteUrl },
      { "@type": "ListItem", "position": 2, "name": "Contacto", "item": `${siteUrl}/contact/` }
    ]
  }
};

const faqs = [
  {
    q: "¿Vendes programas de coaching o planes personalizados?",
    a: "No. Documento lo que me funciona y lo comparto públicamente — eso es todo. No vendo programas, planes de alimentación ni coaching 1 a 1. Todo lo que hago está en YouTube y en este sitio, gratis."
  },
  {
    q: "¿Puedo preguntarte sobre mi configuración de Speediance o tecnología fitness?",
    a: "Sí — para eso estoy aquí. Escríbeme con detalles específicos. Responderé si tengo algo útil que aportar. Si es una pregunta común, podría convertirse en un video o una entrada de blog."
  },
  {
    q: "¿Aceptas patrocinios?",
    a: "Selectivamente. Solo trabajo con productos que realmente uso. Si me escribes sobre Speediance, WHOOP, Garmin, 8Sleep o tecnología fitness similar — te escucho. Los correos fríos sobre proteína en polvo y suplementos generalmente no llegan a nada."
  },
  {
    q: "¿Estás disponible para consultoría sobre stacks de tecnología fitness o automatización?",
    a: "A veces. Si eres una empresa o una persona que quiere construir sistemas de entrenamiento basados en datos — especialmente con OpenClaw, hardware de gimnasio en casa o integración con wearables — escríbeme. Te diré con honestidad si puedo ayudar."
  },
  {
    q: "¿Cuánto tardas en responder?",
    a: "Normalmente dentro de unos días. Soy una sola persona con una agenda de entrenamiento completa y un trabajo de día. Leo todo — simplemente no respondo rápido."
  },
  {
    q: "¿Puedo colaborar en contenido o cocrear algo?",
    a: "Tal vez. Cuéntame qué estás construyendo y por qué crees que encaja. No estoy buscando llenar mi calendario de publicaciones — pero ¿un proyecto realmente interesante? Estoy abierto."
  }
];
---

<Layout
  title="Contacto — TobyOnFitnessTech"
  description="Ponte en contacto con Toby Glenn Peters para patrocinios, consultoría, preguntas sobre tecnología fitness o colaboraciones."
  breadcrumbs={[{ name: "Inicio", url: "/" }, { name: "Contacto", url: "/contact" }]}
  jsonLd={contactPageSchema}
>
  <main class="min-h-screen bg-neutral-950 text-white">

    {/* Hero */}
    <section class="pt-20 pb-12 md:pt-28 md:pb-16 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-blue-900/10 to-transparent pointer-events-none" />
      <div class="container mx-auto px-4 relative z-10 max-w-4xl">
        <p class="text-xs font-bold tracking-widest text-blue-500 uppercase mb-4">Contacto</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Ponte en contacto
        </h1>
        <p class="text-xl text-neutral-400 max-w-2xl leading-relaxed">
          No soy difícil de encontrar. Solo soy selectivo con aquello a lo que le digo que sí. Si tienes algo real que discutir, voy a responder.
        </p>
      </div>
    </section>

    {/* Contact + Social */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="grid md:grid-cols-2 gap-8">

          {/* Email Card */}
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-xl bg-blue-600/20 border border-blue-500/30 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <h2 class="text-xl font-bold text-white">Correo electrónico</h2>
                <p class="text-neutral-500 text-sm">La mejor forma de contactarme</p>
              </div>
            </div>
            <a
              href="mailto:toby@tobyonfitness.tech"
              class="text-blue-400 hover:text-blue-300 font-mono text-lg font-semibold transition-colors"
            >
              toby@tobyonfitness.tech
            </a>
            <p class="text-neutral-500 text-sm mt-4 leading-relaxed">
              Leo cada correo. Respondo cuando tengo algo útil que decir — normalmente en unos pocos días.
            </p>
          </div>

          {/* Social Links */}
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-8">
            <h2 class="text-xl font-bold text-white mb-6">Sígueme</h2>
            <div class="space-y-4">
              <a
                href="https://www.youtube.com/@tobyonfitness"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-4 p-4 rounded-xl bg-neutral-950 border border-neutral-800 hover:border-red-500/40 hover:bg-red-950/10 transition-all group"
              >
                <div class="w-10 h-10 rounded-lg bg-red-600/20 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#ef4444"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.54C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon fill="white" points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
                </div>
                <div>
                  <div class="text-white font-semibold group-hover:text-red-400 transition-colors">YouTube</div>
                  <div class="text-neutral-500 text-sm">@tobyonfitness</div>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-auto text-neutral-700 group-hover:text-neutral-400 transition-colors"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>

              <a
                href="https://www.instagram.com/tobyonfitness"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-4 p-4 rounded-xl bg-neutral-950 border border-neutral-800 hover:border-pink-500/40 hover:bg-pink-950/10 transition-all group"
              >
                <div class="w-10 h-10 rounded-lg bg-pink-600/20 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ec4899" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
                </div>
                <div>
                  <div class="text-white font-semibold group-hover:text-pink-400 transition-colors">Instagram</div>
                  <div class="text-neutral-500 text-sm">@tobyonfitness</div>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-auto text-neutral-700 group-hover:text-neutral-400 transition-colors"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    {/* What to Expect */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-5xl">
        <h2 class="text-3xl font-bold text-white mb-3">A lo que realmente respondo</h2>
        <p class="text-neutral-500 mb-10">Sin rodeos. Esto sí vale la pena escribirlo por correo:</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">🤝</div>
            <h3 class="text-lg font-bold text-white mb-2">Patrocinios</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              Solo tecnología fitness — equipo que realmente usaría. Territorio Speediance, WHOOP, Garmin, 8Sleep. No me interesan suplementos que nunca he probado.
            </p>
          </div>

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">🔧</div>
            <h3 class="text-lg font-bold text-white mb-2">Consultoría</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              ¿Estás construyendo un stack fitness basado en datos? ¿Automatizando decisiones de entrenamiento con datos de wearables? Eso sí es interesante. Hablemos primero del alcance.
            </p>
          </div>

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">❓</div>
            <h3 class="text-lg font-bold text-white mb-2">Preguntas</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              Las preguntas genuinas sobre Speediance, WHOOP, BJJ o mi enfoque de entrenamiento son bienvenidas. Si es una pregunta que no puedo responder brevemente, lo diré.
            </p>
          </div>

          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-blue-500/30 transition-all">
            <div class="text-3xl mb-4">🎬</div>
            <h3 class="text-lg font-bold text-white mb-2">Colaboraciones</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              Si estás construyendo algo en el espacio de tecnología fitness o automatización y encaja de verdad — estoy abierto. Cuéntame la idea.
            </p>
          </div>

        </div>
      </div>
    </section>

    {/* Response Expectations */}
    <section class="py-12 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="bg-neutral-900/50 border border-neutral-800 rounded-2xl p-8 flex flex-col md:flex-row items-start gap-6">
          <div class="text-4xl flex-shrink-0">⏱️</div>
          <div>
            <h3 class="text-xl font-bold text-white mb-2">Tiempo de respuesta</h3>
            <p class="text-neutral-400 leading-relaxed">
              Soy una sola persona. Entreno a las 6:30 AM, trabajo todo el día y hago BJJ la mayoría de las noches. Leo todo — pero respondo cuando tengo algo útil que decir, no solo para confirmar que lo recibí. Dale unos días antes de volver a escribir.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* FAQ */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4 max-w-4xl">
        <h2 class="text-3xl font-bold text-white mb-3">Preguntas frecuentes</h2>
        <p class="text-neutral-500 mb-10">Revisa aquí antes de escribir — tu respuesta quizá ya esté aquí.</p>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 hover:border-neutral-700 transition-all">
              <h3 class="text-white font-semibold mb-3 flex items-start gap-3">
                <span class="text-blue-500 font-bold flex-shrink-0">P:</span>
                {faq.q}
              </h3>
              <p class="text-neutral-400 leading-relaxed pl-6">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* CTA */}
    <section class="py-24 border-t border-neutral-900">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-4">¿Listo para escribirme?</h2>
        <p class="text-neutral-400 mb-8 max-w-xl mx-auto">
          Envíame un mensaje. Sé específico y de verdad te responderé.
        </p>
        <a
          href="mailto:toby@tobyonfitness.tech"
          class="inline-flex items-center gap-2 px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-full transition-all hover:scale-105"
        >
          Enviar correo a Toby
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
      </div>
    </section>

  </main>
</Layout>
