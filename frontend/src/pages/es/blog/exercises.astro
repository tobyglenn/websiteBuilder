---
import Layout from '../../../layouts/Layout.astro';
import { getExercises } from '../../../data/exercises.js';

const { allExercises, grouped, totalCount } = getExercises();

const pageTitle = "Biblioteca de ejercicios";
const pageDescription = "Explora todos los ejercicios realizados en Speediance con pesos PR. Filtra por grupo muscular: Espalda y dorsales, Pecho y tríceps, Piernas y glúteos, Core y brazos.";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cuál es el ejercicio más pesado en Speediance?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El peso muerto con barra tiene el PR más alto con 388 lbs, seguido por el hip thrust con barra con 240 lbs y el press de banca con barra con 232 lbs."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuántos ejercicios únicos hay en la biblioteca de ejercicios?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `La biblioteca contiene ${totalCount} ejercicios únicos en todos los programas de entrenamiento de Speediance.`
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué grupos musculares puedo entrenar con Speediance?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Speediance permite entrenar todos los grupos musculares principales: Espalda y dorsales, Pecho y tríceps, Piernas y glúteos, y Core y brazos (incluyendo bíceps, hombros y abdominales)."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuál es el mejor ejercicio en Speediance para desarrollar un pecho grande?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El press de banca con barra tiene el PR de pecho más alto con 232 lbs. Otros ejercicios de pecho efectivos incluyen el press de banca inclinado con barra (185 lbs PR) y el press de banca con doble asa (90 lbs PR)."
      }
    },
    {
      "@type": "Question",
      "name": "¿Puedo seguir mis récords personales en Speediance?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "¡Sí! Speediance rastrea automáticamente tu máximo de una repetición (1RM) para cada ejercicio. Esta página muestra todos tus PR, desde el peso muerto de 388 lbs hasta movimientos de aislamiento más pequeños."
      }
    }
  ]
};

const muscleGroups = ['Todos', 'Espalda y dorsales', 'Pecho y tríceps', 'Piernas y glúteos', 'Core y brazos'];
---

<Layout 
  title={`${pageTitle} | Toby on Fitness Tech`}
  description={pageDescription}
  jsonLd={faqSchema}
>
  <section class="py-20 bg-neutral-950 border-b border-neutral-800">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Biblioteca de ejercicios</h1>
      <p class="text-lg md:text-xl text-neutral-400 max-w-2xl mx-auto">
        Explora los {totalCount} ejercicios realizados en Speediance con pesos de récord personal.
      </p>
    </div>
  </section>

  <section class="py-8 bg-neutral-900 border-b border-neutral-800 sticky top-16 z-40">
    <div class="container mx-auto px-4">
      <div class="flex flex-wrap justify-center gap-3">
        {muscleGroups.map((group) => (
          <button
            data-filter={group}
            class={`filter-btn px-5 py-2.5 rounded-full text-sm font-medium transition-all ${
              group === 'Todos' 
                ? 'bg-blue-600 text-white' 
                : 'bg-neutral-800 text-neutral-300 hover:bg-neutral-700 hover:text-white border border-neutral-700'
            }`}
          >
            {group}
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-neutral-950">
    <div class="container mx-auto px-4">
      <div id="exerciseGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {allExercises.map((exercise) => (
          <div 
            data-group={exercise.muscleGroup}
            class="exercise-card bg-neutral-900 rounded-xl p-5 border border-neutral-800 hover:border-blue-500/50 transition-all hover:shadow-lg hover:shadow-blue-500/10"
          >
            <h3 class="text-white font-semibold text-lg mb-3 line-clamp-2">{exercise.name}</h3>
            
            <div class="mb-3">
              <span class={`inline-block px-3 py-1 rounded-full text-xs font-medium ${
                exercise.muscleGroup === 'Back & Lats' ? 'bg-blue-500/20 text-blue-400' :
                exercise.muscleGroup === 'Chest & Triceps' ? 'bg-red-500/20 text-red-400' :
                exercise.muscleGroup === 'Legs & Glutes' ? 'bg-green-500/20 text-green-400' :
                'bg-purple-500/20 text-purple-400'
              }`}>
                {exercise.muscleGroup === 'Back & Lats' ? 'Espalda y dorsales' :
                 exercise.muscleGroup === 'Chest & Triceps' ? 'Pecho y tríceps' :
                 exercise.muscleGroup === 'Legs & Glutes' ? 'Piernas y glúteos' :
                 'Core y brazos'}
              </span>
            </div>
            
            <div class="flex items-baseline gap-2">
              <span class="text-2xl font-bold text-white">{exercise.prWeight || '—'}</span>
              <span class="text-sm text-neutral-400">lbs PR</span>
            </div>
          </div>
        ))}
      </div>
      
      <div id="noResults" class="hidden text-center py-16">
        <div class="text-6xl mb-4">🏋️</div>
        <p class="text-xl text-neutral-400">No se encontraron ejercicios para esta categoría.</p>
      </div>
    </div>
  </section>

  <section class="py-12 bg-neutral-900 border-t border-neutral-800">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-blue-400 mb-1">{grouped['Back & Lats']?.length || 0}</div>
          <div class="text-sm text-neutral-400">Espalda y dorsales</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-red-400 mb-1">{grouped['Chest & Triceps']?.length || 0}</div>
          <div class="text-sm text-neutral-400">Pecho y tríceps</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-green-400 mb-1">{grouped['Legs & Glutes']?.length || 0}</div>
          <div class="text-sm text-neutral-400">Piernas y glúteos</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-purple-400 mb-1">{grouped['Core & Arms']?.length || 0}</div>
          <div class="text-sm text-neutral-400">Core y brazos</div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.exercise-card');
    const noResults = document.getElementById('noResults');
    
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');
        
        filterBtns.forEach(b => {
          b.classList.remove('bg-blue-600', 'text-white');
          b.classList.add('bg-neutral-800', 'text-neutral-300', 'border', 'border-neutral-700');
        });
        btn.classList.remove('bg-neutral-800', 'text-neutral-300', 'border', 'border-neutral-700');
        btn.classList.add('bg-blue-600', 'text-white');
        
        let visibleCount = 0;
        cards.forEach(card => {
          const group = card.getAttribute('data-group');
          const normalizedGroup = group === 'Back & Lats' ? 'Espalda y dorsales' :
            group === 'Chest & Triceps' ? 'Pecho y tríceps' :
            group === 'Legs & Glutes' ? 'Piernas y glúteos' :
            group === 'Core & Arms' ? 'Core y brazos' : group;
          if (filter === 'Todos' || normalizedGroup === filter) {
            (card as HTMLElement).style.display = 'block';
            visibleCount++;
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });
        
        if (noResults) {
          if (visibleCount === 0) {
            noResults.classList.remove('hidden');
          } else {
            noResults.classList.add('hidden');
          }
        }
      });
    });
  });
</script>
