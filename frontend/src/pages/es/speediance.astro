        </div>
      </div>
    </section>

    {/* ── Personal Records ──────────────────────────────────────────────────── */}
    <section id="personal-records" class="py-12 border-t border-neutral-900">
      <div class="container mx-auto px-4">
        <div class="mb-8">
          <h2 class="text-2xl font-bold mb-2">Récords personales</h2>
          <p class="text-neutral-400 text-sm">Las mejores estimaciones de 1RM registradas por Speediance. Son números reales.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
          {exercisePRs.map((pr, i) => (
            <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-4 hover:border-orange-800/50 transition-colors group">
              <div class="flex items-start justify-between">
                <div class="flex-1 min-w-0 mr-2">
                  <div class="text-sm font-medium text-neutral-200 leading-snug">{pr.name}</div>
                  <div class="text-xs text-neutral-600 mt-1">{pr.workout}</div>
                </div>
                <div class="shrink-0 text-right">
                  <div class="text-xl font-bold text-orange-400">{pr.weight}</div>
                  <div class="text-xs text-neutral-600">lbs</div>
                </div>
              </div>
              {i === 0 && (
                <div class="mt-2 pt-2 border-t border-neutral-800">
                  <span class="text-xs text-yellow-500 font-semibold">🏆 PR principal</span>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── Recent Sessions Table ─────────────────────────────────────────────── */}
    <section id="recent-workouts" class="py-12 border-t border-neutral-900">
      <div class="container mx-auto px-4">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h2 class="text-2xl font-bold mb-1">Entrenamientos recientes</h2>
            <p class="text-neutral-400 text-sm">Las últimas 20 sesiones de Speediance</p>
          </div>
          <a
            href="/videos/"
            class="text-sm text-orange-400 hover:text-orange-300 font-medium flex items-center gap-1 transition-colors"
          >
            Ver videos de entrenamientos
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        {/* Desktop table */}
        <div class="hidden md:block overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-neutral-800 text-left">
                <th class="pb-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider pr-4">Fecha</th>
                <th class="pb-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider pr-4">Entrenamiento</th>
                <th class="pb-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider pr-4 text-right">Volumen</th>
                <th class="pb-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider pr-4 text-right">Duración</th>
                <th class="pb-3 text-xs font-semibold text-neutral-500 uppercase tracking-wider text-right">Calorías</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-neutral-900">
              {recentSessions.map((s) => (
                <tr class="hover:bg-neutral-900/50 transition-colors">
                  <td class="py-3 pr-4 text-neutral-400 font-mono text-xs whitespace-nowrap">{s.date}</td>
                  <td class="py-3 pr-4 text-neutral-200 font-medium">{s.title}</td>
                  <td class="py-3 pr-4 text-right font-mono font-semibold text-orange-400">
                    {s.volume >= 1000 ? (s.volume / 1000).toFixed(1) + 'k' : s.volume} lbs
                  </td>
                  <td class="py-3 pr-4 text-right text-neutral-300 font-mono">{s.duration}m</td>
                  <td class="py-3 text-right text-neutral-400 font-mono">
                    {s.calories > 0 ? s.calories + ' kcal' : '—'}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        {/* Mobile cards */}
        <div class="md:hidden space-y-3">
          {recentSessions.slice(0, 10).map((s) => (
            <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-4">
              <div class="flex items-start justify-between mb-2">
                <div class="flex-1 min-w-0 mr-3">
                  <div class="font-medium text-white text-sm">{s.title}</div>
                  <div class="text-xs text-neutral-500 mt-0.5">{s.date}</div>
                </div>
                <div class="text-right shrink-0">
                  <div class="font-bold text-orange-400 font-mono">
                    {s.volume >= 1000 ? (s.volume / 1000).toFixed(1) + 'k' : s.volume}
                  </div>
                  <div class="text-xs text-neutral-600">lbs</div>
                </div>
              </div>
              <div class="grid grid-cols-2 gap-2 mt-3">
                <div>
                  <div class="text-white font-mono">{s.duration}m</div>
                  <div class="text-xs text-neutral-600 uppercase tracking-wider">Duración</div>
                </div>
                <div>
                  <div class="text-neutral-300 font-mono">{s.calories > 0 ? s.calories + ' kcal' : '—'}</div>
                  <div class="text-xs text-neutral-600 uppercase tracking-wider">Calorías</div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── Workout Heatmap ────────────────────────────────────────────────── */}
    <section id="workout-frequency" class="py-16 border-t border-neutral-800/60">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
          <div>
            <h2 class="text-2xl font-bold text-white">Frecuencia de entrenamiento</h2>
            <p class="text-neutral-400 text-sm mt-1">Últimas 52 semanas</p>
          </div>
          <div class="flex gap-6 text-sm">
            <div class="text-center">
              <div class="text-2xl font-bold text-orange-400">{currentStreak}</div>
              <div class="text-neutral-400 text-xs">Racha actual</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-orange-300">{longestStreak}</div>
              <div class="text-neutral-400 text-xs">Racha más larga</div>
            </div>
          </div>
        </div>

        {/* Month labels */}
        <div class="overflow-x-auto pb-2">
          <div style={`display:grid;grid-template-columns:repeat(${weeks.length},minmax(0,1fr));min-width:${weeks.length * 14}px`} class="mb-1">
            {weeks.map((_, colIdx) => {
              const label = monthLabels.find(m => m.col === colIdx);
              return (
                <div class="text-[10px] text-neutral-500 h-4" style="min-width:12px">
                  {label ? label.label : ''}
                </div>
              );
            })}
          </div>

          {/* Heatmap grid — 7 rows (days), N columns (weeks) */}
          <div class="flex gap-[3px]">
            {weeks.map((week) => (
              <div class="flex flex-col gap-[3px]">
                {week.map((day, rowIdx) => (
                  day ? (
                    <div
                      class={`w-3 h-3 rounded-sm ${heatColor(day.count)} cursor-default`}
                      title={`${day.label}: ${day.count} entrenamiento${day.count !== 1 ? 's' : ''}`}
                    />
                  ) : (
                    <div class="w-3 h-3" />
                  )
                ))}
              </div>
            ))}
          </div>
        </div>

        {/* Legend */}
        <div class="flex items-center gap-2 mt-3 text-xs text-neutral-500">
          <span>Menos</span>
          <div class="w-3 h-3 rounded-sm bg-neutral-800" />
          <div class="w-3 h-3 rounded-sm bg-orange-900" />
          <div class="w-3 h-3 rounded-sm bg-orange-600" />
          <div class="w-3 h-3 rounded-sm bg-orange-400" />
          <span>Más</span>
        </div>
      </div>
    </section>

    {/* ── Callout / CTA ─────────────────────────────────────────────────────── */}
    <section class="py-16 border-t border-neutral-900">
      <div class="container mx-auto px-4">
        <div class="bg-gradient-to-r from-orange-900/20 to-red-900/20 border border-orange-800/30 rounded-2xl p-8 flex flex-col md:flex-row items-center gap-6 max-w-3xl mx-auto">
          <div class="text-5xl shrink-0">🏋️</div>
          <div class="flex-1 text-center md:text-left">
            <h3 class="text-xl font-bold text-white mb-2">De 188 a 218 lbs, sin gimnasio comercial</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              Speediance reemplazó mi membresía del gimnasio. {stats.totalVolumeFmt} lbs de volumen, cero traslados,
              y más sobrecarga progresiva de la que jamás obtuve en un gimnasio tradicional.
              Los datos no mienten.
            </p>
          </div>
          <a
            href="/about/"
            class="shrink-0 inline-flex items-center gap-2 px-6 py-3 bg-orange-600 hover:bg-orange-700 text-white font-bold rounded-full transition-all hover:scale-105 text-sm"
          >
            Lee mi historia
          </a>
        </div>
      </div>
    </section>

  </main>
</Layout>

{/* ── Pass data to client ───────────────────────────────────────────────────── */}
<script define:vars={{ chartData, donutData }}>
  window.__SPEEDIANCE_CHART_DATA__ = chartData;
  window.__SPEEDIANCE_DONUT_DATA__ = donutData;
</script>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>

<script is:inline>
  (function () {
    Chart.defaults.color = '#737373';
    Chart.defaults.borderColor = '#262626';
    Chart.defaults.font.family = 'ui-sans-serif, system-ui, sans-serif';

    const chartData = window.__SPEEDIANCE_CHART_DATA__ || [];
    const donutData = window.__SPEEDIANCE_DONUT_DATA__ || [];

    // ── Monthly Volume Bar Chart ───────────────────────────────────────────
    (function buildVolumeChart() {
      const canvas = document.getElementById('volumeChart');
      if (!canvas) return;

      const labels = chartData.map(d => d.label);
      const volumes = chartData.map(d => d.volume);
      const workouts = chartData.map(d => d.workouts);
      const maxVol = Math.max(...volumes);

      const bgColors = volumes.map(v => {
        const intensity = v / maxVol;
        const alpha = 0.25 + intensity * 0.55;
        return `rgba(249,115,22,${alpha.toFixed(2)})`;
      });

      new Chart(canvas, {
        type: 'bar',
        data: {
          labels,
          datasets: [{
            label: 'Volumen (lbs)',
            data: volumes,
            backgroundColor: bgColors,
            borderColor: 'rgba(249,115,22,0.8)',
            borderWidth: 1,
            borderRadius: 8,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: '#171717',
              borderColor: '#404040',
              borderWidth: 1,
              padding: 10,
              callbacks: {
                label: (item) => {
                  const lbs = item.raw;
                  const formatted = lbs >= 1000 ? (lbs / 1000).toFixed(1) + 'k lbs' : lbs + ' lbs';
                  return ` ${formatted} · ${workouts[item.dataIndex]} entrenamientos`;
                },
              },
            },
          },
          scales: {
            x: {
              grid: { color: '#1a1a1a' },
              ticks: { maxRotation: 30, font: { size: 11 } },
            },
            y: {
              grid: { color: '#1a1a1a' },
              ticks: {
                callback: v => v >= 1000 ? (v / 1000).toFixed(0) + 'k' : v,
              },
              min: 0,
            },
          },
        },
      });
    })();

    // ── Workout Type Donut Chart ───────────────────────────────────────────
    (function buildDonutChart() {
      const canvas = document.getElementById('donutChart');
      if (!canvas) return;

      const colors = [
        'rgba(249,115,22,0.85)',
        'rgba(239,68,68,0.80)',
        'rgba(251,191,36,0.80)',
        'rgba(234,179,8,0.75)',
        'rgba(249,115,22,0.50)',
        'rgba(239,68,68,0.45)',
        'rgba(251,191,36,0.45)',
        'rgba(180,83,9,0.60)',
      ];

      new Chart(canvas, {
        type: 'doughnut',
        data: {
          labels: donutData.map(d => d.name),
          datasets: [{
            data: donutData.map(d => d.volume),
            backgroundColor: colors,
            borderColor: '#171717',
            borderWidth: 2,
            hoverOffset: 4,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          cutout: '65%',
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: '#171717',
              borderColor: '#404040',
              borderWidth: 1,
              padding: 10,
              callbacks: {
                label: (item) => {
                  const v = item.raw;
                  const pct = donutData[item.dataIndex]?.pct || 0;
                  return ` ${(v / 1000).toFixed(0)}k lbs · ${pct}%`;
                },
              },
            },
          },
        },
      });
    })();
  })();
</script>
