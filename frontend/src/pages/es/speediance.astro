---
import Layout from '../layouts/Layout.astro';
import { getSpeedianceData } from '../data/speediance.js';

const { stats, chartData, donutData, workoutTypeBreakdown, exercisePRs, recentSessions } = getSpeedianceData();

// ── Heatmap data ──────────────────────────────────────────────────────────
import rawSpeediance from '../data/speediance_dashboard_data.json';
const allSessions = rawSpeediance.allSessions || [];

// Build date → count map
const workoutDateMap: Record<string, number> = {};
for (const s of allSessions) {
  if (s.date) {
    workoutDateMap[s.date] = (workoutDateMap[s.date] || 0) + 1;
  }
}

// Generate last 52 weeks of dates (364 days)
const today = new Date();
today.setHours(0, 0, 0, 0);
const heatmapDays: { date: string; count: number; label: string }[] = [];
for (let i = 363; i >= 0; i--) {
  const d = new Date(today);
  d.setDate(d.getDate() - i);
  const iso = d.toISOString().slice(0, 10);
  heatmapDays.push({
    date: iso,
    count: workoutDateMap[iso] || 0,
    label: d.toLocaleDateString('es-419', { month: 'short', day: 'numeric', year: 'numeric' }),
  });
}

// Pad start so first day aligns to its weekday (0=Sun)
const firstDay = new Date(heatmapDays[0].date).getDay();
const paddedDays = [
  ...Array(firstDay).fill(null),
  ...heatmapDays,
];

// Build week columns for the grid
const weeks: (typeof heatmapDays[0] | null)[][] = [];
for (let i = 0; i < paddedDays.length; i += 7) {
  weeks.push(paddedDays.slice(i, i + 7));
}

// Streak calculation
let currentStreak = 0;
let longestStreak = 0;
let running = 0;
for (let i = heatmapDays.length - 1; i >= 0; i--) {
  if (heatmapDays[i].count > 0) {
    running++;
    if (currentStreak === 0) currentStreak = running;
    longestStreak = Math.max(longestStreak, running);
  } else {
    if (currentStreak === 0) running = 0;
    longestStreak = Math.max(longestStreak, running);
    running = 0;
  }
}
longestStreak = Math.max(longestStreak, running);

// Month labels for heatmap header
const monthLabels: { label: string; col: number }[] = [];
let lastMonth = '';
weeks.forEach((week, colIdx) => {
  const firstReal = week.find(d => d !== null);
  if (firstReal) {
    const m = new Date(firstReal.date).toLocaleString('es-419', { month: 'short' });
    if (m !== lastMonth) {
      monthLabels.push({ label: m, col: colIdx });
      lastMonth = m;
    }
  }
});

const heatColor = (count: number) => {
  if (count === 0) return 'bg-neutral-800';
  if (count === 1) return 'bg-orange-900';
  if (count === 2) return 'bg-orange-600';
  return 'bg-orange-400';
};

// Serialize for client-side charts
const chartJSON = JSON.stringify(chartData);
const donutJSON = JSON.stringify(donutData);
---

<Layout
  title={`${stats.totalVolumeFmt} lbs levantadas: Mi trayectoria con Speediance — TobyOnFitnessTech`}
  description={`${stats.totalWorkouts} entrenamientos, ${stats.totalVolumeFmt} lbs levantadas en Speediance. Datos reales del gimnasio en casa de Toby: tendencias mensuales de volumen, ejercicios principales y récords personales.`}
  breadcrumbs={[{ name: "Inicio", url: "/" }, { name: "Trayectoria con Speediance", url: "/speediance" }]}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Trayectoria con Speediance",
    "description": `${stats.totalWorkouts} entrenamientos, ${stats.totalVolumeFmt} lbs levantadas en Speediance. Datos reales del gimnasio en casa de Toby.`,
    "author": { "@type": "Person", "name": "Toby Glenn Peters" },
    "datePublished": "2026-03-04",
    "url": "https://tobyonfitnesstech.com/speediance"
  }}
>
  <main class="min-h-screen bg-neutral-950 text-white">

    {/* ── Hero ──────────────────────────────────────────────────────────────── */}
    <section id="hero" class="pt-32 pb-16 md:pt-40 md:pb-24 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-900/10 to-transparent pointer-events-none" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(249,115,22,0.08),_transparent_70%)] pointer-events-none" />
      <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-3xl">
          <p class="text-xs font-bold tracking-widest text-orange-500 uppercase mb-4">Datos de Speediance · Jul 2025 – Feb 2026</p>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
            {stats.totalVolumeFmt} lbs levantadas:<br />
            <span class="bg-gradient-to-r from-orange-500 to-red-500 bg-clip-text text-transparent">
              Mi trayectoria con Speediance
            </span>
          </h2>
          <p class="text-xl text-neutral-400 leading-relaxed max-w-2xl mb-8">
            Cambié el gimnasio comercial por un gimnasio inteligente para casa de Speediance y no he mirado atrás.
            {stats.totalWorkouts} entrenamientos, {stats.totalVolumeFmt} lbs de volumen y un cuerpo que pasó de
            188 lbs a 218 lbs de músculo. Cada sesión registrada, cada PR seguido.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href="https://www.speediance.com"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-orange-600/20 hover:bg-orange-600/30 border border-orange-500/30 hover:border-orange-500/60 text-orange-400 hover:text-orange-300 font-medium rounded-full transition-all text-sm"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4v6a6 6 0 0 0 12 0V4"/><line x1="4" x2="20" y1="20" y2="20"/></svg>
              Speediance.com
            </a>
            <a
              href="/videos/?q=speediance"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-neutral-800/60 hover:bg-neutral-800 border border-neutral-700/50 hover:border-neutral-600 text-neutral-300 hover:text-white font-medium rounded-full transition-all text-sm"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              Ver mis videos de Speediance
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* ── Summary Stats ─────────────────────────────────────────────────────── */}
    <section id="summary-stats" class="py-12 border-t border-neutral-900">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5 col-span-2 sm:col-span-1 lg:col-span-1">
            <div class="text-3xl font-bold text-orange-400 mb-1">{stats.totalVolumeFmt}</div>
            <div class="text-xs text-neutral-500 uppercase tracking-wider">lbs levantadas</div>
            <div class="text-xs text-neutral-600 mt-1">Volumen total</div>
          </div>
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5">
            <div class="text-3xl font-bold text-white mb-1">{stats.totalWorkouts}</div>
            <div class="text-xs text-neutral-500 uppercase tracking-wider">Entrenamientos</div>
            <div class="text-xs text-neutral-600 mt-1">Desde julio de 2025</div>
          </div>
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5">
            <div class="text-3xl font-bold text-white mb-1">{stats.totalHours}h</div>
            <div class="text-xs text-neutral-500 uppercase tracking-wider">Tiempo entrenado</div>
            <div class="text-xs text-neutral-600 mt-1">Duración total</div>
          </div>
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5">
            <div class="text-3xl font-bold text-white mb-1">{(stats.avgVolume / 1000).toFixed(1)}k</div>
            <div class="text-xs text-neutral-500 uppercase tracking-wider">Prom. / sesión</div>
            <div class="text-xs text-neutral-600 mt-1">lbs por entrenamiento</div>
          </div>
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5">
            <div class="text-3xl font-bold text-white mb-1">{(stats.bestSessionVolume / 1000).toFixed(1)}k</div>
            <div class="text-xs text-neutral-500 uppercase tracking-wider">Mejor sesión</div>
            <div class="text-xs text-neutral-600 mt-1">{stats.bestSessionDate}</div>
          </div>
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-5">
            <div class="text-3xl font-bold text-red-400 mb-1">{(stats.totalCalories / 1000).toFixed(1)}k</div>
            <div class="text-xs text-neutral-500 uppercase tracking-wider">Calorías quemadas</div>
            <div class="text-xs text-neutral-600 mt-1">kcal totales</div>
          </div>
        </div>
      </div>
    </section>

    {/* ── Charts ────────────────────────────────────────────────────────────── */}
    <section id="volume-over-time" class="py-12 border-t border-neutral-900">
      <div class="container mx-auto px-4">
        <div class="mb-8">
          <h2 class="text-2xl font-bold mb-2">Volumen a lo largo del tiempo</h2>
          <p class="text-neutral-400 text-sm">Volumen mensual levantado: mira cómo suben los números conforme maduró la programación.</p>
        </div>

        <div class="grid lg:grid-cols-3 gap-6">
          {/* Monthly volume bar chart */}
          <div class="lg:col-span-2 bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-sm font-semibold text-neutral-300 uppercase tracking-wider">Volumen mensual (lbs)</h3>
              <span class="text-xs text-neutral-600 bg-neutral-800 px-2 py-1 rounded-full">{stats.dateStart} → {stats.dateEnd}</span>
            </div>
            <div class="relative h-64 md:h-72">
              <canvas id="volumeChart"></canvas>
            </div>
          </div>

          {/* Workout type donut */}
          <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6">
            <h3 class="text-sm font-semibold text-neutral-300 uppercase tracking-wider mb-4">Volumen por tipo de entrenamiento</h3>
            <div class="relative h-48">
              <canvas id="donutChart"></canvas>
            </div>
            <div class="mt-4 space-y-2">
              {workoutTypeBreakdown.slice(0, 5).map((t) => (
                <div class="flex items-center justify-between text-xs">
                  <span class="text-neutral-400 truncate mr-2">{t.name}</span>
                  <span class="text-neutral-300 font-mono shrink-0">{t.pct}%</span>
