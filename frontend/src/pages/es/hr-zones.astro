---
import Layout from '../layouts/Layout.astro';
import { hrZones } from '../data/hrZones.js';

const zones = [
  { name: 'Zona 1 - Recuperación', color: '#60a5fa', key: 'z1', desc: '50-60% FC máx. - Esfuerzo muy ligero, recuperación' },
  { name: 'Zona 2 - Aeróbica', color: '#3b82f6', key: 'z2', desc: '60-70% FC máx. - Esfuerzo ligero, quema de grasa, base aeróbica' },
  { name: 'Zona 3 - Ritmo', color: '#2563eb', key: 'z3', desc: '70-80% FC máx. - Esfuerzo moderado, resistencia aeróbica' },
  { name: 'Zona 4 - Umbral', color: '#1d4ed8', key: 'z4', desc: '80-90% FC máx. - Esfuerzo fuerte, umbral de lactato' },
  { name: 'Zona 5 - Máxima', color: '#1e40af', key: 'z5', desc: '90-100% FC máx. - Esfuerzo máximo, sprints' },
];
---
<Layout title="Análisis de zonas de frecuencia cardíaca | TobyOnFitnessTech">
  <section class="bg-neutral-950 text-white py-16 px-4 text-center">
    <h1 class="text-4xl md:text-5xl font-bold">Análisis de zonas de frecuencia cardíaca</h1>
    <p class="mt-4 text-lg text-blue-400 max-w-2xl mx-auto">Sigue la distribución de intensidad de tus carreras a partir de {hrZones.totalRuns} actividades de Garmin</p>
  </section>
  <section class="max-w-6xl mx-auto py-8 px-4"><div class="grid grid-cols-2 md:grid-cols-4 gap-4"><div class="bg-neutral-900 rounded-lg p-6 text-center"><div class="text-3xl font-bold text-blue-500">{hrZones.totalRuns}</div><div class="text-gray-400 text-sm mt-1">Carreras totales</div></div><div class="bg-neutral-900 rounded-lg p-6 text-center"><div class="text-3xl font-bold text-blue-500">{hrZones.avgHR}</div><div class="text-gray-400 text-sm mt-1">FC prom. (ppm)</div></div><div class="bg-neutral-900 rounded-lg p-6 text-center"><div class="text-3xl font-bold text-blue-500">{hrZones.totalHours}</div><div class="text-gray-400 text-sm mt-1">Horas en zonas</div></div><div class="bg-neutral-900 rounded-lg p-6 text-center"><div class="text-3xl font-bold text-blue-500">{hrZones.avgDistance.toFixed(1)}</div><div class="text-gray-400 text-sm mt-1">Distancia prom. (km)</div></div></div></section>
  <section class="max-w-4xl mx-auto py-8 px-4"><h2 class="text-2xl font-bold mb-6 text-white">Distribución por zonas</h2><div class="space-y-4">{zones.map((zone, i) => { const pct = hrZones.zonePercentages[zone.key]; const mins = hrZones.totalTimeInMinutes[zone.key]; return (<div class="bg-neutral-900 rounded-lg p-4"><div class="flex justify-between items-center mb-2"><div><span class="font-semibold text-white">{zone.name}</span><p class="text-gray-500 text-xs">{zone.desc}</p></div><div class="text-right"><span class="text-xl font-bold" style={`color: ${zone.color}`}>{pct}%</span><p class="text-gray-500 text-xs">{mins} min</p></div></div><div class="h-3 bg-neutral-800 rounded-full overflow-hidden"><div class="h-full rounded-full transition-all" style={`width: ${pct}%; background-color: ${zone.color}`}></div></div></div>);})}</div></section>
  <section class="max-w-6xl mx-auto py-8 px-4"><h2 class="text-2xl font-bold mb-6 text-white">Carreras recientes</h2><div class="overflow-x-auto"><table class="min-w-full divide-y divide-neutral-800 text-sm"><thead class="bg-neutral-900"><tr><th class="px-4 py-3 text-left text-gray-400 font-medium">Fecha</th><th class="px-4 py-3 text-left text-gray-400 font-medium">Distancia</th><th class="px-4 py-3 text-left text-gray-400 font-medium">FC prom.</th><th class="px-4 py-3 text-left text-gray-400 font-medium">Z1</th><th class="px-4 py-3 text-left text-gray-400 font-medium">Z2</th><th class="px-4 py-3 text-left text-gray-400 font-medium">Z3</th><th class="px-4 py-3 text-left text-gray-400 font-medium">Z4</th><th class="px-4 py-3 text-left text-gray-400 font-medium">Z5</th></tr></thead><tbody class="divide-y divide-neutral-800">{hrZones.recentRuns.map((run) => (<tr class="hover:bg-neutral-900"><td class="px-4 py-3 text-white">{run.date?.slice(0, 10)}</td><td class="px-4 py-3 text-white">{run.distance?.toFixed(1)} km</td><td class="px-4 py-3 text-white">{run.avgHR} ppm</td><td class="px-4 py-3 text-blue-400">{run.z1}m</td><td class="px-4 py-3 text-blue-400">{run.z2}m</td><td class="px-4 py-3 text-blue-400">{run.z3}m</td><td class="px-4 py-3 text-blue-400">{run.z4}m</td><td class="px-4 py-3 text-blue-400">{run.z5}m</td></tr>))}</tbody></table></div></section>
  <script type="application/ld+json">{JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"¿Qué son las zonas de frecuencia cardíaca?","acceptedAnswer":{"@type":"Answer","text":"Las zonas de frecuencia cardíaca son rangos que indican la intensidad del entrenamiento, desde recuperación (Zona 1) hasta esfuerzo máximo (Zona 5)."}},{"@type":"Question","name":"¿Cómo se calculan estos datos?","acceptedAnswer":{"@type":"Answer","text":"Los datos se agregan a partir de actividades de Garmin, sumando los segundos en cada zona de FC y calculando porcentajes."}},{"@type":"Question","name":"¿Qué significan las zonas?","acceptedAnswer":{"@type":"Answer","text":"La Zona 1 es recuperación (50-60% FC máx.), la Zona 2 es aeróbica (60-70%), la Zona 3 es ritmo (70-80%), la Zona 4 es umbral (80-90%) y la Zona 5 es máxima (90-100%)."}}]})}</script>
</Layout>