---
const posthogKey = import.meta.env.PUBLIC_POSTHOG_KEY;
const posthogHost = import.meta.env.PUBLIC_POSTHOG_HOST || 'https://us.i.posthog.com';
---

{posthogKey && (
  <>
    <script define:vars={{ posthogKey, posthogHost }}>
      window.__TOFT_POSTHOG_CONFIG__ = {
        key: posthogKey,
        host: posthogHost,
      };
    </script>
    <script src="/js/posthog-analytics.js" defer></script>
  </>
)}
