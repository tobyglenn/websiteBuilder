---
// LangDetect.astro - Auto-detect user language and redirect on first visit
---

<script>
  (function() {
    const STORAGE_KEY = 'site-lang';
    const LEGACY_STORAGE_KEY = 'preferredLang';
    const SUPPORTED_LANGS = ['es', 'pt', 'hi', 'de'];
    const LOCALE_PATH_REGEX = /^\/(es|pt|hi|de)\//;

    function getStoredLang() {
      return localStorage.getItem(STORAGE_KEY) || localStorage.getItem(LEGACY_STORAGE_KEY);
    }

    function persistLang(langCode) {
      localStorage.setItem(STORAGE_KEY, langCode);
      localStorage.setItem(LEGACY_STORAGE_KEY, langCode);
    }
    
    function init() {
      // Skip if already on a locale path
      if (LOCALE_PATH_REGEX.test(window.location.pathname)) {
        return;
      }
      
      // Check if user has already set a preference
      const storedLang = getStoredLang();
      if (storedLang === 'en') {
        persistLang('en');
        return;
      }

      if (storedLang && SUPPORTED_LANGS.includes(storedLang)) {
        persistLang(storedLang);
        const targetPath = `/${storedLang}${window.location.pathname}`;
        window.location.replace(targetPath);
        return;
      }
      
      // Detect language from browser
      const browserLang = navigator.language || navigator.languages?.[0] || '';
      const langCode = browserLang.split('-')[0].toLowerCase();
      
      // If detected language is supported, redirect
      if (SUPPORTED_LANGS.includes(langCode)) {
        persistLang(langCode);
        const targetPath = `/${langCode}${window.location.pathname}`;
        window.location.replace(targetPath);
      }
    }
    
    // Run on page load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
