# Copy to .env and fill in your values (never commit .env)

# Google YouTube Data API v3 key
# Get one at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Vizard API key
# Used by scripts/vizard-links.mjs to build captions and optionally publish clips.
VIZARDAI_API_KEY=your_vizard_api_key_here

# Website base URL for full-video links appended to Vizard captions.
SITE_URL_BASE=https://tobyonfitnesstech.com
